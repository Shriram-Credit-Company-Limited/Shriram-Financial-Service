---
import { navigation } from '../../config/navigation';
const currentPath = Astro.url.pathname;
const products = navigation.find(n => n.label === 'Products')!;
const about     = navigation.find(n => n.label === 'About')!;
---

<header id="site-header" class="sticky top-0 z-50 h-[80px] border-b border-[#f2f2f2] bg-white transition-transform duration-300 ease-in-out">
  <div class="site-wrap flex h-full items-center justify-between">

    <!-- Logo -->
    <div class="flex shrink-0 items-center gap-4 xl:gap-6 2xl:gap-16">
      <a href="/" class="flex shrink-0 items-center" aria-label="Shriram Financial Services">
        <img src="/logo-shriram.svg" alt="Shriram Financial Services" width="180" height="64"
             class="h-[56px] w-auto object-contain" />
      </a>

      <!-- Desktop Nav — every item opens the full-page panel -->
      <nav class="hidden items-center gap-2 lg:flex 2xl:gap-6" aria-label="Primary">

        <button class="nav-trigger flex items-center gap-1 rounded-[10px] px-3 py-1 text-[15px] font-medium text-[#333] transition-colors hover:bg-[var(--color-n100)]"
                data-panel="products" aria-haspopup="dialog" aria-expanded="false">
          Products
          <svg class="nav-chevron h-4 w-4 transition-transform duration-300" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6l4 4 4-4"/></svg>
        </button>

        <button class="nav-trigger flex items-center gap-1 rounded-[10px] px-3 py-1 text-[15px] font-medium text-[#333] transition-colors hover:bg-[var(--color-n100)]"
                data-panel="learning-centre" aria-haspopup="dialog" aria-expanded="false">
          Research Centre
          <svg class="nav-chevron h-4 w-4 transition-transform duration-300" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6l4 4 4-4"/></svg>
        </button>

        <button class="nav-trigger flex items-center gap-1 rounded-[10px] px-3 py-1 text-[15px] font-medium text-[#333] transition-colors hover:bg-[var(--color-n100)]"
                data-panel="calculators" aria-haspopup="dialog" aria-expanded="false">
          Calculators
          <svg class="nav-chevron h-4 w-4 transition-transform duration-300" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6l4 4 4-4"/></svg>
        </button>

        <button class="nav-trigger flex items-center gap-1 rounded-[10px] px-3 py-1 text-[15px] font-medium text-[#333] transition-colors hover:bg-[var(--color-n100)]"
                data-panel="support" aria-haspopup="dialog" aria-expanded="false">
          Support
          <svg class="nav-chevron h-4 w-4 transition-transform duration-300" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6l4 4 4-4"/></svg>
        </button>

        <a href="/about/become-a-partner/" class="rounded-[10px] px-3 py-1 text-[15px] font-medium text-[#333] transition-colors hover:bg-[var(--color-n100)]">
          Become a Partner
        </a>

      </nav>
    </div>

    <!-- Right: Login + CTA + Hamburger -->
    <div class="flex min-w-0 items-center gap-6 2xl:gap-16">
      <div class="flex items-center gap-4 lg:gap-6">

        <!-- Login -->
        <div class="group relative hidden lg:block">
          <button class="flex shrink-0 items-center gap-1.5 whitespace-nowrap text-[16px] font-semibold text-[#2f7ef4] transition-opacity hover:opacity-80">
            Login
            <svg class="h-4 w-4 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6l4 4 4-4"/></svg>
          </button>
          <div class="invisible absolute right-0 top-full z-50 pt-2 opacity-0 transition-all duration-200 group-hover:visible group-hover:opacity-100">
            <div class="w-44 overflow-hidden rounded-lg border border-[var(--color-n400)] bg-white py-1 shadow-[var(--shadow-heavy)]">
              <a href="https://antara.way2wealth.com/login" target="_blank" rel="noopener noreferrer" class="block px-4 py-2.5 text-[13px] text-[var(--color-ink)] hover:bg-[var(--color-n100)]">Antara Web Login</a>
              <a href="/about/antara-web-login/" class="block px-4 py-2.5 text-[13px] text-[var(--color-ink)] hover:bg-[var(--color-n100)]">Back Office</a>
            </div>
          </div>
        </div>

        <!-- Open A Demat Account CTA -->
        <a href="/about/open-demat-account/" class="hidden h-[40px] w-[190px] xl:w-[220px] shrink-0 items-center justify-center whitespace-nowrap rounded-[6px] bg-[#2b2b2b] text-[12px] xl:text-[13px] font-semibold text-white transition-colors hover:bg-[#111] lg:flex 2xl:h-[44px] 2xl:text-[14px]">
          Open A Demat Account
        </a>

        <!-- Mobile hamburger -->
        <button id="menu-toggle" class="flex h-9 w-9 items-center justify-center rounded border border-[var(--color-n400)] text-[var(--color-ink)] lg:hidden" aria-label="Open menu" aria-expanded="false">
          <svg id="icon-open" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          <svg id="icon-close" class="hidden h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div id="mobile-menu" class="hidden border-t border-[var(--color-n400)] bg-white lg:hidden">
    <div class="max-h-[80vh] overflow-y-auto px-5 py-4">
      <details class="group mb-1">
        <summary class="flex cursor-pointer select-none items-center justify-between rounded px-3 py-3 text-[14px] font-semibold text-[var(--color-ink)] hover:bg-[var(--color-n100)]">
          Products
          <svg class="h-4 w-4 opacity-50 transition-transform group-open:rotate-180" viewBox="0 0 16 16" fill="currentColor"><path d="M4 6l4 4 4-4H4z"/></svg>
        </summary>
        <div class="ml-3 mt-1 grid grid-cols-2 gap-1 border-l-2 border-[var(--color-n400)] pl-3 pb-2">
          {products.children.map(p => (
            <a href={p.href} class="rounded px-3 py-2 text-[13px] text-[var(--color-muted)] hover:text-[var(--color-brand)]">{p.label}</a>
          ))}
        </div>
      </details>
      <a href="/research/" class="block rounded px-3 py-3 text-[14px] font-semibold text-[var(--color-ink)] hover:bg-[var(--color-n100)]">Research Centre</a>
      <a href="/calculators/sip/" class="block rounded px-3 py-3 text-[14px] font-semibold text-[var(--color-ink)] hover:bg-[var(--color-n100)]">Calculators</a>
      <a href="/about/support/" class="block rounded px-3 py-3 text-[14px] font-semibold text-[var(--color-ink)] hover:bg-[var(--color-n100)]">Support</a>
      <details class="group mb-1">
        <summary class="flex cursor-pointer select-none items-center justify-between rounded px-3 py-3 text-[14px] font-semibold text-[var(--color-ink)] hover:bg-[var(--color-n100)]">
          About
          <svg class="h-4 w-4 opacity-50 transition-transform group-open:rotate-180" viewBox="0 0 16 16" fill="currentColor"><path d="M4 6l4 4 4-4H4z"/></svg>
        </summary>
        <div class="ml-3 mt-1 border-l-2 border-[var(--color-n400)] pl-3 pb-2">
          {about.children.map(c => (
            <a href={c.href} class="block rounded px-3 py-2 text-[13px] text-[var(--color-muted)] hover:text-[var(--color-brand)]">{c.label}</a>
          ))}
        </div>
      </details>
      <div class="mt-4 flex flex-col gap-3 border-t border-[var(--color-n400)] pt-4">
        <a href="https://antara.way2wealth.com/login" target="_blank" rel="noopener noreferrer" class="block rounded-[6px] border border-[var(--color-n400)] py-3 text-center text-[13px] font-semibold text-[#2f7ef4]">Login</a>
        <a href="/about/open-demat-account/" class="block rounded-[6px] bg-[#333] py-3 text-center text-[13px] font-medium text-white">Open A Demat Account</a>
      </div>
    </div>
  </div>
</header>

<!-- ══ Unified Full-Page Navigation Panel ══════════════════════════ -->
<div id="nav-panel" role="dialog" aria-modal="true" aria-label="Site navigation">

  <!-- Left sidebar: dark olive gradient + logo + all nav items -->
  <div id="nps-sidebar">
    <button id="nps-go-back" aria-label="Go back to main navigation">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M15 18l-6-6 6-6"/>
      </svg>
      Go Back
    </button>
    <nav class="nps-nav" aria-label="Panel navigation">
      <button class="nps-item" data-for="products">Products</button>
      <button class="nps-item" data-for="learning-centre">Research Centre</button>
      <button class="nps-item" data-for="calculators">Calculators</button>
      <button class="nps-item" data-for="support">Support</button>
    </nav>
  </div>

  <!-- Right content: cream/white, section-specific -->
  <div id="nps-content">
    <!-- Scrollable upper area: all nav sections live here -->
    <div id="nps-scroll-area">

      <!-- ── Products ── -->
      <div class="nps-section" data-section="products">
        <h2 class="nps-heading">Products</h2>
        <div class="nps-grid">
          <div class="nps-trade-block">
            <p class="nps-col-title">Trade And Invest</p>
            <div class="nps-trade-cols">
              <div class="nps-col-items">
                <a href="/products/equity/">Equity</a>
                <a href="/products/currency/">Currency</a>
                <a href="/products/commodities/">Commodities</a>
                <a href="/products/mtf/">Margin Trading Facility (MTF)</a>
                <a href="/products/derivative/">Derivatives</a>
                <a href="/products/bonds/">Bonds</a>
              </div>
              <div class="nps-col-items">
                <a href="/products/mutual-funds/">Mutual Funds</a>
                <a href="/products/etf/">ETFs</a>
                <a href="/products/nps/">National Pension Scheme (NPS)</a>
                <a href="/products/nfo/">NFO</a>
                <a href="/products/ipo/">IPO</a>
              </div>
            </div>
          </div>
          <div class="nps-divider" aria-hidden="true"></div>
          <div class="nps-col">
            <p class="nps-col-title">Featured</p>
            <div class="nps-col-items">
              <a href="/products/lamf/">Loan Against Mutual Funds</a>
              <a href="/products/las/">Loan Against Stocks</a>
            </div>
          </div>
        </div>
        <div class="nps-view-all">
          <a href="/products/">View All Products</a>
        </div>
      </div>

      <!-- ── Research Centre ── -->
      <div class="nps-section" data-section="learning-centre">
        <h2 class="nps-heading">Research Centre</h2>
        <div class="nps-grid">
          <div class="nps-col">
            <div class="nps-col-items">
              <a href="/research/technical/">Technical Research</a>
              <a href="/research/fundamental/">Fundamental Research</a>
              <a href="/research/mutual-funds/">Mutual Fund Research</a>
            </div>
          </div>
        </div>
        <div class="nps-view-all">
          <a href="/research/">View Research</a>
        </div>
      </div>

      <!-- ── Calculators ── -->
      <div class="nps-section" data-section="calculators">
        <h2 class="nps-heading">Calculators</h2>
        <div class="nps-grid">
          <div class="nps-col">
            <p class="nps-col-title">Investment Calculators</p>
            <div class="nps-col-items">
              <a href="/calculators/sip/">SIP Calculator</a>
              <a href="/calculators/lumpsum/">Lumpsum Calculator</a>
              <a href="/calculators/fd/">Fixed Deposit Calculator</a>
              <a href="/calculators/swp/">SWP Calculator</a>
              <a href="/calculators/nps/">NPS Calculator</a>
            </div>
          </div>
        </div>
      </div>

      <!-- ── Support ── -->
      <div class="nps-section" data-section="support">
        <h2 class="nps-heading">Support</h2>
        <div class="nps-grid">
          <div class="nps-col">
            <p class="nps-col-title">Get Help</p>
            <div class="nps-col-items">
              <a href="/about/support/">Contact &amp; Help</a>
              <a href="/about/support/">Grievance Redressal</a>
              <a href="/about/regulatory/">Regulatory &amp; Compliance</a>
            </div>
          </div>
        </div>
        <div class="nps-view-all">
          <a href="/about/support/">View All Support</a>
        </div>
      </div>


    </div><!-- /nps-scroll-area -->

  </div><!-- /nps-content -->
</div>

<style>
  /* ── Panel base (hidden) ─────────────────────────────────────── */
  #nav-panel {
    position: fixed;
    inset: 0;
    z-index: 60;
    display: flex;
    align-items: stretch;
    background: #fff;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }
  #nav-panel[data-open] {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Left sidebar ─────────────────────────────────────────────── */
  #nps-sidebar {
    width: clamp(240px, 27vw, 400px);
    min-height: 100%;
    flex-shrink: 0;
    align-self: stretch;
    display: flex;
    flex-direction: column;
    padding: clamp(40px, 6vw, 96px) clamp(28px, 4.5vw, 72px);
    border-radius: 0 40px 40px 0;
    background: radial-gradient(ellipse at top left, #4f583b 0%, #363a2c 50%, #1d1d1d 100%);
    transform: translateX(-36px);
    transition: transform 0.48s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
  }
  #nav-panel[data-open] #nps-sidebar { transform: translateX(0); }

  .nps-logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    border-radius: 4px;
    padding: 10px 12px;
    margin-bottom: clamp(36px, 5.5vw, 80px);
    align-self: flex-start;
  }
  .nps-logo img { height: 48px; width: auto; display: block; object-fit: contain; }

  .nps-nav { display: flex; flex-direction: column; gap: clamp(24px, 3.5vw, 48px); }

  .nps-item {
    font-size: clamp(16px, 2vw, 28px);
    font-weight: 300;
    color: #bcaf99;
    line-height: 1;
    font-family: 'Outfit', sans-serif;
    transition: color 0.2s ease;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    padding: 0;
  }
  .nps-item:hover { color: #fff; }

  /* Active sidebar item per open section */
  #nav-panel[data-panel="products"]        .nps-item[data-for="products"],
  #nav-panel[data-panel="learning-centre"] .nps-item[data-for="learning-centre"],
  #nav-panel[data-panel="calculators"]     .nps-item[data-for="calculators"],
  #nav-panel[data-panel="support"]         .nps-item[data-for="support"] {
    color: #f3b83f;
    font-weight: 600;
  }

  /* ── Right content ─────────────────────────────────────────────── */
  #nps-content {
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;          /* scroll area grows, footer stays at bottom */
    background: radial-gradient(ellipse at top right, #ebdec6 0%, #ffffff 58%);
    transform: translateX(24px);
    opacity: 0;
    transition:
      transform 0.48s cubic-bezier(0.4, 0, 0.2, 1) 0.06s,
      opacity   0.48s ease                           0.06s;
  }
  #nav-panel[data-open] #nps-content { transform: translateX(0); opacity: 1; }

  /* Scrollable upper portion — contains all nav sections */
  #nps-scroll-area {
    flex: 1;
    overflow-y: auto;
    padding: clamp(72px, 9vw, 144px) clamp(36px, 5vw, 80px) clamp(24px, 3vw, 40px);
  }

  /* Sections: only the active one visible */
  .nps-section { display: none; flex-direction: column; flex: 1; }

  #nav-panel[data-panel="products"]        .nps-section[data-section="products"],
  #nav-panel[data-panel="learning-centre"] .nps-section[data-section="learning-centre"],
  #nav-panel[data-panel="calculators"]     .nps-section[data-section="calculators"],
  #nav-panel[data-panel="support"]         .nps-section[data-section="support"] {
    display: flex;
  }

  /* Heading */
  .nps-heading {
    font-size: clamp(20px, 2.2vw, 32px);
    font-weight: 500;
    color: #3a3c39;
    line-height: 1;
    margin-bottom: clamp(28px, 3.5vw, 48px);
    font-family: 'Outfit', sans-serif;
  }

  /* Grid + columns */
  .nps-grid { display: flex; align-items: flex-start; flex: 1; }

  .nps-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: clamp(18px, 2.5vw, 32px);
    padding: 0 clamp(16px, 2.5vw, 40px);
  }
  .nps-col:first-child { padding-left: 0; }
  .nps-col:last-child  { padding-right: 0; }

  .nps-col-title {
    font-size: clamp(14px, 1.3vw, 20px);
    font-weight: 500;
    color: #3a3c39;
    text-transform: capitalize;
    font-family: 'Outfit', sans-serif;
    line-height: 1.2;
  }

  .nps-col-items {
    display: flex;
    flex-direction: column;
    gap: clamp(14px, 1.8vw, 24px);
  }

  .nps-col-items a {
    font-size: clamp(12px, 1.05vw, 16px);
    color: #333;
    text-decoration: none;
    font-family: 'Outfit', sans-serif;
    line-height: 1.4;
    transition: color 0.2s ease;
  }
  .nps-col-items a:hover { color: var(--color-brand, #f3b83f); }

  .nps-divider {
    width: 1px;
    align-self: stretch;
    background: #e0ddd8;
    flex-shrink: 0;
    margin-top: calc(clamp(18px, 2.5vw, 32px) + clamp(14px, 1.3vw, 20px));
  }

  /* ── Go Back button in sidebar ────────────────────────────────── */
  #nps-go-back {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: clamp(20px, 3vw, 40px);
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px 0;
    font-family: 'Outfit', sans-serif;
    font-size: clamp(12px, 0.85vw, 14px);
    font-weight: 400;
    color: rgba(255,255,255,0.70);
    letter-spacing: 0.01em;
    line-height: 1;
    transition: color 0.2s ease;
  }
  #nps-go-back:hover { color: #fff; }
  #nps-go-back svg { width: 16px; height: 16px; flex-shrink: 0; }

  /* ── Trade And Invest two-column block ────────────────────────── */
  .nps-trade-block {
    flex: 2;
    display: flex;
    flex-direction: column;
    gap: clamp(18px, 2.5vw, 32px);
    padding-right: clamp(16px, 2.5vw, 40px);
  }
  .nps-trade-cols {
    display: flex;
    gap: clamp(20px, 3vw, 48px);
  }
  .nps-trade-cols .nps-col-items { flex: 1; padding: 0; }

  /* View All Products button in Products panel */
  .nps-view-all {
    margin-top: clamp(28px, 4vw, 56px);
  }
  .nps-view-all a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 44px;
    padding: 0 28px;
    border: 1.5px solid #3a3c39;
    border-radius: 6px;
    font-size: clamp(12px, 1vw, 15px);
    font-family: 'Outfit', sans-serif;
    font-weight: 500;
    color: #3a3c39;
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .nps-view-all a:hover {
    background: #3a3c39;
    color: #fff;
  }

  /* Chevron rotates when panel is open */
  .nav-trigger[aria-expanded="true"] .nav-chevron { transform: rotate(180deg); }
</style>

<script>
  // ── Scroll-aware sticky header ─────────────────────────────────
  const siteHeader = document.getElementById('site-header')!;
  let lastY = 0;
  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    if (y > lastY && y > 80) {
      siteHeader.style.transform = 'translateY(-100%)';
    } else {
      siteHeader.style.transform = 'translateY(0)';
    }
    lastY = y;
  }, { passive: true });

  // ── Mobile drawer ──────────────────────────────────────────────
  const toggle    = document.getElementById('menu-toggle')!;
  const menu      = document.getElementById('mobile-menu')!;
  const iconOpen  = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;
  toggle.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', isOpen);
    iconOpen.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  // ── Full-page nav panels ──────────────────────────────────────
  const navPanel = document.getElementById('nav-panel')!;
  let activeBtn: HTMLElement | null = null;

  function openPanel(section: string, btn: HTMLElement) {
    navPanel.setAttribute('data-open', '');
    navPanel.setAttribute('data-panel', section);
    if (activeBtn && activeBtn !== btn) activeBtn.setAttribute('aria-expanded', 'false');
    btn.setAttribute('aria-expanded', 'true');
    activeBtn = btn;
    document.body.style.overflow = 'hidden';
  }

  function closePanel() {
    navPanel.removeAttribute('data-open');
    navPanel.removeAttribute('data-panel');
    document.body.style.overflow = '';
    if (activeBtn) { activeBtn.setAttribute('aria-expanded', 'false'); activeBtn.focus(); activeBtn = null; }
  }

  // Header nav buttons
  document.querySelectorAll<HTMLElement>('.nav-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const p = btn.dataset.panel!;
      (navPanel.hasAttribute('data-open') && navPanel.dataset.panel === p) ? closePanel() : openPanel(p, btn);
    });
  });

  // Sidebar buttons switch the right-side section (stay in panel)
  navPanel.querySelectorAll<HTMLElement>('.nps-item').forEach(item => {
    item.addEventListener('click', () => {
      const p = item.dataset.for!;
      navPanel.setAttribute('data-panel', p);
      if (activeBtn) activeBtn.setAttribute('aria-expanded', 'false');
      const hBtn = document.querySelector<HTMLElement>(`.nav-trigger[data-panel="${p}"]`);
      if (hBtn) { hBtn.setAttribute('aria-expanded', 'true'); activeBtn = hBtn; }
    });
  });

  document.getElementById('nps-go-back')?.addEventListener('click', () => { window.location.href = '/'; });
  document.addEventListener('keydown', e => { if (e.key === 'Escape' && navPanel.hasAttribute('data-open')) closePanel(); });
  navPanel.querySelectorAll('a').forEach(a => a.addEventListener('click', closePanel));
</script>
