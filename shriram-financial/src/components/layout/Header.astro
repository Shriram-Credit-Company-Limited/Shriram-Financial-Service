---
import { navigation } from '../../config/navigation';
const currentPath = Astro.url.pathname;
const products = navigation.find(n => n.label === 'Products')!;
const research  = navigation.find(n => n.label === 'Research')!;
const about     = navigation.find(n => n.label === 'About')!;
---

<header id="site-header" class="sticky top-0 z-50 h-[80px] border-b border-[#f2f2f2] bg-[rgba(255,255,255,0.80)] backdrop-blur-[30px]">
  <div class="site-wrap flex h-full items-center justify-between">

    <!-- Logo -->
    <div class="flex shrink-0 items-center gap-8 2xl:gap-16">
      <a href="/" class="flex shrink-0 items-center" aria-label="Shriram Financial Services">
        <img src="/images/logo-component6.png" alt="Shriram Financial Services" width="113" height="52"
             class="h-[52px] w-auto rounded-[4px] object-contain" />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden items-center gap-2 lg:flex 2xl:gap-6" aria-label="Primary">

        <!-- Products — click triggers full-page panel -->
        <button
          id="products-btn"
          class="flex items-center gap-1 rounded-[10px] px-3 py-1 text-[16px] font-medium text-[#333] transition-colors hover:bg-[var(--color-n100)]"
          aria-haspopup="dialog"
          aria-expanded="false"
          aria-controls="products-panel"
        >
          Products
          <svg id="products-chevron" class="h-4 w-4 transition-transform duration-300" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6l4 4 4-4"/></svg>
        </button>

        <!-- Learning Centre -->
        <div class="group relative">
          <button class="flex items-center gap-1 rounded-[10px] px-3 py-1 text-[16px] font-medium text-[#333] transition-colors hover:bg-[var(--color-n100)]" aria-haspopup="true">
            Learning Centre
            <svg class="h-4 w-4 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6l4 4 4-4"/></svg>
          </button>
          <div class="invisible absolute left-0 top-full z-50 pt-3 opacity-0 transition-all duration-200 group-hover:visible group-hover:opacity-100">
            <div class="w-52 overflow-hidden rounded-lg border border-[var(--color-n400)] bg-white py-1 shadow-[var(--shadow-heavy)]">
              {[
                {label:'Research & Insights', href:'/research/'},
                {label:'Technical Analysis',  href:'/research/technical/'},
                {label:'Market News',          href:'/research/'},
              ].map(c => (
                <a href={c.href} class="block px-4 py-2.5 text-[13px] text-[var(--color-ink)] hover:bg-[var(--color-n100)]">{c.label}</a>
              ))}
            </div>
          </div>
        </div>

        <!-- Calculators -->
        <div class="group relative">
          <button class="flex items-center gap-1 rounded-[10px] px-3 py-1 text-[16px] font-medium text-[#333] transition-colors hover:bg-[var(--color-n100)]" aria-haspopup="true">
            Calculators
            <svg class="h-4 w-4 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6l4 4 4-4"/></svg>
          </button>
          <div class="invisible absolute left-0 top-full z-50 pt-3 opacity-0 transition-all duration-200 group-hover:visible group-hover:opacity-100">
            <div class="w-52 overflow-hidden rounded-lg border border-[var(--color-n400)] bg-white py-1 shadow-[var(--shadow-heavy)]">
              {[
                {label:'SIP Calculator',      href:'/product-hub/'},
                {label:'Returns Calculator',  href:'/product-hub/'},
                {label:'EMI Calculator',      href:'/product-hub/'},
              ].map(c => (
                <a href={c.href} class="block px-4 py-2.5 text-[13px] text-[var(--color-ink)] hover:bg-[var(--color-n100)]">{c.label}</a>
              ))}
            </div>
          </div>
        </div>

        <!-- Support -->
        <div class="group relative">
          <button class="flex items-center gap-1 rounded-[10px] px-3 py-1 text-[16px] font-medium text-[#333] transition-colors hover:bg-[var(--color-n100)]" aria-haspopup="true">
            Support
            <svg class="h-4 w-4 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6l4 4 4-4"/></svg>
          </button>
          <div class="invisible absolute left-0 top-full z-50 pt-3 opacity-0 transition-all duration-200 group-hover:visible group-hover:opacity-100">
            <div class="w-52 overflow-hidden rounded-lg border border-[var(--color-n400)] bg-white py-1 shadow-[var(--shadow-heavy)]">
              {[
                {label:'Contact & Help',          href:'/about/support/'},
                {label:'Grievance Redressal',     href:'/about/support/'},
                {label:'Regulatory & Compliance', href:'/about/regulatory/'},
              ].map(c => (
                <a href={c.href} class="block px-4 py-2.5 text-[13px] text-[var(--color-ink)] hover:bg-[var(--color-n100)]">{c.label}</a>
              ))}
            </div>
          </div>
        </div>

        <!-- Become a Partner -->
        <a href="/about/become-a-partner/" class="rounded-[10px] px-3 py-1 text-[16px] font-medium text-[#333] transition-colors hover:bg-[var(--color-n100)]">Become a Partner</a>
      </nav>
    </div>

    <!-- Right: Login + CTA + Hamburger -->
    <div class="flex min-w-0 items-center gap-6 2xl:gap-16">
      <div class="flex items-center gap-4 lg:gap-6">

        <!-- Login -->
        <div class="group relative hidden lg:block">
          <button class="flex shrink-0 items-center gap-1.5 whitespace-nowrap text-[16px] font-semibold text-[#2f7ef4] transition-opacity hover:opacity-80">
            Login
            <svg class="h-4 w-4 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6l4 4 4-4"/></svg>
          </button>
          <div class="invisible absolute right-0 top-full z-50 pt-2 opacity-0 transition-all duration-200 group-hover:visible group-hover:opacity-100">
            <div class="w-44 overflow-hidden rounded-lg border border-[var(--color-n400)] bg-white py-1 shadow-[var(--shadow-heavy)]">
              <a href="/about/antara-web-login/" class="block px-4 py-2.5 text-[13px] text-[var(--color-ink)] hover:bg-[var(--color-n100)]">Antara Web Login</a>
              <a href="/about/antara-web-login/" class="block px-4 py-2.5 text-[13px] text-[var(--color-ink)] hover:bg-[var(--color-n100)]">Back Office</a>
            </div>
          </div>
        </div>

        <!-- Open A Trading Account CTA -->
        <a href="/about/open-demat-account/" class="hidden h-[40px] w-[220px] shrink-0 items-center justify-center whitespace-nowrap rounded-[6px] bg-[#2b2b2b] text-[13px] font-semibold text-white transition-colors hover:bg-[#111] lg:flex 2xl:h-[44px] 2xl:text-[14px]">
          Open A Trading Account
        </a>

        <!-- Mobile hamburger -->
        <button id="menu-toggle" class="flex h-9 w-9 items-center justify-center rounded border border-[var(--color-n400)] text-[var(--color-ink)] lg:hidden" aria-label="Open menu" aria-expanded="false">
          <svg id="icon-open" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          <svg id="icon-close" class="hidden h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div id="mobile-menu" class="hidden border-t border-[var(--color-n400)] bg-white lg:hidden">
    <div class="max-h-[80vh] overflow-y-auto px-5 py-4">
      <details class="group mb-1">
        <summary class="flex cursor-pointer select-none items-center justify-between rounded px-3 py-3 text-[14px] font-semibold text-[var(--color-ink)] hover:bg-[var(--color-n100)]">
          Products
          <svg class="h-4 w-4 opacity-50 transition-transform group-open:rotate-180" viewBox="0 0 16 16" fill="currentColor"><path d="M4 6l4 4 4-4H4z"/></svg>
        </summary>
        <div class="ml-3 mt-1 grid grid-cols-2 gap-1 border-l-2 border-[var(--color-n400)] pl-3 pb-2">
          {products.children.map(p => (
            <a href={p.href} class="rounded px-3 py-2 text-[13px] text-[var(--color-muted)] hover:text-[var(--color-brand)]">{p.label}</a>
          ))}
        </div>
      </details>
      <a href="/research/" class="block rounded px-3 py-3 text-[14px] font-semibold text-[var(--color-ink)] hover:bg-[var(--color-n100)]">Learning Centre</a>
      <a href="/product-hub/" class="block rounded px-3 py-3 text-[14px] font-semibold text-[var(--color-ink)] hover:bg-[var(--color-n100)]">Calculators</a>
      <a href="/about/support/" class="block rounded px-3 py-3 text-[14px] font-semibold text-[var(--color-ink)] hover:bg-[var(--color-n100)]">Support</a>
      <a href="/about/become-a-partner/" class="block rounded px-3 py-3 text-[14px] font-semibold text-[var(--color-ink)] hover:bg-[var(--color-n100)]">Become a Partner</a>
      <details class="group mb-1">
        <summary class="flex cursor-pointer select-none items-center justify-between rounded px-3 py-3 text-[14px] font-semibold text-[var(--color-ink)] hover:bg-[var(--color-n100)]">
          About
          <svg class="h-4 w-4 opacity-50 transition-transform group-open:rotate-180" viewBox="0 0 16 16" fill="currentColor"><path d="M4 6l4 4 4-4H4z"/></svg>
        </summary>
        <div class="ml-3 mt-1 border-l-2 border-[var(--color-n400)] pl-3 pb-2">
          {about.children.map(c => (
            <a href={c.href} class="block rounded px-3 py-2 text-[13px] text-[var(--color-muted)] hover:text-[var(--color-brand)]">{c.label}</a>
          ))}
        </div>
      </details>
      <div class="mt-4 flex flex-col gap-3 border-t border-[var(--color-n400)] pt-4">
        <a href="/about/antara-web-login/" class="block rounded-[6px] border border-[var(--color-n400)] py-3 text-center text-[13px] font-semibold text-[#2f7ef4]">Login</a>
        <a href="/about/open-demat-account/" class="block rounded-[6px] bg-[#333] py-3 text-center text-[13px] font-medium text-white">Open A Trading Account</a>
      </div>
    </div>
  </div>
</header>

<!-- ── Products Full-Page Panel ────────────────────────────────────── -->
<div
  id="products-panel"
  role="dialog"
  aria-modal="true"
  aria-label="Products navigation"
>
  <!-- Left sidebar: dark olive gradient, logo + nav -->
  <div id="products-sidebar">
    <div class="products-logo">
      <img src="/images/logo-component6.png" alt="Shriram Financial Services" width="113" height="48" />
    </div>
    <nav class="products-nav" aria-label="Products panel navigation">
      <span class="products-nav-active">Products</span>
      <a href="/research/" class="products-nav-link">Learning Centre</a>
      <a href="/product-hub/" class="products-nav-link">Calculators</a>
      <a href="/about/support/" class="products-nav-link">Support</a>
      <a href="/about/become-a-partner/" class="products-nav-link">Become a Partner</a>
    </nav>
  </div>

  <!-- Right content: cream/white, 3-column products grid -->
  <div id="products-content">

    <!-- Close button -->
    <button id="products-close" aria-label="Close products menu">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <h2 class="products-heading">Products</h2>

    <div class="products-grid">

      <!-- Trade -->
      <div class="products-col">
        <p class="products-col-title">Trade</p>
        <div class="products-col-items">
          <a href="/products/equity/">Equity</a>
          <a href="/products/currency/">Currency</a>
          <a href="/products/commodities/">Commodities</a>
          <a href="/products/mtf/">Margin Trading Facility (MTF)</a>
          <a href="/products/derivative/">Derivatives</a>
        </div>
      </div>

      <div class="products-divider" aria-hidden="true"></div>

      <!-- Invest -->
      <div class="products-col">
        <p class="products-col-title">Invest</p>
        <div class="products-col-items">
          <a href="/products/mutual-funds/">Mutual Funds</a>
          <a href="/products/etf/">ETFs</a>
          <a href="/products/bonds/">Bonds</a>
          <a href="/products/nps/">National Pension Scheme (NPS)</a>
          <a href="/products/nfo/">NFO</a>
          <a href="/products/ipo/">IPO</a>
        </div>
      </div>

      <div class="products-divider" aria-hidden="true"></div>

      <!-- Featured -->
      <div class="products-col">
        <p class="products-col-title">Featured</p>
        <div class="products-col-items">
          <a href="/products/loan-against-mf/">Personal Loan Against Mutual Funds</a>
          <a href="/products/loan-against-stocks/">Personal Loan Against Stocks</a>
          <a href="/products/loans/">Other Loans</a>
          <a href="/products/insurance/">Insurances</a>
          <a href="/products/fd/">Fixed Deposit</a>
        </div>
      </div>

    </div>
  </div>
</div>

<style>
  /* ── Products panel: base state (hidden) ──────────────────────── */
  #products-panel {
    position: fixed;
    inset: 0;
    z-index: 60;
    display: flex;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Open state */
  #products-panel[data-open] {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Left sidebar ─────────────────────────────────────────────── */
  #products-sidebar {
    position: relative;
    width: clamp(240px, 27vw, 400px);
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    padding: clamp(40px, 6vw, 96px) clamp(28px, 4.5vw, 72px);
    border-radius: 0 40px 40px 0;
    /* Figma radial gradient: dark olive → near-black */
    background: radial-gradient(ellipse at top left, #4f583b 0%, #363a2c 50%, #1d1d1d 100%);
    transform: translateX(-36px);
    transition: transform 0.48s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
  }

  #products-panel[data-open] #products-sidebar {
    transform: translateX(0);
  }

  .products-logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    border-radius: 4px;
    padding: 10px 12px;
    margin-bottom: clamp(36px, 5.5vw, 80px);
    align-self: flex-start;
  }
  .products-logo img {
    height: 48px;
    width: auto;
    display: block;
    object-fit: contain;
  }

  .products-nav {
    display: flex;
    flex-direction: column;
    gap: clamp(28px, 4vw, 56px);
  }
  .products-nav-active {
    font-size: clamp(18px, 2.2vw, 28px);
    font-weight: 600;
    color: #f3b83f;
    line-height: 1;
    font-family: 'Outfit', sans-serif;
  }
  .products-nav-link {
    font-size: clamp(16px, 2vw, 28px);
    font-weight: 300;
    color: #bcaf99;
    line-height: 1;
    text-decoration: none;
    font-family: 'Outfit', sans-serif;
    transition: color 0.2s ease;
  }
  .products-nav-link:hover {
    color: #fff;
  }

  /* ── Right content ────────────────────────────────────────────── */
  #products-content {
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: clamp(72px, 9vw, 144px) clamp(36px, 5vw, 80px) clamp(36px, 5vw, 72px);
    /* Figma warm cream radial gradient */
    background: radial-gradient(ellipse at top right, #ebdec6 0%, #ffffff 58%);
    transform: translateX(24px);
    opacity: 0;
    /* 60ms stagger after sidebar */
    transition:
      transform 0.48s cubic-bezier(0.4, 0, 0.2, 1) 0.06s,
      opacity   0.48s ease                           0.06s;
    overflow-y: auto;
  }

  #products-panel[data-open] #products-content {
    transform: translateX(0);
    opacity: 1;
  }

  /* Close button */
  #products-close {
    position: absolute;
    top: clamp(72px, 8vw, 128px);
    right: clamp(24px, 3vw, 48px);
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(18, 18, 18, 0.05);
    border-radius: 50%;
    border: none;
    cursor: pointer;
    color: #333;
    transition: background 0.2s ease;
  }
  #products-close:hover {
    background: rgba(18, 18, 18, 0.12);
  }
  #products-close svg {
    width: 18px;
    height: 18px;
  }

  /* Products heading */
  .products-heading {
    font-size: clamp(20px, 2.2vw, 32px);
    font-weight: 500;
    color: #3a3c39;
    line-height: 1;
    margin-bottom: clamp(28px, 3.5vw, 48px);
    font-family: 'Outfit', sans-serif;
  }

  /* 3-column grid */
  .products-grid {
    display: flex;
    gap: 0;
    align-items: flex-start;
    flex: 1;
  }
  .products-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: clamp(18px, 2.5vw, 32px);
    padding: 0 clamp(16px, 2.5vw, 40px);
  }
  .products-col:first-child {
    padding-left: 0;
  }
  .products-col:last-child {
    padding-right: 0;
  }
  .products-col-title {
    font-size: clamp(14px, 1.3vw, 20px);
    font-weight: 500;
    color: #3a3c39;
    text-transform: capitalize;
    font-family: 'Outfit', sans-serif;
    line-height: 1.2;
  }
  .products-col-items {
    display: flex;
    flex-direction: column;
    gap: clamp(14px, 1.8vw, 24px);
  }
  .products-col-items a {
    font-size: clamp(12px, 1.05vw, 16px);
    color: #333;
    text-decoration: none;
    font-family: 'Outfit', sans-serif;
    line-height: 1.4;
    transition: color 0.2s ease;
  }
  .products-col-items a:hover {
    color: var(--color-brand, #f3b83f);
  }
  .products-divider {
    width: 1px;
    align-self: stretch;
    background: #e0ddd8;
    flex-shrink: 0;
    margin-top: calc(clamp(18px, 2.5vw, 32px) + clamp(14px, 1.3vw, 20px));
  }

  /* Chevron rotation reflects panel state */
  #products-btn[aria-expanded="true"] #products-chevron {
    transform: rotate(180deg);
  }
</style>

<script>
  // ── Mobile drawer ──────────────────────────────────────────────
  const toggle    = document.getElementById('menu-toggle')!;
  const menu      = document.getElementById('mobile-menu')!;
  const iconOpen  = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  toggle.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', isOpen);
    iconOpen.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  // ── Products full-page panel ───────────────────────────────────
  const productsBtn   = document.getElementById('products-btn')!;
  const productsPanel = document.getElementById('products-panel')!;
  const productsClose = document.getElementById('products-close')!;

  function openProductsPanel() {
    productsPanel.setAttribute('data-open', '');
    productsBtn.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    productsClose.focus();
  }

  function closeProductsPanel() {
    productsPanel.removeAttribute('data-open');
    productsBtn.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    productsBtn.focus();
  }

  productsBtn.addEventListener('click', () => {
    productsPanel.hasAttribute('data-open') ? closeProductsPanel() : openProductsPanel();
  });

  productsClose.addEventListener('click', closeProductsPanel);

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && productsPanel.hasAttribute('data-open')) {
      closeProductsPanel();
    }
  });

  // Close when a product link is followed
  productsPanel.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeProductsPanel);
  });
</script>
