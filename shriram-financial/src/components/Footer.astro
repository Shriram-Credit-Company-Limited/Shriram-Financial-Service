---
const year = new Date().getFullYear();
const alphabet = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');
---

<footer class="bg-[var(--color-dark-900)] text-[rgba(255,255,255,0.65)]">

  <!-- ── Top nav bar ── -->
  <div class="border-b border-[rgba(255,255,255,0.06)]">
    <div class="site-wrap">
      <nav class="flex flex-wrap items-center gap-x-1 gap-y-0 py-3" aria-label="Footer topics">
        {[
          {label:'Products',        href:'/products/'},
          {label:'Calculator',      href:'/product-hub/'},
          {label:'Stock Markets',   href:'/research/'},
          {label:'Indices',         href:'/research/'},
          {label:'F&O',             href:'/products/derivative/'},
          {label:'Mutual Funds',    href:'/products/mutual-funds/'},
          {label:'ETFs',            href:'/products/etf/'},
          {label:'Fund by Shriram', href:'/products/mutual-funds/'},
          {label:'IPO',             href:'/products/ipo/'},
          {label:'Miscellaneous',   href:'/about/'},
        ].map((item, i) => (
          <>
            {i > 0 && <span class="text-[rgba(255,255,255,0.15)] text-[11px]">|</span>}
            <a href={item.href} class="text-[12px] text-[rgba(255,255,255,0.50)] transition-colors hover:text-white px-1.5 py-1">{item.label}</a>
          </>
        ))}
      </nav>
    </div>
  </div>

  <!-- ── Main footer grid ── -->
  <div class="site-wrap py-12 lg:py-14">
    <div class="grid gap-10 lg:grid-cols-[280px_1fr_1fr_1fr]">

      <!-- Col 1: Brand + Contact -->
      <div>
        <a href="/" class="flex items-center" aria-label="Shriram Financial Services">
          <img src="/shriram-logo.png" alt="Shriram Financial Services" width="160" height="48"
               class="h-10 w-auto object-contain brightness-0 invert" />
        </a>
        <p class="mt-4 text-[12px] leading-relaxed text-[rgba(255,255,255,0.45)]">
          Leading advisory-driven trading firm dedicated to helping clients achieve their financial goals through innovative solutions.
        </p>
        <address class="mt-5 not-italic space-y-2.5 text-[12px] leading-relaxed">
          <div class="flex items-center gap-2.5">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" class="h-3.5 w-3.5 shrink-0 text-[rgba(255,255,255,0.35)]"><path d="M2 3.5h3l1.5 3.5-1.5 1a9 9 0 0 0 3.5 3.5l1-1.5 3.5 1.5v3C9 14.5 2 7.5 2 3.5z"/></svg>
            <a href="tel:18001031212" class="hover:text-white transition-colors">1800-XXX-XXXX</a>
          </div>
          <div class="flex items-center gap-2.5">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" class="h-3.5 w-3.5 shrink-0 text-[rgba(255,255,255,0.35)]"><rect x="2" y="4" width="12" height="9" rx="1.5"/><path d="M2 5l6 4.5L14 5"/></svg>
            <a href="mailto:helpdesk@shriramfinance.in" class="hover:text-white transition-colors">helpdesk@shriramfinance.in</a>
          </div>
          <div class="flex items-start gap-2.5">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" class="mt-0.5 h-3.5 w-3.5 shrink-0 text-[rgba(255,255,255,0.35)]"><path d="M8 1.5a5 5 0 0 1 5 5c0 3.5-5 8-5 8S3 10 3 6.5a5 5 0 0 1 5-5z"/><circle cx="8" cy="6.5" r="1.5"/></svg>
            <span>Shriram Financial Services, Shriram House,<br>T.Nagar, Chennai – 600 017</span>
          </div>
        </address>
        <div class="mt-5 flex items-center gap-2">
          {[
            { label:'Facebook',  d:'M10 1H8a3 3 0 0 0-3 3v2H3v3h2v6h3V9h2l.5-3H8V4c0-.6.4-1 1-1h1V1z' },
            { label:'Twitter/X', d:'M1 1l14 14M1 15L15 1' },
            { label:'LinkedIn',  d:'M2 2h2v2H2V2zm0 4h2v8H2V6zM6 6h2v1.2C8.4 6.4 9.4 6 10 6a3 3 0 0 1 3 3v5h-2V9.5c0-1-.5-1.5-1.3-1.5S8.2 8.5 8 9.5V14H6V6z' },
            { label:'Instagram', d:'M5 2h6a3 3 0 0 1 3 3v6a3 3 0 0 1-3 3H5a3 3 0 0 1-3-3V5a3 3 0 0 1 3-3zm3 3.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zm3.5-.25a.75.75 0 1 0 0 1.5.75.75 0 0 0 0-1.5z' },
          ].map(s => (
            <a href="#" aria-label={s.label} onclick="event.preventDefault()"
               class="grid h-7 w-7 place-items-center rounded-full border border-[rgba(255,255,255,0.12)] text-[rgba(255,255,255,0.45)] transition-all hover:border-white/30 hover:bg-white/10 hover:text-white">
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" class="h-3 w-3">
                <path d={s.d}/>
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-[10px] font-bold uppercase tracking-widest text-[rgba(255,255,255,0.30)]">Company</h3>
        <ul class="mt-4 space-y-2.5">
          {[
            { label:'About Us',          href:'/about/' },
            { label:'Media',             href:'/about/' },
            { label:'Careers',           href:'/about/' },
            { label:'Locate Us',         href:'/about/' },
            { label:'Advertise With Us', href:'/about/' },
          ].map(l => (
            <li><a href={l.href} class="text-[13px] transition-colors hover:text-white">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="text-[10px] font-bold uppercase tracking-widest text-[rgba(255,255,255,0.30)]">Resources</h3>
        <ul class="mt-4 space-y-2.5">
          {[
            { label:'Pricing',            href:'/product-hub/' },
            { label:'Research Reports',   href:'/research/' },
            { label:'Market Insights',    href:'/research/' },
            { label:'FAQs',               href:'/#faq' },
            { label:'Learning Centre',    href:'/research/' },
            { label:'Calculator Tools',   href:'/product-hub/' },
          ].map(l => (
            <li><a href={l.href} class="text-[13px] transition-colors hover:text-white">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-[10px] font-bold uppercase tracking-widest text-[rgba(255,255,255,0.30)]">Legal</h3>
        <ul class="mt-4 space-y-2.5">
          {[
            { label:'Privacy Policy',    href:'/about/regulatory/' },
            { label:'Terms of Service',  href:'/about/regulatory/' },
            { label:'Disclaimer',        href:'/about/regulatory/' },
            { label:'Regulatory',        href:'/about/regulatory/' },
          ].map(l => (
            <li><a href={l.href} class="text-[13px] transition-colors hover:text-white">{l.label}</a></li>
          ))}
        </ul>
      </div>

    </div>
  </div>

  <!-- ── Product sub-nav grid ── -->
  <div class="border-t border-[rgba(255,255,255,0.06)]">
    <div class="site-wrap py-8">
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-3 lg:grid-cols-5">
        <!-- Trade -->
        <div>
          <h4 class="text-[10px] font-bold uppercase tracking-widest text-[rgba(255,255,255,0.30)] mb-3">Trade</h4>
          <ul class="space-y-2">
            {[
              {label:'Equity',                    href:'/products/equity/'},
              {label:'Mutual Funds',              href:'/products/mutual-funds/'},
              {label:'ETFs',                      href:'/products/etf/'},
              {label:'Bonds',                     href:'/products/bonds/'},
              {label:'Margin Trading Facility (MTF)', href:'/products/mtf/'},
              {label:'Derivative',                href:'/products/derivative/'},
            ].map(l => (
              <li><a href={l.href} class="text-[12px] text-[rgba(255,255,255,0.50)] transition-colors hover:text-white">{l.label}</a></li>
            ))}
          </ul>
        </div>
        <!-- Invest -->
        <div>
          <h4 class="text-[10px] font-bold uppercase tracking-widest text-[rgba(255,255,255,0.30)] mb-3">Invest</h4>
          <ul class="space-y-2">
            {[
              {label:'Mutual Funds',              href:'/products/mutual-funds/'},
              {label:'ETFs',                      href:'/products/etf/'},
              {label:'Bonds',                     href:'/products/bonds/'},
              {label:'National Pension Scheme (NPS)', href:'/products/nps/'},
              {label:'IPO',                       href:'/products/ipo/'},
            ].map(l => (
              <li><a href={l.href} class="text-[12px] text-[rgba(255,255,255,0.50)] transition-colors hover:text-white">{l.label}</a></li>
            ))}
          </ul>
        </div>
        <!-- Loans -->
        <div>
          <h4 class="text-[10px] font-bold uppercase tracking-widest text-[rgba(255,255,255,0.30)] mb-3">Loans</h4>
          <ul class="space-y-2">
            {[
              {label:'Personal Loan Against Mutual Fund', href:'/products/mtf/'},
              {label:'Loan Against Stocks',               href:'/products/mtf/'},
            ].map(l => (
              <li><a href={l.href} class="text-[12px] text-[rgba(255,255,255,0.50)] transition-colors hover:text-white">{l.label}</a></li>
            ))}
          </ul>
        </div>
        <!-- Insurance -->
        <div>
          <h4 class="text-[10px] font-bold uppercase tracking-widest text-[rgba(255,255,255,0.30)] mb-3">Insurance</h4>
          <ul class="space-y-2">
            {[
              {label:'Life Insurance',    href:'/about/'},
              {label:'General Insurance', href:'/about/'},
            ].map(l => (
              <li><a href={l.href} class="text-[12px] text-[rgba(255,255,255,0.50)] transition-colors hover:text-white">{l.label}</a></li>
            ))}
          </ul>
        </div>
        <!-- Others -->
        <div>
          <h4 class="text-[10px] font-bold uppercase tracking-widest text-[rgba(255,255,255,0.30)] mb-3">Others</h4>
          <ul class="space-y-2">
            {[
              {label:'Fixed Deposit', href:'/products/fd/'},
            ].map(l => (
              <li><a href={l.href} class="text-[12px] text-[rgba(255,255,255,0.50)] transition-colors hover:text-white">{l.label}</a></li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Stock alphabet nav ── -->
  <div class="border-t border-[rgba(255,255,255,0.06)]">
    <div class="site-wrap py-5">
      <div class="flex flex-wrap items-center gap-1">
        <span class="text-[11px] font-bold uppercase tracking-wider text-[rgba(255,255,255,0.25)] mr-1">Stocks</span>
        {alphabet.map(letter => (
          <a href={`/research/`}
             class="grid h-6 w-6 place-items-center rounded text-[11px] font-medium text-[rgba(255,255,255,0.40)] transition-colors hover:bg-white/10 hover:text-white">
            {letter}
          </a>
        ))}
        <a href="/research/" class="ml-1 text-[11px] font-semibold text-[rgba(255,255,255,0.40)] hover:text-white">View All</a>
      </div>
    </div>
  </div>

  <!-- ── Regulatory partner links ── -->
  <div class="border-t border-[rgba(255,255,255,0.06)]">
    <div class="site-wrap py-4">
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1.5">
        <span class="text-[11px] font-bold uppercase tracking-wider text-[rgba(255,255,255,0.25)]">Others</span>
        {['NSE','BSE','NSDL','CDSL','SEBI','MCX','SMART CDR','RBI','FMC','IRDAI','AMFI'].map(org => (
          <span class="text-[11px] text-[rgba(255,255,255,0.38)]">{org}</span>
        ))}
      </div>
    </div>
  </div>

  <!-- ── Regulatory text ── -->
  <div class="border-t border-[rgba(255,255,255,0.06)]">
    <div class="site-wrap py-8">
      <p class="text-[11px] leading-[1.9] text-[rgba(255,255,255,0.38)]">
        Shriram Financial Services – CIN: U67120DL2022PTC390729 | Stock Broking: SEBI Regn. No.: INZ000176838 | Exchange Memberships: ID NSE: YDSL, BSE: 3971, NSE-SLB, MCX: 56789, Depository Participant: SEBI Regn. No.: IN-DP-679-2022 | CDSL ID: NSE: 1200, PAN: AAABC1234D (Date of Initial registration - 4th Dec 2004, Date of Expiry - 3rd Nov 2027) | PMS/IA: PAN/0000005316 | PAX 0000 - Research Analyst: INH200009624 | Register with AMFI: ARN-29483 | Register on SCORES: Register on iSCORES.
      </p>
      <p class="mt-3 text-[11px] leading-[1.9] text-[rgba(255,255,255,0.38)]">
        Procedure to file a complaint on SEBI SCORES: Register on SCORES portal. Mandatory details for filing complaints on SCORES: Name, PAN, Address, Mobile Number, E-mail ID. Benefits: Effective Communication, Speedy redressal of the grievances.
      </p>
      <p class="mt-3 text-[11px] leading-[1.9] text-[rgba(255,255,255,0.30)]">
        <strong class="font-medium text-[rgba(255,255,255,0.45)]">NSE Disclaimer:</strong> The Stock Exchange, Mumbai is not in any manner responsible or liable to any person or persons for any acts of omission or commission, errors, mistakes and/or violation, actual or perceived, by us or our partners, agents, associates etc., of any of the Rules, Regulations, Bye-laws of the Stock Exchange, BSE Act or any other law in force from time to time. The Stock Exchange, Mumbai is not responsible or liable for any information on this Website or for any services rendered by our employees, our servants, and us.
      </p>
    </div>
  </div>

  <!-- ── Bottom bar ── -->
  <div class="border-t border-[rgba(255,255,255,0.05)]">
    <div class="site-wrap flex flex-col items-start justify-between gap-3 py-4 sm:flex-row sm:items-center">
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1.5 text-[11px] text-[rgba(255,255,255,0.30)]">
        <a href="/about/" class="hover:text-white transition-colors">Account Closure</a>
        <span aria-hidden="true">|</span>
        <a href="/about/regulatory/" class="hover:text-white transition-colors">Terms &amp; Conditions</a>
        <span aria-hidden="true">|</span>
        <a href="/about/regulatory/" class="hover:text-white transition-colors">Terms of Use</a>
        <span aria-hidden="true">|</span>
        <a href="/about/regulatory/" class="hover:text-white transition-colors">Privacy Policy</a>
      </div>
      <div class="flex flex-col items-start gap-1 sm:items-end text-[11px]">
        <span class="text-[rgba(255,255,255,0.28)]">© {year} Shriram Securities. All rights reserved.</span>
        <span class="text-[rgba(255,255,255,0.28)]">SEBI Registered Investment Advisor | ARN 29483</span>
      </div>
    </div>
  </div>

</footer>
