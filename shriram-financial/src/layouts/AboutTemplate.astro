---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  lead: string;
}
const { title, description, lead } = Astro.props;
---

<BaseLayout title={title} description={description}>

  <!-- ── Hero ── -->
  <section class="hero">
    <div class="hero-inner">
      <h1>{title}</h1>
      <p class="lead">{lead}</p>
    </div>
  </section>

  <!-- ── Content ── -->
  <section class="section" style="background:var(--sec-light)">
    <div class="legal-prose">
      <slot />
    </div>
  </section>

  <!-- ── Final CTA ── -->
  <section class="cta-sec" style="background:var(--sec-tint)">
    <div class="cta-box">
      <div class="ct-tt">
        <h3>Ready to Start Investing?</h3>
        <p class="ct-sub">Open a free Demat account in under 10 minutes — zero delivery brokerage, SEBI-registered research, and a dedicated advisor.</p>
      </div>
      <a class="btn-gold" href="/about/open-demat-account/">Open Demat Account</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* Legal / about prose — matches the design-system tokens (see privacy.astro). */
  .legal-prose { display: flex; flex-direction: column; gap: 40px; max-width: 900px; }
  .legal-prose :global(h2) {
    font-weight: 500; font-size: 28px; color: var(--ink); line-height: 1.5;
    margin-top: 16px;
  }
  .legal-prose :global(h2:first-child) { margin-top: 0; }
  .legal-prose :global(h3) {
    font-weight: 500; font-size: 20px; color: var(--ink); line-height: 1.5;
  }
  .legal-prose :global(p) {
    font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.6;
    margin-top: 12px;
  }
  .legal-prose :global(a) { color: #2f7ef4; }
  .legal-prose :global(strong) { font-weight: 600; color: var(--ink); }
  .legal-prose :global(ul) {
    list-style: none; padding: 0; margin: 16px 0 0;
    display: flex; flex-direction: column; gap: 14px;
  }
  .legal-prose :global(ul li) {
    position: relative; padding-left: 24px;
    font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.6;
  }
  .legal-prose :global(ul li::before) {
    content: ""; position: absolute; left: 8px; top: 10px; width: 6px; height: 6px;
    border-radius: 50%; background: var(--olive-title);
  }

  @media (max-width: 768px) {
    .legal-prose { gap: 32px; }
    .legal-prose :global(h2) { font-size: clamp(22px, 5.4vw, 28px); }
    .legal-prose :global(p), .legal-prose :global(ul li) { font-size: 14px; }
  }
</style>
