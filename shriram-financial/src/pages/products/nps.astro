---
import BaseLayout from '../../layouts/BaseLayout.astro';

const accounts = [
  { label: 'Tier 1 Account', desc: 'The primary NPS pension account with tax-deductible contributions. Locked until age 60 — purpose-built for retirement. Minimum: ₹500/year.', tag: 'Tax-Exempt' },
  { label: 'Tier 2 Account', desc: 'A voluntary, fully liquid savings account linked to Tier 1. No tax benefit (except for government employees). Minimum: ₹250/year, withdraw anytime.', tag: 'Flexible' },
];

const assetClasses = [
  { code: 'E', label: 'Equity (Class E)', desc: 'Equity and equity-related instruments. Up to 75% allocation (tapers after age 50). Highest growth potential and highest volatility.' },
  { code: 'C', label: 'Corporate Bonds (Class C)', desc: 'High-rated corporate debt (AA and above). Moderate risk with stable, predictable returns — good for core stability in your NPS mix.' },
  { code: 'G', label: 'Government Securities (Class G)', desc: 'Central and state government bonds — the lowest-risk NPS class. Suitable for conservative investors nearing retirement.' },
  { code: 'A', label: 'Alternative Investments (Class A)', desc: 'REITs, InvITs, and alternative assets. Capped at 5% allocation — adds diversification beyond traditional debt and equity.' },
];

const taxRows = [
  { section: '80CCD(1)', limit: '₹1,50,000 per year', category: 'Employee / Self-employed', note: 'Part of overall 80C limit of ₹1.5 lakh' },
  { section: '80CCD(1B)', limit: '₹50,000 per year (additional)', category: 'All NPS subscribers', note: 'Over and above the 80C limit — exclusive to NPS' },
  { section: '80CCD(2)', limit: 'Up to 10% of Basic + DA', category: 'Salaried (employer contribution)', note: 'No upper limit; employer\'s contribution is deductible' },
];

const vsRows = [
  { feature: 'Purpose', nps: 'Market-linked retirement savings', epf: 'Retirement corpus for salaried', ppf: 'Tax-free long-term savings' },
  { feature: 'Returns', nps: 'Market-linked (8–12% historically)', epf: '8.25% (FY2024, declared by EPFO)', ppf: '7.1% (current, reviewed quarterly)' },
  { feature: 'Lock-in', nps: 'Until age 60', epf: 'Until retirement (partial withdrawal allowed)', ppf: '15 years (partial withdrawal from year 7)' },
  { feature: 'Tax on Maturity', nps: '60% tax-free, 40% annuity (taxable)', epf: 'Tax-free (if 5+ years)', ppf: 'Fully tax-free' },
  { feature: 'Employer Contribution', nps: '10% of Basic+DA (govt), 14% for govt employee', epf: '12% of Basic+DA (mandatory)', ppf: 'No employer contribution' },
  { feature: 'SEBI/PFRDA Regulated', nps: 'PFRDA', epf: 'EPFO', ppf: 'Ministry of Finance' },
];

const steps = [
  { n: '01', title: 'Choose PRAN Account Type', desc: 'Select Tier 1 (pension) or Tier 1 + Tier 2 (pension + savings). Choose your Pension Fund Manager (HDFC, SBI, Kotak, etc.).' },
  { n: '02', title: 'Submit KYC & Documents', desc: 'Complete Aadhaar-based e-KYC on the Shriram platform. Submit PAN, address proof, and nominee details digitally.' },
  { n: '03', title: 'Choose Asset Allocation', desc: 'Select Active Choice (you control the E/C/G split) or Auto Choice (age-based automatic rebalancing) — or the aggressive/moderate/conservative lifecycle fund.' },
  { n: '04', title: 'Start Contributing', desc: 'Make your first contribution (minimum ₹500 for Tier 1, ₹250 for Tier 2). Set up auto-debit for regular contributions and track your corpus in real time.' },
];

const faqs = [
  { q: 'Can I withdraw from NPS before retirement?', a: 'Yes — after 3 years, you can withdraw up to 25% of your own contributions for specific reasons: child\'s education/marriage, home purchase, critical illness, or business setup. A maximum of 3 withdrawals are allowed in a lifetime.' },
  { q: 'What happens to NPS at retirement (age 60)?', a: 'At 60, withdraw up to 60% of the corpus tax-free. The remaining 40% must purchase a PFRDA-registered annuity, which pays a monthly pension. You can defer withdrawal until age 75.' },
  { q: 'Is NPS better than PPF for tax saving?', a: 'NPS allows up to ₹2 lakh deduction (80C + 80CCD(1B)), vs PPF\'s ₹1.5 lakh under 80C. PPF maturity is fully tax-free; NPS annuity income is taxable. Most advisors recommend both for maximum tax efficiency.' },
  { q: 'What is the minimum annual contribution for NPS?', a: 'Tier 1: ₹500 per contribution, ₹1,000 per year minimum. Tier 2: ₹250 per contribution, no annual minimum. Missing Tier 1\'s annual minimum makes your PRAN inactive with a ₹100/year penalty.' },
  { q: 'Can self-employed individuals invest in NPS?', a: 'Yes. All Indian citizens aged 18–70 can open NPS. Self-employed subscribers claim 80CCD(1) up to 20% of gross income (within ₹1.5 lakh 80C limit), plus the exclusive ₹50,000 under 80CCD(1B).' },
];
---

<BaseLayout
  title="NPS Investment India — Tax Saving National Pension Scheme | Shriram"
  description="Invest in NPS online and save up to ₹2 lakh in tax deductions annually. Market-linked retirement corpus, PFRDA regulated, flexible fund choice. Open NPS account today."
>

  <!-- ══ 1. HERO ═══════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[var(--color-dark-800)]">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[560px] w-[560px] rounded-full bg-[var(--color-brand)]/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-32 left-0 h-80 w-80 rounded-full bg-[var(--color-brand)]/5 blur-3xl"></div>
    <div class="site-wrap relative py-[120px]">
      <p class="equity-reveal text-[14px] font-medium tracking-[.04em] text-[var(--color-brand)]">National Pension Scheme</p>
      <h1 class="equity-reveal mt-[22px] max-w-[880px] text-[clamp(32px,4vw,52px)] font-bold leading-[1.06] text-white" style="font-family:var(--font-display)">
        Retire Rich with NPS — <span class="text-[var(--color-brand)]">Tax-Efficient &amp; Market-Linked</span>
      </h1>
      <p class="equity-reveal mt-[26px] max-w-[600px] text-[18px] leading-relaxed text-white/70">
        The National Pension Scheme (NPS) offers up to ₹2 lakh in tax deductions annually, market-linked returns, and a guaranteed retirement income — all in one PFRDA-regulated account.
      </p>
      <div class="equity-reveal mt-[38px] flex flex-wrap gap-[14px]">
        <a href="/about/open-demat-account/" class="btn-primary">Open NPS Account</a>
        <a href="/about/support/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Talk to RM</a>
      </div>
      <div class="equity-reveal mt-[54px] flex flex-wrap gap-x-9 gap-y-3 border-t border-white/15 pt-9">
        {['✓ Up to ₹2L tax saving', '✓ PFRDA regulated', '✓ Market-linked returns', '✓ Flexible fund choice'].map(f => (
          <span class="text-[15px] font-medium text-white/90">
            <span class="mr-2 text-[var(--color-brand)]">{f.slice(0,1)}</span>{f.slice(1)}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 2. ACCOUNT TYPES ══════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto grid max-w-[1000px] items-start gap-[72px] lg:grid-cols-[5fr_7fr]">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          NPS Account Types — <span class="text-[var(--color-brand)]">Tier 1 &amp; Tier 2</span>
        </h2>
        <div class="space-y-5 text-[17px] leading-relaxed text-[var(--color-muted)]">
          <p>NPS operates through two types of accounts designed for different financial needs — mandatory pension savings and flexible voluntary savings.</p>
          <p>Together, they allow you to maximise retirement savings while maintaining some liquidity for short-term needs.</p>
        </div>
      </div>
      <div class="equity-reveal mx-auto mt-[76px] max-w-[1000px] border-t border-[var(--color-n400)] pt-[60px]">
        <div class="grid gap-5 sm:grid-cols-2">
          {accounts.map((a, i) => (
            <div class="product-card-light p-[34px]" style={`animation-delay:${i*80}ms`}>
              <span class="inline-flex w-fit rounded-full bg-[var(--color-brand)]/15 px-3 py-1 text-[11px] font-bold uppercase tracking-wide text-[var(--color-brand-deep)]">{a.tag}</span>
              <h3 class="mt-4 text-[18px] font-bold text-[var(--color-dark-olive)]" style="font-family:var(--font-display)">{a.label}</h3>
              <p class="mt-3 text-[14px] leading-relaxed text-[var(--color-muted)]">{a.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 3. ASSET CLASSES ══════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          NPS Asset Classes — <span class="text-[var(--color-brand)]">Where Your Money Is Invested</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Four classes covering the full risk-return spectrum — from equity to government bonds to alternatives.</p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {assetClasses.map((a, i) => (
          <div class="equity-reveal product-card-light flex flex-col gap-3 p-6" style={`animation-delay:${i*60}ms`}>
            <div class="flex h-10 w-auto min-w-[60px] items-center justify-center rounded-[10px] bg-[var(--color-dark-olive)] px-3 w-fit">
              <span class="text-[13px] font-bold text-[var(--color-brand)]">Class {a.code}</span>
            </div>
            <h3 class="text-[15px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{a.label}</h3>
            <p class="text-[13px] leading-relaxed text-[var(--color-muted)]">{a.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 4. TAX SAVINGS ════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Tax Savings <span class="text-[var(--color-brand)]">with NPS</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">NPS offers the highest combined tax deduction among all Section 80 instruments — up to ₹2 lakh per year with the right combination.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto"><table class="w-full text-[15.5px]">
          <thead><tr class="bg-[var(--color-dark-olive)]"><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Section</th><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Deduction Limit</th><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Eligible For</th><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Note</th></tr></thead>
          <tbody>{taxRows.map((r,i) => (<tr class={i%2===0?'bg-white':'bg-[#f8f6f1]'}><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-brand-deep)]">{r.section}</td><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-medium text-[var(--color-ink)]">{r.limit}</td><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.category}</td><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[12px] text-[var(--color-muted)]">{r.note}</td></tr>))}</tbody>
        </table></div>
      </div>
    </div>
  </section>

  <!-- ══ 5. HOW TO JOIN ════════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How to <span class="text-[var(--color-brand)]">Join NPS</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Four steps from registration to your first contribution — fully digital and paperless.</p>
      </div>
      <div class="equity-reveal steps-grid overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        {steps.map(s => (
          <div class="px-[30px] py-[34px]">
            <div class="mb-[22px] font-display text-[34px] font-normal leading-none text-[var(--color-brand)]">{s.n}</div>
            <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">{s.title}</h4>
            <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 6. NPS VS EPF VS PPF ══════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          NPS vs EPF <span class="text-[var(--color-brand)]">vs PPF</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Compare India's three major retirement savings instruments across returns, lock-in, and tax efficiency.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto"><table class="w-full text-[15.5px]">
          <thead><tr class="bg-[var(--color-dark-olive)]"><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Feature</th><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">NPS</th><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">EPF</th><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">PPF</th></tr></thead>
          <tbody>{vsRows.map((r,i) => (<tr class={i%2===0?'bg-white':'bg-[#f8f6f1]'}><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.feature}</td><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.nps}</td><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.epf}</td><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.ppf}</td></tr>))}</tbody>
        </table></div>
      </div>
    </div>
  </section>

  <!-- ══ 7. FAQ ════════════════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Frequently Asked <span class="text-[var(--color-brand)]">Questions</span>
        </h2>
      </div>
      <div class="equity-reveal mx-auto max-w-[840px] border-t border-[var(--color-n400)]">
        {faqs.map(item => (
          <details class="eq-faq group border-b border-[var(--color-n400)]">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-5 py-[26px] px-2">
              <span class="text-[18px] font-semibold text-[var(--color-ink)]">{item.q}</span>
              <span class="shrink-0 text-[22px] leading-none text-[var(--color-brand)] transition-transform duration-300 group-open:rotate-45">+</span>
            </summary>
            <div class="overflow-hidden px-2 pb-0 text-[16px] leading-relaxed text-[var(--color-muted)] transition-all duration-300 group-open:pb-[28px]">
              <p class="max-w-[680px]">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 8. FINAL CTA ══════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal overflow-hidden rounded-[22px] bg-[var(--color-dark-800)] px-[60px] py-[64px] text-center">
        <h3 class="mx-auto max-w-[560px] text-[38px] font-bold leading-[1.12] text-white" style="font-family:var(--font-display)">Secure Your Retirement with NPS Today</h3>
        <p class="mx-auto mt-[18px] max-w-[480px] text-[17px] leading-relaxed text-white/70">Open your NPS PRAN account with Shriram Financial Services. Save tax, grow wealth, and ensure a guaranteed monthly pension.</p>
        <div class="mt-[34px] flex flex-wrap justify-center gap-[14px]">
          <a href="/about/open-demat-account/" class="btn-primary">Open NPS Account</a>
          <a href="/about/support/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Talk to an RM</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .equity-reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s cubic-bezier(0.22, 0.61, 0.36, 1), transform 0.7s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .equity-reveal.in-view { opacity: 1; transform: none; }

  .steps-grid { display: grid; grid-template-columns: repeat(2, 1fr); }
  .steps-grid > * { border-right: 1px solid var(--color-n400); border-bottom: 1px solid var(--color-n400); }
  .steps-grid > *:nth-child(2n) { border-right: 0; }
  .steps-grid > *:nth-last-child(-n+2) { border-bottom: 0; }
  @media (min-width: 1024px) {
    .steps-grid { grid-template-columns: repeat(4, 1fr); }
    .steps-grid > * { border-right: 1px solid var(--color-n400); border-bottom: 0; }
    .steps-grid > *:last-child { border-right: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .equity-reveal { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).classList.add('in-view');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.10 });
  document.querySelectorAll('.equity-reveal').forEach(el => obs.observe(el));

  document.querySelectorAll<HTMLDetailsElement>('.eq-faq').forEach(d => {
    d.addEventListener('toggle', () => {
      if (d.open) document.querySelectorAll<HTMLDetailsElement>('.eq-faq').forEach(o => { if (o !== d) o.removeAttribute('open'); });
    });
  });
</script>
