---
import BaseLayout from '../../layouts/BaseLayout.astro';

const accounts = [
  { label: 'Tier 1 Account', desc: 'The primary NPS pension account. Contributions are tax-deductible. Locked until age 60 — purpose-built for retirement. Minimum: ₹500/year.', tag: 'Tax-Exempt' },
  { label: 'Tier 2 Account', desc: 'A voluntary, fully liquid savings account linked to Tier 1. No tax benefit (except for government employees). Minimum: ₹250/year — withdraw anytime.', tag: 'Flexible' },
];

const assetClasses = [
  { code: 'E', label: 'Equity (Class E)', desc: 'Equity and equity-related instruments. Up to 75% allocation (tapers after age 50). Highest growth potential, highest volatility.' },
  { code: 'C', label: 'Corporate Bonds (Class C)', desc: 'High-rated corporate debt (AA and above). Moderate risk with stable, predictable returns — good for core stability.' },
  { code: 'G', label: 'Government Securities (Class G)', desc: 'Central and state government bonds — the lowest-risk NPS class. Suitable for conservative investors nearing retirement.' },
  { code: 'A', label: 'Alternatives (Class A)', desc: 'REITs, InvITs, and alternative assets. Capped at 5% allocation — adds diversification beyond traditional debt and equity.' },
];

const taxRows = [
  { section: '80CCD(1)', limit: '₹1,50,000 per year', category: 'Employee / Self-employed', note: 'Part of overall 80C limit of ₹1.5 lakh' },
  { section: '80CCD(1B)', limit: '₹50,000 per year (additional)', category: 'All NPS subscribers', note: 'Over and above the 80C limit — exclusive to NPS' },
  { section: '80CCD(2)', limit: 'Up to 10% of Basic + DA', category: 'Salaried (employer contribution)', note: "No upper limit; employer's contribution is fully deductible" },
];

const vsRows = [
  { feature: 'Purpose', nps: 'Market-linked retirement savings', epf: 'Retirement corpus for salaried', ppf: 'Tax-free long-term savings' },
  { feature: 'Returns', nps: 'Market-linked (8–12% historically)', epf: '8.25% (FY2024, EPFO declared)', ppf: '7.1% (reviewed quarterly)' },
  { feature: 'Lock-in', nps: 'Until age 60', epf: 'Until retirement (partial allowed)', ppf: '15 years (partial from year 7)' },
  { feature: 'Tax on Maturity', nps: '60% tax-free; 40% annuity (taxable)', epf: 'Tax-free (if 5+ years service)', ppf: 'Fully tax-free' },
  { feature: 'Employer Contribution', nps: '10% Basic+DA (govt); 14% for central govt', epf: '12% Basic+DA (mandatory)', ppf: 'No employer contribution' },
  { feature: 'Regulator', nps: 'PFRDA', epf: 'EPFO', ppf: 'Ministry of Finance' },
];

const steps = [
  { n: '01', title: 'Choose PRAN Account Type', desc: 'Select Tier 1 (pension) or Tier 1 + Tier 2 (pension + savings). Choose your Pension Fund Manager — HDFC, SBI, Kotak, and more.' },
  { n: '02', title: 'Submit KYC & Documents', desc: 'Complete Aadhaar-based e-KYC on the Shriram platform. Submit PAN, address proof, and nominee details digitally.' },
  { n: '03', title: 'Choose Asset Allocation', desc: 'Select Active Choice (you control E/C/G split) or Auto Choice (age-based rebalancing) — conservative, moderate, or aggressive lifecycle fund.' },
  { n: '04', title: 'Start Contributing', desc: 'Make your first contribution (min ₹500 Tier 1, ₹250 Tier 2). Set up auto-debit for regular contributions and track corpus in real time.' },
];

const withdrawalReasons = [
  "Child's education or marriage",
  "Home purchase or construction",
  "Critical illness or disability",
  "Starting a business",
];

const annuityPoints = [
  { label: '60% of corpus', desc: 'Fully tax-free withdrawal at age 60 — no tax liability on this portion.' },
  { label: '40% mandatory annuity', desc: 'Must purchase a PFRDA-registered annuity. Monthly pension paid; annuity income taxable per slab.' },
  { label: 'Deferred exit', desc: 'Defer withdrawal until age 75 if you wish to continue growing the corpus.' },
  { label: 'Lump sum below ₹5L', desc: 'If total corpus is below ₹5 lakh, the entire amount can be withdrawn as a lump sum.' },
];

const faqs = [
  { q: 'Can I withdraw from NPS before retirement?', a: "Yes — after 3 years, you can withdraw up to 25% of your own contributions for specific reasons: child's education/marriage, home purchase, critical illness, or business setup. Maximum 3 withdrawals over the lifetime of the PRAN." },
  { q: 'What happens to NPS at age 60?', a: 'At 60, withdraw up to 60% of the corpus tax-free. The remaining 40% must purchase a PFRDA-registered annuity for a monthly pension. You can defer the entire withdrawal until age 75.' },
  { q: 'Is NPS better than PPF for tax saving?', a: "NPS allows up to ₹2 lakh deduction (80C + 80CCD(1B)), vs PPF's ₹1.5 lakh under 80C. PPF maturity is fully tax-free; NPS annuity income is taxable. Most advisors recommend both for maximum efficiency." },
  { q: 'What is the minimum annual contribution?', a: "Tier 1: ₹500 per contribution, ₹1,000 per year minimum. Tier 2: ₹250 per contribution, no annual minimum. Missing Tier 1's annual minimum makes your PRAN inactive with a ₹100/year penalty." },
  { q: 'Can self-employed individuals invest in NPS?', a: 'Yes. All Indian citizens aged 18–70 can open NPS. Self-employed subscribers claim 80CCD(1) up to 20% of gross income (within ₹1.5 lakh 80C limit), plus the exclusive ₹50,000 under 80CCD(1B).' },
  { q: 'Who regulates NPS?', a: 'NPS is regulated by PFRDA (Pension Fund Regulatory and Development Authority), a statutory body under the Ministry of Finance. All Pension Fund Managers (PFMs) are PFRDA-registered.' },
  { q: 'Can I change my Pension Fund Manager (PFM)?', a: 'Yes. You can switch your PFM or investment scheme once per year at no cost. Active Choice allows you to rebalance your E/C/G/A allocation at any time.' },
  { q: 'What happens to NPS if I die before 60?', a: "The entire accumulated corpus is paid to the nominee (or legal heir) as a lump sum — no mandatory annuity. Nominee is exempt from the 40% annuity rule in the subscriber's case." },
];
---

<BaseLayout
  title="NPS India 2026 — National Pension Scheme Tax Saving | Shriram"
  description="Invest in NPS India 2026 and save up to ₹2 lakh in tax deductions annually. Market-linked retirement corpus, PFRDA regulated, flexible fund choice. Open NPS account today."
>

  <!-- ══ S1: HERO ════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[var(--color-dark-800)]">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[560px] w-[560px] rounded-full bg-[var(--color-brand)]/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-32 left-0 h-80 w-80 rounded-full bg-[var(--color-brand)]/5 blur-3xl"></div>
    <div class="site-wrap relative py-[120px]">
      <p class="equity-reveal text-[14px] font-medium tracking-[.04em] text-[var(--color-brand)]">National Pension Scheme</p>
      <h1 class="equity-reveal mt-[22px] max-w-[880px] text-[clamp(32px,4vw,52px)] font-bold leading-[1.06] text-white" style="font-family:var(--font-display)">
        <span class="text-[var(--color-brand)]">NPS India 2026</span> — Tax-Efficient &amp; Market-Linked Retirement
      </h1>
      <p class="equity-reveal mt-[26px] max-w-[600px] text-[18px] leading-relaxed text-white/70">
        The National Pension Scheme (NPS) offers up to ₹2 lakh in tax deductions annually, market-linked returns, and a guaranteed retirement income — all in one PFRDA-regulated account.
      </p>
      <div class="equity-reveal mt-[38px] flex flex-wrap gap-[14px]">
        <a href="/about/open-demat-account/" class="btn-primary">Open NPS Account</a>
        <a href="/about/support/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Talk to RM</a>
      </div>
      <div class="equity-reveal mt-[54px] flex flex-wrap gap-x-9 gap-y-3 border-t border-white/15 pt-9">
        {['✓ Up to ₹2L tax saving', '✓ PFRDA regulated', '✓ Market-linked returns', '✓ Flexible fund choice'].map(f => (
          <span class="text-[15px] font-medium text-white/90">{f}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S2: WHAT IS NPS? ═══════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto grid max-w-[1000px] items-start gap-[72px] lg:grid-cols-[5fr_7fr]">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          What is <span class="text-[var(--color-brand)]">NPS?</span>
        </h2>
        <div class="space-y-5 text-[17px] leading-relaxed text-[var(--color-muted)]">
          <p>NPS (National Pension Scheme) is a voluntary, government-backed retirement savings plan regulated by PFRDA. Contributions are invested in market-linked instruments — equity, corporate bonds, and government securities.</p>
          <p>NPS operates through two types of accounts designed for different financial needs: mandatory pension savings (Tier 1) and flexible voluntary savings (Tier 2).</p>
        </div>
      </div>
      <div class="equity-reveal mx-auto mt-[76px] max-w-[1000px] border-t border-[var(--color-n400)] pt-[60px]">
        <div class="grid gap-5 sm:grid-cols-2">
          {accounts.map((a, i) => (
            <div class="product-card-light p-[34px]" style={`animation-delay:${i*80}ms`}>
              <span class="inline-flex w-fit rounded-full bg-[var(--color-brand)]/15 px-3 py-1 text-[11px] font-bold uppercase tracking-wide text-[var(--color-brand-deep)]">{a.tag}</span>
              <h3 class="mt-4 text-[18px] font-bold text-[var(--color-dark-olive)]" style="font-family:var(--font-display)">{a.label}</h3>
              <p class="mt-3 text-[14px] leading-relaxed text-[var(--color-muted)]">{a.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S3: NPS ASSET CLASSES ══════════════════════════════════════ -->
  <section class="bg-[var(--color-n100)] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          NPS Asset Classes — <span class="text-[var(--color-brand)]">Where Your Money Is Invested</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Four classes covering the full risk-return spectrum — from equity to government bonds to alternatives.</p>
      </div>
      <div class="cat-grid">
        {assetClasses.map((a, i) => (
          <div class="equity-reveal product-card-light flex flex-col gap-3 p-6" style={`animation-delay:${i*60}ms`}>
            <div class="flex h-10 w-fit min-w-[60px] items-center justify-center rounded-[10px] bg-[var(--color-dark-olive)] px-3">
              <span class="text-[13px] font-bold text-[var(--color-brand)]">Class {a.code}</span>
            </div>
            <h3 class="text-[15px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{a.label}</h3>
            <p class="text-[13px] leading-relaxed text-[var(--color-muted)]">{a.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S4: NPS TAX BENEFITS ═══════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          NPS Tax Benefits — <span class="text-[var(--color-brand)]">Up to ₹2 Lakh Deduction</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">NPS offers the highest combined tax deduction among all Section 80 instruments. Combine 80CCD(1), 80CCD(1B), and 80CCD(2) for maximum savings.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Section</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Deduction Limit</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Eligible For</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Note</th>
              </tr>
            </thead>
            <tbody>
              {taxRows.map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[var(--color-n100)]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-brand-deep)]">{r.section}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-medium text-[var(--color-ink)]">{r.limit}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.category}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[12px] text-[var(--color-muted)]">{r.note}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S5: NPS RETURNS CALCULATOR ═════════════════════════════════ -->
  <section class="bg-[var(--color-n100)] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          NPS Returns <span class="text-[var(--color-brand)]">Calculator</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Estimate your NPS retirement corpus based on your age, monthly contribution, and expected returns. Plan early, retire comfortably.</p>
      </div>
      <div class="equity-reveal mx-auto max-w-[680px]">
        <a href="/calculators/sip/" class="product-card-light flex flex-col items-center gap-5 p-[48px] text-center transition-shadow hover:shadow-lg">
          <div class="flex h-16 w-16 items-center justify-center rounded-full bg-[var(--color-dark-olive)]">
            <span class="text-[28px] font-bold text-[var(--color-brand)]">₹</span>
          </div>
          <div>
            <h3 class="text-[22px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">NPS Retirement Calculator</h3>
            <p class="mt-2 text-[15px] text-[var(--color-muted)]">Project your corpus, monthly pension, and annuity income. Adjust contributions and fund choice to see the impact.</p>
          </div>
          <span class="inline-flex h-11 items-center justify-center rounded-[9px] bg-[var(--color-dark-olive)] px-[28px] text-[14px] font-semibold text-[var(--color-brand)]">Calculate Now →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ══ S6: NPS VS EPF VS PPF ══════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          NPS vs EPF <span class="text-[var(--color-brand)]">vs PPF</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Compare India's three major retirement savings instruments across returns, lock-in, tax treatment, and regulatory structure.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Feature</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">NPS</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">EPF</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">PPF</th>
              </tr>
            </thead>
            <tbody>
              {vsRows.map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[var(--color-n100)]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.feature}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.nps}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.epf}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.ppf}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S7: HOW TO OPEN NPS ACCOUNT ═══════════════════════════════ -->
  <section class="bg-[var(--color-n100)] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How to Open Your <span class="text-[var(--color-brand)]">NPS Account</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Four steps from registration to your first contribution — fully digital and paperless.</p>
      </div>
      <div class="equity-reveal steps-grid overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        {steps.map(s => (
          <div class="px-[30px] py-[34px]">
            <div class="mb-[22px] text-[34px] font-bold leading-none text-[var(--color-brand)]">{s.n}</div>
            <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">{s.title}</h4>
            <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S8: PARTIAL WITHDRAWAL RULES ══════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Partial Withdrawal <span class="text-[var(--color-brand)]">Rules</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">NPS locks your corpus until retirement, but PFRDA permits partial withdrawals in specific situations.</p>
      </div>
      <div class="equity-reveal grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <div class="bg-[var(--color-dark-800)] rounded-[14px] p-[28px]">
          <div class="mb-3 text-[36px] font-bold leading-none text-[var(--color-brand)]">3 yrs</div>
          <h4 class="mb-2 text-[16px] font-semibold text-white" style="font-family:var(--font-display)">Minimum Tenure</h4>
          <p class="text-[13px] leading-relaxed text-white/60">Must have been a subscriber for at least 3 years before any partial withdrawal is permitted.</p>
        </div>
        <div class="bg-[var(--color-dark-800)] rounded-[14px] p-[28px]">
          <div class="mb-3 text-[36px] font-bold leading-none text-[var(--color-brand)]">25%</div>
          <h4 class="mb-2 text-[16px] font-semibold text-white" style="font-family:var(--font-display)">Max of Own Contributions</h4>
          <p class="text-[13px] leading-relaxed text-white/60">Only your own contributions are counted — not employer contributions or investment returns.</p>
        </div>
        <div class="bg-[var(--color-dark-800)] rounded-[14px] p-[28px]">
          <div class="mb-3 text-[36px] font-bold leading-none text-[var(--color-brand)]">3x</div>
          <h4 class="mb-2 text-[16px] font-semibold text-white" style="font-family:var(--font-display)">Lifetime Withdrawals</h4>
          <p class="text-[13px] leading-relaxed text-white/60">Maximum of 3 partial withdrawals allowed over the entire lifetime of the PRAN account.</p>
        </div>
        <div class="bg-[var(--color-dark-800)] rounded-[14px] p-[28px]">
          <div class="mb-3 text-[20px] font-bold leading-none text-[var(--color-brand)]">Eligible Reasons</div>
          <ul class="space-y-1.5">
            {withdrawalReasons.map(r => (
              <li class="flex items-start gap-2 text-[12.5px] text-white/60">
                <span class="shrink-0 text-[var(--color-brand)]">→</span>{r}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S9: MATURITY & ANNUITY ═════════════════════════════════════ -->
  <section class="bg-[var(--color-n100)] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Maturity &amp; Annuity — <span class="text-[var(--color-brand)]">What Happens at Age 60</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">At retirement, NPS follows a structured withdrawal: 60% lump sum (tax-free) and 40% mandatory annuity for a monthly pension.</p>
      </div>
      <div class="equity-reveal mx-auto max-w-[900px] grid gap-5 sm:grid-cols-2">
        {annuityPoints.map((p, i) => (
          <div class="product-card-light p-[30px]" style={`animation-delay:${i*70}ms`}>
            <div class="mb-3 inline-flex h-9 items-center justify-center rounded-[8px] bg-[var(--color-dark-olive)] px-4">
              <span class="text-[12px] font-bold text-[var(--color-brand)]">{p.label}</span>
            </div>
            <p class="text-[14px] leading-relaxed text-[var(--color-muted)]">{p.desc}</p>
          </div>
        ))}
      </div>
      <div class="equity-reveal mx-auto mt-[48px] max-w-[900px] rounded-[14px] bg-[var(--color-brand-light)] border border-[var(--color-brand)]/30 p-[32px]">
        <p class="text-[15px] font-medium text-[var(--color-brand-deep)]"><strong>Note on annuity providers:</strong> PFRDA maintains a list of empanelled life insurers (LIC, SBI Life, HDFC Life, and others) from which you must purchase the annuity. Multiple payout options are available — life annuity, joint life with spouse, guaranteed period, and more.</p>
      </div>
    </div>
  </section>

  <!-- ══ S10: NPS CONTRIBUTION LIMITS & RULES 2026 ═════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          NPS Contribution Limits <span class="text-[var(--color-brand)]">& Rules 2026</span>
        </h2>
