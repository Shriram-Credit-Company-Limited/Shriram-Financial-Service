<style>
  .equity-reveal { opacity: 0; transform: translateY(20px); transition: opacity .55s ease, transform .55s ease; }
  .equity-reveal.in-view { opacity: 1; transform: none; }
  .steps-grid { display: grid; grid-template-columns: repeat(2,1fr); }
  @media (min-width:1024px) { .steps-grid { grid-template-columns: repeat(4,1fr); } }
  .cat-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 1rem; }
  @media (min-width:1024px) { .cat-grid { grid-template-columns: repeat(4,1fr); } }
  .eq-faq summary { list-style: none; cursor: pointer; }
  .eq-faq summary::-webkit-details-marker { display: none; }

  .steps-grid > * { border-right: 1px solid var(--color-n400); border-bottom: 1px solid var(--color-n400); }
  .steps-grid > *:nth-child(2n) { border-right: 0; }
  .steps-grid > *:nth-last-child(-n+2) { border-bottom: 0; }
  @media (min-width: 1024px) {
    .steps-grid > * { border-right: 1px solid var(--color-n400); border-bottom: 0; }
    .steps-grid > *:last-child { border-right: 0; }
  }
</style>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in-view'); obs.unobserve(e.target); } });
  }, { threshold: 0.10 });
  document.querySelectorAll('.equity-reveal').forEach(el => obs.observe(el));
  document.querySelectorAll('.eq-faq').forEach(d => {
    d.addEventListener('toggle', () => { if (d.open) document.querySelectorAll('.eq-faq').forEach(o => { if (o !== d) o.open = false; }); });
  });
</script>
