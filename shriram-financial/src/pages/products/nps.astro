---
import BaseLayout from '../../layouts/BaseLayout.astro';

const accounts = [
  { label: 'Tier 1 Account', desc: 'The primary NPS pension account. Contributions are tax-deductible. Locked until age 60 — purpose-built for retirement. Minimum: ₹500/year.' },
  { label: 'Tier 2 Account', desc: 'A voluntary, fully liquid savings account linked to Tier 1. No tax benefit (except for government employees). Minimum: ₹250/year — withdraw anytime.' },
];

const assetClasses = [
  { label: 'Class E — Equity',                       desc: 'Equity and equity-related instruments. Up to 75% allocation (tapers after age 50). Highest growth potential, highest volatility.' },
  { label: 'Class C — Corporate Bonds',               desc: 'High-rated corporate debt (AA and above). Moderate risk with stable, predictable returns — good for core stability.' },
  { label: 'Class G — Government Securities',         desc: 'Central and state government bonds — the lowest-risk NPS class. Suitable for conservative investors nearing retirement.' },
  { label: 'Class A — Alternatives',                  desc: 'REITs, InvITs, and alternative assets. Capped at 5% allocation — adds diversification beyond traditional debt and equity.' },
];

const taxRows = [
  { section: '80CCD(1)',   limit: '₹1,50,000 per year',            category: 'Employee / Self-employed',            note: 'Part of overall 80C limit of ₹1.5 lakh' },
  { section: '80CCD(1B)', limit: '₹50,000 per year (additional)',   category: 'All NPS subscribers',                 note: 'Over and above the 80C limit — exclusive to NPS' },
  { section: '80CCD(2)',  limit: 'Up to 10% of Basic + DA',         category: 'Salaried (employer contribution)',     note: "No upper limit; employer's contribution is fully deductible" },
];

const vsRows = [
  { feature: 'Purpose',               nps: 'Market-linked retirement savings',            epf: 'Retirement corpus for salaried',           ppf: 'Tax-free long-term savings' },
  { feature: 'Returns',               nps: 'Market-linked (8–12% historically)',           epf: '8.25% (FY2024, EPFO declared)',            ppf: '7.1% (reviewed quarterly)' },
  { feature: 'Lock-in',               nps: 'Until age 60',                                epf: 'Until retirement (partial allowed)',        ppf: '15 years (partial from year 7)' },
  { feature: 'Tax on Maturity',       nps: '60% tax-free; 40% annuity (taxable)',         epf: 'Tax-free (if 5+ years service)',           ppf: 'Fully tax-free' },
  { feature: 'Employer Contribution', nps: '10% Basic+DA (govt); 14% for central govt',  epf: '12% Basic+DA (mandatory)',                 ppf: 'No employer contribution' },
  { feature: 'Regulator',             nps: 'PFRDA',                                       epf: 'EPFO',                                     ppf: 'Ministry of Finance' },
];

const steps = [
  { n: '01', title: 'Choose PRAN Account Type',    desc: 'Select Tier 1 (pension) or Tier 1 + Tier 2 (pension + savings). Choose your Pension Fund Manager — HDFC, SBI, Kotak, and more.' },
  { n: '02', title: 'Submit KYC & Documents',      desc: 'Complete Aadhaar-based e-KYC on the Shriram platform. Submit PAN, address proof, and nominee details digitally.' },
  { n: '03', title: 'Choose Asset Allocation',     desc: 'Select Active Choice (you control E/C/G split) or Auto Choice (age-based rebalancing) — conservative, moderate, or aggressive lifecycle fund.' },
  { n: '04', title: 'Start Contributing',           desc: 'Make your first contribution (min ₹500 Tier 1, ₹250 Tier 2). Set up auto-debit for regular contributions and track corpus in real time.' },
];

const withdrawalReasons = [
  "Child's education or marriage",
  "Home purchase or construction",
  "Critical illness or disability",
  "Starting a business",
];

const annuityPoints = [
  { label: '60% of corpus',          desc: 'Fully tax-free withdrawal at age 60 — no tax liability on this portion.' },
  { label: '40% mandatory annuity',  desc: 'Must purchase a PFRDA-registered annuity. Monthly pension paid; annuity income taxable per slab.' },
  { label: 'Deferred exit',          desc: 'Defer withdrawal until age 75 if you wish to continue growing the corpus.' },
  { label: 'Lump sum below ₹5L',    desc: 'If total corpus is below ₹5 lakh, the entire amount can be withdrawn as a lump sum.' },
];

const faqs = [
  { q: 'Can I withdraw from NPS before retirement?',         a: "Yes — after 3 years, you can withdraw up to 25% of your own contributions for specific reasons: child's education/marriage, home purchase, critical illness, or business setup. Maximum 3 withdrawals over the lifetime of the PRAN." },
  { q: 'What happens to NPS at age 60?',                    a: 'At 60, withdraw up to 60% of the corpus tax-free. The remaining 40% must purchase a PFRDA-registered annuity for a monthly pension. You can defer the entire withdrawal until age 75.' },
  { q: 'Is NPS better than PPF for tax saving?',            a: "NPS allows up to ₹2 lakh deduction (80C + 80CCD(1B)), vs PPF's ₹1.5 lakh under 80C. PPF maturity is fully tax-free; NPS annuity income is taxable. Most advisors recommend both for maximum efficiency." },
  { q: 'What is the minimum annual contribution?',           a: "Tier 1: ₹500 per contribution, ₹1,000 per year minimum. Tier 2: ₹250 per contribution, no annual minimum. Missing Tier 1's annual minimum makes your PRAN inactive with a ₹100/year penalty." },
  { q: 'Can self-employed individuals invest in NPS?',       a: 'Yes. All Indian citizens aged 18–70 can open NPS. Self-employed subscribers claim 80CCD(1) up to 20% of gross income (within ₹1.5 lakh 80C limit), plus the exclusive ₹50,000 under 80CCD(1B).' },
  { q: 'Who regulates NPS?',                                 a: 'NPS is regulated by PFRDA (Pension Fund Regulatory and Development Authority), a statutory body under the Ministry of Finance. All Pension Fund Managers (PFMs) are PFRDA-registered.' },
  { q: 'Can I change my Pension Fund Manager (PFM)?',        a: 'Yes. You can switch your PFM or investment scheme once per year at no cost. Active Choice allows you to rebalance your E/C/G/A allocation at any time.' },
  { q: 'What happens to NPS if I die before 60?',           a: "The entire accumulated corpus is paid to the nominee (or legal heir) as a lump sum — no mandatory annuity. Nominee is exempt from the 40% annuity rule in the subscriber's case." },
];
---

<BaseLayout
  title="NPS India 2026 — National Pension Scheme Tax Saving | Shriram"
  description="Invest in NPS India 2026 and save up to ₹2 lakh in tax deductions annually. Market-linked retirement corpus, PFRDA regulated, flexible fund choice. Open NPS account today."
>

  <!-- ══ HERO ═══════════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-inner">
      <h1><span class="g">NPS India 2026</span> — Tax-Efficient &amp; Market-Linked Retirement</h1>
      <p class="lead">The National Pension Scheme offers up to ₹2 lakh in tax deductions annually, market-linked returns, and a guaranteed retirement income — all in one PFRDA-regulated account.</p>
      <div class="cta-row">
        <a class="btn-gold" href="/about/open-demat-account/">Open NPS Account</a>
        <a class="btn-ghost" href="/about/support/">Talk to RM</a>
      </div>
      <ul class="feats">
        {['Up to ₹2L tax saving', 'PFRDA regulated', 'Market-linked returns', 'Flexible fund choice'].map(f => (
          <li class="feat"><span class="tk">✓</span><span class="lb">{f}</span></li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ══ WHAT IS NPS? ═══════════════════════════════════════════════ -->
  <section class="section auto" style="background:var(--sec-light)">
    <div class="def-row">
      <p class="sec-title">What is <span class="g">NPS?</span></p>
      <div class="def-body">
        <p>NPS (National Pension Scheme) is a voluntary, government-backed retirement savings plan regulated by PFRDA. Contributions are invested in market-linked instruments — equity, corporate bonds, and government securities.</p>
        <p>NPS operates through two types of accounts designed for different financial needs: mandatory pension savings (Tier 1) and flexible voluntary savings (Tier 2).</p>
      </div>
    </div>
    <div class="cat-grid" style="margin-top:64px;grid-template-columns:repeat(2,1fr)">
      {accounts.map((a, i) => (
        <div class="cat" style={i===1?'border-right:0':''}>
          <h4>{a.label}</h4>
          <p>{a.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ══ NPS ASSET CLASSES ══════════════════════════════════════════ -->
  <section class="section" style="background:var(--sec-tint)">
    <p class="sec-title">NPS Asset Classes — <span class="g">Where Your Money Is Invested</span></p>
    <p class="sec-lead" style="margin-top:16px">Four classes covering the full risk-return spectrum — from equity to government bonds to alternatives.</p>
    <div class="cat-grid" style="margin-top:48px">
      {assetClasses.map((a, i) => (
        <div class="cat" style={i===3?'border-right:0':''}>
          <h4>{a.label}</h4>
          <p>{a.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ══ NPS TAX BENEFITS ═══════════════════════════════════════════ -->
  <section class="section" style="background:var(--sec-light)">
    <p class="sec-title">NPS Tax Benefits — <span class="g">Up to ₹2 Lakh Deduction</span></p>
    <p class="sec-lead" style="margin-top:16px">NPS offers the highest combined tax deduction among all Section 80 instruments. Combine 80CCD(1), 80CCD(1B), and 80CCD(2) for maximum savings.</p>
    <div class="t-wrap" style="margin-top:48px">
      <div class="t-scroll">
        <table>
          <thead><tr>
            <th>Section</th><th class="hl">Deduction Limit</th><th class="hl">Eligible For</th><th class="hl">Note</th>
          </tr></thead>
          <tbody>
            {taxRows.map(r => (
              <tr>
                <td class="k">{r.section}</td><td class="hl">{r.limit}</td><td>{r.category}</td><td>{r.note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ══ NPS RETURNS CALCULATOR ════════════════════════════════════ -->
  <section class="section auto" style="background:var(--sec-tint)">
    <p class="sec-title">NPS Returns <span class="g">Calculator</span></p>
    <p class="sec-lead" style="margin-top:16px">Estimate your NPS retirement corpus based on your age, monthly contribution, and expected returns. Plan early, retire comfortably.</p>
    <div style="margin-top:48px;max-width:640px">
      <a href="/calculators/sip/" class="card calc-card">
        <div class="calc-icon">₹</div>
        <div>
          <p class="card-h">NPS Retirement Calculator</p>
          <p class="card-p" style="margin-top:8px">Project your corpus, monthly pension, and annuity income. Adjust contributions and fund choice to see the impact.</p>
        </div>
        <span class="btn-dark" style="width:fit-content">Calculate Now →</span>
      </a>
    </div>
  </section>

  <!-- ══ NPS vs EPF vs PPF ══════════════════════════════════════════ -->
  <section class="section" style="background:var(--sec-light)">
    <p class="sec-title">NPS vs EPF <span class="g">vs PPF</span></p>
    <p class="sec-lead" style="margin-top:16px">Compare India's three major retirement savings instruments across returns, lock-in, tax treatment, and regulatory structure.</p>
    <div class="t-wrap" style="margin-top:48px">
      <div class="t-scroll">
        <table>
          <thead><tr>
            <th>Feature</th><th class="hl">NPS</th><th>EPF</th><th>PPF</th>
          </tr></thead>
          <tbody>
            {vsRows.map(r => (
              <tr>
                <td class="k">{r.feature}</td><td class="hl">{r.nps}</td><td>{r.epf}</td><td>{r.ppf}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ══ HOW TO OPEN NPS ACCOUNT ════════════════════════════════════ -->
  <section class="section" style="background:var(--sec-tint)">
    <p class="sec-title">How to Open Your <span class="g">NPS Account</span></p>
    <p class="sec-lead" style="margin-top:16px">Four steps from registration to your first contribution — fully digital and paperless.</p>
    <div class="steps" style="margin-top:48px">
      {steps.map((s, i, arr) => (<>
        <div class="step">
          <div class="num">{s.n}</div>
          <h4>{s.title}</h4>
          <p>{s.desc}</p>
        </div>
        {i < arr.length - 1 && <div class="step-div"></div>}
      </>))}
    </div>
  </section>

  <!-- ══ PARTIAL WITHDRAWAL RULES ══════════════════════════════════ -->
  <section class="section" style="background:var(--sec-light)">
    <p class="sec-title">Partial Withdrawal <span class="g">Rules</span></p>
    <p class="sec-lead" style="margin-top:16px">NPS locks your corpus until retirement, but PFRDA permits partial withdrawals in specific situations.</p>
    <div class="wd-grid" style="margin-top:48px">
      <div class="appr">
        <div class="stat-n">3 yrs</div>
        <h4>Minimum Tenure</h4>
        <p>Must have been a subscriber for at least 3 years before any partial withdrawal is permitted.</p>
      </div>
      <div class="appr">
        <div class="stat-n">25%</div>
        <h4>Max of Own Contributions</h4>
        <p>Only your own contributions are counted — not employer contributions or investment returns.</p>
      </div>
      <div class="appr">
        <div class="stat-n">3×</div>
        <h4>Lifetime Withdrawals</h4>
        <p>Maximum of 3 partial withdrawals allowed over the entire lifetime of the PRAN account.</p>
      </div>
      <div class="appr">
        <h4>Eligible Reasons</h4>
        <ul class="reason-list">
          {withdrawalReasons.map(r => (
            <li><span class="tk">→</span><span>{r}</span></li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ══ MATURITY & ANNUITY ════════════════════════════════════════ -->
  <section class="section" style="background:var(--sec-tint)">
    <p class="sec-title">Maturity &amp; Annuity — <span class="g">What Happens at Age 60</span></p>
    <p class="sec-lead" style="margin-top:16px">At retirement, NPS follows a structured withdrawal: 60% lump sum (tax-free) and 40% mandatory annuity for a monthly pension.</p>
    <div class="cat-grid" style="margin-top:48px;grid-template-columns:repeat(2,1fr)">
      {annuityPoints.map((p, i) => (
        <div class="cat" style={i===1||i===3?'border-right:0':''}>
          <h4>{p.label}</h4>
          <p>{p.desc}</p>
        </div>
      ))}
    </div>
    <div class="note-box" style="margin-top:32px">
      <p><strong>Note on annuity providers:</strong> PFRDA maintains a list of empanelled life insurers (LIC, SBI Life, HDFC Life, and others) from which you must purchase the annuity. Multiple payout options are available — life annuity, joint life with spouse, guaranteed period, and more.</p>
    </div>
  </section>

  <!-- ══ CONTRIBUTION LIMITS & RULES ════════════════════════════════ -->
  <section class="section" style="background:var(--sec-light)">
    <p class="sec-title">NPS Contribution Limits <span class="g">&amp; Rules 2026</span></p>
    <p class="sec-lead" style="margin-top:16px">Maximise your NPS tax benefits by understanding the three deduction sections available under the Income Tax Act.</p>
    <div class="t-wrap" style="margin-top:48px">
      <div class="t-scroll">
        <table>
          <thead><tr>
            <th>Section</th><th class="hl">Annual Limit</th><th class="hl">Eligible For</th><th>Key Note</th>
          </tr></thead>
          <tbody>
            {[
              { sec: '80CCD(1)',   limit: 'Up to ₹1,50,000',      who: 'Employee / Self-employed',            note: 'Within the overall ₹1.5L 80C limit' },
              { sec: '80CCD(1B)', limit: '₹50,000 additional',     who: 'All NPS subscribers',                 note: 'Exclusive to NPS — over and above 80C' },
              { sec: '80CCD(2)',  limit: '10% of Basic + DA',       who: 'Salaried (employer contribution)',    note: 'No upper rupee cap — deductible in full' },
            ].map(r => (
              <tr>
                <td class="k">{r.sec}</td><td class="hl">{r.limit}</td><td>{r.who}</td><td>{r.note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
    <div class="note-box" style="margin-top:24px;text-align:center">
      <p>Maximum total NPS deduction: <strong style="color:var(--gold-2)">₹2,00,000/year</strong> (₹1.5L under 80CCD(1) + ₹50,000 under 80CCD(1B)) — more than any other retirement instrument.</p>
    </div>
  </section>

  <!-- ══ RETURNS & HISTORICAL PERFORMANCE ══════════════════════════ -->
  <section class="section" style="background:var(--sec-tint)">
    <p class="sec-title">NPS Returns &amp; <span class="g">Historical Performance</span></p>
    <p class="sec-lead" style="margin-top:16px">NPS returns are market-linked and vary by asset class and pension fund manager. Here are indicative historical returns.</p>
    <div class="t-wrap" style="margin-top:48px">
      <div class="t-scroll">
        <table>
          <thead><tr>
            <th>Asset Class</th><th class="hl">5-Year CAGR</th><th class="hl">10-Year CAGR</th><th>Risk Level</th>
          </tr></thead>
          <tbody>
            {[
              { cls: 'Class E — Equity',                    five: '12–15% p.a.', ten: '10–13% p.a.',    risk: 'High' },
              { cls: 'Class C — Corporate Bonds',           five: '7–9% p.a.',   ten: '7–8.5% p.a.',   risk: 'Moderate' },
              { cls: 'Class G — Government Securities',     five: '6.5–8% p.a.', ten: '6–7.5% p.a.',   risk: 'Low' },
              { cls: 'Class A — Alternatives (capped 5%)', five: '8–11% p.a.',  ten: 'N/A (recent)', risk: 'Moderate-High' },
            ].map(r => (
              <tr>
                <td class="k">{r.cls}</td><td class="hl">{r.five}</td><td class="hl">{r.ten}</td><td>{r.risk}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
    <p class="sec-lead" style="margin-top:16px;font-size:13px">* Past returns are indicative only. NPS returns are not guaranteed. Source: PFRDA performance data, 2024.</p>
  </section>

  <!-- ══ NPS FEES & CHARGES ════════════════════════════════════════ -->
  <section class="section" style="background:var(--sec-light)">
    <p class="sec-title">NPS Fees &amp; <span class="g">Charges Explained</span></p>
    <p class="sec-lead" style="margin-top:16px">NPS has one of the lowest fee structures of any retirement instrument in India — here's a complete breakdown.</p>
    <div class="cat-grid" style="margin-top:48px;grid-template-columns:repeat(3,1fr)">
      {[
        { label: 'PRAN Card Issuance',              fee: '₹40 one-time',              note: 'For physical PRAN card; ePRAN is free' },
        { label: 'CRA Annual Maintenance',           fee: '₹95 per year',              note: 'CRA record-keeping fee charged by CRA' },
        { label: 'Fund Management Charge',           fee: '0.09% p.a.',                note: 'Charged on AUM — lowest in the industry' },
        { label: 'Contribution Processing (PoP)',    fee: '0.25% (min ₹20)',           note: 'Per contribution via Point of Presence' },
        { label: 'eNPS Digital Contribution',        fee: '₹5–₹20 per transaction',   note: 'Payment gateway charges (UPI/Net Banking)' },
        { label: 'Exit / Withdrawal Charge',         fee: '0.125% of corpus',          note: 'On premature exit; no charge at age 60 maturity' },
      ].map((f, i) => (
        <div class="cat" style={i%3===2?'border-right:0':''}>
          <div class="fee-n">{f.fee}</div>
          <h4>{f.label}</h4>
          <p>{f.note}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ══ FAQ ════════════════════════════════════════════════════════ -->
  <section class="faq-wrap" id="sec-faq">
    <div class="faq-cols">
      <div class="faq-left">
        <p class="faq-title">Frequently Asked <span class="g">Questions</span></p>
        <ul class="faq-acc">
          {faqs.map(item => (
            <li class="faq-item">
              <details>
                <summary class="faq-sum">
                  <span class="qt">{item.q}</span>
                  <svg class="faq-icon faq-v" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="2" x2="8" y2="14"/><line x1="2" y1="8" x2="14" y2="8"/></svg>
                  <svg class="faq-icon faq-h" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><line x1="2" y1="8" x2="14" y2="8"/></svg>
                </summary>
                <div class="qa"><p>{item.a}</p></div>
              </details>
            </li>
          ))}
        </ul>
      </div>
      <div class="faq-side">
        <img src="/images/advisor-avatar.png" alt="Financial advisor" class="usr-img" />
        <div class="side-in">
          <div class="side-tx">
            <h4>Still got questions?</h4>
            <p>Our NPS experts will help you choose the right allocation, PFM, and tax strategy for your retirement goals.</p>
          </div>
          <a class="btn-gold" href="/about/support/">Book a Call</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ FINAL CTA ══════════════════════════════════════════════════ -->
  <section class="cta-sec" style="background:var(--sec-light)">
    <div class="cta-box">
      <p class="cta-h">Secure Your Retirement with <span class="g">NPS Today</span></p>
      <p class="cta-sub">Open your NPS PRAN account with Shriram Financial Services. Save up to ₹2 lakh in tax, grow wealth, and ensure a guaranteed monthly pension.</p>
      <div class="cta-row" style="margin-top:0;justify-content:center">
        <a class="btn-gold" href="/about/open-demat-account/">Open NPS Account</a>
        <a class="btn-dark" href="/about/support/">Talk to an RM</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  :root {
    --sec-light:#fef8ee; --sec-tint:#f6efe1;
    --card:#fffdf8; --card-border:#e1e0db; --card-border-soft:rgba(28,28,22,.13); --row-line:rgba(28,28,22,.08);
    --olive-title:#2e3914; --olive-head:#2d3813; --olive-deep:#1b2010;
    --ink:#1c1c16; --ink-2:#46463c; --ink-3:#595959; --muted:#73736a;
    --gold:#e0a82e; --gold-2:#f2b83f; --gold-btn:#f3b83f; --gold-ink:#231a06; --olive-ink:#2e3914; --green:#009d58;
    --pad:clamp(20px,8vw,144px); --section-y:72px; --cta-w:220px;
  }
  *, *::before, *::after { box-sizing: border-box; }
  a { color: inherit; text-decoration: none; }
  p { line-height: 1.5; margin: 0; }
  ul { list-style: none; padding: 0; margin: 0; }

  .section { padding: var(--section-y) var(--pad); min-height: 100vh; min-height: 100dvh; display: flex; flex-direction: column; justify-content: center; }
  .section.auto { min-height: 0; }
  .sec-title { font-weight: 400; font-size: 40px; color: var(--olive-title); line-height: 1.4; max-width: 860px; }
  .sec-lead  { font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.5; max-width: 640px; }
  .g { color: var(--gold-2); }

  .hero { padding: 0 var(--pad); display: flex; flex-direction: column; justify-content: center; overflow: hidden; background: radial-gradient(125% 210% at 100% -8%, #4f583b 0%, #363a2c 50%, #1d1d1d 100%); }
  .hero-inner { padding: clamp(80px,12vw,140px) 0 clamp(48px,6vw,80px); display: flex; flex-direction: column; }
  .hero h1 { font-weight: 500; font-size: 40px; color: #fff; line-height: 1.5; max-width: 860px; }
  .hero .lead { margin-top: 32px; font-weight: 400; font-size: 18px; line-height: 1.5; color: rgba(255,255,255,.74); max-width: 600px; }
  .cta-row { margin-top: 40px; display: flex; flex-wrap: wrap; gap: 14px; align-items: center; }
  .feats { margin-top: 40px; display: flex; flex-wrap: wrap; gap: 14px 16px; max-width: 760px; padding-top: 36px; border-top: 1px solid rgba(255,255,255,.16); }
  .feat { display: flex; gap: 10px; align-items: center; }
