---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Currency Trading in India — NSE & BSE Currency Futures | Shriram"
  description="Trade currency in India — USDINR, EURINR, GBPINR futures & options on NSE & BSE. SEBI & RBI compliant. Flat ₹20/order. Open currency trading account today."
>

  <!-- ══ S1. HERO ══════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[var(--color-dark-800)] py-[100px] lg:py-[120px]">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[560px] w-[560px] rounded-full bg-[var(--color-brand)]/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-32 left-0 h-80 w-80 rounded-full bg-[var(--color-brand)]/5 blur-3xl"></div>
    <div class="site-wrap relative">
      <h1 class="equity-reveal max-w-[880px] text-[clamp(32px,4vw,52px)] font-bold leading-[1.06] text-white" style="font-family:var(--font-display)">
        <span class="text-[var(--color-brand)]">Currency Trading</span> in India — USDINR, EURINR on NSE &amp; BSE
      </h1>
      <p class="equity-reveal mt-[26px] max-w-[600px] text-[18px] leading-relaxed text-white/70">
        Trade currency futures and options on NSE &amp; BSE. SEBI &amp; RBI-compliant. Flat ₹20/order. Hedge forex risk or speculate on exchange rate movements.
      </p>
      <div class="equity-reveal mt-[38px] flex flex-wrap gap-[14px]">
        <a href="/about/open-demat-account/" class="btn-primary">Open Currency Account</a>
        <a href="/about/open-demat-account/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Start Trading</a>
      </div>
      <div class="equity-reveal mt-[54px] flex flex-wrap gap-x-9 gap-y-3 border-t border-white/15 pt-9">
        {['✓ SEBI & RBI-compliant', '✓ NSE & BSE listed', '✓ Flat ₹20/order', '✓ FEMA-compliant'].map(f => (
          <span class="text-[15px] font-medium text-white/90">{f}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S2. WHAT IS CURRENCY TRADING? ════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          What is <span class="text-[var(--color-brand)]">Currency Trading?</span> — Meaning &amp; Basics
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">
          Currency trading in India means trading exchange-rate derivatives (futures and options) on NSE and BSE — NOT spot forex trading. SEBI and RBI regulate all currency derivatives.
        </p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Feature</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">India Currency Trading</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Offshore Forex</th>
              </tr>
            </thead>
            <tbody>
              {[
                { feature: 'Exchange', india: 'NSE / BSE (SEBI-regulated)', offshore: 'OTC / unregulated platforms' },
                { feature: 'Regulator', india: 'SEBI + RBI', offshore: 'Unregulated (illegal for Indians)' },
                { feature: 'Products', india: 'Futures & Options on 7 pairs', offshore: 'Spot and CFD forex' },
                { feature: 'Legal Status', india: 'Fully legal', offshore: 'Illegal under FEMA for Indians' },
                { feature: 'Settlement', india: 'Cash settlement in INR', offshore: 'USD or other currency' },
              ].map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.feature}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.india}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.offshore}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S3. HOW CURRENCY TRADING WORKS (NSE & BSE) ════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How <span class="text-[var(--color-brand)]">Currency Trading</span> Works — NSE &amp; BSE
        </h2>
      </div>
      <div class="equity-reveal steps-grid overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        {[
          { n: '01', title: 'Choose Currency Pair', desc: 'Select from USDINR, EURINR, GBPINR, or JPYINR.' },
          { n: '02', title: 'Select Contract Month', desc: 'Currency futures expire on the last business day of each month.' },
          { n: '03', title: 'Place Order', desc: 'Buy (go long) or sell (go short) based on your exchange rate view.' },
          { n: '04', title: 'Cash Settlement', desc: 'Positions are cash-settled in INR at RBI reference rate on expiry.' },
        ].map(s => (
          <div class="px-[30px] py-[34px]">
            <div class="mb-[22px] text-[34px] font-bold leading-none text-[var(--color-brand)]">{s.n}</div>
            <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">{s.title}</h4>
            <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S4. CURRENCY PAIRS AVAILABLE IN INDIA ════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          <span class="text-[var(--color-brand)]">Currency Pairs</span> Available in India — NSE &amp; BSE
        </h2>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[14.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[20px] py-[16px] text-left text-[13px] font-semibold text-white">Currency Pair</th>
                <th class="px-[20px] py-[16px] text-left text-[13px] font-semibold text-[var(--color-brand)]">Lot Size</th>
                <th class="px-[20px] py-[16px] text-left text-[13px] font-semibold text-[var(--color-brand)]">Tick Size</th>
                <th class="px-[20px] py-[16px] text-left text-[13px] font-semibold text-[var(--color-brand)]">Exchange</th>
                <th class="px-[20px] py-[16px] text-left text-[13px] font-semibold text-[var(--color-brand)]">Segment</th>
              </tr>
            </thead>
            <tbody>
              {[
                { pair: 'USDINR', lot: 'USD 1,000', tick: '₹0.0025', ex: 'NSE & BSE', seg: 'Futures & Options' },
                { pair: 'EURINR', lot: 'EUR 1,000', tick: '₹0.0025', ex: 'NSE & BSE', seg: 'Futures & Options' },
                { pair: 'GBPINR', lot: 'GBP 1,000', tick: '₹0.0025', ex: 'NSE & BSE', seg: 'Futures & Options' },
                { pair: 'JPYINR', lot: 'JPY 100,000', tick: '₹0.0025', ex: 'NSE & BSE', seg: 'Futures & Options' },
                { pair: 'EURUSD', lot: 'EUR 1,000', tick: 'USD 0.0001', ex: 'NSE', seg: 'Futures only (cross currency)' },
                { pair: 'GBPUSD', lot: 'GBP 1,000', tick: 'USD 0.0001', ex: 'NSE', seg: 'Futures only (cross currency)' },
                { pair: 'USDJPY', lot: 'USD 1,000', tick: 'JPY 0.01', ex: 'NSE', seg: 'Futures only (cross currency)' },
              ].map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[20px] py-[15px] font-semibold text-[var(--color-ink)]">{r.pair}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[20px] py-[15px] text-[var(--color-muted)]">{r.lot}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[20px] py-[15px] text-[var(--color-muted)]">{r.tick}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[20px] py-[15px] font-medium text-[var(--color-dark-olive)]">{r.ex}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[20px] py-[15px] text-[var(--color-muted)]">{r.seg}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S5. CURRENCY FUTURES VS OPTIONS ══════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          <span class="text-[var(--color-brand)]">Currency Futures vs Options</span> — Key Differences
        </h2>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Feature</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Currency Futures</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Currency Options</th>
              </tr>
            </thead>
            <tbody>
              {[
                { feature: 'Obligation', fut: 'Must settle at expiry', opt: 'Right only (buyer)' },
                { feature: 'Premium', fut: 'No premium — margin', opt: 'Buyer pays premium' },
                { feature: 'Max Loss (Buyer)', fut: 'Unlimited (MTM daily)', opt: 'Limited to premium' },
                { feature: 'Use Case', fut: 'Speculation, hedging', opt: 'Hedging, premium income' },
                { feature: 'Capital Required', fut: 'SPAN + Exposure margin', opt: 'Premium amount' },
              ].map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.feature}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.fut}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.opt}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S6. IS CURRENCY TRADING LEGAL IN INDIA? ══════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Is <span class="text-[var(--color-brand)]">Currency Trading Legal</span> in India? — RBI &amp; SEBI Rules
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">
          Yes — on SEBI-regulated exchanges. Trading unregulated offshore forex platforms is ILLEGAL under FEMA.
        </p>
      </div>
      <div class="equity-reveal grid gap-5 sm:grid-cols-2">
        <div class="product-card-light px-[28px] py-[32px]">
          <h3 class="mb-3 text-[20px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">Legal ✓</h3>
          <p class="text-[14px] leading-relaxed text-[var(--color-muted)]">Trade USDINR, EURINR, GBPINR, JPYINR futures &amp; options on NSE/BSE through a SEBI-registered broker. Regulated by RBI (FEMA) and SEBI. Shriram is SEBI-registered: INE231103833.</p>
        </div>
        <div class="product-card-light px-[28px] py-[32px]">
          <h3 class="mb-3 text-[20px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">Illegal ✗</h3>
          <p class="text-[14px] leading-relaxed text-[var(--color-muted)]">Using offshore 'forex' or 'CFD' platforms (MT4/MT5 based, USD-funded) is illegal under FEMA for Indian residents. SEBI has issued multiple warnings against such platforms.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S7. TAXATION ON CURRENCY TRADING ═════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Taxation on <span class="text-[var(--color-brand)]">Currency Trading</span> Profits
        </h2>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Income Type</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Tax Treatment</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">ITR Form</th>
              </tr>
            </thead>
            <tbody>
              {[
                { type: 'Currency F&O profits', tax: 'Non-speculative business income (not capital gains)', itr: 'ITR-3' },
                { type: 'Currency F&O losses', tax: 'Offset against business income; carry forward 8 years', itr: 'ITR-3' },
                { type: 'Brokerage & charges', tax: 'Deductible as business expense', itr: 'ITR-3' },
                { type: 'GST on brokerage', tax: '18% on brokerage (not on trade value)', itr: '—' },
              ].map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.type}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.tax}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.itr}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
      <p class="mt-4 text-[13px] text-[var(--color-muted)]">Maintain detailed trade logs and consult a CA for ITR filing.</p>
    </div>
  </section>

  <!-- ══ S8. HOW TO START CURRENCY TRADING ════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How to Start <span class="text-[var(--color-brand)]">Currency Trading</span> in India
        </h2>
      </div>
      <div class="equity-reveal steps-grid overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        {[
          { n: '01', title: 'Open Trading Account', desc: 'Open Demat + Trading account with Shriram. 100% digital, 10 minutes.' },
          { n: '02', title: 'Activate Currency Segment', desc: 'Request currency derivatives segment activation. Submit KYC and income proof.' },
          { n: '03', title: 'Add Margin', desc: 'Transfer SPAN + Exposure margin (typically ₹2,000–₹4,000 per USDINR lot).' },
          { n: '04', title: 'Trade & Monitor', desc: 'Select pair, expiry, execute orders. Monitor rate using RBI reference rate and global forex data.' },
        ].map(s => (
          <div class="px-[30px] py-[34px]">
            <div class="mb-[22px] text-[34px] font-bold leading-none text-[var(--color-brand)]">{s.n}</div>
            <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">{s.title}</h4>
            <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S9. CURRENCY TRADING STRATEGIES FOR BEGINNERS ════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          <span class="text-[var(--color-brand)]">Currency Trading Strategies</span> for Beginners
        </h2>
      </div>
      <div class="equity-reveal grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { title: 'USDINR Directional', desc: 'Trade based on RBI policy, Fed rate decisions, and India CAD/trade balance data.' },
          { title: 'Hedging for Importers', desc: 'If you import USD-priced goods, buy USDINR futures to lock in exchange rate.' },
          { title: 'Technical Strategy', desc: 'Use RSI, pivot points, and 9/21 EMA crossovers on USDINR 15-minute chart.' },
          { title: 'Calendar Spread', desc: 'Buy near-month, sell far-month USDINR contracts. Benefits from time decay differential.' },
        ].map(c => (
          <div class="product-card-light px-[28px] py-[32px]">
            <h3 class="mb-3 text-[17px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{c.title}</h3>
            <p class="text-[14px] leading-relaxed text-[var(--color-muted)]">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S10. FAQs — CURRENCY TRADING INDIA ═══════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          FAQs — <span class="text-[var(--color-brand)]">Currency Trading</span> India
        </h2>
      </div>
      <div class="equity-reveal mx-auto max-w-[840px] border-t border-[var(--color-n400)]">
        {[
          { q: 'What is currency derivatives trading in India?', a: 'Exchange-traded contracts on currency pairs (USDINR, EURINR, etc.) on NSE/BSE. It is NOT spot forex trading — it is regulated by SEBI and RBI.' },
          { q: 'Is currency trading legal in India?', a: 'Yes — on SEBI-regulated exchanges NSE and BSE. Trading offshore forex/CFD platforms is illegal under FEMA for Indian residents.' },
          { q: 'What is the minimum capital to trade USDINR?', a: 'One USDINR futures lot (USD 1,000) requires approximately ₹2,000–₹4,000 in SPAN + Exposure margin.' },
          { q: 'What are trading hours for currency derivatives?', a: '9 AM to 5 PM (INR pairs). Cross-currency pairs (EURUSD, GBPUSD, USDJPY) trade until 7:30 PM on NSE.' },
          { q: 'How is currency F&O settled?', a: 'Currency derivatives are cash-settled in INR at the RBI reference rate on the last business day of the expiry month.' },
          { q: 'What is the tax on currency trading profits?', a: 'Currency F&O profits are non-speculative business income — taxed as per your income slab. File ITR-3. Losses can be carried forward for 8 years.' },
          { q: 'Can NRIs trade currency derivatives in India?', a: 'NRIs can trade currency derivatives through RBI-approved brokers using NRE/NRO accounts, subject to FEMA guidelines.' },
          { q: 'What is the difference between USDINR futures and spot forex?', a: 'USDINR futures are exchange-traded, SEBI-regulated, cash-settled contracts. Spot forex is OTC and unregulated — illegal for Indian residents under FEMA.' },
        ].map(item => (
          <details class="eq-faq group border-b border-[var(--color-n400)]">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-5 py-[26px] px-2">
              <span class="text-[18px] font-semibold text-[var(--color-ink)]">{item.q}</span>
              <span class="shrink-0 text-[22px] leading-none text-[var(--color-brand)] transition-transform duration-300 group-open:rotate-45">+</span>
            </summary>
            <div class="overflow-hidden px-2 pb-0 text-[16px] leading-relaxed text-[var(--color-muted)] transition-all duration-300 group-open:pb-[28px]">
              <p class="max-w-[680px]">{item.a}</p>
            </div>
          </details>
        ))}
      </div>

      <!-- Dark CTA block after FAQs -->
      <div class="equity-reveal mt-[56px] overflow-hidden rounded-[22px] bg-[var(--color-dark-800)] px-[60px] py-[64px] text-center">
        <h3 class="mx-auto max-w-[560px] text-[38px] font-bold leading-[1.12] text-white" style="font-family:var(--font-display)">Open Currency Trading Account — NSE &amp; BSE</h3>
        <div class="mt-[34px] flex flex-wrap justify-center gap-[14px]">
          <a href="/about/open-demat-account/" class="btn-primary">Open Account</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .equity-reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s cubic-bezier(0.22, 0.61, 0.36, 1), transform 0.7s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .equity-reveal.in-view { opacity: 1; transform: none; }

  .steps-grid { display: grid; grid-template-columns: repeat(2, 1fr); }
  .steps-grid > * { border-right: 1px solid var(--color-n400); border-bottom: 1px solid var(--color-n400); }
  .steps-grid > *:nth-child(2n) { border-right: 0; }
  .steps-grid > *:nth-last-child(-n+2) { border-bottom: 0; }
  @media (min-width: 1024px) {
    .steps-grid { grid-template-columns: repeat(4, 1fr); }
    .steps-grid > * { border-right: 1px solid var(--color-n400); border-bottom: 0; }
    .steps-grid > *:last-child { border-right: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .equity-reveal { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).classList.add('in-view');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.10 });
  document.querySelectorAll('.equity-reveal').forEach(el => obs.observe(el));

  document.querySelectorAll<HTMLDetailsElement>('.eq-faq').forEach(d => {
    d.addEventListener('toggle', () => {
      if (d.open) document.querySelectorAll<HTMLDetailsElement>('.eq-faq').forEach(o => { if (o !== d) o.removeAttribute('open'); });
    });
  });
</script>
