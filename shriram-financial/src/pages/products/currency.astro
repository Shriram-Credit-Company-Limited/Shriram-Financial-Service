---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pairs = [
  { pair: 'USD/INR', full: 'US Dollar / Indian Rupee', desc: 'India\'s most liquid currency pair. Moves on RBI interventions, US Fed policy, and India\'s trade balance data.', lot: '1,000 USD', tick: '0.25 paise' },
  { pair: 'EUR/INR', full: 'Euro / Indian Rupee', desc: 'Driven by ECB policy and Eurozone data. Second most traded INR pair on NSE.', lot: '1,000 EUR', tick: '0.25 paise' },
  { pair: 'GBP/INR', full: 'British Pound / Indian Rupee', desc: 'Reacts to Bank of England decisions and UK economic indicators.', lot: '1,000 GBP', tick: '0.25 paise' },
  { pair: 'JPY/INR', full: 'Japanese Yen / Indian Rupee', desc: 'Driven by Bank of Japan policy and risk-on/risk-off flows. Priced per 100 JPY.', lot: '1,00,000 JPY', tick: '0.25 paise' },
];

const steps = [
  { n: '01', title: 'Enable Currency Segment', desc: 'Add the currency derivatives segment to your Shriram trading account — fully digital, no branch visit required.' },
  { n: '02', title: 'Add Trading Margin', desc: 'Transfer the required SPAN + Exposure margin. Currency futures require relatively low margins compared to equity F&O.' },
  { n: '03', title: 'Choose Pair & Expiry', desc: 'Select your currency pair (USD/INR, EUR/INR, etc.) and the contract expiry — monthly contracts settling on the last business day.' },
  { n: '04', title: 'Trade & Hedge', desc: 'Place orders, monitor your P&L in real time, and use the position to either speculate or hedge your forex exposure.' },
];

const chargeRows = [
  { label: 'Brokerage', value: '₹20 per executed order' },
  { label: 'STT', value: 'Nil (not applicable on currency derivatives)' },
  { label: 'GST', value: '18% on brokerage + exchange charges' },
  { label: 'Exchange Charges (NSE Currency)', value: '0.00035%' },
  { label: 'SEBI Turnover Fee', value: '₹1 per crore' },
];

const vsRows = [
  { feature: 'Purpose', currency: 'Hedge forex risk or speculate on exchange rates', equity: 'Invest in company ownership' },
  { feature: 'Underlying', currency: 'Currency pair (USD/INR, EUR/INR, etc.)', equity: 'Stocks, indices' },
  { feature: 'Lot Size', currency: '1,000 units of foreign currency', equity: 'Varies per contract' },
  { feature: 'Settlement', currency: 'Cash settlement in INR at RBI reference rate', equity: 'Physical or cash settlement' },
  { feature: 'Margin Required', currency: 'Low (2–4% of contract value)', equity: 'Higher (5–15%)' },
  { feature: 'Trading Hours', currency: '9:00 AM – 5:00 PM (Mon–Fri)', equity: '9:15 AM – 3:30 PM' },
];

const risks = [
  { n: '01', label: 'Exchange Rate Risk', desc: 'Currency prices are highly sensitive to central bank policy, macroeconomic data releases, and geopolitical events — causing sudden, large moves.' },
  { n: '02', label: 'RBI Intervention Risk', desc: 'The Reserve Bank of India actively intervenes in the INR market to curb excess volatility — creating sharp, unpredictable counter-trend moves.' },
  { n: '03', label: 'Leverage Risk', desc: 'Currency futures are leveraged instruments. A small adverse rate movement can result in margin calls and losses exceeding your initial deposit.' },
  { n: '04', label: 'Liquidity Risk', desc: 'EUR/INR, GBP/INR, and JPY/INR pairs have significantly lower liquidity than USD/INR — making it harder to exit large positions at fair prices.' },
];

const faqs = [
  { q: 'Who should trade currency derivatives in India?', a: 'Exporters and importers hedge forex receivables/payables. Portfolio investors hedge foreign asset exposure. Retail traders with macro knowledge can speculate on exchange rate movements.' },
  { q: 'Is RBI approval required for currency trading?', a: 'No special approval is needed for residents trading on NSE/BSE. For speculative USD/INR positions up to $100 million, no underlying forex exposure is required.' },
  { q: 'How is currency futures settlement done?', a: 'Currency futures are cash-settled in INR. On expiry (last business day of the month), settlement uses the RBI reference rate published at 12:30 PM. No physical forex delivery occurs.' },
  { q: 'What is the USDINR lot size?', a: 'One USD/INR lot = 1,000 USD, with a notional value of ~₹83,000–₹85,000 at current rates. Non-bank entities can hold up to 6 million USD in open positions.' },
  { q: 'Can NRIs trade currency derivatives in India?', a: 'No. Only persons resident in India as defined by FEMA are eligible. NRIs are currently not permitted to participate in Indian currency futures and options markets.' },
];
---

<BaseLayout
  title="Currency Trading in India — USD INR Forex Futures NSE | Shriram"
  description="Start currency trading in India on NSE. Trade USD/INR, EUR/INR, GBP/INR, and JPY/INR futures. Flat ₹20 brokerage, low margin, expert guidance. Enable forex trading today."
>

  <!-- ══ 1. HERO ═══════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[var(--color-dark-800)]">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[560px] w-[560px] rounded-full bg-[var(--color-brand)]/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-32 left-0 h-80 w-80 rounded-full bg-[var(--color-brand)]/5 blur-3xl"></div>
    <div class="site-wrap relative py-[120px]">
      <p class="equity-reveal text-[14px] font-medium tracking-[.04em] text-[var(--color-brand)]">Currency</p>
      <h1 class="equity-reveal mt-[22px] max-w-[880px] text-[clamp(32px,4vw,52px)] font-bold leading-[1.06] text-white" style="font-family:var(--font-display)">
        <span class="text-[var(--color-brand)]">Currency Trading in India</span> — Hedge Forex Risk on NSE
      </h1>
      <p class="equity-reveal mt-[26px] max-w-[600px] text-[18px] leading-relaxed text-white/70">
        Access all four INR currency pairs — USD, EUR, GBP, and JPY — with live pricing, low margin requirements, and expert guidance from Shriram Financial Services.
      </p>
      <div class="equity-reveal mt-[38px] flex flex-wrap gap-[14px]">
        <a href="/about/open-demat-account/" class="btn-primary">Enable Currency Trading</a>
        <a href="/about/support/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Talk to RM</a>
      </div>
      <div class="equity-reveal mt-[54px] flex flex-wrap gap-x-9 gap-y-3 border-t border-white/15 pt-9">
        {['✓ NSE Currency Segment', '✓ Flat ₹20/order', '✓ Low margin requirements', '✓ Live RBI rate alerts'].map(f => (
          <span class="text-[15px] font-medium text-white/90">
            <span class="mr-2 text-[var(--color-brand)]">{f.slice(0,1)}</span>{f.slice(1)}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 2. CURRENCY PAIRS ═══════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto grid max-w-[1000px] items-start gap-[72px] lg:grid-cols-[5fr_7fr]">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Currency Pairs <span class="text-[var(--color-brand)]">Available on NSE</span>
        </h2>
        <div class="space-y-5 text-[17px] leading-relaxed text-[var(--color-muted)]">
          <p>India's NSE offers futures and options on four INR-based currency pairs. All are cash-settled in INR at the RBI reference rate on expiry.</p>
          <p>Each pair has distinct drivers — from US Fed policy to Bank of Japan interventions — making currency derivatives a powerful diversification and hedging tool.</p>
        </div>
      </div>
      <div class="equity-reveal mx-auto mt-[76px] max-w-[1000px] border-t border-[var(--color-n400)] pt-[60px]">
        <div class="grid gap-5 sm:grid-cols-2">
          {pairs.map((p, i) => (
            <div class="product-card-light p-[34px]" style={`animation-delay:${i*60}ms`}>
              <div class="mb-4 flex h-11 w-auto min-w-[60px] items-center justify-center rounded-[10px] bg-[var(--color-dark-olive)] px-3 self-start">
                <span class="text-[13px] font-bold text-[var(--color-brand)]">{p.pair}</span>
              </div>
              <h3 class="text-[17px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{p.full}</h3>
              <p class="mt-2 text-[13px] leading-relaxed text-[var(--color-muted)]">{p.desc}</p>
              <div class="mt-4 flex gap-6 text-[12px]">
                <div><span class="font-semibold text-[var(--color-ink)]">Lot: </span><span class="text-[var(--color-muted)]">{p.lot}</span></div>
                <div><span class="font-semibold text-[var(--color-ink)]">Tick: </span><span class="text-[var(--color-muted)]">{p.tick}</span></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 3. HOW TO START ════════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How to Start <span class="text-[var(--color-brand)]">Currency Trading</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Four steps from enabling your segment to placing your first currency order.</p>
      </div>
      <div class="equity-reveal steps-grid overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        {steps.map(s => (
          <div class="px-[30px] py-[34px]">
            <div class="mb-[22px] font-display text-[34px] font-normal leading-none text-[var(--color-brand)]">{s.n}</div>
            <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">{s.title}</h4>
            <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 4. CHARGES ════════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Brokerage &amp; <span class="text-[var(--color-brand)]">Charges</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">A complete breakdown of all costs involved in currency futures trading.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto"><table class="w-full text-[15.5px]">
          <thead><tr class="bg-[var(--color-dark-olive)]"><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Charge Type</th><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Amount / Rate</th></tr></thead>
          <tbody>{chargeRows.map((r,i) => (<tr class={i%2===0?'bg-white':'bg-[#f8f6f1]'}><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.label}</td><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.value}</td></tr>))}</tbody>
        </table></div>
      </div>
    </div>
  </section>

  <!-- ══ 5. COMPARISON TABLE ═══════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Currency vs <span class="text-[var(--color-brand)]">Equity Derivatives</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">How currency futures compare to equity futures across key dimensions.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto"><table class="w-full text-[15.5px]">
          <thead><tr class="bg-[var(--color-dark-olive)]"><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Feature</th><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Currency Derivatives</th><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Equity Derivatives</th></tr></thead>
          <tbody>{vsRows.map((r,i) => (<tr class={i%2===0?'bg-white':'bg-[#f8f6f1]'}><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.feature}</td><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.currency}</td><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.equity}</td></tr>))}</tbody>
        </table></div>
      </div>
    </div>
  </section>

  <!-- ══ 6. RISKS ════════════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Risks of <span class="text-[var(--color-brand)]">Currency Trading</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Understand what can move against you before entering the forex market.</p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {risks.map(r => (
          <div class="equity-reveal rounded-[18px] bg-[var(--color-dark-800)] p-[36px]">
            <div class="mb-[18px] text-[48px] font-bold leading-none text-[var(--color-brand)]/25">{r.n}</div>
            <h4 class="mb-3 text-[20px] font-medium text-white" style="font-family:var(--font-display)">{r.label}</h4>
            <p class="text-[14.5px] leading-relaxed text-white/60">{r.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 6b. IS CURRENCY TRADING LEGAL IN INDIA? ═══════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Is Currency Trading Legal in India? <span class="text-[var(--color-brand)]">RBI, SEBI &amp; FEMA Rules</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Yes — currency futures and options trading on recognised exchanges is fully legal in India. Offshore forex (OTC) trading is not.</p>
      </div>
      <div class="equity-reveal grid gap-5 sm:grid-cols-2">
        <div class="product-card-light p-[34px]">
          <div class="mb-4 flex h-11 w-auto min-w-[80px] items-center justify-center rounded-[10px] bg-[var(--color-dark-olive)] px-4 self-start">
            <span class="text-[12px] font-bold text-[var(--color-brand)]">LEGAL</span>
          </div>
          <h3 class="mb-3 text-[20px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">What Is Permitted</h3>
          <div class="space-y-3 text-[13.5px] text-[var(--color-muted)]">
            {[
              'Currency futures and options on NSE, BSE, and MSE — fully SEBI regulated',
              'INR-based pairs only: USD/INR, EUR/INR, GBP/INR, JPY/INR',
              'Speculative positions up to $100 million without underlying forex exposure',
              'Hedging forex payables/receivables from import-export business',
            ].map(item => (
              <div class="flex items-start gap-2.5">
                <span class="shrink-0 text-[14px] font-bold text-[var(--color-brand)]">✓</span>
                <span>{item}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="product-card-light p-[34px]">
          <div class="mb-4 flex h-11 w-auto min-w-[80px] items-center justify-center rounded-[10px] bg-red-800/80 px-4 self-start">
            <span class="text-[12px] font-bold text-white">ILLEGAL</span>
          </div>
          <h3 class="mb-3 text-[20px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">What Is Not Permitted</h3>
          <div class="space-y-3 text-[13.5px] text-[var(--color-muted)]">
            {[
              'Offshore forex brokers (e.g., MetaTrader platforms offering FX on margin) — prohibited under FEMA',
              'Derivatives on cross-currency pairs (e.g., EUR/USD) — not permitted for Indian residents',
              'NRI participation in Indian currency futures (currently not allowed)',
              'Leveraged OTC forex with unregulated brokers — SEBI classifies this as illegal',
            ].map(item => (
              <div class="flex items-start gap-2.5">
                <span class="shrink-0 text-[14px] font-bold text-red-600">✗</span>
                <span>{item}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
      <div class="equity-reveal mt-[28px] rounded-[18px] bg-[var(--color-dark-800)] p-[28px] text-[14px] leading-relaxed text-white/70">
        <strong class="text-[var(--color-brand)]">Key regulation:</strong> All currency derivatives in India are governed by SEBI and the RBI, with the overarching framework set by FEMA 1999. Shriram Financial Services is a SEBI-registered broker with NSE currency segment membership — all trades are exchange-cleared, transparent, and legally compliant.
      </div>
    </div>
  </section>

  <!-- ══ 7. FAQ ════════════════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Frequently Asked <span class="text-[var(--color-brand)]">Questions</span>
        </h2>
      </div>
      <div class="equity-reveal mx-auto max-w-[840px] border-t border-[var(--color-n400)]">
        {faqs.map(item => (
          <details class="eq-faq group border-b border-[var(--color-n400)]">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-5 py-[26px] px-2">
              <span class="text-[18px] font-semibold text-[var(--color-ink)]">{item.q}</span>
              <span class="shrink-0 text-[22px] leading-none text-[var(--color-brand)] transition-transform duration-300 group-open:rotate-45">+</span>
            </summary>
            <div class="overflow-hidden px-2 pb-0 text-[16px] leading-relaxed text-[var(--color-muted)] transition-all duration-300 group-open:pb-[28px]">
              <p class="max-w-[680px]">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 8. FINAL CTA ══════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal overflow-hidden rounded-[22px] bg-[var(--color-dark-800)] px-[60px] py-[64px] text-center">
        <h3 class="mx-auto max-w-[560px] text-[38px] font-bold leading-[1.12] text-white" style="font-family:var(--font-display)">Trade Currency Derivatives Today</h3>
        <p class="mx-auto mt-[18px] max-w-[480px] text-[17px] leading-relaxed text-white/70">Hedge your forex exposure or speculate on exchange rates. Flat ₹20 brokerage, live pricing, and expert support.</p>
        <div class="mt-[34px] flex flex-wrap justify-center gap-[14px]">
          <a href="/about/open-demat-account/" class="btn-primary">Get Started</a>
          <a href="/about/support/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Talk to an RM</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .equity-reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s cubic-bezier(0.22, 0.61, 0.36, 1), transform 0.7s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .equity-reveal.in-view { opacity: 1; transform: none; }

  .steps-grid { display: grid; grid-template-columns: repeat(2, 1fr); }
  .steps-grid > * { border-right: 1px solid var(--color-n400); border-bottom: 1px solid var(--color-n400); }
  .steps-grid > *:nth-child(2n) { border-right: 0; }
  .steps-grid > *:nth-last-child(-n+2) { border-bottom: 0; }
  @media (min-width: 1024px) {
    .steps-grid { grid-template-columns: repeat(4, 1fr); }
    .steps-grid > * { border-right: 1px solid var(--color-n400); border-bottom: 0; }
    .steps-grid > *:last-child { border-right: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .equity-reveal { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).classList.add('in-view');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.10 });
  document.querySelectorAll('.equity-reveal').forEach(el => obs.observe(el));

  document.querySelectorAll<HTMLDetailsElement>('.eq-faq').forEach(d => {
    d.addEventListener('toggle', () => {
      if (d.open) document.querySelectorAll<HTMLDetailsElement>('.eq-faq').forEach(o => { if (o !== d) o.removeAttribute('open'); });
    });
  });
</script>
