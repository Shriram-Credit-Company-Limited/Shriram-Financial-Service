---
import BaseLayout from '../../layouts/BaseLayout.astro';

const categories = [
  { label: 'Precious Metals', items: 'Gold (GOLD), Silver (SILVER), Platinum', desc: 'Safe-haven assets that appreciate during inflation, currency weakness, or market uncertainty.' },
  { label: 'Energy', items: 'Crude Oil (CRUDEOIL), Natural Gas (NATURALGAS)', desc: 'Driven by global supply-demand, OPEC policy, and geopolitical events. Highly liquid with active participation.' },
  { label: 'Agricultural', items: 'Cotton, Chana, Castor Seed, Jeera, Guar', desc: 'Seasonally influenced by monsoon, production cycles, and export demand. Traded on NCDEX with physical delivery.' },
  { label: 'Base Metals', items: 'Copper, Aluminium, Zinc, Nickel, Lead', desc: 'Tied to industrial output and infrastructure demand. Widely used as leading indicators of global economic growth.' },
];

const exchanges = [
  { code: 'MCX', name: 'Multi Commodity Exchange', desc: 'India\'s largest commodity exchange with 90%+ market share. Focuses on metals and energy. Also offers options on Gold, Silver, and Crude Oil.' },
  { code: 'NCDEX', name: 'National Commodity & Derivatives Exchange', desc: 'India\'s premier agri commodity exchange. Futures and options on chana, castor seed, guar, and cotton — with physical delivery settlement.' },
];

const eligibility = [
  'Indian resident individual, HUF, or corporate entity',
  'Valid PAN Card (mandatory)',
  'Active trading account with commodity segment enabled',
  'Bank account for fund settlement',
  'For physical delivery: warehouse receipt and delivery centre access',
];

const documents = [
  'PAN Card (mandatory)',
  'Address Proof — Aadhaar / Passport / Utility Bill',
  'Bank Account Details — cancelled cheque or bank statement',
  'Photograph (passport-size, JPEG format)',
];

const steps = [
  { n: '01', title: 'Enable Commodity Segment', desc: 'Add MCX/NCDEX commodity trading segment to your existing Shriram trading account — no new account needed.' },
  { n: '02', title: 'Add Margin Funds', desc: 'Transfer margin funds for the contracts you wish to trade. Commodity futures require SPAN + Exposure margin.' },
  { n: '03', title: 'Choose Commodity & Contract', desc: 'Select the commodity, lot size, and expiry month. Check live commodity prices and research before entering.' },
  { n: '04', title: 'Trade & Monitor', desc: 'Place buy or sell orders through the Antara platform. Monitor live spot prices, basis, and roll costs.' },
];

const chargeRows = [
  { label: 'Brokerage', value: '₹20 per executed order' },
  { label: 'CTT (Commodity Transaction Tax)', value: '0.01% on sell side (non-agri); Nil on agri futures' },
  { label: 'GST', value: '18% on brokerage + exchange charges' },
  { label: 'Exchange Charges (MCX)', value: '0.0026% (metals); 0.00035% (energy)' },
  { label: 'SEBI Turnover Fee', value: '₹10 per crore' },
];

const risks = [
  { n: '01', label: 'Price Volatility', desc: 'Commodity prices are influenced by global macroeconomic factors, weather events, and geopolitical tensions — causing sudden, large price swings.' },
  { n: '02', label: 'Delivery Risk', desc: 'If a futures position is not squared off before expiry, it may result in compulsory physical delivery — requiring warehouse receipts and logistics.' },
  { n: '03', label: 'Basis Risk', desc: 'The difference between spot price and futures price (basis) can widen unexpectedly, reducing hedge effectiveness and increasing unexpected mark-to-market losses.' },
  { n: '04', label: 'Leverage Risk', desc: 'Commodity futures are traded on margin. A small adverse price movement can result in losses much larger than the initial margin deposited.' },
];

const faqs = [
  { q: 'What is the minimum investment to start commodity trading in India?', a: 'No regulatory minimum, but you need margin to cover one contract. GOLD Mini (100g) requires ₹20,000–₹40,000; Crude Oil (100 barrels) requires ₹15,000–₹30,000 depending on volatility.' },
  { q: 'What are the trading hours for commodities on MCX?', a: 'MCX trades Mon–Fri: day session 9:00 AM–5:00 PM; evening session 5:00 PM–11:30 PM (11:55 PM during US daylight saving). NCDEX agri commodities trade 9:00 AM–5:00 PM only.' },
  { q: 'Is physical delivery mandatory for commodity futures?', a: 'Only if you hold through the tender period (last few days before expiry). Most retail traders exit before this window. Shriram\'s platform alerts you as expiry nears so you can roll or close.' },
  { q: 'How are commodity trades settled?', a: 'Futures are marked-to-market daily — P&L is credited/debited each day. At expiry, settlement is either physical delivery or cash settlement at the daily settlement price.' },
  { q: 'Can I hedge my business exposure using commodity futures?', a: 'Yes. MCX and NCDEX futures let jewellers, oil distributors, and agri traders lock in input prices. Shriram\'s research team provides hedging advisory to eligible clients.' },
];
---

<BaseLayout
  title="Commodity Trading in India — MCX Gold Silver Crude Oil | Shriram"
  description="Start commodity trading in India on MCX and NCDEX. Trade gold, silver, crude oil, and agri commodities. Flat ₹20 brokerage, research-backed advisory. Start today."
>

  <!-- ══ 1. HERO ═══════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[var(--color-dark-800)]">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[560px] w-[560px] rounded-full bg-[var(--color-brand)]/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-32 left-0 h-80 w-80 rounded-full bg-[var(--color-brand)]/5 blur-3xl"></div>
    <div class="site-wrap relative py-[120px]">
      <p class="equity-reveal text-[14px] font-medium tracking-[.04em] text-[var(--color-brand)]">Commodities</p>
      <h1 class="equity-reveal mt-[22px] max-w-[880px] text-[clamp(32px,4vw,52px)] font-bold leading-[1.06] text-white" style="font-family:var(--font-display)">
        <span class="text-[var(--color-brand)]">Commodity Trading in India</span> — Gold, Crude Oil &amp; More
      </h1>
      <p class="equity-reveal mt-[26px] max-w-[600px] text-[18px] leading-relaxed text-white/70">
        Diversify your portfolio with commodity futures and options on MCX and NCDEX. Hedge against inflation, trade energy cycles, and capitalise on agri seasonality.
      </p>
      <div class="equity-reveal mt-[38px] flex flex-wrap gap-[14px]">
        <a href="/about/open-demat-account/" class="btn-primary">Start Commodity Trading</a>
        <a href="/about/support/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Talk to RM</a>
      </div>
      <div class="equity-reveal mt-[54px] flex flex-wrap gap-x-9 gap-y-3 border-t border-white/15 pt-9">
        {['✓ MCX & NCDEX Access', '✓ Flat ₹20/order', '✓ Research-backed', '✓ Physical delivery support'].map(f => (
          <span class="text-[15px] font-medium text-white/90">
            <span class="mr-2 text-[var(--color-brand)]">{f.slice(0,1)}</span>{f.slice(1)}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 2. TYPES OF COMMODITIES ════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto grid max-w-[1000px] items-start gap-[72px] lg:grid-cols-[5fr_7fr]">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Types of Commodities <span class="text-[var(--color-brand)]">You Can Trade</span>
        </h2>
        <div class="space-y-5 text-[17px] leading-relaxed text-[var(--color-muted)]">
          <p>Commodities are broadly split into four categories. Each behaves differently and is driven by distinct supply-demand dynamics.</p>
          <p>From precious metals that hedge inflation to agricultural commodities driven by monsoon cycles — India's commodity markets offer unique opportunities for diversification.</p>
        </div>
      </div>
      <div class="equity-reveal mx-auto mt-[76px] max-w-[1000px] border-t border-[var(--color-n400)] pt-[60px]">
        <div class="grid gap-5 sm:grid-cols-2">
          {categories.map((c, i) => (
            <div class="product-card-light flex flex-col gap-4 p-[34px]" style={`animation-delay:${i*60}ms`}>
              <div>
                <h3 class="text-[17px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{c.label}</h3>
                <p class="mt-1 text-[12px] font-medium text-[var(--color-brand-deep)]">{c.items}</p>
              </div>
              <p class="text-[13px] leading-relaxed text-[var(--color-muted)]">{c.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 3. HOW THE MARKET WORKS ════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How the Commodity Market <span class="text-[var(--color-brand)]">Works in India</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Two primary exchanges handle all commodity futures and options activity in India.</p>
      </div>
      <div class="equity-reveal grid gap-5 sm:grid-cols-2">
        {exchanges.map(e => (
          <div class="product-card-light p-[34px]">
            <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-[10px] bg-[var(--color-dark-olive)]">
              <span class="text-[11px] font-bold text-[var(--color-brand)]">{e.code}</span>
            </div>
            <h3 class="text-[17px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{e.name}</h3>
            <p class="mt-3 text-[14px] leading-relaxed text-[var(--color-muted)]">{e.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 4. ELIGIBILITY & DOCUMENTS ════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Eligibility &amp; <span class="text-[var(--color-brand)]">Documents Required</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">What you need to qualify and activate commodity segment trading.</p>
      </div>
      <div class="equity-reveal grid gap-6 sm:grid-cols-2">
        <div class="product-card-light p-[34px]">
          <h4 class="mb-6 text-[22px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">Eligibility Criteria</h4>
          <ul class="space-y-4">
            {eligibility.map(item => (
              <li class="flex items-start gap-[14px] border-b border-[var(--color-n400)]/50 pb-4 last:border-0 last:pb-0">
                <span class="shrink-0 text-[15px] font-bold leading-[1.7] text-[var(--color-brand)]">✓</span>
                <span class="text-[15.5px] text-[var(--color-muted)]">{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="product-card-light p-[34px]">
          <h4 class="mb-6 text-[22px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">Documents Required</h4>
          <ul class="space-y-4">
            {documents.map(item => (
              <li class="flex items-start gap-[14px] border-b border-[var(--color-n400)]/50 pb-4 last:border-0 last:pb-0">
                <span class="shrink-0 text-[15px] font-bold leading-[1.7] text-[var(--color-brand)]">✓</span>
                <span class="text-[15.5px] text-[var(--color-muted)]">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 5. HOW TO START ════════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How to Start <span class="text-[var(--color-brand)]">Trading Commodities</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Four steps from enabling your segment to placing your first commodity trade.</p>
      </div>
      <div class="equity-reveal steps-grid overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        {steps.map(s => (
          <div class="px-[30px] py-[34px]">
            <div class="mb-[22px] font-display text-[34px] font-normal leading-none text-[var(--color-brand)]">{s.n}</div>
            <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">{s.title}</h4>
            <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 6. CHARGES ════════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Brokerage &amp; <span class="text-[var(--color-brand)]">Charges</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">A complete breakdown of all costs involved in commodity futures trading.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto"><table class="w-full text-[15.5px]">
          <thead><tr class="bg-[var(--color-dark-olive)]"><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Charge Type</th><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Amount / Rate</th></tr></thead>
          <tbody>{chargeRows.map((r,i) => (<tr class={i%2===0?'bg-white':'bg-[#f8f6f1]'}><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.label}</td><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.value}</td></tr>))}</tbody>
        </table></div>
      </div>
    </div>
  </section>

  <!-- ══ 7. RISKS ════════════════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Risks of <span class="text-[var(--color-brand)]">Commodity Trading</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Understand what can move against you before you commit capital.</p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {risks.map(r => (
          <div class="equity-reveal rounded-[18px] bg-[var(--color-dark-800)] p-[36px]">
            <div class="mb-[18px] text-[48px] font-bold leading-none text-[var(--color-brand)]/25">{r.n}</div>
            <h4 class="mb-3 text-[20px] font-medium text-white" style="font-family:var(--font-display)">{r.label}</h4>
            <p class="text-[14.5px] leading-relaxed text-white/60">{r.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 7b. COMMODITY FUTURES REFERENCE TABLE ═════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Types of Commodities — <span class="text-[var(--color-brand)]">Exchange, Lot Size &amp; Price Drivers</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">A quick-reference guide to key commodities available for trading in India.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[14.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[20px] py-[16px] text-left text-[13px] font-semibold text-white">Commodity</th>
                <th class="px-[20px] py-[16px] text-left text-[13px] font-semibold text-[var(--color-brand)]">Category</th>
                <th class="px-[20px] py-[16px] text-left text-[13px] font-semibold text-[var(--color-brand)]">Exchange</th>
                <th class="px-[20px] py-[16px] text-left text-[13px] font-semibold text-[var(--color-brand)]">Lot Size</th>
                <th class="px-[20px] py-[16px] text-left text-[13px] font-semibold text-[var(--color-brand)]">Key Price Driver</th>
              </tr>
            </thead>
            <tbody>
              {[
                { name: 'Gold', cat: 'Precious Metal', ex: 'MCX', lot: '1 kg', driver: 'USD strength, inflation, geopolitics' },
                { name: 'Silver', cat: 'Precious Metal', ex: 'MCX', lot: '30 kg', driver: 'Industrial demand, gold price movement' },
                { name: 'Crude Oil', cat: 'Energy', ex: 'MCX', lot: '100 barrels', driver: 'OPEC+ policy, US inventory data, geopolitics' },
                { name: 'Copper', cat: 'Base Metal', ex: 'MCX', lot: '2.5 MT', driver: 'China manufacturing data, global GDP growth' },
                { name: 'Zinc', cat: 'Base Metal', ex: 'MCX', lot: '5 MT', driver: 'Galvanising demand, mine supply' },
                { name: 'Aluminium', cat: 'Base Metal', ex: 'MCX', lot: '5 MT', driver: 'Energy cost, China production, EVs demand' },
                { name: 'Wheat (Jeera)', cat: 'Agricultural', ex: 'NCDEX', lot: '3 MT', driver: 'Monsoon, exports, MSP, acreage' },
                { name: 'Soybean', cat: 'Agricultural', ex: 'NCDEX', lot: '10 MT', driver: 'Kharif crop output, import parity, edible oil demand' },
              ].map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[20px] py-[15px] font-semibold text-[var(--color-ink)]">{r.name}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[20px] py-[15px] text-[var(--color-muted)]">{r.cat}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[20px] py-[15px] font-medium text-[var(--color-dark-olive)]">{r.ex}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[20px] py-[15px] text-[var(--color-muted)]">{r.lot}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[20px] py-[15px] text-[var(--color-muted)]">{r.driver}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 7c. IS COMMODITY TRADING LEGAL? SEBI RULES ═════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Is Commodity Trading Legal in India? <span class="text-[var(--color-brand)]">SEBI Rules Explained</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Yes — commodity futures and options trading in India is 100% legal and tightly regulated by SEBI.</p>
      </div>
      <div class="equity-reveal grid gap-5 sm:grid-cols-3">
        {[
          { body: 'SEBI', full: 'Securities and Exchange Board of India', desc: 'SEBI became the unified regulator for commodity derivatives in September 2015 (absorbing the erstwhile FMC). It sets margin rules, position limits, and participant eligibility for MCX and NCDEX.' },
          { body: 'MCX', full: 'Multi Commodity Exchange of India Ltd', desc: 'India\'s leading commodity exchange, regulated by SEBI. MCX is a publicly listed company (NSE: MCX) and handles over 90% of commodity derivative volumes in India.' },
          { body: 'NCDEX', full: 'National Commodity & Derivatives Exchange', desc: 'India\'s premier agricultural commodity exchange, also regulated by SEBI. NCDEX provides physical delivery infrastructure for farm commodities with government-approved warehouses across India.' },
        ].map((b, i) => (
          <div class="product-card-light flex flex-col gap-4 p-[34px]" style={`animation-delay:${i*80}ms`}>
            <div class="flex h-11 w-auto min-w-[60px] items-center justify-center rounded-[10px] bg-[var(--color-dark-olive)] px-4 self-start">
              <span class="text-[13px] font-bold text-[var(--color-brand)]">{b.body}</span>
            </div>
            <h3 class="text-[15px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{b.full}</h3>
            <p class="text-[13px] leading-relaxed text-[var(--color-muted)]">{b.desc}</p>
          </div>
        ))}
      </div>
      <div class="equity-reveal mt-[34px] rounded-[18px] bg-[#f8f6f1] border border-[var(--color-n400)] p-[28px] text-[14px] leading-relaxed text-[var(--color-muted)]">
        <strong class="text-[var(--color-ink)]">Key regulatory points:</strong> All commodity brokers must be SEBI-registered members of MCX or NCDEX. Individual investors need only a trading account (no special licence). Position limits apply to prevent market manipulation. SEBI mandates upfront margin collection before every trade.
      </div>
    </div>
  </section>

  <!-- ══ 8. FAQ ════════════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Frequently Asked <span class="text-[var(--color-brand)]">Questions</span>
        </h2>
      </div>
      <div class="equity-reveal mx-auto max-w-[840px] border-t border-[var(--color-n400)]">
        {faqs.map(item => (
          <details class="eq-faq group border-b border-[var(--color-n400)]">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-5 py-[26px] px-2">
              <span class="text-[18px] font-semibold text-[var(--color-ink)]">{item.q}</span>
              <span class="shrink-0 text-[22px] leading-none text-[var(--color-brand)] transition-transform duration-300 group-open:rotate-45">+</span>
            </summary>
            <div class="overflow-hidden px-2 pb-0 text-[16px] leading-relaxed text-[var(--color-muted)] transition-all duration-300 group-open:pb-[28px]">
              <p class="max-w-[680px]">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 9. FINAL CTA ══════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal overflow-hidden rounded-[22px] bg-[var(--color-dark-800)] px-[60px] py-[64px] text-center">
        <h3 class="mx-auto max-w-[560px] text-[38px] font-bold leading-[1.12] text-white" style="font-family:var(--font-display)">Start Commodity Trading Today</h3>
        <p class="mx-auto mt-[18px] max-w-[480px] text-[17px] leading-relaxed text-white/70">Access MCX and NCDEX with a single account. Flat ₹20 brokerage, live prices, and expert research support.</p>
        <div class="mt-[34px] flex flex-wrap justify-center gap-[14px]">
          <a href="/about/open-demat-account/" class="btn-primary">Get Started</a>
          <a href="/about/support/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Talk to an RM</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .equity-reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s cubic-bezier(0.22, 0.61, 0.36, 1), transform 0.7s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .equity-reveal.in-view { opacity: 1; transform: none; }

  .steps-grid { display: grid; grid-template-columns: repeat(2, 1fr); }
  .steps-grid > * { border-right: 1px solid var(--color-n400); border-bottom: 1px solid var(--color-n400); }
  .steps-grid > *:nth-child(2n) { border-right: 0; }
  .steps-grid > *:nth-last-child(-n+2) { border-bottom: 0; }
  @media (min-width: 1024px) {
    .steps-grid { grid-template-columns: repeat(4, 1fr); }
    .steps-grid > * { border-right: 1px solid var(--color-n400); border-bottom: 0; }
    .steps-grid > *:last-child { border-right: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .equity-reveal { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).classList.add('in-view');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.10 });
  document.querySelectorAll('.equity-reveal').forEach(el => obs.observe(el));

  document.querySelectorAll<HTMLDetailsElement>('.eq-faq').forEach(d => {
    d.addEventListener('toggle', () => {
      if (d.open) document.querySelectorAll<HTMLDetailsElement>('.eq-faq').forEach(o => { if (o !== d) o.removeAttribute('open'); });
    });
  });
</script>
