---
import BaseLayout from '../../layouts/BaseLayout.astro';

const commodityTypes = [
  { label: 'Precious Metals',  desc: 'Gold and silver traded on MCX. Driven by USD, global inflation, central bank reserves, and safe-haven demand. Lot size: Gold 1 kg, Silver 30 kg.' },
  { label: 'Energy',           desc: 'Crude oil and natural gas on MCX. Price drivers include OPEC supply decisions, US inventory data, weather, and geopolitics. Lot size: Crude 100 bbl.' },
  { label: 'Base Metals',      desc: 'Copper, zinc, aluminium on MCX. Closely linked to global manufacturing PMI and China economic data. Lot size: Copper 1,000 kg.' },
  { label: 'Agricultural',     desc: 'Soybean, chana, cotton, guar on NCDEX. Driven by monsoon data, MSP announcements, and domestic crop production. Lot size: Soybean 10,000 kg.' },
  { label: 'Soft Commodities', desc: 'Jeera, turmeric, coriander, castor seed on NCDEX. Niche markets with strong seasonal price patterns and domestic consumption drivers.' },
];

const benefits = [
  { label: 'Inflation Hedge',           desc: 'Gold and silver historically preserve purchasing power during high-inflation periods — a natural store of value outside equities.' },
  { label: 'Portfolio Diversification', desc: 'Commodities have low correlation with equities and bonds. Adding them reduces overall portfolio volatility across market cycles.' },
  { label: 'Leverage via Futures',      desc: 'Trade large notional positions with a fraction of capital through exchange-mandated SPAN + Exposure margin on MCX / NCDEX.' },
  { label: 'Global Demand Exposure',    desc: 'Participate in macro themes: China growth, energy transition, monsoon seasons, and OPEC supply cycles from a single Indian account.' },
  { label: 'Extended Trading Hours',    desc: 'MCX metals and energy contracts trade until 11:55 PM IST — covering the US session and key international price discovery windows.' },
];

const advantages = [
  { n: '01', title: 'MCX + NCDEX in One Account', desc: 'Access all commodity exchanges — metals, energy on MCX and agri commodities on NCDEX — through a single Shriram trading account.' },
  { n: '02', title: 'Flat ₹20 Brokerage',          desc: 'Zero delivery brokerage on commodity positions. F&O orders capped at flat ₹20/order regardless of trade size or commodity.' },
  { n: '03', title: 'Live Price Streaming',         desc: 'Real-time MCX and NCDEX prices on the Antara app with level-2 order book, commodity charts, and intraday alerts.' },
  { n: '04', title: 'SEBI-Registered Broker',       desc: 'Shriram holds SEBI commodity broker registration INZ000002135. Fully compliant with MCX and NCDEX membership requirements.' },
  { n: '05', title: 'Low Initial Margin',           desc: 'Start commodity trading from ₹7,000 (Gold Mini). Margin requirements displayed upfront before order placement.' },
  { n: '06', title: '40+ Years of Trust',           desc: 'Backed by the Shriram Group — one of India\'s most trusted financial conglomerates with ₹2 lakh crore AUM.' },
];

const vsRows = [
  { feature: 'Obligation',       fut: 'Must settle at expiry (buy/sell)', opt: 'Buyer has right only — no obligation' },
  { feature: 'Premium',          fut: 'No premium — margin-based',         opt: 'Buyer pays upfront premium' },
  { feature: 'Max Loss (buyer)', fut: 'Unlimited (mark-to-market)',         opt: 'Limited to premium paid' },
  { feature: 'Leverage',         fut: 'Higher leverage',                    opt: 'Lower leverage' },
  { feature: 'Complexity',       fut: 'Simpler — one contract to track',    opt: 'Strike, expiry, Greeks to manage' },
  { feature: 'Best Use',         fut: 'Price speculation, import hedging',  opt: 'Premium income, defined-risk bets' },
];

const steps = [
  { n: '01', title: 'Open Trading Account',         desc: 'Open Demat + Trading account with Shriram online in under 10 minutes. PAN, Aadhaar, bank details — fully paperless.' },
  { n: '02', title: 'Activate Commodity Segment',   desc: 'Request MCX and/or NCDEX segment activation. Submit income proof for F&O activation. Done digitally in 24 hours.' },
  { n: '03', title: 'Transfer Margin Funds',         desc: 'Transfer SPAN + Exposure margin via UPI or NEFT. Margin requirement displayed per commodity before placing order.' },
  { n: '04', title: 'Select Commodity & Contract',  desc: 'Pick commodity (Gold, Crude, Soybean), contract month, and lot size. Near-month contracts have highest liquidity.' },
  { n: '05', title: 'Place Buy / Sell Order',        desc: 'Market or limit order on MCX/NCDEX. Set stop-loss to cap downside. MTM profit/loss reflected in real time.' },
  { n: '06', title: 'Square Off Before Expiry',     desc: 'Exit position before expiry to avoid physical delivery. Cash-settled contracts auto-settle at final settlement price.' },
];

const sebiRules = [
  { rule: 'SEBI Registration',       detail: 'All commodity brokers must be registered with SEBI as stockbrokers with commodity segment approval. Shriram Reg: INZ000002135.' },
  { rule: 'Position Limits',         detail: 'SEBI and exchanges set client-level position limits per commodity to prevent cornering. Limits reset each contract month.' },
  { rule: 'Margin Reporting',        detail: 'Brokers must report daily client margin utilisation to MCX/NCDEX. Under-margined positions are squared off by the broker.' },
  { rule: 'Delivery Settlement',     detail: 'Commodity contracts with physical delivery must be settled via accredited warehouses. Cash-settled contracts use final settlement price.' },
  { rule: 'Commodity CTT',           detail: 'Commodity Transaction Tax (CTT) applies to non-agri commodity futures at 0.01% on sell side. Agri commodity futures are CTT-exempt.' },
  { rule: 'Algorithmic Trading',     detail: 'Algo orders on MCX/NCDEX require prior exchange approval and risk controls compliant with SEBI circular SEBI/MRD/2/CIR/2012/2.' },
];

const taxRows = [
  { type: 'Non-agri Commodity F&O', treatment: 'Non-speculative business income', ctt: '0.01% on sell',   itr: 'ITR-3' },
  { type: 'Agri Commodity F&O',     treatment: 'Speculative business income',     ctt: 'CTT exempt',       itr: 'ITR-3' },
  { type: 'Physical Delivery Gains',treatment: 'Capital gains (STCG/LTCG)',        ctt: 'CTT + STT apply', itr: 'ITR-2 / ITR-3' },
  { type: 'Losses (F&O)',           treatment: 'Set off vs business income',        ctt: '—',               itr: 'ITR-3 (audit if > ₹1 Cr)' },
];

const strategies = [
  { label: 'Trend Following',          desc: 'Use 20-day and 50-day moving averages on Gold and Crude Oil charts to identify directional momentum. Trade with the trend, not against it.' },
  { label: 'Spread Trading',           desc: 'Go long near-month and short far-month (calendar spread) to capture basis differentials — lower risk than outright directional bets.' },
  { label: 'Seasonal Gold Strategy',   desc: 'Gold historically strengthens Oct–Feb driven by festive demand and central bank buying. Monitor USD Index and FOMC rate decisions.' },
  { label: 'Agri-Monsoon Play',        desc: 'NCDEX agri prices are highly sensitive to monsoon rainfall data. Build positions before IMD forecasts and exit after the sowing season.' },
];

const faqs = [
  { q: 'What is commodity trading in India?',                        a: 'Commodity trading in India is the buying and selling of raw materials — metals, energy, and agri products — through exchange-traded futures and options contracts on MCX (Multi Commodity Exchange) and NCDEX (National Commodity & Derivatives Exchange), both regulated by SEBI.' },
  { q: 'Is commodity trading legal in India?',                       a: 'Yes. Commodity trading on SEBI-regulated exchanges MCX and NCDEX is 100% legal. Avoid unregulated offshore platforms and OTC dealers that are not registered with SEBI — those are illegal under FEMA and SCRA.' },
  { q: 'What is the difference between MCX and NCDEX?',              a: 'MCX focuses on metals (gold, silver, copper) and energy (crude oil, natural gas) with trading hours until 11:55 PM IST. NCDEX focuses on agricultural commodities (soybean, chana, cotton) with hours until 5 PM IST.' },
  { q: 'What is the minimum capital to start commodity trading?',    a: 'You can start from ₹7,000–₹10,000 with a Gold Mini contract (100 grams). A full Gold contract (1 kg) requires ₹70,000–₹90,000 in margin. Crude oil requires approximately ₹30,000–₹40,000 per lot.' },
  { q: 'How is commodity trading taxed in India?',                   a: 'Non-agri commodity F&O profits are taxed as non-speculative business income at your applicable slab rate. Agri commodity F&O profits are treated as speculative business income. File ITR-3 and disclose all commodity transactions.' },
  { q: 'What is CTT in commodity trading?',                          a: 'CTT (Commodity Transaction Tax) is charged at 0.01% on the sell side for non-agricultural commodity futures contracts on MCX. Agricultural commodity derivatives are exempt from CTT. CTT is deductible as a business expense.' },
  { q: 'Can I take physical delivery of gold on MCX?',               a: 'Yes. Selected MCX Gold and Silver contracts allow physical delivery. You must specify delivery intent before the delivery period begins and have a registered vault account. Most retail traders square off before expiry.' },
  { q: 'What is SPAN margin in commodity trading?',                  a: 'SPAN (Standard Portfolio Analysis of Risk) margin covers the worst-case one-day loss on your commodity position as calculated by the exchange. Exposure margin is added on top. Both are blocked when you enter a futures position.' },
  { q: 'What are trading hours for MCX?',                            a: 'MCX trading runs from 9:00 AM to 11:30 PM IST for most contracts. International contracts (crude oil, copper, gold) extend to 11:55 PM to cover the US trading session. Saturday and Sunday are non-trading days.' },
  { q: 'What is the lot size for crude oil on MCX?',                 a: 'The standard crude oil lot size on MCX is 100 barrels. A Mini crude contract is 10 barrels, suitable for smaller capital. Lot sizes are standardised by the exchange and cannot be changed.' },
];
---

<BaseLayout
  title="Commodity Trading in India — MCX & NCDEX Gold, Crude Oil | Shriram"
  description="Trade commodities in India on MCX & NCDEX with Shriram Financial Services. Gold, silver, crude oil, copper, agri commodities — SEBI-registered broker, flat ₹20/order, live MCX prices."
>

  <!-- ══ 1. HERO ══════════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-inner">
      <h1>Commodity Trading in India — <span class="g">40+ Markets</span> on MCX &amp; NCDEX</h1>
      <p class="lead">Trade Gold, Silver, Crude Oil, Copper, and Agri commodities through India's trusted SEBI-regulated broker. Low margins, flat ₹20/order, live MCX and NCDEX prices on the Antara app.</p>
      <div class="cta-row">
        <a class="btn-gold" href="/about/open-demat-account/">Open Demat Account</a>
        <a class="btn-ghost" href="/about/support/">Talk to an Expert</a>
      </div>
      <div class="hero-feats">
        <div class="feats">
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;SEBI-registered</span></div>
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;MCX &amp; NCDEX approved</span></div>
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;Flat ₹20/order</span></div>
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;Live commodity prices</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 2. WHAT IS COMMODITY TRADING? ═══════════════════════════════ -->
  <section class="section stack" id="sec-what" style="background:var(--sec-light);gap:48px">
    <div class="stack" style="gap:16px">
      <p class="sec-title">What is Commodity Trading?</p>
      <p class="sec-lead">Commodity trading is the buying and selling of raw materials and primary products through regulated exchanges. In India, commodity trading takes place as exchange-traded derivatives — primarily futures and options — giving investors price exposure without physically handling the underlying goods.</p>
      <p class="sec-lead">Unlike equity trading on BSE/NSE, commodity derivatives are traded on MCX (Multi Commodity Exchange) and NCDEX (National Commodity &amp; Derivatives Exchange), both regulated by SEBI since 2015. Commodities are broadly classified into metals, energy, and agricultural products — each with distinct price drivers, lot sizes, and trading hours.</p>
    </div>
    <div class="row-2">
      <div class="card">
        <p class="card-h">MCX — Metals &amp; Energy</p>
        <p class="card-p">MCX handles metals (gold, silver, copper, zinc, aluminium) and energy (crude oil, natural gas). Trading runs 9 AM–11:55 PM IST, covering international price discovery including the US trading session.</p>
      </div>
      <div class="card">
        <p class="card-h">NCDEX — Agricultural Commodities</p>
        <p class="card-p">NCDEX specialises in agri commodities — soybean, chana, jeera, turmeric, cotton, guar. Agricultural contracts follow domestic price drivers including monsoon data and MSP announcements from the government.</p>
      </div>
    </div>
  </section>

  <!-- ══ 3. TYPES OF COMMODITIES IN INDIA ════════════════════════════ -->
  <section class="section stack" id="sec-types" style="background:var(--sec-tint);gap:48px">
    <div class="stack" style="gap:16px">
      <p class="sec-title">Types of Commodities in India</p>
      <p class="sec-lead">India's commodity markets span five major categories traded across MCX and NCDEX. Each segment has distinct exchanges, lot sizes, and price drivers. Hard commodities include metals and energy resources; soft commodities cover agricultural products and livestock.</p>
    </div>
    <div class="cat-grid cat-3">
      {commodityTypes.map(t => (
        <div class="cat"><h4>{t.label}</h4><p>{t.desc}</p></div>
      ))}
    </div>
  </section>

  <!-- ══ 4. WHY INVEST IN COMMODITIES? ═══════════════════════════════ -->
  <section class="section stack" id="sec-why" style="background:var(--sec-light);gap:48px">
    <div class="stack" style="gap:16px">
      <p class="sec-title">Why Invest in Commodities? — Benefits</p>
      <p class="sec-lead">Commodities offer portfolio benefits that equities and fixed income alone cannot. Here are the five core reasons investors and hedgers choose commodity derivatives on MCX and NCDEX.</p>
    </div>
    <div class="cat-grid cat-3">
      {benefits.map(b => (
        <div class="cat"><h4>{b.label}</h4><p>{b.desc}</p></div>
      ))}
    </div>
  </section>

  <!-- ══ 5. ADVANTAGES OF COMMODITIES (Shriram) ══════════════════════ -->
  <section class="section stack" id="sec-adv" style="background:var(--sec-tint);gap:48px">
    <div class="stack" style="gap:16px">
      <p class="sec-title">Advantage of Commodities Trading with Shriram</p>
      <p class="sec-lead">Beyond the asset class itself, Shriram's platform adds specific advantages that make commodity trading more accessible, cost-effective, and transparent.</p>
    </div>
    <div class="num-grid">
      {advantages.map(a => (
        <div class="num-item">
          <span class="num-n">{a.n}</span>
          <h4>{a.title}</h4>
          <p>{a.desc}</p>
        </div>
      ))}
    </div>
    <a class="btn-gold" href="/about/open-demat-account/" style="align-self:center">Start Commodity Trading</a>
  </section>

  <!-- ══ 6. HOW COMMODITY TRADING WORKS ══════════════════════════════ -->
  <section class="section stack" id="sec-how" style="background:var(--sec-light);gap:48px">
    <div class="stack" style="gap:16px">
      <p class="sec-title">How Commodity Trading Works — MCX &amp; NCDEX</p>
      <p class="sec-lead">Commodity trading in India happens through exchange-traded futures and options contracts. When you buy a crude oil futures contract on MCX, you agree to buy a fixed quantity (100 barrels) at a predetermined price on a specific expiry date. Most retail traders square off positions before expiry, settling in cash rather than taking physical delivery.</p>
    </div>
    <div class="t-scroll">
      <div class="table t3">
        <div class="cell th"><p>Feature</p></div>
        <div class="cell th"><p>MCX</p></div>
        <div class="cell th"><p>NCDEX</p></div>
        {[
          { feature: 'Full Form',       mcx: 'Multi Commodity Exchange',            ncdex: 'National Commodity & Derivatives Exchange' },
          { feature: 'Focus',           mcx: 'Metals, energy — Gold, Silver, Crude', ncdex: 'Agri commodities — Soybean, Chana, Cotton' },
          { feature: 'Trading Hours',   mcx: '9 AM – 11:30 PM / 11:55 PM IST',       ncdex: '9 AM – 5 PM IST' },
          { feature: 'Settlement',      mcx: 'Cash + physical (gold, silver)',        ncdex: 'Mostly physical delivery' },
          { feature: 'Exchange City',   mcx: 'Mumbai',                               ncdex: 'Mumbai' },
          { feature: 'Regulator',       mcx: 'SEBI',                                 ncdex: 'SEBI' },
        ].map(r => (
          <>
            <div class="cell tb"><p class="k">{r.feature}</p></div>
            <div class="cell tb"><p class="v">{r.mcx}</p></div>
            <div class="cell tb"><p class="v">{r.ncdex}</p></div>
          </>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 7. COMMODITY FUTURES VS OPTIONS ═════════════════════════════ -->
  <section class="section stack" id="sec-fvso" style="background:var(--sec-tint);gap:48px">
    <div class="stack" style="gap:16px">
      <p class="sec-title">Commodity Futures vs Options — Key Differences</p>
      <p class="sec-lead">Both instruments give exposure to commodity prices but differ fundamentally in obligation, risk profile, and capital requirement. Beginners usually start with futures for simplicity; options suit more experienced traders seeking defined-risk strategies.</p>
    </div>
    <div class="t-scroll">
      <div class="table t3">
        <div class="cell th"><p>Feature</p></div>
        <div class="cell th"><p>Commodity Futures</p></div>
        <div class="cell th"><p>Commodity Options</p></div>
        {vsRows.map(r => (
          <>
            <div class="cell tb"><p class="k">{r.feature}</p></div>
            <div class="cell tb"><p class="v">{r.fut}</p></div>
            <div class="cell tb"><p class="v">{r.opt}</p></div>
          </>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 8. HOW TO START — STEP BY STEP ══════════════════════════════ -->
  <section class="section stack" id="sec-start" style="background:var(--sec-light);gap:48px">
    <div class="stack" style="gap:16px">
      <p class="sec-title">How to Start Commodity Trading — Step by Step</p>
      <p class="sec-lead">Six steps from account opening to your first commodity trade — entirely online, no physical paperwork required. Commodity segment can be activated alongside your existing equity account.</p>
    </div>
    <div class="num-grid">
      {steps.map(s => (
        <div class="num-item">
          <span class="num-n">{s.n}</span>
          <h4>{s.title}</h4>
          <p>{s.desc}</p>
        </div>
      ))}
    </div>
    <a class="btn-gold" href="/about/open-demat-account/" style="align-self:center">Open Demat Account</a>
  </section>

  <!-- ══ 9. SEBI RULES & REGULATIONS ═════════════════════════════════ -->
  <section class="section stack" id="sec-sebi" style="background:var(--sec-tint);gap:48px">
    <div class="stack" style="gap:16px">
      <p class="sec-title">SEBI Rules &amp; Regulations for Commodity Trading in India</p>
      <p class="sec-lead">Commodity trading in India is fully legal and regulated by SEBI since 2015, when the Forward Markets Commission (FMC) was merged into SEBI. Every registered commodity broker must comply with position limits, margin reporting, and delivery settlement rules.</p>
    </div>
    <div class="cat-grid cat-3">
      {sebiRules.map(r => (
        <div class="cat"><h4>{r.rule}</h4><p>{r.detail}</p></div>
      ))}
    </div>
  </section>

  <!-- ══ 10. TAXATION ═════════════════════════════════════════════════ -->
  <section class="section stack" id="sec-tax" style="background:var(--sec-light);gap:48px">
    <div class="stack" style="gap:16px">
      <p class="sec-title">Taxation on Commodity Trading Profits</p>
      <p class="sec-lead">Commodity F&O profits are treated as business income — not capital gains — regardless of holding period. Maintain proper books of account and file ITR-3. Losses can be set off against other business income and carried forward for up to 8 years.</p>
    </div>
    <div class="t-scroll">
      <div class="table t4">
        <div class="cell th"><p>Transaction Type</p></div>
        <div class="cell th"><p>Tax Treatment</p></div>
        <div class="cell th"><p>CTT</p></div>
        <div class="cell th"><p>ITR Form</p></div>
        {taxRows.map(r => (
          <>
            <div class="cell tb"><p class="k">{r.type}</p></div>
            <div class="cell tb"><p class="v">{r.treatment}</p></div>
            <div class="cell tb"><p class="v">{r.ctt}</p></div>
            <div class="cell tb"><p class="v">{r.itr}</p></div>
          </>
        ))}
      </div>
    </div>
    <div class="card" style="border-color:var(--card-border-soft)">
      <p class="card-h" style="font-size:16px">Important: Consult a CA</p>
      <p class="card-p">Commodity F&O accounting requires turnover calculation (sum of absolute profits + losses), Books of Account under Section 44AB if turnover exceeds ₹1 Cr, and proper disclosure of open positions at year-end. Always consult a chartered accountant for your specific situation.</p>
    </div>
  </section>

  <!-- ══ 11. TRADING STRATEGIES ═══════════════════════════════════════ -->
  <section class="section stack" id="sec-strategies" style="background:var(--sec-tint);gap:48px">
    <div class="stack" style="gap:16px">
      <p class="sec-title">Commodity Trading Strategies for Beginners</p>
      <p class="sec-lead">These are the most widely used approaches in Indian commodity markets. Each suits a different risk appetite, capital size, and time horizon. Start with one strategy and a single commodity before diversifying.</p>
    </div>
    <div class="cat-grid cat-4">
      {strategies.map(s => (
        <div class="cat"><h4>{s.label}</h4><p>{s.desc}</p></div>
      ))}
    </div>
  </section>

  <!-- ══ 12. FAQ ════════════════════════════════════════════════════════ -->
  <section class="faq-wrap" style="background:var(--sec-light)">
    <div class="faq-cols">
      <div class="faq-left">
        <h2 class="faq-title">Frequently asked<br>questions.</h2>
        <div class="faq-acc" role="list">
          {faqs.map(f => (
            <details class="faq-item" role="listitem">
              <summary class="faq-sum">
                <span class="qt">{f.q}</span>
                <svg class="faq-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="8" y1="3" x2="8" y2="13"/><line x1="3" y1="8" x2="13" y2="8" class="faq-h"/></svg>
              </summary>
              <div class="qa"><p>{f.a}</p></div>
            </details>
          ))}
        </div>
      </div>
      <div class="faq-side">
        <div class="usr" aria-hidden="true">
          <svg viewBox="0 0 131 147" fill="none"><circle cx="65.5" cy="42" r="34" stroke="currentColor" stroke-width="2"/><path d="M4 147c0-34 27.6-61.5 61.5-61.5S127 113 127 147" stroke="currentColor" stroke-width="2"/></svg>
        </div>
        <div class="side-in">
          <div class="side-tx">
            <h4>Ready to Trade Commodities?</h4>
            <p>Open your Demat account with Shriram in under 10 minutes. Flat ₹20/order. MCX + NCDEX access. SEBI-registered.</p>
          </div>
          <a class="btn-gold" href="/about/open-demat-account/" style="align-self:flex-start">Open Demat Account</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 13. FINAL CTA ═════════════════════════════════════════════════ -->
  <section class="cta-sec" style="background:var(--sec-tint)">
    <div class="cta-box">
      <h2 class="cta-h">Open Commodity Trading Account — <span class="g">MCX &amp; NCDEX</span></h2>
      <p class="cta-sub">Zero account opening fee. SEBI-registered. Flat ₹20/order. 40+ years of trust.</p>
      <div class="cta-row">
        <a class="btn-gold" href="/about/open-demat-account/">Open Demat Account</a>
        <a class="btn-ghost-dark" href="/about/support/">Talk to an Expert</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Design tokens ─────────────────────────────────────────────── */
  :root {
    --sec-light: #fef8ee;
    --sec-tint: #f6efe1;
    --card: #fffdf8;
    --card-border: #e1e0db;
    --card-border-soft: rgba(28,28,22,.13);
    --row-line: rgba(28,28,22,.08);
    --olive-title: #2e3914;
    --olive-head: #2d3813;
    --olive-deep: #1b2010;
    --ink: #1c1c16;
    --ink-2: #46463c;
    --ink-3: #595959;
    --muted: #73736a;
    --muted-2: #9a9a8e;
    --gold: #e0a82e;
    --gold-2: #f2b83f;
    --gold-btn: #f3b83f;
    --olive-ink: #2e3914;
    --green: #009d58;
    --pad: clamp(20px, 8vw, 144px);
    --container-pad: 32px;
    --section-y: 72px;
    --cta-w: 220px;
  }

  *, *::before, *::after { box-sizing: border-box; }
  a { color: inherit; text-decoration: none; }
  p { line-height: 1.5; }

  /* ── Section shell ───────────────────────────────────────────────── */
  .section {
    padding: var(--section-y) var(--pad);
    min-height: 100vh; min-height: 100dvh;
    display: flex; flex-direction: column; justify-content: center;
  }
  #sec-what { min-height: 0; }
  .stack { display: flex; flex-direction: column; }

