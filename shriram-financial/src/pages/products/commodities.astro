---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Commodity Trading in India — MCX, NCDEX Gold & Crude Oil | Shriram"
  description="Trade commodities in India on MCX & NCDEX. Gold, silver, crude oil, copper, agri commodities. SEBI-registered broker. Flat ₹20/order. Open commodity trading account today."
>

  <!-- ══ S1. HERO ══════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[var(--color-dark-800)] py-[100px] lg:py-[120px]">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[560px] w-[560px] rounded-full bg-[var(--color-brand)]/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-32 left-0 h-80 w-80 rounded-full bg-[var(--color-brand)]/5 blur-3xl"></div>
    <div class="site-wrap relative">
      <h1 class="equity-reveal max-w-[880px] text-[clamp(32px,4vw,52px)] font-bold leading-[1.06] text-white" style="font-family:var(--font-display)">
        <span class="text-[var(--color-brand)]">Commodity Trading</span> in India — MCX, NCDEX, Gold &amp; Crude
      </h1>
      <p class="equity-reveal mt-[26px] max-w-[600px] text-[18px] leading-relaxed text-white/70">
        Trade Gold, Silver, Crude Oil, Copper, and Agri commodities on MCX &amp; NCDEX. SEBI-regulated. Flat ₹20/order. Open a commodity trading account in minutes.
      </p>
      <div class="equity-reveal mt-[38px] flex flex-wrap gap-[14px]">
        <a href="/about/open-demat-account/" class="btn-primary">Open Commodity Account</a>
        <a href="/about/open-demat-account/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Start Trading</a>
      </div>
      <div class="equity-reveal mt-[54px] flex flex-wrap gap-x-9 gap-y-3 border-t border-white/15 pt-9">
        {['✓ SEBI-regulated', '✓ MCX & NCDEX approved', '✓ Flat ₹20/order', '✓ Live commodity prices'].map(f => (
          <span class="text-[15px] font-medium text-white/90">{f}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S2. WHAT IS COMMODITY TRADING? ═══════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          What is <span class="text-[var(--color-brand)]">Commodity Trading?</span> — Meaning &amp; Basics
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">
          Commodity trading is the buying and selling of raw materials — metals, energy, and agricultural products — through exchange-traded futures and options contracts on MCX and NCDEX.
        </p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Feature</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Description</th>
              </tr>
            </thead>
            <tbody>
              {[
                { feature: 'Exchange', desc: 'MCX (metals, energy) and NCDEX (agri commodities)' },
                { feature: 'Contract Type', desc: 'Futures and options on standardised lot sizes' },
                { feature: 'Regulator', desc: 'SEBI (merged with FMC in 2015)' },
                { feature: 'Settlement', desc: 'Physical or cash settlement depending on contract' },
              ].map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.feature}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.desc}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S3. TYPES OF COMMODITIES IN INDIA ════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Types of <span class="text-[var(--color-brand)]">Commodities</span> in India — All Categories
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">
          Commodities traded on Indian exchanges fall into four categories.
        </p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[14.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[20px] py-[16px] text-left text-[13px] font-semibold text-white">Commodity</th>
                <th class="px-[20px] py-[16px] text-left text-[13px] font-semibold text-[var(--color-brand)]">Category</th>
                <th class="px-[20px] py-[16px] text-left text-[13px] font-semibold text-[var(--color-brand)]">Exchange</th>
                <th class="px-[20px] py-[16px] text-left text-[13px] font-semibold text-[var(--color-brand)]">Lot Size</th>
                <th class="px-[20px] py-[16px] text-left text-[13px] font-semibold text-[var(--color-brand)]">Key Price Driver</th>
              </tr>
            </thead>
            <tbody>
              {[
                { name: 'Gold', cat: 'Precious Metal', ex: 'MCX', lot: '1 kg', driver: 'USD, inflation, central bank demand' },
                { name: 'Silver', cat: 'Precious Metal', ex: 'MCX', lot: '30 kg', driver: 'Industrial demand, USD, gold ratio' },
                { name: 'Crude Oil', cat: 'Energy', ex: 'MCX', lot: '100 bbl', driver: 'OPEC supply, USD, geopolitics' },
                { name: 'Natural Gas', cat: 'Energy', ex: 'MCX', lot: '1,250 mmBTU', driver: 'Weather, US inventory data' },
                { name: 'Copper', cat: 'Base Metal', ex: 'MCX', lot: '1,000 kg', driver: 'China demand, global manufacturing PMI' },
                { name: 'Zinc', cat: 'Base Metal', ex: 'MCX', lot: '5,000 kg', driver: 'Galvanizing demand, mining output' },
                { name: 'Soybean', cat: 'Agri', ex: 'NCDEX', lot: '10,000 kg', driver: 'Monsoon, MSP, global soy production' },
                { name: 'Chana (Chickpea)', cat: 'Agri', ex: 'NCDEX', lot: '5,000 kg', driver: 'Rabi crop output, government procurement' },
              ].map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[20px] py-[15px] font-semibold text-[var(--color-ink)]">{r.name}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[20px] py-[15px] text-[var(--color-muted)]">{r.cat}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[20px] py-[15px] font-medium text-[var(--color-dark-olive)]">{r.ex}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[20px] py-[15px] text-[var(--color-muted)]">{r.lot}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[20px] py-[15px] text-[var(--color-muted)]">{r.driver}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S4. WHY INVEST IN COMMODITIES? ═══════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Why <span class="text-[var(--color-brand)]">Invest in Commodities?</span> — Benefits
        </h2>
      </div>
      <div class="equity-reveal grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { title: 'Inflation Hedge', desc: 'Gold and silver preserve purchasing power during high-inflation periods.' },
          { title: 'Portfolio Diversification', desc: 'Commodities have low correlation with equities — reduce overall portfolio volatility.' },
          { title: 'Leverage Opportunities', desc: 'Trade large notional values with a fraction of capital via futures margin.' },
          { title: 'Global Demand Exposure', desc: 'Participate in global commodity cycles — China growth, energy transition, monsoon data.' },
        ].map(c => (
          <div class="product-card-light px-[28px] py-[32px]">
            <h3 class="mb-3 text-[17px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{c.title}</h3>
            <p class="text-[14px] leading-relaxed text-[var(--color-muted)]">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S5. HOW COMMODITY TRADING WORKS (MCX & NCDEX) ════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How <span class="text-[var(--color-brand)]">Commodity Trading</span> Works — MCX &amp; NCDEX
        </h2>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Feature</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">MCX</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">NCDEX</th>
              </tr>
            </thead>
            <tbody>
              {[
                { feature: 'Full Form', mcx: 'Multi Commodity Exchange', ncdex: 'National Commodity & Derivatives Exchange' },
                { feature: 'Focus', mcx: 'Metals (gold, silver, copper) & Energy (crude, natural gas)', ncdex: 'Agri commodities (soybean, chana, cotton)' },
                { feature: 'Settlement', mcx: 'Cash + physical delivery (gold, silver)', ncdex: 'Mostly physical delivery' },
                { feature: 'Trading Hours', mcx: '9 AM – 11:30 PM / 11:55 PM', ncdex: '9 AM – 5 PM' },
                { feature: 'Regulator', mcx: 'SEBI', ncdex: 'SEBI' },
              ].map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.feature}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.mcx}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.ncdex}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S6. COMMODITY FUTURES VS OPTIONS ══════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          <span class="text-[var(--color-brand)]">Commodity Futures vs Options</span> — Key Differences
        </h2>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Feature</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Commodity Futures</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Commodity Options</th>
              </tr>
            </thead>
            <tbody>
              {[
                { feature: 'Obligation', fut: 'Must buy/sell at expiry', opt: 'Right only (buyer)' },
                { feature: 'Premium', fut: 'No premium (margin-based)', opt: 'Buyer pays premium' },
                { feature: 'Max Loss', fut: 'Unlimited (MTM)', opt: 'Limited to premium (buyer)' },
                { feature: 'Leverage', fut: 'Higher', opt: 'Lower' },
                { feature: 'Use Case', fut: 'Price speculation, hedging', opt: 'Premium income, hedging' },
              ].map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.feature}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.fut}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.opt}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S7. HOW TO START — STEP BY STEP ══════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How to Start <span class="text-[var(--color-brand)]">Commodity Trading</span> — Step by Step
        </h2>
      </div>
      <div class="equity-reveal steps-grid overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        {[
          { n: '01', title: 'Open Trading Account', desc: 'Register with Shriram. Open Demat + Trading account digitally in 10 minutes.' },
          { n: '02', title: 'Activate Commodity Segment', desc: 'Request MCX/NCDEX segment activation. Submit KYC documents.' },
          { n: '03', title: 'Add Margin', desc: 'Transfer SPAN + Exposure margin. Margin varies by commodity and contract.' },
          { n: '04', title: 'Place Orders', desc: 'Select commodity, contract month, lot size, and execute buy/sell on MCX/NCDEX.' },
        ].map(s => (
          <div class="px-[30px] py-[34px]">
            <div class="mb-[22px] text-[34px] font-bold leading-none text-[var(--color-brand)]">{s.n}</div>
            <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">{s.title}</h4>
            <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S8. MARGIN, LOT SIZE & CHARGES ════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Commodity <span class="text-[var(--color-brand)]">Margin, Lot Size &amp; Charges</span>
        </h2>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Commodity</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Lot Size</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Approx SPAN Margin</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Brokerage</th>
              </tr>
            </thead>
            <tbody>
              {[
                { name: 'Gold (MCX)', lot: '1 kg', margin: '~₹70,000–₹90,000', brok: '₹20/order' },
                { name: 'Silver (MCX)', lot: '30 kg', margin: '~₹45,000–₹55,000', brok: '₹20/order' },
                { name: 'Crude Oil (MCX)', lot: '100 bbl', margin: '~₹30,000–₹40,000', brok: '₹20/order' },
                { name: 'Copper (MCX)', lot: '1,000 kg', margin: '~₹25,000–₹35,000', brok: '₹20/order' },
                { name: 'Soybean (NCDEX)', lot: '10,000 kg', margin: '~₹20,000–₹30,000', brok: '₹20/order' },
              ].map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.name}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.lot}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.margin}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.brok}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
      <p class="mt-4 text-[13px] text-[var(--color-muted)]">* Margin figures are approximate and change based on market volatility.</p>
    </div>
  </section>

  <!-- ══ S9. IS COMMODITY TRADING LEGAL? — SEBI RULES ════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Is <span class="text-[var(--color-brand)]">Commodity Trading Legal</span> in India? — SEBI Rules
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">
          Yes. Commodity trading in India is fully legal and regulated by SEBI since 2015.
        </p>
      </div>
      <div class="equity-reveal grid gap-5 sm:grid-cols-2">
        <div class="product-card-light px-[28px] py-[32px]">
          <h3 class="mb-3 text-[20px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">Legal (SEBI-regulated)</h3>
          <p class="text-[14px] leading-relaxed text-[var(--color-muted)]">Trading on SEBI-regulated exchanges MCX and NCDEX through registered brokers is 100% legal. Shriram holds SEBI registration INZ000002135 for commodities.</p>
        </div>
        <div class="product-card-light px-[28px] py-[32px]">
          <h3 class="mb-3 text-[20px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">Illegal (avoid)</h3>
          <p class="text-[14px] leading-relaxed text-[var(--color-muted)]">Unregulated online 'forex' platforms, bucket shops, and OTC commodity dealers without SEBI registration are illegal under FEMA and SCRA.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S10. TAXATION ON COMMODITY TRADING PROFITS ════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Taxation on <span class="text-[var(--color-brand)]">Commodity Trading</span> Profits
        </h2>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Transaction Type</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Tax Treatment</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">ITR Form</th>
              </tr>
            </thead>
            <tbody>
              {[
                { type: 'Non-agri commodity F&O', tax: 'Non-speculative business income', itr: 'ITR-3' },
                { type: 'Agri commodity F&O', tax: 'Speculative business income', itr: 'ITR-3' },
                { type: 'Physical delivery gains', tax: 'As per capital gains', itr: 'ITR-2 or ITR-3' },
                { type: 'Brokerage & charges', tax: 'Deductible as business expense', itr: 'ITR-3' },
              ].map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.type}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.tax}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.itr}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
      <p class="mt-4 text-[13px] text-[var(--color-muted)]">Consult a CA for your specific tax situation.</p>
    </div>
  </section>

  <!-- ══ S11. COMMODITY TRADING STRATEGIES FOR BEGINNERS ═══════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          <span class="text-[var(--color-brand)]">Commodity Trading Strategies</span> for Beginners
        </h2>
      </div>
