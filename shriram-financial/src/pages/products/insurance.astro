---
import BaseLayout from '../../layouts/BaseLayout.astro';

const insuranceTypes = [
  { label: 'Term Life Insurance', desc: 'Pure life cover for a fixed term — the nominee receives the sum assured on death. No maturity benefit, but the highest cover at the lowest premium.', highlight: 'Highest cover at lowest premium' },
  { label: 'Health Insurance', desc: 'Covers hospitalisation, surgery, ICU, daycare, and pre/post-hospitalisation costs. Shields your savings from catastrophic medical bills.', highlight: 'Cashless treatment at 10,000+ hospitals' },
  { label: 'Motor Insurance', desc: 'Mandatory third-party cover for all vehicles in India. Comprehensive plans add own-damage, theft, and natural-calamity protection.', highlight: 'Mandatory by law (third-party)' },
  { label: 'ULIP', desc: 'Unit Linked Insurance Plan — part of the premium provides life cover, and the remainder invests in market-linked equity or debt funds.', highlight: 'Insurance + investment in one' },
];

const whyInsure = [
  { label: 'Protect Your Family', desc: 'Life cover ensures your family can maintain their lifestyle, repay home loans, and fund children\'s education — even in your absence.' },
  { label: 'Shield Against Medical Costs', desc: 'One hospitalisation can cost ₹2–10 lakh. Health insurance prevents a medical emergency from wiping out your savings and investments.' },
  { label: 'Save on Tax', desc: 'Life insurance premiums get ₹1.5 lakh deduction under 80C. Health premiums get up to ₹50,000 under 80D for senior citizens.' },
  { label: 'Mandatory Compliance', desc: 'Motor third-party insurance is legally required for every vehicle. Lapsed cover means fines and personal liability in accidents.' },
];

const steps = [
  { n: '1', title: 'Assess Your Needs', desc: 'Determine the type and quantum of cover needed. Use our calculators: HLV (Human Life Value) for life insurance, sum-insured calculator for health.' },
  { n: '2', title: 'Compare Plans', desc: 'Compare premiums, features, claim settlement ratios, and network hospitals across multiple insurers on the Shriram platform.' },
  { n: '3', title: 'Apply & Undergo Medical Tests', desc: 'Fill the proposal form digitally. For higher life covers, an insurer-appointed doctor may conduct a medical examination.' },
  { n: '4', title: 'Receive Policy Document', desc: 'Once underwriting is complete and premium is paid, your policy is issued digitally. Claim support is provided by Shriram\'s insurance team.' },
];

const faqs = [
  { q: 'How much life insurance cover do I need?', a: 'A standard benchmark is 10–15x your annual income. Factor in home loan balances, children\'s education costs, and your spouse\'s income gap. Use Shriram\'s HLV calculator for a precise figure.' },
  { q: 'What is the difference between a cashless and reimbursement health claim?', a: 'Cashless claims are settled directly between your insurer and a network hospital — you pay nothing upfront. Reimbursement claims require you to pay the bill first and apply for a refund; used for non-network hospitals.' },
  { q: 'Does health insurance cover pre-existing diseases?', a: 'Most plans have a 2–4 year waiting period for pre-existing diseases. After the waiting period, they are covered. Always disclose PEDs accurately — non-disclosure leads to claim rejection.' },
  { q: 'Is it better to buy a term plan or an endowment plan?', a: 'Term plans deliver more cover per rupee. Endowment and ULIP returns often trail a term plan + mutual fund combination. Most advisors recommend "buy term, invest the rest" for optimal outcomes.' },
  { q: 'What is the claim settlement ratio (CSR) and why does it matter?', a: 'CSR is the percentage of claims settled by an insurer in a year. IRDAI publishes it annually. Above 97% signals reliability — Shriram recommends only partners with strong CSR track records.' },
];
---

<BaseLayout
  title="Insurance Plans India — Term Life, Health & ULIP | Shriram"
  description="Compare term life insurance, health insurance, motor, and ULIP plans in India from top IRDAI-regulated insurers. Expert advisory, fast digital application. Get covered today."
>

  <!-- ══ 1. HERO ══════════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-inner">
      <h1>Best <span class="g">Insurance Plans in India</span> — Term, Health &amp; More</h1>
      <p class="lead">Compare term life, health, motor and ULIP insurance plans from India's leading insurers — with expert advisory, easy digital application and dedicated claims support from Shriram.</p>
      <div class="cta"><a class="btn-gold" href="/about/support/">Explore Insurance Plans</a></div>
      <div class="hero-feats">
        <div class="feats">
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;Multiple insurers</span></div>
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;IRDAI-regulated</span></div>
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;Tax benefits (80C, 80D)</span></div>
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;Claims assistance</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 2. INSURANCE PRODUCTS ════════════════════════════════════════ -->
  <section class="section stack" id="sec-products" style="background:var(--sec-light);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Insurance Products We Offer</h2>
      <p class="sec-lead">We partner with India's leading IRDAI-regulated insurers to offer comprehensive coverage for every stage of life — from pure protection plans to wealth-building ULIPs, all in one place.</p>
    </div>
    <div class="stack" style="gap:32px">
      <div class="row-2">
        {insuranceTypes.slice(0, 2).map(t => (
          <div class="card">
            <h4 class="card-h">{t.label}</h4>
            <p class="card-p">{t.desc}</p>
            <p style="font-weight:500;font-size:14px;color:var(--gold);line-height:1.5;margin-top:auto">{t.highlight}</p>
          </div>
        ))}
      </div>
      <div class="row-2">
        {insuranceTypes.slice(2).map(t => (
          <div class="card">
            <h4 class="card-h">{t.label}</h4>
            <p class="card-p">{t.desc}</p>
            <p style="font-weight:500;font-size:14px;color:var(--gold);line-height:1.5;margin-top:auto">{t.highlight}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 3. WHY YOU NEED INSURANCE ════════════════════════════════════ -->
  <section class="section stack" id="sec-why" style="background:var(--sec-tint);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Why You Need Insurance</h2>
      <p class="sec-lead">Insurance is the foundation of any sound financial plan — before investments, before savings.</p>
    </div>
    <div class="risks">
      {whyInsure.map(w => (
        <div class="risk">
          <h4>{w.label}</h4>
          <p>{w.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ══ 4. HOW TO BUY ════════════════════════════════════════════════ -->
  <section class="section stack" id="sec-how" style="background:var(--sec-light);gap:56px;align-items:center;justify-content:center">
    <div class="stack" style="gap:16px;width:100%">
      <h2 class="sec-title">How to Choose &amp; Buy Insurance</h2>
      <p class="sec-lead">Four steps from assessing your needs to receiving your policy document.</p>
    </div>
    <div class="steps">
      {steps.map((s, i) => (
        <>
          {i > 0 && <div class="step-div"></div>}
          <div class="step">
            <div class="num">{s.n}</div>
            <div class="st-body">
              <h4>{s.title}</h4>
              <p>{s.desc}</p>
            </div>
          </div>
        </>
      ))}
    </div>
    <a class="btn-gold" href="/about/support/" style="align-self:center">Talk to an Advisor</a>
  </section>

  <!-- ══ 5. GENERAL QUESTIONS (FAQ) ═══════════════════════════════════ -->
  <section class="faq-wrap" id="sec-faq" style="background:var(--sec-tint)">
    <div class="faq-cols">
      <div class="faq-left">
        <h2 class="faq-title">General Questions</h2>
        <div class="faq-acc">
          {faqs.map((item, i) => (
            <div class={`faq-item${i === 0 ? ' open' : ''}`}>
              <button class="faq-q" type="button">
                <span class="qt">{item.q}</span>
                <span class="faq-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none">
                    <line class="v" x1="12" y1="5" x2="12" y2="19" stroke="#404040" stroke-width="2" stroke-linecap="round"/>
                    <line x1="5" y1="12" x2="19" y2="12" stroke="#404040" stroke-width="2" stroke-linecap="round"/>
                  </svg>
                </span>
              </button>
              <div class="qa-wrap">
                <div class="qa"><p>{item.a}</p></div>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="faq-side">
        <div class="usr" aria-hidden="true">
          <svg viewBox="0 0 128 144" fill="none" xmlns="http://www.w3.org/2000/svg" width="128" height="144">
            <circle cx="64" cy="48" r="32" stroke="#2d3813" stroke-width="2"/>
            <path d="M8 144c0-30.928 25.072-56 56-56s56 25.072 56 56" stroke="#2d3813" stroke-width="2"/>
          </svg>
        </div>
        <div class="side-in">
          <div class="side-tx">
            <h3>Need A Clearer Direction?</h3>
            <p>Let's get in touch on a 15-minute call where we can answer any questions you may have. Our advisor will help map your protection needs and recommend the right cover for your family.</p>
          </div>
          <a class="btn-gold" href="/about/support/">Book A Discovery Call</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 6. FINAL CTA ═════════════════════════════════════════════════ -->
  <section class="cta-sec" id="sec-final-cta" style="background:var(--sec-light)">
    <div class="cta-box">
      <div class="ct-tt">
        <h3>Protect Your Family's Future Today</h3>
        <p class="ct-sub">Compare India's best insurance plans and get expert guidance — fast application, transparent pricing, dedicated claims support.</p>
      </div>
      <a class="btn-gold" href="/about/support/">Get Covered</a>
    </div>
  </section>

</BaseLayout>

<script>
  /* FAQ button accordion — one open at a time */
  document.querySelectorAll('.faq-acc').forEach(acc => {
    acc.querySelectorAll('.faq-item').forEach(item => {
      const btn = item.querySelector('.faq-q');
      if (!btn) return;
      btn.addEventListener('click', () => {
        const isOpen = item.classList.contains('open');
        acc.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
        if (!isOpen) item.classList.add('open');
      });
    });
  });
</script>
