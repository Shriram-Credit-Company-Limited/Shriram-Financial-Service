---
import BaseLayout from '../../layouts/BaseLayout.astro';

const equityTypes = [
  {
    label: 'Common Equity Shares',
    desc: 'These are the most widely traded shares. Investors receive voting rights and participate in profits through dividends and price appreciation. Value stocks focus on capital appreciation. Blue-chip stocks represent large, stable companies. Penny stocks are low-priced, high-risk shares.',
  },
  {
    label: 'Preferred Equity Shares',
    desc: 'Preferred shareholders receive preference in dividend payments over common shareholders. However, these shares generally carry limited voting rights and trade at lower volatility.',
  },
];

const eligibility = [
  'Indian resident (100%) or minor if guardian opens the account',
  'Valid PAN Card mandatory for all account holders',
  'Valid KYC as per SEBI regulations for legal entities',
  'For NRI: RBI-approved broker and NRE/NRO bank account required',
  'Age 18+ years for independent account opening',
  'For minors, guardian\'s PAN and signature are required',
];

const documents = [
  'PAN Card / Form 60 (for NRI accounts)',
  'Address Proof — Aadhaar / Passport / Driver\'s Licence / Utility Bill',
  'Bank Account Details — cancelled cheque or latest bank statement',
  'Passport-size photograph (JPEG format)',
];

const steps = [
  { n: '01', title: 'Open Demat + Trading Account', desc: 'Register digitally on the Shriram platform. Link your existing Demat account or open a new one — fully paperless.' },
  { n: '02', title: 'Complete PAN / KYC / Bank Linking', desc: 'Submit your PAN, complete e-KYC via Aadhaar OTP, and link your bank account for instant fund transfers.' },
  { n: '03', title: 'Search and Analyse Stocks', desc: 'Use our research desk, stock screener, and SEBI-registered analyst recommendations to shortlist stocks.' },
  { n: '04', title: 'Buy, Hold, Sell & Track', desc: 'Place orders on NSE or BSE, monitor real-time P&L, and manage your portfolio via the Antara app.' },
];

const brokerageRows = [
  { label: 'Brokerage', delivery: '₹0 (Zero)', intraday: '₹20 per executed order' },
  { label: 'STT', delivery: '0.1% on sell side', intraday: '0.025% on buy & sell side' },
  { label: 'GST', delivery: '18% on brokerage + exchange charges', intraday: '18% on brokerage + exchange charges' },
  { label: 'DP Charges', delivery: '₹15.93 per scrip on sell', intraday: 'N/A' },
  { label: 'Exchange Charges', delivery: '0.00345% (NSE) / 0.00375% (BSE)', intraday: '0.00345% (NSE) / 0.00375% (BSE)' },
];

const taxRows = [
  { feature: 'Holding Period', stcg: 'Up to 12 months', ltcg: 'More than 12 months' },
  { feature: 'Tax Rate', stcg: '20% Flat', ltcg: '12.5%' },
  { feature: 'Tax-Free Limit', stcg: 'Nil (taxed from ₹1)', ltcg: 'Up to ₹1.25 Lakh per year' },
  { feature: 'Indexation Benefit', stcg: 'Not Applicable', ltcg: 'Not Applicable' },
  { feature: 'Applicable Section', stcg: 'Section 70A', ltcg: 'Section 70A' },
];

const categories = [
  { label: 'Large Cap', desc: 'Top 100 companies by market cap. Stable, low-risk, ideal for long-term wealth building.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><circle cx="12" cy="12" r="9"/><path d="M9 9.5h1.5a1.5 1.5 0 0 1 0 3H9v3m3-6v6"/></svg>` },
  { label: 'Mid Cap', desc: 'Companies ranked 101–250 by market cap. Balanced risk and growth potential.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M3 3v18h18"/><path d="m7 16 4-4 4 4 4-4"/></svg>` },
  { label: 'Small Cap', desc: 'Companies beyond 250 in market cap ranking. High growth potential with higher volatility.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M3 3v18h18"/><path d="m7 12 4-4 4 4 4-4"/></svg>` },
  { label: 'Blue Chip', desc: 'Established, financially sound companies with a history of reliable performance.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>` },
  { label: 'Growth Stocks', desc: 'Companies expected to grow faster than the market. Higher valuations, reinvest profits.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M7 17l9.2-9.2M17 17V7H7"/></svg>` },
  { label: 'Dividend Stocks', desc: 'Companies that regularly distribute profits as dividends. Ideal for passive income.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 3H8L2 7h20l-6-4zM12 12v4M10 14h4"/></svg>` },
  { label: 'Value Stocks', desc: 'Undervalued companies trading below intrinsic value. Suitable for patient investors.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 1 0 0 7h5a3.5 3.5 0 1 1 0 7H6"/></svg>` },
  { label: 'Penny Stocks', desc: 'Low-priced, small company shares. High risk and high reward — for experienced traders only.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 3"/></svg>` },
];

const research = [
  {
    title: 'Fundamental Research',
    desc: 'In-depth company analysis, financial modelling, and valuation reports to help you pick stocks with strong long-term potential.',
    href: '/research/',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="#202318" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 shrink-0"><path d="M3 3v18h18"/><path d="m7 16 4-4 4 4 4-4"/></svg>`,
  },
  {
    title: 'Technical Research',
    desc: 'Chart patterns, price action, and technical indicators to identify optimal entry and exit points for your trades.',
    href: '/research/',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="#202318" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 shrink-0"><rect x="3" y="3" width="4" height="18"/><rect x="10" y="8" width="4" height="13"/><rect x="17" y="5" width="4" height="16"/></svg>`,
  },
];

const strategies = [
  { label: 'Intraday Trading', tools: 'Charts, screeners, real-time data', profitability: 'High (with skill)', time: 'Full-time (market hours)', skill: 'Advanced', capital: 'Moderate', risk: 'Very High' },
  { label: 'Swing Trading', tools: 'Technical analysis, alerts', profitability: 'Medium–High', time: 'Part-time (daily review)', skill: 'Intermediate', capital: 'Moderate', risk: 'Medium–High' },
  { label: 'Long-Term Investing', tools: 'Fundamental research, SIP', profitability: 'High (long horizon)', time: 'Minimal (periodic review)', skill: 'Beginner–Intermediate', capital: 'Low to High', risk: 'Low–Medium' },
];

const vsRows = [
  { feature: 'Control', equity: 'Full control over stock selection', mf: 'Fund manager decides' },
  { feature: 'Returns', equity: 'Potentially higher (and lower)', mf: 'Moderate, diversified' },
  { feature: 'Risk', equity: 'Higher (concentrated positions)', mf: 'Lower (diversified)' },
  { feature: 'Minimum Investment', equity: '1 share (can be < ₹10)', mf: '₹500 (SIP)' },
  { feature: 'Taxation', equity: 'STCG 20% / LTCG 12.5%', mf: 'Equity MF: same as equity' },
  { feature: 'Liquidity', equity: 'Instant (exchange hours)', mf: 'T+1 to T+3 redemption' },
  { feature: 'Transparency', equity: 'Real-time price discovery', mf: 'NAV declared daily' },
  { feature: 'Expertise Required', equity: 'Medium to High', mf: 'Low (passive investing)' },
];

const risks = [
  { label: 'Market Risk', desc: 'Broad market downturns due to economic events, interest rate changes, or geopolitical developments can affect all stocks regardless of company performance.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6"><path d="m3 3 18 18M3 12c0 5 3.6 9 9 9s9-4 9-9"/><path d="M12 3a9 9 0 0 1 9 9"/></svg>` },
  { label: 'Volatility', desc: 'Stock prices can swing sharply in the short term, creating paper losses even for sound investments. Emotional decision-making during dips can crystallise losses.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>` },
  { label: 'Stock-Specific Risk', desc: 'Individual companies can face fraud, management issues, regulatory action, or business model failure. Concentration in a single stock amplifies this risk significantly.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6"><circle cx="12" cy="12" r="9"/><path d="M12 8v4M12 16h.01"/></svg>` },
  { label: 'Behavioural Risk', desc: 'FOMO buying at peaks, panic selling at lows, and overtrading due to news noise are among the most common causes of poor equity returns for retail investors.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>` },
];

const faqs = [
  { q: 'What is the difference between large cap, mid cap, and small cap stocks?', a: 'Large cap stocks are the top 100 companies by market capitalisation — stable and lower risk. Mid cap stocks (rank 101–250) offer a balance of growth and stability. Small cap stocks (rank 251+) are smaller companies with higher growth potential but also higher volatility and risk.' },
  { q: 'What is the safest platform to invest in equity?', a: 'SEBI-registered brokers are the safest option. Shriram Financial Services is a SEBI-registered stockbroker (member of NSE & BSE). Your shares are held in your Demat account with CDSL — a government-regulated depository — and your funds are kept in a segregated client account, never commingled with company funds.' },
  { q: 'Should I invest in equity or mutual funds?', a: 'It depends on your expertise, time availability, and risk appetite. If you want control and can research stocks yourself (or have access to expert advisory like Shriram\'s SEBI-registered research desk), direct equity can deliver higher returns. Mutual funds are better for passive investors who prefer professional fund management with diversification built in.' },
  { q: 'How do I calculate a full breakdown of equity investment returns?', a: 'Your net return = (Sell Value − Buy Value) − (Brokerage + STT + GST + DP Charges + Exchange Charges) − Tax (STCG at 20% or LTCG at 12.5% depending on holding period). Use our Brokerage Calculator on this page for an instant estimate before placing any order.' },
  { q: 'What is a Demat account and do I need one for equity investing?', a: 'A Demat (Dematerialised) account is a digital account that holds your shares in electronic form, replacing physical share certificates. Yes, a Demat account linked with a trading account is mandatory for buying and selling shares on Indian stock exchanges. Shriram Financial Services helps you open both in under 10 minutes, completely paperless.' },
  { q: 'What is the minimum amount needed to start equity investing?', a: 'There is no regulatory minimum. You can start with as little as the price of a single share — many quality blue-chip stocks are available for under ₹500. Shriram Financial Services offers zero delivery brokerage, so there are no additional costs for buy-and-hold investing.' },
];
---

<BaseLayout
  title="Equity Trading — Build Wealth Through Stocks | Shriram Financial Services"
  description="Buy and invest in equity stocks in India with zero delivery brokerage, live market data, SEBI-registered research, and expert-backed advisory from Shriram Financial Services."
>

  <!-- ══ 1. HERO ═══════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[var(--color-dark-800)]">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[560px] w-[560px] rounded-full bg-[var(--color-brand)]/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-32 left-0 h-80 w-80 rounded-full bg-[var(--color-brand)]/5 blur-3xl"></div>
    <div class="site-wrap relative py-16 lg:py-28">
      <p class="reveal reveal-1 text-[11px] font-bold uppercase tracking-widest text-[var(--color-brand)]">Equity Investing</p>
      <h1 class="reveal reveal-2 mt-4 max-w-3xl text-[32px] font-bold leading-tight text-white sm:text-[40px] lg:text-[56px]" style="font-family:var(--font-display)">
        Build Long-Term Wealth<br class="hidden sm:block"> Through Equity Investing
      </h1>
      <p class="reveal reveal-3 mt-5 max-w-2xl text-[15px] leading-relaxed text-white/60 lg:text-[17px]">
        Buy and invest in equity stocks in India with live market data, deep research insights, stock analysis tools, and expert-backed guidance from Shriram Financial Services.
      </p>
      <div class="reveal reveal-3 mt-7 grid grid-cols-2 gap-x-6 gap-y-3 sm:flex sm:gap-8">
        {[
          { label: 'SEBI-registered', icon: `<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" class="h-4 w-4"><circle cx="8" cy="8" r="6"/><path d="M5 8l2 2 4-4"/></svg>` },
          { label: 'Full-service',    icon: `<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" class="h-4 w-4"><path d="M2 12l6-8 6 8"/><path d="M5 9h6"/></svg>` },
          { label: 'Research-led',    icon: `<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" class="h-4 w-4"><circle cx="7" cy="7" r="4"/><path d="m12 12-2.5-2.5"/></svg>` },
          { label: 'Transparent',     icon: `<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" class="h-4 w-4"><rect x="2" y="2" width="12" height="12" rx="2"/><path d="M5 8h6M8 5v6"/></svg>` },
        ].map(b => (
          <div class="flex items-center gap-2 text-[13px] font-medium text-white/70">
            <span class="text-[var(--color-brand)]" set:html={b.icon} />{b.label}
          </div>
        ))}
      </div>
      <div class="reveal reveal-4 mt-9 flex flex-wrap gap-3">
        <a href="/about/open-demat-account/" class="btn-primary">Open Demat Account</a>
        <a href="/about/support/" class="inline-flex h-12 w-[220px] items-center justify-center rounded-[6px] border border-white/25 text-[14px] font-medium text-white transition-colors hover:bg-white/10">Talk to RM</a>
      </div>
    </div>
  </section>

  <!-- ══ 2. WHAT ARE EQUITY STOCKS ════════════════════════════════ -->
  <section class="bg-white py-16 lg:py-24">
    <div class="site-wrap">
      <div class="equity-reveal">
        <p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-brand)]">The Basics</p>
        <h2 class="mt-3 text-[28px] font-bold text-[var(--color-ink)] lg:text-[38px]" style="font-family:var(--font-display)">What Are Equity Stocks</h2>
        <div class="mt-6 max-w-3xl space-y-4 text-[15px] leading-relaxed text-[var(--color-muted)] lg:text-[16px]">
          <p>Equity stocks, also known as shares, represent ownership in a company. When you purchase equity shares, you become a partial owner of that company and gain rights to a portion of its assets and earnings.</p>
          <p>In India, equity shares are traded on two major exchanges: the National Stock Exchange (NSE) and the Bombay Stock Exchange (BSE). All trading activities are regulated by the Securities and Exchange Board of India (SEBI) to protect investor interests.</p>
        </div>
      </div>

      <!-- Types of Equity Stocks -->
      <div class="equity-reveal mt-12">
        <h3 class="mb-6 text-[20px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">Types of Equity Stocks</h3>
        <div class="grid gap-5 sm:grid-cols-2">
          {equityTypes.map((t, i) => (
            <div class="product-card-light p-7">
              <h4 class="text-[17px] font-bold text-[var(--color-dark-olive)]" style="font-family:var(--font-display)">{t.label}</h4>
              <p class="mt-3 text-[14px] leading-relaxed text-[var(--color-muted)]">{t.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 3. HOW STOCK MARKET WORKS IN INDIA ════════════════════════ -->
  <section class="bg-[#f8f6f1] py-16 lg:py-24">
    <div class="site-wrap">
      <div class="equity-reveal">
        <p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-brand)]">Market Structure</p>
        <h2 class="mt-3 text-[28px] font-bold text-[var(--color-ink)] lg:text-[38px]" style="font-family:var(--font-display)">How Stock Market Works in India</h2>
        <p class="mt-4 max-w-3xl text-[15px] leading-relaxed text-[var(--color-muted)] lg:text-[16px]">
          The stock market in India functions through exchanges like the NSE (National Stock Exchange) and BSE (Bombay Stock Exchange). These platforms connect buyers and sellers of shares in a transparent, regulated environment.
        </p>
      </div>
      <div class="equity-reveal mt-10 grid gap-5 sm:grid-cols-2">
        <div class="product-card-light p-8">
          <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-[10px] bg-[var(--color-dark-olive)]">
            <span class="text-[13px] font-bold text-[var(--color-brand)]">NSE</span>
          </div>
          <h3 class="text-[17px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">National Stock Exchange (NSE)</h3>
          <p class="mt-3 text-[14px] leading-relaxed text-[var(--color-muted)]">Founded in 1992, India's largest stock exchange by trading volume. Known for its technology-driven infrastructure, the NSE operates the NIFTY 50 index and offers electronic trading in equities, derivatives, currency, and debt instruments with high speed and transparency.</p>
        </div>
        <div class="product-card-light p-8">
          <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-[10px] bg-[var(--color-dark-olive)]">
            <span class="text-[13px] font-bold text-[var(--color-brand)]">BSE</span>
          </div>
          <h3 class="text-[17px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">Bombay Stock Exchange (BSE)</h3>
          <p class="mt-3 text-[14px] leading-relaxed text-[var(--color-muted)]">Established in 1875, Asia's oldest stock exchange. The BSE lists over 5,000 companies and operates the SENSEX index, tracking the top 30 companies. It serves as the primary exchange for large-cap listed companies and institutional investors across India.</p>
        </div>
      </div>
      <div class="equity-reveal mt-8 text-center">
        <a href="/about/open-demat-account/" class="inline-flex h-12 w-[220px] items-center justify-center rounded-[6px] bg-[var(--color-dark-olive)] text-[14px] font-semibold text-white transition-colors hover:bg-[#1a2010]">Open Demat Account</a>
      </div>
    </div>
  </section>

  <!-- ══ 4. ELIGIBILITY & DOCUMENTS ════════════════════════════════ -->
  <section class="bg-white py-16 lg:py-24">
    <div class="site-wrap">
      <div class="equity-reveal">
        <p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-brand)]">Requirements</p>
        <h2 class="mt-3 text-[28px] font-bold text-[var(--color-ink)] lg:text-[38px]" style="font-family:var(--font-display)">Eligibility &amp; Documents Required</h2>
        <p class="mt-3 text-[15px] text-[var(--color-muted)]">Check the eligibility and the documents required for starting your equity journey.</p>
      </div>
      <div class="equity-reveal mt-10 grid gap-6 sm:grid-cols-2">
        <!-- Eligibility -->
        <div class="rounded-[20px] border border-[var(--color-warm-border)] bg-[#f8f6f1] p-8">
          <div class="mb-5 flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-[var(--color-dark-olive)]">
              <svg viewBox="0 0 20 20" fill="none" stroke="var(--color-brand)" stroke-width="1.8" class="h-5 w-5"><circle cx="10" cy="10" r="8"/><path d="M7 10l2 2 4-4"/></svg>
            </div>
            <h3 class="text-[17px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">Eligibility Criteria</h3>
          </div>
          <ul class="space-y-3">
            {eligibility.map(item => (
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-[var(--color-brand)]/20">
                  <svg viewBox="0 0 12 12" fill="none" stroke="var(--color-brand-deep)" stroke-width="2" class="h-3 w-3"><path d="M2 6l3 3 5-5"/></svg>
                </span>
                <span class="text-[13px] leading-snug text-[var(--color-ink)]">{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <!-- Documents -->
        <div class="rounded-[20px] border border-[var(--color-warm-border)] bg-[#f8f6f1] p-8">
          <div class="mb-5 flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-[var(--color-dark-olive)]">
              <svg viewBox="0 0 20 20" fill="none" stroke="var(--color-brand)" stroke-width="1.8" class="h-5 w-5"><rect x="4" y="2" width="12" height="16" rx="2"/><path d="M8 7h4M8 11h4M8 15h2"/></svg>
            </div>
            <h3 class="text-[17px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">Documents Required</h3>
          </div>
          <ul class="space-y-3">
            {documents.map(item => (
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-[var(--color-brand)]/20">
                  <svg viewBox="0 0 12 12" fill="none" stroke="var(--color-brand-deep)" stroke-width="2" class="h-3 w-3"><path d="M2 6l3 3 5-5"/></svg>
                </span>
                <span class="text-[13px] leading-snug text-[var(--color-ink)]">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 5. HOW TO START INVESTING ════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-16 lg:py-24">
    <div class="site-wrap">
      <div class="equity-reveal text-center">
        <p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-brand)]">Getting Started</p>
        <h2 class="mt-3 text-[28px] font-bold text-[var(--color-ink)] lg:text-[38px]" style="font-family:var(--font-display)">How to Start Investing</h2>
      </div>
      <div class="equity-reveal mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {steps.map((s, i) => (
          <div class="relative flex flex-col gap-4 rounded-[20px] border border-[var(--color-warm-border)] bg-white p-7" style={`animation-delay:${i*60}ms`}>
            <span class="flex h-10 w-10 items-center justify-center rounded-full bg-[var(--color-dark-olive)] text-[13px] font-bold text-[var(--color-brand)]">{s.n}</span>
            {i < steps.length - 1 && <span class="absolute -right-3 top-9 hidden h-5 w-5 items-center justify-center lg:flex"><svg viewBox="0 0 12 12" fill="none" stroke="var(--color-brand)" stroke-width="2" class="h-3 w-3"><path d="M2 6h8M6 2l4 4-4 4"/></svg></span>}
            <h3 class="text-[15px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{s.title}</h3>
            <p class="text-[13px] leading-relaxed text-[var(--color-muted)]">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 6. BROKERAGE & CHARGES ════════════════════════════════════ -->
  <section class="bg-white py-16 lg:py-24">
    <div class="site-wrap">
      <div class="equity-reveal">
        <p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-brand)]">Costs</p>
