  /* ── Category grid ───────────────────────────────────────────────── */
  .cat-grid {
    border: 1px solid var(--card-border);
    border-radius: 24px;
    overflow: hidden;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    background: var(--card);
  }
  .cat {
    background: var(--card);
    padding: var(--container-pad);
    display: flex;
    flex-direction: column;
    gap: 12px;
