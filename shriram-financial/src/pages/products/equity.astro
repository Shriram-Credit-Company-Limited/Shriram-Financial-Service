---
import BaseLayout from '../../layouts/BaseLayout.astro';

const equityTypes = [
  {
    label: 'Common Equity Shares',
    desc: 'The most widely traded shares. Investors receive voting rights and participate in the company\'s profits through dividends and price appreciation.',
  },
  {
    label: 'Preferred Equity Shares',
    desc: 'Preferred shareholders receive preference in dividend payments over common shareholders. These shares generally carry limited or no voting rights.',
  },
];

const eligibility = [
  'Indian resident (NRIs can invest through specific routes)',
  'Valid PAN card mandatory for all account holders',
  'Active bank account in your name',
  'Completed KYC verification as per SEBI regulations',
  '18+ years of age (minors can invest through guardians)',
];

const documents = [
  'PAN card (mandatory)',
  'Aadhaar card for identity verification',
  'Address proof — Aadhaar, Passport, or Utility Bill',
  'Cancelled cheque or recent bank statement',
  'Passport-size photograph (JPEG format)',
  'Valid mobile number and email ID',
];

const steps = [
  { n: '01', title: 'Open Demat + Trading Account', desc: 'Register digitally on the Shriram platform. Link your existing Demat account or open a new one — fully paperless.' },
  { n: '02', title: 'Complete PAN / KYC / Bank Linking', desc: 'Submit your PAN, complete e-KYC via Aadhaar OTP, and link your bank account for instant fund transfers.' },
  { n: '03', title: 'Search and Analyse Stocks', desc: 'Use our research desk, stock screener, and SEBI-registered analyst recommendations to shortlist stocks.' },
  { n: '04', title: 'Buy, Hold, Sell & Track', desc: 'Place orders on NSE or BSE, monitor real-time P&L, and manage your portfolio via the Antara app.' },
];

const brokerageRows = [
  { label: 'Brokerage', delivery: '₹0 (Zero)', intraday: '₹20 per executed order', fo: '₹20 per executed order' },
  { label: 'STT', delivery: '0.1% on sell side', intraday: '0.025% on buy & sell side', fo: '0.02% on sell side' },
  { label: 'GST', delivery: '18% on brokerage + exchange charges', intraday: '18% on brokerage + exchange charges', fo: '18% on brokerage + exchange charges' },
  { label: 'DP Charges', delivery: '₹15.93 per scrip on sell', intraday: 'N/A', fo: 'N/A' },
  { label: 'Exchange Charges', delivery: '0.00345% (NSE) / 0.00375% (BSE)', intraday: '0.00345% (NSE) / 0.00375% (BSE)', fo: '0.002%' },
];

const taxRows = [
  { feature: 'Holding Period', stcg: 'Up to 12 months', ltcg: 'More than 12 months' },
  { feature: 'Tax Rate', stcg: '20% Flat', ltcg: '12.5%' },
  { feature: 'Tax-Free Limit', stcg: 'Nil (taxed from ₹1)', ltcg: 'Up to ₹1.25 Lakh per year' },
  { feature: 'Indexation Benefit', stcg: 'Not Applicable', ltcg: 'Not Applicable' },
  { feature: 'Applicable Section', stcg: 'Section 111A', ltcg: 'Section 112A' },
];

const categories = [
  { label: 'Large Cap',      desc: 'Top 100 companies by market cap — stable and lower risk.' },
  { label: 'Mid Cap',        desc: 'Companies ranked 101–250 — a balance of growth and stability.' },
  { label: 'Small Cap',      desc: 'Companies ranked beyond 250 — higher growth potential with higher risk.' },
  { label: 'Growth Stocks',  desc: 'Companies expected to grow earnings faster than the broader market.' },
  { label: 'Dividend Stocks',desc: 'Companies that share regular profits with shareholders as dividends.' },
  { label: 'Value Stocks',   desc: 'Stocks trading below their intrinsic worth — potentially undervalued.' },
  { label: 'Blue Chip',      desc: 'Well-established, financially sound market leaders with a strong record.' },
  { label: 'Cyclical Stocks',desc: 'Stocks whose performance moves in line with broader economic cycles.' },
];

const research = [
  {
    title: 'Fundamental Research',
    idx: 'Approach 01',
    desc: 'In-depth company analysis, financial modelling and valuation reports to assess a stock\'s true intrinsic worth.',
    href: '/research/',
  },
  {
    title: 'Technical Research',
    idx: 'Approach 02',
    desc: 'Chart patterns, price action and technical indicators to time entries and exits with greater precision.',
    href: '/research/',
  },
];

const strategyRows = [
  { label: 'Holding Period',    intraday: 'Same day (square-off before close)', swing: '2 days to a few weeks', lt: '1+ years (often 5–10+ years)' },
  { label: 'Time Commitment',   intraday: 'High — active monitoring', swing: 'Moderate — daily/weekly check', lt: 'Low — periodic review' },
  { label: 'Capital Required',  intraday: 'Lower entry, margin common', swing: 'Moderate', lt: 'Can start small via SIP (₹500+)' },
  { label: 'Risk Level',        intraday: 'Very High', swing: 'High', lt: 'Moderate to Low' },
];

const vsRows = [
  { feature: 'Control',              equity: 'Direct ownership and control', mf: 'Fund manager decides' },
  { feature: 'Risk',                 equity: 'Company-specific risk', mf: 'Diversified risk' },
  { feature: 'Return Potential',     equity: 'Potentially higher (unlimited upside)', mf: 'Market-linked returns' },
  { feature: 'Research Involvement', equity: 'Active research needed', mf: 'Professional management' },
  { feature: 'Suitable For',         equity: 'Knowledgeable investors', mf: 'All investor types' },
  { feature: 'Cost',                 equity: 'Brokerage per trade', mf: 'Expense ratio annually' },
  { feature: 'Liquidity',            equity: 'Real-time during market hours', mf: 'End-of-day NAV' },
  { feature: 'Management',           equity: 'Self-managed portfolio', mf: 'Professionally managed' },
];

const risks = [
  { n: '01', label: 'Market Risk',       desc: 'Broad market movements can affect all stocks due to economic events, policy changes or global sentiment.' },
  { n: '02', label: 'Volatility',        desc: 'Prices can fluctuate significantly within short periods, testing investor discipline and patience.' },
  { n: '03', label: 'Stock-Specific Risk', desc: 'Company-specific factors such as poor earnings or governance issues can impact a single stock sharply.' },
  { n: '04', label: 'Behavioural Risk',  desc: 'Emotional decisions driven by fear or greed can lead to poor timing and avoidable losses.' },
];

const faqs = [
  { q: 'What is the difference between large-cap, mid-cap and small-cap stocks?', a: 'Large-cap stocks are the top 100 companies by market capitalisation and tend to be stable. Mid-caps (ranked 101–250) balance growth and stability, while small-caps (beyond 250) offer higher growth potential at higher risk.' },
  { q: 'How is stock market profit taxed in India in 2026?', a: 'Short-term capital gains (held up to 12 months) are taxed at 20% flat, while long-term gains (held over 12 months) are taxed at 12.5% beyond the ₹1.25 lakh annual exemption.' },
  { q: 'What is a P/E ratio and why does it matter for investors?', a: 'The price-to-earnings (P/E) ratio compares a stock\'s price to its earnings per share. It helps investors gauge whether a stock is over- or under-valued relative to its peers and historical levels.' },
  { q: 'Should I invest a lump sum or use SIP for equity investments?', a: 'A SIP spreads investments over time and averages out market volatility, making it ideal for most investors. Lump-sum investing can work when markets are favourable and you have a longer horizon and higher risk appetite.' },
  { q: 'How do I evaluate if a stock is fundamentally strong?', a: 'Assess consistent revenue and profit growth, low debt, healthy return ratios (ROE / ROCE), strong cash flows and competent management. Combine these fundamentals with reasonable valuations before investing.' },
  { q: 'What is the minimum amount needed to start equity investing?', a: 'No regulatory minimum exists. You can start with the price of one share — many blue-chips trade under ₹500. Zero delivery brokerage at Shriram means no extra cost for buy-and-hold investors.' },
];
---

<BaseLayout
  title="Buy Shares NSE BSE — Zero Brokerage Equity Trading | Shriram"
  description="Buy equity stocks on NSE & BSE with zero delivery brokerage, SEBI-registered research, and live market data. Start equity investing today with Shriram Financial Services."
>

  <!-- ══ 1. HERO ═══════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[var(--color-dark-800)]">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[560px] w-[560px] rounded-full bg-[var(--color-brand)]/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-32 left-0 h-80 w-80 rounded-full bg-[var(--color-brand)]/5 blur-3xl"></div>
    <div class="site-wrap relative py-[120px]">
      <p class="equity-reveal text-[14px] font-medium tracking-[.04em] text-[var(--color-brand)]">Equity Investing, Made Simple</p>
      <h1 class="equity-reveal mt-[22px] max-w-[880px] text-[clamp(32px,4vw,52px)] font-bold leading-[1.06] text-white" style="font-family:var(--font-display)">
        Build Long-Term Wealth Through <span class="text-[var(--color-brand)]">Equity Investing</span>
      </h1>
      <p class="equity-reveal mt-[26px] max-w-[600px] text-[18px] leading-relaxed text-white/70">
        Buy and invest in equity stocks in India with live market data, deep research insights, stock analysis tools, and expert-backed guidance from Shriram Financial Services.
      </p>
      <div class="equity-reveal mt-[38px] flex flex-wrap gap-[14px]">
        <a href="/about/open-demat-account/" class="btn-primary">Open Demat Account</a>
        <a href="/about/support/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Talk to RM</a>
      </div>
      <div class="equity-reveal mt-[54px] flex flex-wrap gap-x-9 gap-y-3 border-t border-white/15 pt-9">
        {[
          '✓ SEBI-registered',
          '✓ Research-led',
          '✓ Full-service',
          '✓ Transparent',
        ].map(f => (
          <span class="text-[15px] font-medium text-white/90">
            <span class="mr-2 text-[var(--color-brand)]">{f.slice(0,1)}</span>{f.slice(1)}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 2. WHAT ARE EQUITY STOCKS — editorial + exchanges ════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <!-- Editorial two-column -->
      <div class="equity-reveal mx-auto grid max-w-[1000px] items-start gap-[72px] lg:grid-cols-[5fr_7fr]">
        <h2 class="text-[40px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          What Are <span class="text-[var(--color-brand)]">Equity Stocks?</span>
        </h2>
        <div class="space-y-5 text-[17px] leading-relaxed text-[var(--color-muted)]">
          <p>Equity stocks, also known as shares, represent ownership in a company. When you purchase equity shares, you become a partial owner of that company and gain rights to a portion of its assets and earnings.</p>
          <p>In India, equity stocks trade on two major exchanges, with all activity regulated by the Securities and Exchange Board of India (SEBI) to protect investor interests.</p>
        </div>
      </div>

      <!-- Part: Where Equity Stocks Trade -->
      <div class="equity-reveal mx-auto mt-[76px] max-w-[1000px] border-t border-[var(--color-n400)] pt-[60px]">
        <h3 class="mb-[10px] text-[26px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">Where Equity Stocks Trade</h3>
        <p class="mb-[34px] max-w-[680px] text-[16px] text-[var(--color-muted)]">The market functions through two primary exchanges that enable transparent, electronic trading of shares.</p>
        <div class="grid gap-6 sm:grid-cols-2">
          <div class="product-card-light p-[34px]">
            <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-[10px] bg-[var(--color-dark-olive)]">
              <span class="text-[13px] font-bold text-[var(--color-brand)]">NSE</span>
            </div>
            <h4 class="mb-[10px] text-[22px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">National Stock Exchange</h4>
            <p class="text-[15px] leading-relaxed text-[var(--color-muted)]">India's largest exchange by trading volume, offering electronic trading across equities, derivatives and debt instruments with high liquidity and transparent price discovery.</p>
          </div>
          <div class="product-card-light p-[34px]">
            <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-[10px] bg-[var(--color-dark-olive)]">
              <span class="text-[13px] font-bold text-[var(--color-brand)]">BSE</span>
            </div>
            <h4 class="mb-[10px] text-[22px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">Bombay Stock Exchange</h4>
            <p class="text-[15px] leading-relaxed text-[var(--color-muted)]">Asia's oldest stock exchange, home to thousands of listed companies and the benchmark Sensex index, providing a deep and well-regulated marketplace for investors.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 3. TYPES OF EQUITY STOCKS ════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <!-- Centered sec-head -->
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Types of <span class="text-[var(--color-brand)]">Equity Stocks</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Stocks are grouped two ways — by the rights they carry, and by the size and style of the company behind them.</p>
      </div>

      <!-- By Shareholder Rights -->
      <div class="equity-reveal">
        <h3 class="mb-[10px] text-[26px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">By Shareholder Rights</h3>
        <p class="mb-[34px] max-w-[680px] text-[16px] text-[var(--color-muted)]">Companies issue different classes of shares, each carrying its own rights to voting, dividends and profits.</p>
        <div class="grid gap-6 sm:grid-cols-2">
          {equityTypes.map(t => (
            <div class="product-card-light p-[34px]">
              <h4 class="mb-[10px] text-[22px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">{t.label}</h4>
              <p class="text-[15px] leading-relaxed text-[var(--color-muted)]">{t.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Part: By Size and Style — cat-grid -->
      <div class="equity-reveal mt-[76px] border-t border-[var(--color-n400)] pt-[60px]">
        <h3 class="mb-[10px] text-[26px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">By Size and Style</h3>
        <p class="mb-[34px] max-w-[680px] text-[16px] text-[var(--color-muted)]">The main categories investors use to classify and compare stocks.</p>
        <div class="cat-grid overflow-hidden rounded-[14px] border-l border-t border-[var(--color-n400)]">
          {categories.map(c => (
            <div class="border-b border-r border-[var(--color-n400)] bg-white px-[28px] py-[32px]">
              <h4 class="mb-[9px] text-[19px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">{c.label}</h4>
              <p class="text-[14px] leading-relaxed text-[var(--color-muted)]">{c.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 4. HOW TO START INVESTING ════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <!-- Centered sec-head -->
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How to <span class="text-[var(--color-brand)]">Start Investing</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Four simple steps from sign-up to your first trade — plus exactly what you'll need to qualify.</p>
      </div>

      <!-- Steps connected grid -->
      <div class="equity-reveal steps-grid overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        {steps.map(s => (
          <div class="px-[30px] py-[34px]">
            <div class="mb-[22px] font-display text-[34px] font-normal leading-none text-[var(--color-brand)]">{s.n}</div>
            <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">{s.title}</h4>
            <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">{s.desc}</p>
          </div>
        ))}
      </div>

      <!-- Part: Eligibility & Documents -->
      <div class="equity-reveal mt-[76px] border-t border-[var(--color-n400)] pt-[60px]">
        <h3 class="mb-[10px] text-[26px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">Eligibility &amp; Documents</h3>
        <p class="mb-[34px] max-w-[680px] text-[16px] text-[var(--color-muted)]">Everything you need to qualify and complete your account opening.</p>
        <div class="grid gap-6 sm:grid-cols-2">
          <!-- Eligibility -->
          <div class="product-card-light p-[34px]">
            <h4 class="mb-6 flex items-center gap-3 text-[22px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">
              <span class="grid h-[34px] w-[34px] shrink-0 place-items-center rounded-[8px] border border-[var(--color-n400)] text-[13px] font-bold text-[var(--color-dark-olive)]">01</span>
              Eligibility Criteria
            </h4>
            <ul class="space-y-4">
              {eligibility.map(item => (
                <li class="flex items-start gap-[14px] border-b border-[var(--color-n400)]/50 pb-4 last:border-0 last:pb-0">
                  <span class="shrink-0 text-[15px] font-bold leading-[1.7] text-[var(--color-brand)]">✓</span>
                  <span class="text-[15.5px] text-[var(--color-muted)]">{item}</span>
                </li>
              ))}
            </ul>
          </div>
          <!-- Documents -->
          <div class="product-card-light p-[34px]">
            <h4 class="mb-6 flex items-center gap-3 text-[22px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">
              <span class="grid h-[34px] w-[34px] shrink-0 place-items-center rounded-[8px] border border-[var(--color-n400)] text-[13px] font-bold text-[var(--color-dark-olive)]">02</span>
              Documents Required
            </h4>
            <ul class="space-y-4">
              {documents.map(item => (
                <li class="flex items-start gap-[14px] border-b border-[var(--color-n400)]/50 pb-4 last:border-0 last:pb-0">
                  <span class="shrink-0 text-[15px] font-bold leading-[1.7] text-[var(--color-brand)]">✓</span>
                  <span class="text-[15.5px] text-[var(--color-muted)]">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <!-- Center CTA -->
      <div class="equity-reveal mt-[52px] text-center">
        <a href="/about/open-demat-account/" class="btn-primary">Open Demat Account</a>
      </div>
    </div>
  </section>

  <!-- ══ 5. COSTS & TAXES ══════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <!-- Centered sec-head -->
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Costs &amp; <span class="text-[var(--color-brand)]">Taxes</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">What you pay to trade, and how your gains are taxed — with no hidden costs.</p>
      </div>

      <!-- Brokerage table -->
      <div class="equity-reveal">
        <h3 class="mb-[10px] text-[26px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">Brokerage &amp; Charges</h3>
        <p class="mb-[34px] max-w-[680px] text-[16px] text-[var(--color-muted)]">A clear breakdown of the charges that apply across delivery, intraday and F&amp;O segments.</p>
        <div class="overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
          <div class="overflow-x-auto">
            <table class="w-full text-[15.5px]">
              <thead>
                <tr class="bg-[var(--color-dark-olive)]">
                  <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Charge Type</th>
                  <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Delivery</th>
                  <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Intraday</th>
                  <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">F&amp;O</th>
                </tr>
              </thead>
              <tbody>
                {brokerageRows.map((r, i) => (
                  <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                    <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.label}</td>
                    <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.delivery}</td>
                    <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.intraday}</td>
                    <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.fo}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Part: Tax table -->
      <div class="equity-reveal mt-[76px] border-t border-[var(--color-n400)] pt-[60px]">
        <h3 class="mb-[10px] text-[26px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">Tax on Equity Stocks — LTCG &amp; STCG</h3>
        <p class="mb-[34px] max-w-[680px] text-[16px] text-[var(--color-muted)]">How short-term and long-term capital gains are treated for equity investors.</p>
        <div class="overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
          <div class="overflow-x-auto">
            <table class="w-full text-[15.5px]">
              <thead>
                <tr class="bg-[var(--color-dark-olive)]">
                  <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Feature</th>
                  <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Short-Term (STCG)</th>
                  <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Long-Term (LTCG)</th>
                </tr>
              </thead>
              <tbody>
                {taxRows.map((r, i) => (
                  <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                    <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.feature}</td>
                    <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.stcg}</td>
                    <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.ltcg}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 6. ANALYSE & DECIDE ═══════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <!-- Centered sec-head -->
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Analyse and <span class="text-[var(--color-brand)]">Decide</span>
        </h2>
