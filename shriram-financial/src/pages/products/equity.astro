</BaseLayout>

<style>
  /* Scroll-reveal for equity page sections */
  .equity-reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.65s cubic-bezier(0.22, 1, 0.36, 1), transform 0.65s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .equity-reveal.in-view {
    opacity: 1;
    transform: translateY(0);
  }

  /* Calculator tab active state */
  .calc-tab.active {
    background: var(--color-dark-olive);
    color: #fff;
    border-color: var(--color-dark-olive);
  }

  /* Net P&L color based on sign */
  .calc-net-loss { color: #c62828; }
</style>

<script>
  /* ── Scroll-reveal ─────────────────────────────────────────── */
  const revealEls = document.querySelectorAll<HTMLElement>('.equity-reveal');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          const el = e.target as HTMLElement;
          const delay = el.style.animationDelay || '0ms';
          setTimeout(() => el.classList.add('in-view'), parseInt(delay) || 0);
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.12 }
  );
  revealEls.forEach(el => observer.observe(el));

  /* ── FAQ accordion ─────────────────────────────────────────── */
  document.querySelectorAll<HTMLDetailsElement>('.eq-faq').forEach(d => {
    d.addEventListener('toggle', () => {
      if (d.open) document.querySelectorAll<HTMLDetailsElement>('.eq-faq').forEach(o => { if (o !== d) o.removeAttribute('open'); });
    });
  });

  /* ── Brokerage Calculator ──────────────────────────────────── */
  const qtyEl  = document.getElementById('calc-qty')   as HTMLInputElement;
  const buyEl  = document.getElementById('calc-buy')   as HTMLInputElement;
  const sellEl = document.getElementById('calc-sell')  as HTMLInputElement;
  const grossEl     = document.getElementById('calc-gross')!;
  const brokerageEl = document.getElementById('calc-brokerage')!;
  const taxesEl     = document.getElementById('calc-taxes')!;
  const netEl       = document.getElementById('calc-net')!;

  let brokeragePer = 0; // ₹0 for delivery

  function fmt(n: number) {
    return '₹' + Math.abs(n).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  function calculate() {
    const qty  = Math.max(0, parseFloat(qtyEl.value) || 0);
    const buy  = Math.max(0, parseFloat(buyEl.value) || 0);
    const sell = Math.max(0, parseFloat(sellEl.value) || 0);

    const turnover = qty * (buy + sell);
    const gross = qty * (sell - buy);

    // Simplified statutory charges (delivery): STT 0.1% on sell, exchange 0.00345%, GST 18% on brokerage+exchange, SEBI 0.0001%
    const stt = qty * sell * 0.001;
    const exchange = turnover * 0.0000345;
    const sebi = turnover * 0.000001;
    const brokerage = brokeragePer; // per order
    const gst = (brokerage + exchange) * 0.18;
    const dp = 15.93; // depository per sell
    const totalCharges = brokerage + stt + exchange + sebi + gst + dp;
    const net = gross - totalCharges;

    grossEl.textContent = (gross >= 0 ? '' : '-') + fmt(gross);
    brokerageEl.textContent = fmt(brokerage);
    taxesEl.textContent = fmt(totalCharges - brokerage);
    netEl.textContent = (net >= 0 ? '' : '-') + fmt(net);
    netEl.style.color = net >= 0 ? '#2e7d32' : '#c62828';
  }

  [qtyEl, buyEl, sellEl].forEach(el => el?.addEventListener('input', calculate));

  document.querySelectorAll<HTMLElement>('.calc-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll<HTMLElement>('.calc-tab').forEach(t => t.classList.remove('active', 'bg-[var(--color-dark-olive)]', 'text-white'));
      tab.classList.add('active');
      brokeragePer = parseFloat(tab.dataset.brokerage || '0');
      calculate();
    });
  });

  calculate();
</script>
