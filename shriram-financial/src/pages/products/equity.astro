                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Intraday</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">F&amp;O</th>
              </tr>
            </thead>
            <tbody>
              {brokerageRows.map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.label}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.delivery}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.intraday}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.fo}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
