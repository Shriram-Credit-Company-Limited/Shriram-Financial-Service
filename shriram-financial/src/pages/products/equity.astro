  .appr:hover { background: #26301a; border-color: #3a471b; }
  .appr .explore span:last-child { transition: transform .25s ease; }
  .appr:hover .explore span:last-child { transform: translateX(8px); }
  .appr-main { flex: 1 0 0; min-width: 0; display: flex; flex-direction: column; gap: 32px; }
  .appr .idx { font-weight: 400; font-size: 14px; color: rgba(255,255,255,.5); letter-spacing: 1px; line-height: 1.5; }
  .appr-tt { display: flex; flex-direction: column; gap: 16px; }
  .appr h4 { font-weight: 500; font-size: 24px; color: #fff; line-height: 1.5; }
  .appr p  { font-weight: 400; font-size: 16px; color: rgba(255,255,255,.72); line-height: 1.5; max-width: 448px; }
  .appr .explore { display: flex; gap: 8px; align-items: flex-start; color: var(--gold-2); font-weight: 600; font-size: 15px; line-height: 1.5; white-space: nowrap; flex: none; }

  /* ── Risk cards ──────────────────────────────────────────────────── */
  .risks { display: flex; gap: 24px; align-items: stretch; }
  .risk  { flex: 1 0 0; min-width: 0; background: var(--card); border: 1px solid var(--card-border); border-radius: 24px; padding: var(--container-pad); display: flex; flex-direction: column; gap: 12px; }
  .risk h4 { font-weight: 500; font-size: 20px; color: var(--ink); line-height: 1.5; }
  .risk p  { font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.5; }

  /* ── FAQ ─────────────────────────────────────────────────────────── */
  .faq-wrap  { padding: var(--section-y) var(--pad); }
  .faq-cols  { display: flex; gap: 48px; align-items: stretch; }
  .faq-left  { flex: 1 0 0; min-width: 0; display: flex; flex-direction: column; gap: 48px; }
  .faq-title { font-weight: 400; font-size: 40px; color: var(--olive-title); text-transform: capitalize; line-height: 1.5; white-space: nowrap; }
  .faq-acc   { border-radius: 24px; overflow: hidden; display: flex; flex-direction: column; gap: 2px; width: 100%; }
  .faq-item  { background: var(--card); }

  /* button accordion */
  .faq-q {
    width: 100%; background: none; border: 0; margin: 0; cursor: pointer; font-family: inherit;
    padding: 24px; display: flex; gap: 40px; align-items: flex-start; text-align: left;
  }
  .faq-q .qt { flex: 1 0 0; min-width: 0; font-weight: 500; font-size: 14px; color: #333; line-height: 1.5; }
  .faq-item.open .faq-q .qt { font-weight: 600; }
  .faq-icon { width: 24px; height: 24px; flex: none; }
  .faq-icon svg { display: block; width: 24px; height: 24px; }
  .faq-icon svg .v {
    transform-box: fill-box; transform-origin: center;
    transition: transform .38s cubic-bezier(.4,0,.2,1), opacity .38s ease;
  }
  .faq-item.open .faq-icon svg .v { transform: scaleY(0); opacity: 0; }
  .qa-wrap { display: grid; grid-template-rows: 0fr; transition: grid-template-rows .38s cubic-bezier(.4,0,.2,1); }
  .faq-item.open .qa-wrap { grid-template-rows: 1fr; }
  .qa { overflow: hidden; min-height: 0; }
  .qa p { padding: 0 24px 24px; font-weight: 400; font-size: 14px; color: #404040; line-height: 1.5; }

  /* faq-side — light card with user avatar watermark */
  .faq-side {
    width: 464px; flex: none;
    background: var(--card);
    border-radius: 24px;
    padding: var(--container-pad);
    position: relative; overflow: hidden;
    display: flex; flex-direction: column; gap: 40px; justify-content: flex-end;
  }
  .faq-side .usr { position: absolute; left: var(--container-pad); top: 64px; width: 128px; height: 144px; opacity: .1; }
  .faq-side .usr svg { width: 100%; height: 100%; display: block; }
  .faq-side .side-in { display: flex; flex-direction: column; gap: 32px; position: relative; }
  .faq-side .side-tx { display: flex; flex-direction: column; gap: 8px; color: #222320; }
  .faq-side .side-tx h3 { font-weight: 500; font-size: 20px; line-height: 1.5; }
  .faq-side .side-tx p  { font-weight: 400; font-size: 14px; line-height: 1.5; color: var(--ink-3); }

  /* ── Final CTA ───────────────────────────────────────────────────── */
  .cta-sec { padding: var(--section-y) var(--pad); }
  .cta-box {
    height: 304px;
    border-radius: 24px;
    padding: 64px;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 32px; text-align: center;
  }
  .ct-tt { display: flex; flex-direction: column; align-items: center; gap: 16px; color: var(--olive-deep); }
  .cta-box h3 { font-weight: 500; font-size: 40px; line-height: 1.2; letter-spacing: -1px; }
  .ct-sub { font-weight: 400; font-size: 17px; line-height: 1.5; color: var(--ink-2); }

  /* ── Responsive ──────────────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .cat-grid { grid-template-columns: repeat(2, 1fr); }
    .cat-grid .cat:nth-child(2n) { border-right: 0; }
    .cat-grid .cat:nth-child(7), .cat-grid .cat:nth-child(8) { border-bottom: 0; }
    .risks { flex-wrap: wrap; }
    .risk  { flex: 1 1 calc(50% - 12px); }
    .faq-side .usr { display: none; }
  }

  @media (max-width: 900px) {
    .steps { flex-direction: column; }
    .step-div { display: none; }
    .step { border-bottom: 1px solid var(--card-border); }
    .step:last-child { border-bottom: 0; }
    .step h4 { white-space: normal !important; }
    .faq-cols { flex-direction: column; }
    .faq-side { width: 100%; }
    .faq-title { white-space: normal; }
  }

  @media (max-width: 820px) {
    .approaches { flex-direction: column; }
    .appr p { max-width: none; }
  }

  @media (max-width: 768px) {
    :root { --pad: 16px; --container-pad: 24px; --section-y: 56px; }
    .feats { padding-top: 32px; }
    .hero-inner { padding: 48px 0; }
    .hero h1 { font-size: clamp(28px, 7vw, 40px); }
    .hero .lead { font-size: 16px; }
    .sec-title, .faq-title { font-size: clamp(28px, 7vw, 40px); }
    .sub-title { font-size: clamp(20px, 5.4vw, 24px); }
    .row-2 { flex-direction: column; }
    .check-list { gap: 16px; }
    .sec-lead, .sub-lead, .card-p, .cat p, .step p,
    .check-row .tx, .appr p, .risk p, .cell p { font-size: 14px; }
    .cell { padding: 12px 8px; }
    .cta-box { height: auto; padding: 48px; }
    .cta-box h3 { font-size: clamp(24px, 6.4vw, 40px); line-height: 1.2; }
    .ct-sub { font-size: 15px; }
  }

  @media (max-width: 560px) {
    .cat-grid { grid-template-columns: 1fr; }
    .cat { border-right: 0 !important; border-bottom: 1px solid var(--card-border) !important; }
    .cat:nth-child(8) { border-bottom: 0 !important; }
    .risk { flex: 1 1 100%; }
    .faq-q { gap: 20px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .appr, .appr .explore span:last-child { transition: none; }
    .faq-icon svg .v, .qa-wrap { transition: none; }
  }
</style>

<script>
  /* Button accordion — one open at a time */
  document.querySelectorAll<HTMLElement>('.faq-acc').forEach(acc => {
    acc.querySelectorAll<HTMLElement>('.faq-item').forEach(item => {
      const btn = item.querySelector('.faq-q');
      if (!btn) return;
      btn.addEventListener('click', () => {
        const isOpen = item.classList.contains('open');
        acc.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
        if (!isOpen) item.classList.add('open');
      });
    });
  });
</script>
