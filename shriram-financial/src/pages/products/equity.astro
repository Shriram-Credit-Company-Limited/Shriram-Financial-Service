---
import BaseLayout from '../../layouts/BaseLayout.astro';

const brokerageRows = [
  { label: 'Brokerage', delivery: '₹0 (Zero)', intraday: '₹20 per executed order', fo: '₹20 per executed order' },
  { label: 'STT', delivery: '0.1% on sell side', intraday: '0.025% on buy & sell side', fo: '0.02% on sell side' },
  { label: 'GST', delivery: '18% on brokerage + exchange charges', intraday: '18% on brokerage + exchange charges', fo: '18% on brokerage + exchange charges' },
  { label: 'DP Charges', delivery: '₹15.93 per scrip on sell', intraday: 'N/A', fo: 'N/A' },
  { label: 'Exchange Charges', delivery: '0.00345% (NSE) / 0.00375% (BSE)', intraday: '0.00345% (NSE) / 0.00375% (BSE)', fo: '0.002%' },
];

const taxRows = [
  { feature: 'Holding Period', stcg: 'Up to 12 months', ltcg: 'More than 12 months' },
  { feature: 'Tax Rate', stcg: '20% Flat', ltcg: '12.5%' },
  { feature: 'Tax-Free Limit', stcg: 'Nil (taxed from ₹1)', ltcg: 'Up to ₹1.25 Lakh per year' },
  { feature: 'Indexation Benefit', stcg: 'Not Applicable', ltcg: 'Not Applicable' },
  { feature: 'Applicable Section', stcg: 'Section 111A', ltcg: 'Section 112A' },
];

const categories = [
  { label: 'Large Cap',       desc: 'Top 100 companies by market cap — Reliance, TCS, HDFC Bank. Stable, lower risk, ideal for conservative long-term investors.' },
  { label: 'Mid Cap',         desc: 'Companies ranked 101–250 — a balance of growth potential and relative stability. Higher returns over 5–7 years than large-caps historically.' },
  { label: 'Small Cap',       desc: 'Companies ranked beyond 250 — highest growth potential with highest risk. Suited for aggressive investors with 7–10 year horizon.' },
  { label: 'Growth Stocks',   desc: 'Companies expected to grow earnings faster than the market — often reinvest profits rather than paying dividends. Valued on future potential.' },
  { label: 'Dividend Stocks', desc: 'Companies that distribute a portion of profits as regular dividends — utilities, PSU banks, and mature businesses. Provide passive income stream.' },
  { label: 'Value Stocks',    desc: 'Stocks trading below their calculated intrinsic worth — potentially undervalued by the market. Warren Buffett\'s core investing approach.' },
  { label: 'Blue Chip',       desc: 'India\'s most financially sound, market-leading companies with decades of consistent performance. The foundation of most long-term portfolios.' },
  { label: 'Cyclical Stocks', desc: 'Stocks whose performance tracks broader economic cycles — metals, auto, real estate. Strong in bull markets, weak in downturns.' },
];

const strategyRows = [
  { label: 'Holding Period',   intraday: 'Same day (square-off before close)', swing: '2 days to a few weeks', lt: '1+ years (often 5–10+ years)' },
  { label: 'Time Commitment',  intraday: 'High — active monitoring', swing: 'Moderate — daily/weekly check', lt: 'Low — periodic review' },
  { label: 'Capital Required', intraday: 'Lower entry, margin common', swing: 'Moderate', lt: 'Can start small via SIP (₹500+)' },
  { label: 'Risk Level',       intraday: 'Very High', swing: 'High', lt: 'Moderate to Low' },
];

const vsRows = [
  { feature: 'Control',              equity: 'Direct ownership and control', mf: 'Fund manager decides' },
  { feature: 'Risk',                 equity: 'Company-specific risk', mf: 'Diversified risk' },
  { feature: 'Return Potential',     equity: 'Potentially higher (unlimited upside)', mf: 'Market-linked returns' },
  { feature: 'Research Involvement', equity: 'Active research needed', mf: 'Professional management' },
  { feature: 'Suitable For',         equity: 'Knowledgeable investors', mf: 'All investor types' },
  { feature: 'Cost',                 equity: 'Brokerage per trade', mf: 'Expense ratio annually' },
  { feature: 'Liquidity',            equity: 'Real-time during market hours', mf: 'End-of-day NAV' },
  { feature: 'Management',           equity: 'Self-managed portfolio', mf: 'Professionally managed' },
];

const risks = [
  { n: '01', label: 'Market Risk',         desc: 'Broad market movements can affect all stocks due to economic events, policy changes or global sentiment.' },
  { n: '02', label: 'Volatility',          desc: 'Prices can fluctuate significantly within short periods, testing investor discipline and patience.' },
  { n: '03', label: 'Stock-Specific Risk', desc: 'Company-specific factors such as poor earnings or governance issues can impact a single stock sharply.' },
  { n: '04', label: 'Behavioural Risk',    desc: 'Emotional decisions driven by fear or greed can lead to poor timing and avoidable losses.' },
];

const documents = [
  'PAN card (mandatory)',
  'Aadhaar card for identity verification',
  'Address proof — Aadhaar, Passport, or Utility Bill',
  'Cancelled cheque or recent bank statement',
  'Passport-size photograph (JPEG format)',
  'Valid mobile number and email ID',
];

const faqs = [
  { q: 'What is the difference between large-cap, mid-cap and small-cap stocks?', a: 'SEBI defines large-caps as the top 100 companies by market capitalisation, mid-caps as ranked 101–250, and small-caps as beyond 250. Large-caps (e.g., Reliance, TCS) offer stability with moderate returns. Mid-caps balance growth and risk. Small-caps have the highest long-term return potential but also the highest volatility.' },
  { q: 'How is stock market profit taxed in India in 2026?', a: 'Short-term capital gains (STCG) on equity shares held up to 12 months are taxed at 20% flat under Section 111A. Long-term capital gains (LTCG) on holdings over 12 months are taxed at 12.5% under Section 112A, with a ₹1.25 lakh annual exemption. These rates apply per Budget 2025-26.' },
  { q: 'What is a P/E ratio and why does it matter for investors?', a: 'The price-to-earnings (P/E) ratio = stock price ÷ earnings per share. A high P/E suggests the market expects strong future growth but may signal overvaluation. A low P/E can mean undervaluation or declining fundamentals. Always compare P/E within the same sector — a P/E of 25 is expensive for a bank but cheap for an IT company.' },
  { q: 'Should I invest a lump sum or use SIP for equity investments?', a: 'SIP (investing a fixed amount monthly) averages your purchase price through market cycles — ideal for salaried investors building long-term wealth. Lump-sum works when markets are down significantly from highs and you have surplus capital. Many experienced investors do both: SIP for regular savings, lump-sum during market corrections.' },
  { q: 'How do I evaluate if a stock is fundamentally strong?', a: 'Check five key metrics: (1) Consistent revenue and profit growth over 3–5 years, (2) Low debt-to-equity ratio (under 1x is ideal), (3) High ROE (Return on Equity) above 15%, (4) Positive and growing free cash flow, (5) Reasonable P/E vs sector peers. Also assess management quality and competitive moat.' },
  { q: 'What is the minimum amount needed to start equity investing?', a: 'There is no regulatory minimum. You can start with the price of a single share — many quality blue-chips trade under ₹500. With zero delivery brokerage at Shriram, there is no additional transaction cost for buy-and-hold investors, making micro-investing practical from day one.' },
  { q: 'What is an IPO and should I apply?', a: 'An IPO (Initial Public Offering) is when a private company first offers shares to the public on NSE/BSE. You apply during the subscription window via your Demat account. Oversubscribed IPOs of fundamentally strong companies can generate listing-day gains. However, not all IPOs list at a premium — evaluate the company\'s financials and valuation before applying.' },
  { q: 'What is STT (Securities Transaction Tax)?', a: 'STT is a government tax on exchange-traded securities. For delivery (buy-and-hold) trades: 0.1% on the sell side. For intraday trades: 0.025% on both buy and sell. For F&O: 0.02% on options sell side (premium). STT is applied automatically by your broker and is non-refundable.' },
  { q: 'Can I invest in US stocks from India?', a: 'Yes. Under FEMA\'s Liberalised Remittance Scheme (LRS), Indian residents can invest up to USD 250,000 (~₹2 crore) per financial year in foreign stocks. Remittances above ₹7 lakh attract 20% TCS (refundable via ITR). US stock gains are taxed as per your income slab for short-term, and at 12.5% for long-term (2+ years) gains in India.' },
  { q: 'What is a circuit breaker in stocks?', a: 'A circuit breaker is a SEBI-mandated trading halt when a stock or index moves beyond a set limit in one session — typically 5%, 10%, or 20% for individual stocks. For NSE/BSE indices: a 10% move triggers a 45-minute halt, a 15% move triggers a 2-hour halt, and a 20% move closes the market for the day. Circuit breakers prevent panic-driven extreme price moves.' },
];
---

<BaseLayout
  title="Equity Stocks India — Buy Shares on NSE & BSE | Shriram Financial"
  description="Buy equity stocks India on NSE & BSE. SEBI-registered broker, zero delivery brokerage, free analyst research. Open demat account & start investing today."
>

  <!-- ══ S1 — HERO ═════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[var(--color-dark-800)]">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[560px] w-[560px] rounded-full bg-[var(--color-brand)]/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-32 left-0 h-80 w-80 rounded-full bg-[var(--color-brand)]/5 blur-3xl"></div>
    <div class="site-wrap relative py-[120px]">
      <p class="equity-reveal text-[14px] font-medium tracking-[.04em] text-[var(--color-brand)]">Equity Investing</p>
      <h1 class="equity-reveal mt-[22px] max-w-[880px] text-[clamp(32px,4vw,52px)] font-bold leading-[1.06] text-white" style="font-family:var(--font-display)">
        Buy <span class="text-[var(--color-brand)]">Equity Stocks</span> — Invest on NSE &amp; BSE
      </h1>
      <p class="equity-reveal mt-[26px] max-w-[600px] text-[18px] leading-relaxed text-white/70">
        SEBI-registered broker. Zero delivery brokerage. Free analyst research. Open a Demat account in 10 minutes and start buying equity stocks on NSE and BSE — India's two national exchanges.
      </p>
      <div class="equity-reveal mt-[38px] flex flex-wrap gap-[14px]">
        <a href="/about/open-demat-account/" class="btn-primary">Open Demat Account</a>
        <a href="/about/open-demat-account/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Start Investing</a>
      </div>
      <div class="equity-reveal mt-[54px] flex flex-wrap gap-x-9 gap-y-3 border-t border-white/15 pt-9">
        {[
          '✓ SEBI-registered',
          '✓ Zero delivery brokerage',
          '✓ 5,000+ stocks on NSE & BSE',
          '✓ Free analyst research',
        ].map(f => (
          <span class="text-[15px] font-medium text-white/90">{f}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S2 — WHAT ARE EQUITY STOCKS? DEFINITION & TYPES ══════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          What Are <span class="text-[var(--color-brand)]">Equity Stocks?</span> — Definition &amp; Types
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Equity stocks (shares) represent part-ownership in a publicly listed company. When you buy shares on NSE or BSE, you become a partial owner and participate in the company's growth — earning returns through price appreciation and dividends. Equity is historically the highest-returning asset class in India over the long term, with Nifty 50 delivering ~13% CAGR over the last 20 years.</p>
      </div>

      <!-- Comparison table: Common vs Preferred -->
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Feature</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Common Shares</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Preferred Shares</th>
              </tr>
            </thead>
            <tbody>
              <tr class="bg-white">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">Voting Rights</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Yes</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Limited/None</td>
              </tr>
              <tr class="bg-[#f8f6f1]">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">Dividend Priority</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">After preferred</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">First priority</td>
              </tr>
              <tr class="bg-white">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">Risk</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Higher</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Lower</td>
              </tr>
              <tr class="bg-[#f8f6f1]">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">Upside</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Unlimited</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Capped</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S3 — HOW THE STOCK MARKET WORKS IN INDIA ═════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How the <span class="text-[var(--color-brand)]">Stock Market Works</span> in India
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">The Indian stock market operates through SEBI-regulated exchanges where buyers and sellers trade shares electronically in real time during market hours (9:15 AM – 3:30 PM IST, Monday to Friday).</p>
      </div>

      <div class="equity-reveal steps-grid overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        {[
          { n: '01', title: 'SEBI Regulates', desc: 'Securities & Exchange Board of India sets all rules for listed companies, brokers, and investors.' },
          { n: '02', title: 'Companies List on NSE/BSE', desc: 'Companies raise capital by issuing shares on the National Stock Exchange or Bombay Stock Exchange.' },
          { n: '03', title: 'Brokers Facilitate Trades', desc: 'SEBI-registered brokers like Shriram execute your buy/sell orders on the exchange.' },
          { n: '04', title: 'T+1 Settlement', desc: 'Trades settle the next business day — shares credited to your Demat, funds to your bank.' },
        ].map(s => (
          <div class="px-[30px] py-[34px]">
            <div class="mb-[22px] font-display text-[34px] font-normal leading-none text-[var(--color-brand)]">{s.n}</div>
            <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">{s.title}</h4>
            <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S4 — ELIGIBILITY & HOW TO START INVESTING ════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Eligibility &amp; <span class="text-[var(--color-brand)]">How to Start Investing</span> in Stocks
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Open a Demat + Trading account to start. Here is exactly what you need.</p>
      </div>

      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Requirement</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Details</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Status</th>
              </tr>
            </thead>
            <tbody>
              <tr class="bg-white">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">Age</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">18+ (minors via guardian)</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Mandatory</td>
              </tr>
              <tr class="bg-[#f8f6f1]">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">PAN Card</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">SEBI/IT-mandated identity proof</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Mandatory</td>
              </tr>
              <tr class="bg-white">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">Aadhaar</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">e-KYC and address verification</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Mandatory</td>
