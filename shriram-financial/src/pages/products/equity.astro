                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">KYC</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">One-time digital verification</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Mandatory</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="equity-reveal mt-[52px] text-center">
        <a href="/about/open-demat-account/" class="btn-primary">Open Demat Account</a>
      </div>
    </div>
  </section>

  <!-- ══ S5 — STOCK RETURNS CALCULATOR ════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          <span class="text-[var(--color-brand)]">Stock Returns Calculator</span> — Estimate Your Wealth
        </h2>
