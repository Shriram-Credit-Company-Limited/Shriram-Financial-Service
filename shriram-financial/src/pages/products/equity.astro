  .hero-inner { padding: 56px 0; display: flex; flex-direction: column; }
  .hero h1 { font-weight: 500; font-size: 40px; color: #fff; line-height: 1.5; max-width: var(--hero-text-w); }
  .hero h1 .g { color: var(--gold-2); }
  .hero .lead { margin-top: 16px; font-weight: 400; font-size: 18px; line-height: 1.5; color: rgba(255,255,255,.74); max-width: var(--hero-text-w); }
  .hero .cta { margin-top: 40px; }
  .hero-feats { margin-top: 40px; width: 100%; }
  .feats { display: flex; flex-wrap: wrap; align-items: center; gap: 16px; width: 100%; max-width: 760px; padding-top: 36px; border-top: 1px solid rgba(255,255,255,.16); }
