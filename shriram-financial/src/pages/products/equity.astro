---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MarketOverview from '../../components/MarketOverview.astro';

const equityTypes = [
  { label: 'Common Equity Shares',   desc: 'The most widely traded shares. Investors receive voting rights and participate in the company\'s profits through dividends and price appreciation.' },
  { label: 'Preferred Equity Shares', desc: 'Preferred shareholders receive preference in dividend payments over common shareholders. These shares generally carry limited or no voting rights.' },
];

const eligibility = [
  'Indian resident (NRIs can invest through specific routes)',
  'Valid PAN card',
  'Active bank account in your name',
  'Completed KYC verification',
  '18+ years of age (minors can invest through guardians)',
];

const documents = [
  'PAN card (mandatory)',
  'Aadhaar card for identity verification',
  'Address proof (Aadhaar, Passport, Utility Bill)',
  'Cancelled cheque or bank statement',
  'Passport-size photograph',
  'Valid mobile number and email ID',
];

const steps = [
  { n: '1', title: 'Open Demat & Trading Account',      desc: 'Open a Demat and trading account online with Shriram in minutes.' },
  { n: '2', title: 'Complete PAN / KYC / Bank Linking', desc: 'Submit your PAN, complete KYC with Aadhaar and link your bank account.' },
  { n: '3', title: 'Search and Analyse Stocks',         desc: 'Use research tools, screeners and expert analysis to identify quality stocks.' },
  { n: '4', title: 'Buy, Hold, Sell & Track',           desc: 'Execute trades, build your portfolio and track holdings to grow your wealth.' },
];

const brokerageRows = [
  { label: 'Brokerage',        delivery: '0.03%',               intraday: '0.03%',                   fo: '0.03%' },
  { label: 'STT',              delivery: '0.1%',                 intraday: '0.025%',                  fo: '0.02%' },
  { label: 'GST',              delivery: '18% on brokerage',     intraday: '18% on brokerage',        fo: '18% on brokerage' },
  { label: 'DP Charges',       delivery: '₹15 per stock',        intraday: 'N/A',                     fo: 'N/A' },
  { label: 'Exchange Charges', delivery: '0.00325%',             intraday: '0.00325%',                fo: '0.002%' },
];

const taxRows = [
  { feature: 'Holding Period',     stcg: 'Up to 12 months',       ltcg: 'More than 12 months' },
  { feature: 'Tax Rate',           stcg: '20% flat',               ltcg: '12.5%' },
  { feature: 'Tax-Free Limit',     stcg: 'Nil (taxed from ₹1)',    ltcg: 'Up to ₹1.25 lakh per year' },
  { feature: 'Indexation Benefit', stcg: 'Not Applicable',         ltcg: 'Not Applicable' },
  { feature: 'Applicable Section', stcg: 'Section 111A',           ltcg: 'Section 112A' },
];

const categories = [
  { label: 'Large Cap',       desc: 'Top 100 companies by market capitalisation — stable and lower risk.' },
  { label: 'Mid Cap',         desc: 'Companies ranked 101–250 — a balance of growth potential and stability.' },
  { label: 'Small Cap',       desc: 'Companies ranked beyond 250 — higher growth potential with higher risk.' },
  { label: 'Growth Stocks',   desc: 'Companies expected to grow earnings faster than the broader market.' },
  { label: 'Dividend Stocks', desc: 'Companies that share regular profits with shareholders as dividends.' },
  { label: 'Value Stocks',    desc: 'Stocks trading below their intrinsic worth — potentially undervalued.' },
  { label: 'Blue Chip Stocks', desc: 'Well-established, financially sound market leaders with a strong record.' },
  { label: 'Cyclical Stocks', desc: 'Stocks whose performance moves in line with broader economic cycles.' },
];

const research = [
  { title: 'Fundamental Research', idx: 'Approach 01', desc: 'In-depth company analysis, financial modelling and valuation reports to assess a stock\'s true intrinsic worth.', href: '/research/fundamental/' },
  { title: 'Technical Research',   idx: 'Approach 02', desc: 'Chart patterns, price action and technical indicators to time entries and exits with greater precision.',         href: '/research/technical/' },
];

const strategyRows = [
  { label: 'Holding Period',   intraday: 'Same day (square-off before close)', swing: '2 days to a few weeks',        lt: '1+ years (often 5–10+ years)' },
  { label: 'Time Commitment',  intraday: 'High — active monitoring',           swing: 'Moderate — daily / weekly check', lt: 'Low — periodic review' },
  { label: 'Capital Required', intraday: 'Lower entry, margin common',         swing: 'Moderate',                      lt: 'Can start small via SIP (₹500+)' },
  { label: 'Risk Level',       intraday: 'Very High',                          swing: 'High',                          lt: 'Moderate to Low' },
];

const vsRows = [
  { feature: 'Control',              equity: 'Direct ownership and control',          mf: 'Fund manager decides' },
  { feature: 'Risk',                 equity: 'Company-specific risk',                 mf: 'Diversified risk' },
  { feature: 'Return Potential',     equity: 'Potentially higher (unlimited upside)', mf: 'Market-linked returns' },
  { feature: 'Research Involvement', equity: 'Active research needed',                mf: 'Professional management' },
  { feature: 'Suitable For',         equity: 'Knowledgeable investors',               mf: 'All investor types' },
  { feature: 'Cost',                 equity: 'Brokerage per trade',                   mf: 'Expense ratio annually' },
  { feature: 'Liquidity',            equity: 'Real-time during market hours',         mf: 'End-of-day NAV' },
  { feature: 'Management',           equity: 'Self-managed portfolio',                mf: 'Professionally managed' },
];

const risks = [
  { label: 'Market Risk',         desc: 'Broad market movements can affect all stocks due to economic events, policy changes or global sentiment.' },
  { label: 'Volatility',          desc: 'Prices can fluctuate significantly within short periods, testing investor discipline and patience.' },
  { label: 'Stock-Specific Risk', desc: 'Company-specific factors such as poor earnings or governance issues can impact a single stock sharply.' },
  { label: 'Behavioural Risk',    desc: 'Emotional decisions driven by fear or greed can lead to poor timing and avoidable losses.' },
];

const faqs = [
  { q: 'What is a Demat Account?',                                              a: 'A Demat (dematerialised) account holds your shares and securities in electronic form, replacing physical certificates. It lets you buy, sell and hold equities, bonds, ETFs and mutual funds safely, with instant electronic settlement of trades.' },
  { q: 'What are the benefits of a Demat Account?',                             a: 'A Demat account removes the risks of physical certificates — theft, loss and forgery — and enables faster, paperless settlement. You get a single consolidated view of your holdings, easy access to corporate actions such as dividends and bonuses, and the ability to trade from anywhere.' },
  { q: 'What are the brokerage charges for options trading with Shriram?',      a: 'Shriram charges a flat brokerage of 0.03% per executed order for options trading. Use the Brokerage Calculator to estimate the total cost — including brokerage, STT and exchange charges — before placing any trade.' },
  { q: 'Are there any charges associated with the Demat Account?',              a: 'Typical charges include a one-time account opening fee (often waived), an annual maintenance charge (AMC) and per-transaction DP charges. Shriram keeps these fully transparent so you can review the complete schedule before you open your account.' },
  { q: 'What is Intraday brokerage and Option brokerage?',                      a: 'Intraday brokerage applies to positions bought and sold within the same trading day, while option brokerage applies to options contracts. Both are charged per executed order — estimate the exact cost of any trade with our Brokerage Calculator.' },
  { q: 'Can I have multiple Demat Accounts?',                                   a: 'Yes. You may hold more than one Demat account across different depository participants, but you cannot open two accounts with the same DP under the same PAN. Your PAN links all accounts for tax and regulatory purposes.' },
  { q: 'Is a Demat Account mandatory for applying for an IPO?',                 a: 'Yes. To receive shares allotted in an IPO in electronic form you need a Demat account. You can apply via ASBA through your bank or broker, and any allotted shares are credited directly to your Demat account.' },
];
---

<BaseLayout
  title="Buy Equity Stocks India — Zero Brokerage NSE BSE Trading | Shriram"
  description="Buy equity stocks India on NSE & BSE with zero delivery brokerage, SEBI-registered research, and live market data. Start equity investing in India today with Shriram Financial Services."
>

  <!-- ══ 1. HERO ══════════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-inner">
      <h1>Build Long-Term Wealth Through <span class="g">Equity Investing</span></h1>
      <p class="lead">Buy and invest in equity stocks in India with live market data, deep research insights, stock analysis tools and expert-backed guidance from Shriram.</p>
      <div class="cta"><a class="btn-gold" href="/about/open-demat-account/">Open Demat Account</a></div>
      <div class="hero-feats">
        <div class="feats">
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;SEBI-registered</span></div>
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;Research-led</span></div>
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;Full-service</span></div>
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;Transparent</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 1b. MARKET OVERVIEW (live indices + commodities) ═════════════ -->
  <MarketOverview />

  <!-- ══ 2. WHAT ARE EQUITY STOCKS ════════════════════════════════════ -->
  <section class="section stack" id="sec-about" style="background:var(--sec-light);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">What Are Equity Stocks?</h2>
      <p class="sec-lead">Equity stocks, also known as shares, represent ownership in a company. When you purchase equity shares, you become a partial owner of that company and gain rights to a portion of its assets and earnings. In India, equity stocks trade on two major exchanges, with all activity regulated by the Securities and Exchange Board of India (SEBI) to protect investor interests.</p>
    </div>
    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Where Equity Stocks Trade</h3>
        <p class="sub-lead">The market functions through two primary exchanges that enable transparent, electronic trading of shares:</p>
      </div>
      <div class="row-2">
        <div class="card" style="border-color:var(--card-border-soft)">
          <h4 class="card-h">National Stock Exchange</h4>
          <p class="card-p">India's largest exchange by trading volume, offering electronic trading across equities, derivatives and debt instruments with high liquidity and transparent price discovery.</p>
        </div>
        <div class="card" style="border-color:var(--card-border-soft)">
          <h4 class="card-h">Bombay Stock Exchange</h4>
          <p class="card-p">Asia's oldest stock exchange, home to thousands of listed companies and the benchmark Sensex index, providing a deep and well-regulated marketplace for investors.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 3. TYPES OF EQUITY STOCKS ════════════════════════════════════ -->
  <section class="section stack" id="sec-types" style="background:var(--sec-tint);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Types of Equity Stocks</h2>
      <p class="sec-lead">Stocks are grouped two ways — by the rights they carry, and by the size and style of the company behind them.</p>
    </div>

    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">By Shareholder Rights</h3>
        <p class="sub-lead">Companies issue different classes of shares, each carrying its own rights to voting, dividends and profits.</p>
      </div>
      <div class="row-2">
        {equityTypes.map(t => (
          <div class="card">
            <h4 class="card-h">{t.label}</h4>
            <p class="card-p">{t.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">By Size and Style</h3>
        <p class="sub-lead">The main categories investors use to classify and compare stocks.</p>
      </div>
      <div class="cat-grid">
        {categories.map(c => (
          <div class="cat"><h4>{c.label}</h4><p>{c.desc}</p></div>
        ))}
      </div>
    </div>

    <a class="btn-gold" href="/about/open-demat-account/" style="align-self:center">Open Demat Account</a>
  </section>

  <!-- ══ 4. HOW TO START INVESTING ════════════════════════════════════ -->
  <section class="section stack" id="sec-getting-started" style="background:var(--sec-light);gap:56px;align-items:center;justify-content:center">
    <div class="stack" style="gap:16px;width:100%">
      <h2 class="sec-title">How to Start Investing</h2>
      <p class="sec-lead">Four simple steps from sign-up to your first trade — plus exactly what you'll need to qualify.</p>
    </div>

    <div class="steps">
      {steps.map((s, i) => (
        <>
          {i > 0 && <div class="step-div"></div>}
          <div class="step">
            <div class="num">{s.n}</div>
            <div class="st-body">
              <h4>{s.title}</h4>
              <p>{s.desc}</p>
            </div>
          </div>
        </>
      ))}
    </div>

    <div class="stack" style="gap:32px;width:100%">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Eligibility &amp; Documents</h3>
        <p class="sub-lead">Everything you need to qualify and complete your account opening.</p>
      </div>
      <div class="row-2">
        <div class="card check-card">
          <h4 class="ch-title">Eligibility Criteria</h4>
          <div class="check-list">
            {eligibility.map((item, i) => (
              <>
                {i > 0 && <div class="check-sep"></div>}
                <div class="check-row"><span class="ck">✓</span><p class="tx">{item}</p></div>
              </>
            ))}
          </div>
        </div>
        <div class="card check-card">
          <h4 class="ch-title">Documents Required</h4>
          <div class="check-list">
            {documents.map((item, i) => (
              <>
                {i > 0 && <div class="check-sep"></div>}
                <div class="check-row"><span class="ck">✓</span><p class="tx">{item}</p></div>
              </>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 5. COSTS & TAXES ══════════════════════════════════════════════ -->
  <section class="section stack" id="sec-costs" style="background:var(--sec-tint);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Costs &amp; Taxes</h2>
      <p class="sec-lead" style="color:var(--ink-2)">What you pay to trade, and how your gains are taxed — with no hidden costs.</p>
    </div>

    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Brokerage &amp; Charges</h3>
        <p class="sub-lead" style="color:var(--ink-2)">A clear breakdown of the charges that apply across delivery, intraday and F&amp;O segments.</p>
      </div>
      <div class="t-scroll">
        <div class="table t4">
          <div class="cell th"><p>Charge Type</p></div>
          <div class="cell th"><p>Delivery</p></div>
          <div class="cell th"><p>Intraday</p></div>
          <div class="cell th"><p>F&amp;O</p></div>
          {brokerageRows.map(r => (
            <>
              <div class="cell tb"><p class="k">{r.label}</p></div>
              <div class="cell tb"><p class="v">{r.delivery}</p></div>
              <div class="cell tb"><p class="v">{r.intraday}</p></div>
              <div class="cell tb"><p class="v">{r.fo}</p></div>
            </>
          ))}
        </div>
      </div>
    </div>

    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Tax on Equity Stocks — LTCG &amp; STCG</h3>
        <p class="sub-lead" style="color:var(--ink-2)">How short-term and long-term capital gains are treated for equity investors.</p>
      </div>
      <div class="t-scroll">
        <div class="table t3">
          <div class="cell th"><p>Feature</p></div>
          <div class="cell th"><p>Short-Term (STCG)</p></div>
          <div class="cell th"><p>Long-Term (LTCG)</p></div>
          {taxRows.map(r => (
            <>
              <div class="cell tb"><p class="k">{r.feature}</p></div>
              <div class="cell tb"><p class="v">{r.stcg}</p></div>
              <div class="cell tb"><p class="v">{r.ltcg}</p></div>
            </>
          ))}
        </div>
      </div>
    </div>

    <a class="btn-gold" href="/about/open-demat-account/" style="align-self:center">Open Demat Account</a>
  </section>

  <!-- ══ 6. ANALYSE & DECIDE ═══════════════════════════════════════════ -->
  <section class="section stack" id="sec-analyse" style="background:var(--sec-light);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Analyse and Decide</h2>
      <p class="sec-lead" style="color:var(--ink-2)">How to research a stock, choose a strategy, compare your options and weigh the risks.</p>
    </div>

    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Research Approaches</h3>
        <p class="sub-lead" style="color:var(--ink-2)">Two complementary approaches, backed by data-driven insights and research-led ideas.</p>
      </div>
      <div class="approaches">
        {research.map(r => (
          <a class="appr" href={r.href}>
            <div class="appr-main">
              <p class="idx">{r.idx}</p>
              <div class="appr-tt">
                <h4>{r.title}</h4>
                <p>{r.desc}</p>
              </div>
            </div>
            <div class="explore"><span>Explore&nbsp;</span><span>→</span></div>
          </a>
        ))}
      </div>
    </div>

    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Top Trading Strategies</h3>
        <p class="sub-lead" style="color:var(--ink-2)">Match your time, capital and risk appetite to the right approach.</p>
      </div>
      <div class="t-scroll">
        <div class="table t4 bordered">
          <div class="cell th"><p>Parameter</p></div>
          <div class="cell th"><p>Intraday Trading</p></div>
          <div class="cell th"><p>Swing Trading</p></div>
          <div class="cell th"><p>Long-Term Investing</p></div>
          {strategyRows.map(r => (
            <>
              <div class="cell tb"><p class="k">{r.label}</p></div>
              <div class="cell tb"><p class="v">{r.intraday}</p></div>
              <div class="cell tb"><p class="v">{r.swing}</p></div>
              <div class="cell tb"><p class="v">{r.lt}</p></div>
            </>
          ))}
        </div>
      </div>
    </div>

    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Equity Stocks vs Mutual Funds</h3>
        <p class="sub-lead" style="color:var(--ink-2)">Compare direct equity investing with mutual funds across the factors that matter most.</p>
      </div>
      <div class="t-scroll">
        <div class="table t3 bordered">
          <div class="cell th"><p>Feature</p></div>
          <div class="cell th"><p>Equity Stocks</p></div>
          <div class="cell th"><p>Mutual Funds</p></div>
          {vsRows.map(r => (
            <>
              <div class="cell tb"><p class="k">{r.feature}</p></div>
              <div class="cell tb"><p class="v">{r.equity}</p></div>
              <div class="cell tb"><p class="v">{r.mf}</p></div>
            </>
          ))}
        </div>
      </div>
    </div>

    <div class="stack" style="gap:32px">
      <div class="stack" style="gap:16px">
        <h3 class="sub-title">Risks to Weigh</h3>
        <p class="sub-lead" style="color:var(--ink-2)">Understand what can move against you before you commit capital.</p>
      </div>
      <div class="risks">
        {risks.map(r => (
          <div class="risk">
            <h4>{r.label}</h4>
            <p>{r.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <a class="btn-gold" href="/about/open-demat-account/" style="align-self:center">Open Demat Account</a>
  </section>

  <!-- ══ 7. GENERAL QUESTIONS (FAQ) ═══════════════════════════════════ -->
  <section class="faq-wrap" id="sec-faq" style="background:var(--sec-tint)">
    <div class="faq-cols">
      <div class="faq-left">
        <h2 class="faq-title">General Questions</h2>
        <div class="faq-acc">
          {faqs.map((item, i) => (
            <div class={`faq-item${i === 0 ? ' open' : ''}`}>
              <button class="faq-q" type="button">
                <span class="qt">{item.q}</span>
                <span class="faq-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none">
                    <line class="v" x1="12" y1="5" x2="12" y2="19" stroke="#404040" stroke-width="2" stroke-linecap="round"/>
                    <line x1="5" y1="12" x2="19" y2="12" stroke="#404040" stroke-width="2" stroke-linecap="round"/>
                  </svg>
                </span>
              </button>
              <div class="qa-wrap">
                <div class="qa"><p>{item.a}</p></div>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="faq-side">
        <div class="usr" aria-hidden="true">
          <svg viewBox="0 0 128 144" fill="none" xmlns="http://www.w3.org/2000/svg" width="128" height="144">
            <circle cx="64" cy="48" r="32" stroke="#2d3813" stroke-width="2"/>
            <path d="M8 144c0-30.928 25.072-56 56-56s56 25.072 56 56" stroke="#2d3813" stroke-width="2"/>
          </svg>
        </div>
        <div class="side-in">
          <div class="side-tx">
            <h3>Need A Clearer Direction?</h3>
            <p>Let's get in touch on a 15-minute call where we would be able to answer any questions you may have. Our advisor will additionally help map your wealth mix and demonstrate what a dedicated advisor would do differently.</p>
          </div>
          <a class="btn-gold" href="/about/support/">Book A Discovery Call</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 8. FINAL CTA ══════════════════════════════════════════════════ -->
  <section class="cta-sec" id="sec-final-cta" style="background:var(--sec-light)">
    <div class="cta-box">
      <div class="ct-tt">
        <h3>Open Your Demat Account Within Minutes</h3>
        <p class="ct-sub">Start investing in stocks, mutual funds and more — with zero paperwork.</p>
      </div>
      <a class="btn-gold" href="/about/open-demat-account/">Open Demat Account</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Design tokens ─────────────────────────────────────────────── */
  :root {
    --page: #fcf8ef;
    --sec-light: #fef8ee;
    --sec-tint: #f6efe1;
    --card: #fffdf8;
    --card-border: #e1e0db;
    --card-border-soft: rgba(28,28,22,.13);
    --row-line: rgba(28,28,22,.08);
    --olive-title: #2e3914;
    --olive-head: #2d3813;
    --olive-deep: #1b2010;
    --ink: #1c1c16;
    --ink-2: #46463c;
    --ink-3: #595959;
    --muted: #73736a;
    --muted-2: #9a9a8e;
    --gold: #e0a82e;
    --gold-2: #f2b83f;
    --gold-btn: #f3b83f;
    --gold-ink: #231a06;
    --olive-ink: #2e3914;
    --green: #009d58;
    --pad: clamp(20px, 8vw, 144px);
    --container-pad: 32px;
    --section-y: 72px;
    --cta-w: 220px;
    --hero-text-w: 600px;
  }

  *, *::before, *::after { box-sizing: border-box; }
  a { color: inherit; text-decoration: none; }

  /* ── Section shell ───────────────────────────────────────────────── */
  .section { padding: var(--section-y) var(--pad); display: flex; flex-direction: column; }
  .stack { display: flex; flex-direction: column; }

  /* ── Typography ──────────────────────────────────────────────────── */
  .sec-title { font-weight: 400; font-size: 40px; color: var(--olive-title); text-transform: capitalize; line-height: 1.5; }
  .sec-lead  { font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.5; }
  .sub-title { font-weight: 500; font-size: 24px; color: var(--ink); line-height: 1.5; }
  .sub-lead  { font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.5; }
  .card-h    { font-weight: 500; font-size: 20px; color: var(--ink); line-height: 1.5; }
  .card-p    { font-weight: 400; font-size: 16px; color: var(--muted); line-height: 1.5; }

  /* ── Hero ────────────────────────────────────────────────────────── */
  .hero {
    min-height: clamp(440px, 29vw, 552px);
    padding: 0 var(--pad);
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    background: radial-gradient(125% 210% at 100% -8%, #4f583b 0%, #363a2c 50%, #1d1d1d 100%);
