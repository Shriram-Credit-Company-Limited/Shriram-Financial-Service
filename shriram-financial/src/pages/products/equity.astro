  /* ── Buttons ─────────────────────────────────────────────────────── */
  .btn-gold {
    background: var(--gold-btn);
    height: 40px;
    width: var(--cta-w);
    border: 0;
    border-radius: 4px;
    -webkit-appearance: none;
    appearance: none;
    cursor: pointer;
    font-family: inherit;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px 20px;
    font-weight: 500;
    font-size: 12px;
    color: var(--olive-ink);
    white-space: nowrap;
  }

  /* ── Cards ───────────────────────────────────────────────────────── */
  .card {
    background: var(--card);
    border: 1px solid var(--card-border);
    border-radius: 24px;
    padding: var(--container-pad);
    display: flex;
    flex-direction: column;
    gap: 16px;
