---
import BaseLayout from '../../layouts/BaseLayout.astro';

const ipoTypes = [
  { label: 'Mainboard IPO', desc: 'Large companies (₹10 crore+ paid-up capital) listing on NSE/BSE under full SEBI disclosure norms, typically well-covered by analysts.', tag: 'Large Cap' },
  { label: 'SME IPO', desc: 'SMEs with ₹1–25 crore paid-up capital list on NSE Emerge or BSE SME. Higher growth potential — requires thorough due diligence.', tag: 'High Growth' },
  { label: 'Offer for Sale (OFS)', desc: 'Promoters or PE investors sell existing stakes — no new capital raised by the company. Shares transfer directly from seller to buyer.', tag: 'Secondary' },
];

const steps = [
  { n: '01', title: 'Check Upcoming IPOs', desc: 'Browse all live and upcoming IPOs on the Shriram platform. Read the DRHP, review financials, and check GMP and subscription trends.' },
  { n: '02', title: 'Enter Bid Details', desc: 'Choose the price band, lot size, and bid quantity. You can bid at the cut-off price or a specific price within the band.' },
  { n: '03', title: 'ASBA / UPI Mandate', desc: 'Funds are blocked in your bank account via ASBA or UPI mandate — no outflow until allotment. Blocked amounts earn interest.' },
  { n: '04', title: 'Allotment & Listing', desc: 'Allotment is done by lottery (if oversubscribed). Shares are credited to your Demat before listing day. Non-allotment amounts are unblocked immediately.' },
];

const timeline = [
  { label: 'IPO Open Date', desc: 'Issue opens for bidding — typically 3 days. Price band and lot size are fixed.' },
  { label: 'IPO Close Date', desc: 'Last day to place bids. Revisions or cancellations must be done before close time (typically 5 PM).' },
  { label: 'Basis of Allotment', desc: 'Published 6 days after close. Check allotment status on BSE/NSE or Shriram platform.' },
  { label: 'Refund / Unblocking', desc: 'Non-allotted UPI mandates are released within T+1 day of allotment. ASBA amounts are also unblocked.' },
  { label: 'Demat Credit', desc: 'Shares credited to your Demat account one day before listing, typically T+5 or T+6 from close date.' },
  { label: 'Listing Day', desc: 'Stock begins trading on NSE/BSE. You can hold for the long term or book profits on listing day.' },
];

const risks = [
  { n: '01', label: 'Overvaluation Risk', desc: 'IPO prices are set by investment bankers favouring the issuer. Some IPOs list at or below issue price — always analyse fundamentals before applying.' },
  { n: '02', label: 'Non-Allotment Risk', desc: 'Oversubscribed IPOs allocate by lottery in the retail category. You may bid and receive nothing — your funds are simply unblocked.' },
  { n: '03', label: 'Listing Volatility', desc: 'Stocks can swing wildly on listing day — listing high then crashing, or opening below issue price. Market sentiment dominates day-one price action.' },
  { n: '04', label: 'Lock-In Risk', desc: 'Anchor and promoter shares are locked for 30–90 days. Selling pressure after lock-in expiry can sharply depress the post-listing price.' },
];

const faqs = [
  { q: 'What is ASBA in an IPO application?', a: 'ASBA (Application Supported by Blocked Amount) blocks your bid amount in your bank account instead of transferring it. Interest keeps accruing; the amount is debited only on allotment and immediately unblocked if you don\'t get shares.' },
  { q: 'Can I apply for IPO through Shriram Financial Services?', a: 'Yes. Apply via the Antara app or web portal using UPI or ASBA. View upcoming IPOs, track allotment status, and receive Demat credit — all in one place.' },
  { q: 'What is the minimum lot size for IPO applications?', a: 'SEBI sets 1 lot as the retail minimum — typically ₹10,000–₹15,000 per lot (10–200 shares). HNI/Non-Institutional Investors must bid a minimum of ₹2 lakh.' },
  { q: 'Is there a GMP (Grey Market Premium) and should I trust it?', a: 'GMP reflects unofficial pre-listing demand but is unregulated and unreliable. Use it as one data point only — always analyse the company\'s fundamentals before applying.' },
  { q: 'How many IPO applications can I submit?', a: 'One application per PAN card in the Retail category. Duplicate PAN applications are rejected entirely. Family members with separate PANs can each apply independently.' },
];
---

<BaseLayout
  title="IPO 2026 — Apply Online ASBA UPI Upcoming IPOs India | Shriram"
  description="Apply for upcoming IPO 2026 online via ASBA or UPI on Shriram Financial Services. Track allotment, get Demat credit T+5/T+6, and zero brokerage on application. Start today."
>

  <!-- ══ 1. HERO ═══════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[var(--color-dark-800)]">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[560px] w-[560px] rounded-full bg-[var(--color-brand)]/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-32 left-0 h-80 w-80 rounded-full bg-[var(--color-brand)]/5 blur-3xl"></div>
    <div class="site-wrap relative py-[120px]">
      <p class="equity-reveal text-[14px] font-medium tracking-[.04em] text-[var(--color-brand)]">Initial Public Offering</p>
      <h1 class="equity-reveal mt-[22px] max-w-[880px] text-[clamp(32px,4vw,52px)] font-bold leading-[1.06] text-white" style="font-family:var(--font-display)">
        Apply for <span class="text-[var(--color-brand)]">IPO 2026</span> — Before They Hit the Market
      </h1>
      <p class="equity-reveal mt-[26px] max-w-[600px] text-[18px] leading-relaxed text-white/70">
        Access all upcoming Mainboard and SME IPOs through the Shriram platform. Apply via UPI or ASBA, track allotment, and receive shares directly to your Demat.
      </p>
      <div class="equity-reveal mt-[38px] flex flex-wrap gap-[14px]">
        <a href="/about/open-demat-account/" class="btn-primary">Apply for IPO Now</a>
        <a href="/about/support/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Talk to RM</a>
      </div>
      <div class="equity-reveal mt-[54px] flex flex-wrap gap-x-9 gap-y-3 border-t border-white/15 pt-9">
        {['✓ Zero brokerage on application', '✓ UPI & ASBA support', '✓ Real-time allotment tracking', '✓ Demat credit T+5/T+6'].map(f => (
          <span class="text-[15px] font-medium text-white/90">
            <span class="mr-2 text-[var(--color-brand)]">{f.slice(0,1)}</span>{f.slice(1)}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 2. WHAT IS AN IPO ══════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto grid max-w-[1000px] items-start gap-[72px] lg:grid-cols-[5fr_7fr]">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Types of IPO &amp; <span class="text-[var(--color-brand)]">Offer for Sale</span>
        </h2>
        <div class="space-y-5 text-[17px] leading-relaxed text-[var(--color-muted)]">
          <p>Not all public offerings are the same. Understanding the type helps you evaluate risk, pricing, and post-listing behaviour.</p>
          <p>Mainboard IPOs follow full SEBI disclosure norms while SME IPOs offer higher growth potential. Offer for Sale (OFS) involves promoters selling existing stakes without raising new capital.</p>
        </div>
      </div>
      <div class="equity-reveal mx-auto mt-[76px] max-w-[1000px] border-t border-[var(--color-n400)] pt-[60px]">
        <div class="grid gap-5 sm:grid-cols-3">
          {ipoTypes.map((t, i) => (
            <div class="product-card-light flex flex-col gap-4 p-[34px]" style={`animation-delay:${i*60}ms`}>
              <span class="inline-flex w-fit rounded-full bg-[var(--color-brand)]/15 px-3 py-1 text-[11px] font-bold uppercase tracking-wide text-[var(--color-brand-deep)]">{t.tag}</span>
              <h3 class="text-[17px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{t.label}</h3>
              <p class="text-[13px] leading-relaxed text-[var(--color-muted)]">{t.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 3. HOW TO APPLY ════════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How to <span class="text-[var(--color-brand)]">Apply for an IPO</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Four steps from browsing to your Demat credit on allotment day.</p>
      </div>
      <div class="equity-reveal steps-grid overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        {steps.map(s => (
          <div class="px-[30px] py-[34px]">
            <div class="mb-[22px] font-display text-[34px] font-normal leading-none text-[var(--color-brand)]">{s.n}</div>
            <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">{s.title}</h4>
            <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 4. TIMELINE ════════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          IPO Timeline — Application <span class="text-[var(--color-brand)]">to Listing</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">From the day the IPO opens to the moment shares list on exchange — every key milestone.</p>
      </div>
      <div class="equity-reveal space-y-3">
        {timeline.map((t, i) => (
          <div class="flex items-start gap-5 rounded-[16px] border border-[var(--color-n400)] bg-[#f8f6f1] p-5" style={`animation-delay:${i*40}ms`}>
            <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-[var(--color-dark-olive)] text-[11px] font-bold text-[var(--color-brand)]">{i+1}</span>
            <div>
              <h3 class="text-[14px] font-semibold text-[var(--color-ink)]">{t.label}</h3>
              <p class="mt-1 text-[13px] text-[var(--color-muted)]">{t.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 4b. IPO GLOSSARY ══════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          IPO Glossary — <span class="text-[var(--color-brand)]">8 Key Terms Explained</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Know your IPO terminology before you apply — from GMP to DRHP to Kostak.</p>
      </div>
      <div class="equity-reveal grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { term: 'GMP', full: 'Grey Market Premium', def: 'Unofficial pre-listing price premium trading in the informal grey market. Unreliable but widely tracked as a sentiment indicator.' },
          { term: 'Lot Size', full: 'Minimum Bid Quantity', def: 'The minimum number of shares you must apply for. SEBI sets this so retail bids fall between ₹10,000–₹15,000.' },
          { term: 'Price Band', full: 'Price Range for Bidding', def: 'The lower and upper price limits within which you can bid. You can bid at the cut-off price to accept whatever price the company sets.' },
          { term: 'QIB', full: 'Qualified Institutional Buyer', def: 'SEBI-defined institutions (mutual funds, FPIs, banks) that get 50% of mainboard IPO allocation reserved for them.' },
          { term: 'NII', full: 'Non-Institutional Investor', def: 'HNIs and corporates bidding ₹2 lakh or more. Get 15% of mainboard IPO allocation. No lottery — proportionate allotment.' },
          { term: 'DRHP', full: 'Draft Red Herring Prospectus', def: 'The full IPO document filed with SEBI before the issue. Contains company financials, risk factors, objects of the issue, and promoter details.' },
          { term: 'Allotment', full: 'Share Allocation', def: 'The process of assigning shares to applicants. Retail is by lottery if oversubscribed; NII is proportionate to bid size.' },
          { term: 'Kostak', full: 'Application Premium', def: 'Amount paid by one investor to buy another\'s IPO application in the grey market — purely speculative and legally unenforceable.' },
        ].map((g, i) => (
          <div class="product-card-light flex flex-col gap-3 p-[28px]" style={`animation-delay:${i*40}ms`}>
            <div class="flex h-10 w-auto min-w-[60px] items-center justify-center rounded-[10px] bg-[var(--color-dark-olive)] px-3 self-start">
              <span class="text-[12px] font-bold text-[var(--color-brand)]">{g.term}</span>
            </div>
            <h4 class="text-[15px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{g.full}</h4>
            <p class="text-[12.5px] leading-relaxed text-[var(--color-muted)]">{g.def}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 4c. LISTED IPO PERFORMANCE ════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Recent IPO Listing <span class="text-[var(--color-brand)]">Performance</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Illustrative data showing how recently listed IPOs performed on their listing day. Past performance is not indicative of future results.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Company</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Sector</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Issue Price</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Listing Price</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Listing Gain</th>
              </tr>
            </thead>
            <tbody>
              {[
                { co: 'TechVenture Ltd*', sector: 'Technology', issue: '₹420', listing: '₹612', gain: '+45.7%' },
                { co: 'HealthCare Systems*', sector: 'Healthcare', issue: '₹280', listing: '₹336', gain: '+20.0%' },
                { co: 'FinServ Capital*', sector: 'Financial Services', issue: '₹560', listing: '₹504', gain: '-10.0%' },
                { co: 'GreenEnergy Corp*', sector: 'Renewable Energy', issue: '₹190', listing: '₹247', gain: '+30.0%' },
                { co: 'RetailChain Ltd*', sector: 'FMCG / Retail', issue: '₹340', listing: '₹388', gain: '+14.1%' },
              ].map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.co}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.sector}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.issue}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.listing}</td>
                  <td class={`border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold ${r.gain.startsWith('+') ? 'text-green-700' : 'text-red-600'}`}>{r.gain}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
      <p class="mt-4 text-center text-[13px] text-[var(--color-muted)]">*Illustrative placeholder companies. Not real IPO data. Consult Shriram Research for live IPO analysis.</p>
    </div>
  </section>

  <!-- ══ 5. RISKS ════════════════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Risks of <span class="text-[var(--color-brand)]">IPO Investing</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Understand what can move against you before you apply.</p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {risks.map(r => (
          <div class="equity-reveal rounded-[18px] bg-[var(--color-dark-800)] p-[36px]">
            <div class="mb-[18px] text-[48px] font-bold leading-none text-[var(--color-brand)]/25">{r.n}</div>
            <h4 class="mb-3 text-[20px] font-medium text-white" style="font-family:var(--font-display)">{r.label}</h4>
            <p class="text-[14.5px] leading-relaxed text-white/60">{r.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 6. FAQ ════════════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Frequently Asked <span class="text-[var(--color-brand)]">Questions</span>
        </h2>
      </div>
      <div class="equity-reveal mx-auto max-w-[840px] border-t border-[var(--color-n400)]">
        {faqs.map(item => (
          <details class="eq-faq group border-b border-[var(--color-n400)]">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-5 py-[26px] px-2">
              <span class="text-[18px] font-semibold text-[var(--color-ink)]">{item.q}</span>
              <span class="shrink-0 text-[22px] leading-none text-[var(--color-brand)] transition-transform duration-300 group-open:rotate-45">+</span>
            </summary>
            <div class="overflow-hidden px-2 pb-0 text-[16px] leading-relaxed text-[var(--color-muted)] transition-all duration-300 group-open:pb-[28px]">
              <p class="max-w-[680px]">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 7. FINAL CTA ══════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal overflow-hidden rounded-[22px] bg-[var(--color-dark-800)] px-[60px] py-[64px] text-center">
        <h3 class="mx-auto max-w-[560px] text-[38px] font-bold leading-[1.12] text-white" style="font-family:var(--font-display)">Don't Miss the Next Big IPO</h3>
        <p class="mx-auto mt-[18px] max-w-[480px] text-[17px] leading-relaxed text-white/70">Open your Demat account and be ready for every upcoming IPO. Zero commission. Instant UPI application. Fast allotment tracking.</p>
        <div class="mt-[34px] flex flex-wrap justify-center gap-[14px]">
          <a href="/about/open-demat-account/" class="btn-primary">Open Demat Account</a>
          <a href="/about/support/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Talk to an RM</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .equity-reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s cubic-bezier(0.22, 0.61, 0.36, 1), transform 0.7s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .equity-reveal.in-view { opacity: 1; transform: none; }

  .steps-grid { display: grid; grid-template-columns: repeat(2, 1fr); }
  .steps-grid > * { border-right: 1px solid var(--color-n400); border-bottom: 1px solid var(--color-n400); }
  .steps-grid > *:nth-child(2n) { border-right: 0; }
  .steps-grid > *:nth-last-child(-n+2) { border-bottom: 0; }
  @media (min-width: 1024px) {
    .steps-grid { grid-template-columns: repeat(4, 1fr); }
    .steps-grid > * { border-right: 1px solid var(--color-n400); border-bottom: 0; }
    .steps-grid > *:last-child { border-right: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .equity-reveal { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).classList.add('in-view');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.10 });
  document.querySelectorAll('.equity-reveal').forEach(el => obs.observe(el));

  document.querySelectorAll<HTMLDetailsElement>('.eq-faq').forEach(d => {
    d.addEventListener('toggle', () => {
      if (d.open) document.querySelectorAll<HTMLDetailsElement>('.eq-faq').forEach(o => { if (o !== d) o.removeAttribute('open'); });
    });
  });
</script>
