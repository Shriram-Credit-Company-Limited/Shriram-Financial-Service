---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="IPO 2026 — Apply for IPO Online | Shriram Financial Services"
  description="Apply for IPO 2026 online with Shriram. View open IPOs, upcoming IPO calendar, GMP today, allotment status, and step-by-step IPO application guide. SEBI-registered."
>

  <!-- ══ S1 HERO ════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[var(--color-dark-800)] py-[100px] lg:py-[120px]">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[560px] w-[560px] rounded-full bg-[var(--color-brand)]/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-32 left-0 h-80 w-80 rounded-full bg-[var(--color-brand)]/5 blur-3xl"></div>
    <div class="site-wrap relative">
      <h1 class="equity-reveal mt-0 max-w-[880px] text-[clamp(32px,4vw,52px)] font-bold leading-[1.06] text-white" style="font-family:var(--font-display)">
        Apply for <span class="text-[var(--color-brand)]">IPO 2026</span> — Open &amp; Upcoming IPOs in India
      </h1>
      <p class="equity-reveal mt-[26px] max-w-[600px] text-[18px] leading-relaxed text-white/70">
        SEBI-regulated IPO application platform. Zero brokerage on IPO. Apply via UPI/ASBA. Open a Demat account to apply for IPOs in minutes.
      </p>
      <div class="equity-reveal mt-[38px] flex flex-wrap gap-[14px]">
        <a href="/about/open-demat-account/" class="btn-primary">Apply for IPO</a>
        <a href="/about/open-demat-account/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Open Demat Account</a>
      </div>
      <div class="equity-reveal mt-[54px] flex flex-wrap gap-x-9 gap-y-3 border-t border-white/15 pt-9">
        {['✓ SEBI-regulated', '✓ Zero IPO brokerage', '✓ NSE & BSE listed', '✓ UPI/ASBA supported'].map(f => (
          <span class="text-[15px] font-medium text-white/90">{f}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S2 WHAT IS AN IPO ═════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          What is an <span class="text-[var(--color-brand)]">IPO?</span> — Meaning &amp; Definition
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">
          An IPO (Initial Public Offering) is when a private company raises capital by selling shares to the public for the first time on NSE or BSE.
        </p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Term</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Meaning</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Example</th>
              </tr>
            </thead>
            <tbody>
              <tr class="bg-white">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">IPO</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Company's first sale of shares to the public</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Tata Capital IPO 2025</td>
              </tr>
              <tr class="bg-[#f8f6f1]">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">Price Band</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Min &amp; max offer price range</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">₹120–₹130 per share</td>
              </tr>
              <tr class="bg-white">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">Lot Size</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Minimum shares you must apply for</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">1 lot = 115 shares</td>
              </tr>
              <tr class="bg-[#f8f6f1]">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">GMP</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Grey Market Premium — unofficial pre-listing indicator</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">₹+45 above issue price</td>
              </tr>
              <tr class="bg-white">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">QIB</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Qualified Institutional Buyers (banks, MFs, FIIs)</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Reserve 50% of issue</td>
              </tr>
              <tr class="bg-[#f8f6f1]">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">Retail</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Individual investors applying below ₹2L</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Reserve 35% of issue</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S3 HOW THE IPO PROCESS WORKS ══════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How the <span class="text-[var(--color-brand)]">IPO Process</span> Works — Step by Step
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">From SEBI filing to exchange listing — understand the 5-stage IPO lifecycle.</p>
      </div>
      <div class="equity-reveal steps-grid-5 overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="px-[30px] py-[34px]">
          <div class="mb-[22px] text-[34px] font-bold leading-none text-[var(--color-brand)]">01</div>
          <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">SEBI Filing</h4>
          <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">Company files DRHP (Draft Red Herring Prospectus) with SEBI for approval.</p>
        </div>
        <div class="px-[30px] py-[34px]">
          <div class="mb-[22px] text-[34px] font-bold leading-none text-[var(--color-brand)]">02</div>
          <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">DRHP Approval</h4>
          <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">SEBI reviews and approves the offer document within 30 days.</p>
        </div>
        <div class="px-[30px] py-[34px]">
          <div class="mb-[22px] text-[34px] font-bold leading-none text-[var(--color-brand)]">03</div>
          <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">Subscription Window</h4>
          <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">IPO opens for 3 days. Apply via UPI ASBA through your broker.</p>
        </div>
        <div class="px-[30px] py-[34px]">
          <div class="mb-[22px] text-[34px] font-bold leading-none text-[var(--color-brand)]">04</div>
          <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">Allotment</h4>
          <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">Shares allotted based on subscription. Refund for unallotted applications.</p>
        </div>
        <div class="px-[30px] py-[34px]">
          <div class="mb-[22px] text-[34px] font-bold leading-none text-[var(--color-brand)]">05</div>
          <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">Listing Day</h4>
          <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">Shares list on NSE/BSE on T+6 day. Start trading from listing price.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S4 OPEN IPOS ════════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Open <span class="text-[var(--color-brand)]">IPOs</span> — Apply Now
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Check the Shriram platform for currently open IPOs. Apply directly via UPI mandate.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">IPO Name</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Open Date</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Close Date</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Price Band</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Lot Size</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">CTA</th>
              </tr>
            </thead>
            <tbody>
              <tr class="bg-white">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">ABC Technologies Ltd</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">18 Jun 2026</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">20 Jun 2026</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">₹210–₹230</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">65 shares</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px]"><a href="/about/open-demat-account/" class="text-[14px] font-semibold text-[var(--color-brand)]">Apply Now →</a></td>
              </tr>
              <tr class="bg-[#f8f6f1]">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">XYZ Infrastructure Ltd</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">17 Jun 2026</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">19 Jun 2026</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">₹85–₹90</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">166 shares</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px]"><a href="/about/open-demat-account/" class="text-[14px] font-semibold text-[var(--color-brand)]">Apply Now →</a></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
      <p class="mt-4 text-[13px] text-[var(--color-muted)]">* Sample data. Visit Shriram platform for live IPO listings.</p>
      <div class="equity-reveal mt-[40px] text-center">
        <a href="/about/open-demat-account/" class="btn-primary">View All Open IPOs →</a>
      </div>
    </div>
  </section>

  <!-- ══ S5 UPCOMING IPOS ════════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Upcoming <span class="text-[var(--color-brand)]">IPOs 2026</span> — Full Calendar
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Stay ahead of the market with our upcoming IPO calendar. New IPOs added weekly.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">IPO Name</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Expected Open</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Price Band (Est.)</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Issue Size</th>
              </tr>
            </thead>
            <tbody>
              <tr class="bg-white">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">PQR Pharma Ltd</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Jul 2026</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">₹350–₹380</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">₹2,400 Cr</td>
              </tr>
              <tr class="bg-[#f8f6f1]">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">LMN Fintech Ltd</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Jul 2026</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">₹200–₹220</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">₹1,100 Cr</td>
              </tr>
              <tr class="bg-white">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">RST Renewables</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Aug 2026</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">₹120–₹140</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">₹800 Cr</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
      <p class="mt-4 text-[13px] text-[var(--color-muted)]">* Indicative dates. Subject to SEBI approval.</p>
    </div>
  </section>

  <!-- ══ S6 GMP ══════════════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          IPO <span class="text-[var(--color-brand)]">GMP Today</span> — Grey Market Premium Explained
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">GMP (Grey Market Premium) is the unofficial premium at which IPO shares trade before listing. It is NOT a guarantee of listing price.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Term</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Meaning</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Example</th>
              </tr>
            </thead>
            <tbody>
              <tr class="bg-white">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">GMP</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Unofficial premium above issue price</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">GMP ₹+50 on ₹200 IPO = expected listing ~₹250</td>
              </tr>
              <tr class="bg-[#f8f6f1]">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">Kostak Rate</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Price at which application is bought/sold</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">₹500 kostak = ₹500 per lot regardless of allotment</td>
              </tr>
              <tr class="bg-white">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">Subject to Sauda</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Deal where only allotted applications are traded</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Higher risk than kostak</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
      <p class="mt-4 text-[13px] text-[var(--color-muted)]">Grey market trading is unofficial and unregulated. Do not make investment decisions solely based on GMP.</p>
    </div>
  </section>

  <!-- ══ S7 HOW TO APPLY ════════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How to <span class="text-[var(--color-brand)]">Apply for an IPO</span> — Step by Step
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Apply for any IPO in under 5 minutes using UPI ASBA.</p>
      </div>
      <div class="equity-reveal steps-grid-5 overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="px-[30px] py-[34px]">
          <div class="mb-[22px] text-[34px] font-bold leading-none text-[var(--color-brand)]">01</div>
          <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">Open Demat</h4>
          <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">You need an active Demat + Trading account with Shriram to apply for IPOs.</p>
        </div>
        <div class="px-[30px] py-[34px]">
          <div class="mb-[22px] text-[34px] font-bold leading-none text-[var(--color-brand)]">02</div>
          <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">Login &amp; Select IPO</h4>
          <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">Log in to Antara app. Go to IPO section. Choose the open IPO.</p>
        </div>
        <div class="px-[30px] py-[34px]">
          <div class="mb-[22px] text-[34px] font-bold leading-none text-[var(--color-brand)]">03</div>
          <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">Enter Lot Size &amp; Bid</h4>
          <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">Enter number of lots and your bid price (within price band).</p>
        </div>
        <div class="px-[30px] py-[34px]">
