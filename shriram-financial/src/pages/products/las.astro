---
import BaseLayout from '../../layouts/BaseLayout.astro';

const benefits = [
  { title: 'No Need to Sell Shares', desc: 'Pledge stocks as collateral without selling — shares stay in your demat account, earning dividends and bonus shares throughout the loan.' },
  { title: 'High Loan Amount', desc: 'Borrow up to 50–60% of pledged share value. Large portfolios unlock significant liquidity without any asset liquidation.' },
  { title: 'Flexible Overdraft', desc: 'Draw funds when needed, repay when convenient, and redraw again — pay interest only on the outstanding amount, not the total limit.' },
  { title: 'Low Interest Rates', desc: 'LAS rates start at 10% p.a. — far below unsecured personal loans and credit cards, because your shares secure the lender.' },
  { title: 'Continue Earning Benefits', desc: 'Dividends, bonus shares, and rights issues on pledged stocks are all credited to your demat account during the loan period.' },
  { title: 'Digital Pledge Process', desc: 'Pledge creation is 100% online via CDSL/NSDL. No physical certificates or branch visits — done within minutes.' },
];

const eligibleSecurities = [
  { type: 'BSE/NSE Listed Shares', ltv: '50–60%', example: 'NIFTY 50, NIFTY 100, large-cap stocks' },
  { type: 'Mid-cap Stocks', ltv: '40–50%', example: 'NIFTY Midcap 150 constituents (lender-approved list)' },
  { type: 'ETFs (Equity)', ltv: '50–60%', example: 'Nifty BeES, SBI ETF Nifty 50' },
  { type: 'Sovereign Gold Bonds', ltv: '60–70%', example: 'RBI-issued SGBs held in demat form' },
];

const steps = [
  { n: '01', title: 'Submit Pledge Request', desc: 'Select the stocks you want to pledge from your demat account. Shriram initiates a pledge request to CDSL/NSDL on your behalf.' },
  { n: '02', title: 'Authorise via CDSL/NSDL', desc: 'You receive a TPIN-based authorisation request on your registered mobile and email. One-time approval authorises the pledge.' },
  { n: '03', title: 'Pledge Confirmed & Limit Set', desc: 'Once CDSL/NSDL confirms the pledge mark, your loan limit is activated based on the LTV of pledged shares.' },
  { n: '04', title: 'Withdraw & Repay Anytime', desc: 'Draw funds to your bank account. Repay whenever convenient. The pledge is released when the loan is fully repaid.' },
];

const faqs = [
  { q: 'What is Loan Against Stocks (LAS)?', a: 'LAS is a secured overdraft where you pledge equity shares or ETFs in your demat account. CDSL/NSDL marks a lien on the pledged securities — you retain ownership and dividends, but cannot sell until the lien is lifted on full repayment.' },
  { q: 'Which stocks are eligible for pledging?', a: 'Lenders accept NIFTY 50/100 constituents, large-cap and mid-cap exchange-listed shares, and ETFs from their approved list. Penny stocks, illiquid shares, and stocks under special surveillance are ineligible.' },
  { q: 'Do I still receive dividends on pledged shares?', a: 'Yes — pledging transfers only a lien, not ownership. Dividends, bonus shares, rights, and stock splits are credited to your demat account throughout the loan period.' },
  { q: 'What happens if the share price falls sharply?', a: 'If pledged value drops and the loan exceeds the LTV (typically 50–60%), Shriram issues a margin call. You must pledge more shares, deposit cash, or repay part of the loan. The system alerts you well before forced action is triggered.' },
  { q: 'How is LAS different from Margin Trading Facility (MTF)?', a: 'MTF is specifically for buying more securities on margin in your trading account — the bought shares serve as collateral. LAS is a general-purpose credit line against existing demat holdings, disbursed to your bank account for any use, typically at lower rates and longer tenors.' },
];
---

<BaseLayout
  title="Loan Against Shares India — Pledge Stocks for Loan LAS | Shriram"
  description="Pledge your equity shares for instant liquidity without selling. Low rates from 10.5% p.a., flexible overdraft, dividends continue. Apply for LAS with Shriram today."
>

  <!-- ══ 1. HERO ═══════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[var(--color-dark-800)]">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[560px] w-[560px] rounded-full bg-[var(--color-brand)]/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-32 left-0 h-80 w-80 rounded-full bg-[var(--color-brand)]/5 blur-3xl"></div>
    <div class="site-wrap relative py-[120px]">
      <p class="equity-reveal text-[14px] font-medium tracking-[.04em] text-[var(--color-brand)]">Loan Against Stocks</p>
      <h1 class="equity-reveal mt-[22px] max-w-[880px] text-[clamp(32px,4vw,52px)] font-bold leading-[1.06] text-white" style="font-family:var(--font-display)">
        Borrow Against Your Share <span class="text-[var(--color-brand)]">Portfolio Instantly</span>
      </h1>
      <p class="equity-reveal mt-[26px] max-w-[600px] text-[18px] leading-relaxed text-white/70">
        Pledge your equity holdings and unlock a flexible credit line — without selling a single share. Your stocks stay, your dividends continue, and you get the funds you need.
      </p>
      <div class="equity-reveal mt-[38px] flex flex-wrap gap-[14px]">
        <a href="/about/open-demat-account/" class="btn-primary">Get Started</a>
        <a href="/about/support/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Talk to RM</a>
      </div>
      <div class="equity-reveal mt-[54px] flex flex-wrap gap-x-9 gap-y-3 border-t border-white/15 pt-9">
        {['✓ No Share Sale', '✓ Keep Dividends', '✓ Flexible Overdraft', '✓ Low Interest Rates'].map(f => (
          <span class="text-[15px] font-medium text-white/90">
            <span class="mr-2 text-[var(--color-brand)]">{f.slice(0,1)}</span>{f.slice(1)}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 2. WHY CHOOSE LAS ══════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto grid max-w-[1000px] items-start gap-[72px] lg:grid-cols-[5fr_7fr]">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Why Choose <span class="text-[var(--color-brand)]">LAS?</span>
        </h2>
        <div class="space-y-5 text-[17px] leading-relaxed text-[var(--color-muted)]">
          <p>Loan Against Stocks lets you access the value locked in your share portfolio without triggering a sale event or paying capital gains tax.</p>
          <p>A CDSL/NSDL pledge marks a lien on your shares — you retain all shareholder rights including dividends, bonuses, and voting rights throughout the loan tenure.</p>
        </div>
      </div>
      <div class="equity-reveal mx-auto mt-[76px] max-w-[1000px] border-t border-[var(--color-n400)] pt-[60px]">
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {benefits.map((b, i) => (
            <div class="product-card-light flex flex-col gap-3 p-[28px]" style={`animation-delay:${i*60}ms`}>
              <h3 class="text-[16px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{b.title}</h3>
              <p class="text-[13px] leading-relaxed text-[var(--color-muted)]">{b.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 3. ELIGIBLE SECURITIES & LTV ══════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Eligible Securities &amp; <span class="text-[var(--color-brand)]">LTV Ratios</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Loan limits depend on the type and market value of securities pledged. Only exchange-listed, lender-approved shares qualify.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto"><table class="w-full text-[15.5px]">
          <thead><tr class="bg-[var(--color-dark-olive)]"><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Security Type</th><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">LTV Ratio</th><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Examples</th></tr></thead>
          <tbody>{eligibleSecurities.map((r,i) => (<tr class={i%2===0?'bg-white':'bg-[#f8f6f1]'}><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.type}</td><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-bold text-[var(--color-brand)]">{r.ltv}</td><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.example}</td></tr>))}</tbody>
        </table></div>
      </div>
    </div>
  </section>

  <!-- ══ 4. HOW IT WORKS ════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How to Get a Loan <span class="text-[var(--color-brand)]">Against Stocks</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Four steps from pledge request to funds in your bank account.</p>
      </div>
      <div class="equity-reveal steps-grid overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        {steps.map(s => (
          <div class="px-[30px] py-[34px]">
            <div class="mb-[22px] font-display text-[34px] font-normal leading-none text-[var(--color-brand)]">{s.n}</div>
            <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">{s.title}</h4>
            <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 5. FAQ ════════════════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Frequently Asked <span class="text-[var(--color-brand)]">Questions</span>
        </h2>
      </div>
      <div class="equity-reveal mx-auto max-w-[840px] border-t border-[var(--color-n400)]">
        {faqs.map(item => (
          <details class="eq-faq group border-b border-[var(--color-n400)]">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-5 py-[26px] px-2">
              <span class="text-[18px] font-semibold text-[var(--color-ink)]">{item.q}</span>
              <span class="shrink-0 text-[22px] leading-none text-[var(--color-brand)] transition-transform duration-300 group-open:rotate-45">+</span>
            </summary>
            <div class="overflow-hidden px-2 pb-0 text-[16px] leading-relaxed text-[var(--color-muted)] transition-all duration-300 group-open:pb-[28px]">
              <p class="max-w-[680px]">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 6. FINAL CTA ══════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal overflow-hidden rounded-[22px] bg-[var(--color-dark-800)] px-[60px] py-[64px] text-center">
        <h3 class="mx-auto max-w-[560px] text-[38px] font-bold leading-[1.12] text-white" style="font-family:var(--font-display)">Make Your Portfolio Work Harder</h3>
        <p class="mx-auto mt-[18px] max-w-[480px] text-[17px] leading-relaxed text-white/70">Access funds without selling your shares. Keep your portfolio intact and growing while drawing the capital you need.</p>
        <div class="mt-[34px] flex flex-wrap justify-center gap-[14px]">
          <a href="/about/open-demat-account/" class="btn-primary">Apply Now</a>
          <a href="/about/support/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Talk to an RM</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .equity-reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s cubic-bezier(0.22, 0.61, 0.36, 1), transform 0.7s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .equity-reveal.in-view { opacity: 1; transform: none; }

  .steps-grid { display: grid; grid-template-columns: repeat(2, 1fr); }
  .steps-grid > * { border-right: 1px solid var(--color-n400); border-bottom: 1px solid var(--color-n400); }
  .steps-grid > *:nth-child(2n) { border-right: 0; }
  .steps-grid > *:nth-last-child(-n+2) { border-bottom: 0; }
  @media (min-width: 1024px) {
    .steps-grid { grid-template-columns: repeat(4, 1fr); }
    .steps-grid > * { border-right: 1px solid var(--color-n400); border-bottom: 0; }
    .steps-grid > *:last-child { border-right: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .equity-reveal { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).classList.add('in-view');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.10 });
  document.querySelectorAll('.equity-reveal').forEach(el => obs.observe(el));

  document.querySelectorAll<HTMLDetailsElement>('.eq-faq').forEach(d => {
    d.addEventListener('toggle', () => {
      if (d.open) document.querySelectorAll<HTMLDetailsElement>('.eq-faq').forEach(o => { if (o !== d) o.removeAttribute('open'); });
    });
  });
</script>
