---
import BaseLayout from '../../layouts/BaseLayout.astro';

const nfoSteps = [
  { n: '01', title: 'AMC Files SID with SEBI',      desc: "The Asset Management Company submits the Scheme Information Document and Statement of Additional Information to SEBI for review and approval." },
  { n: '02', title: 'SEBI Approves the NFO',         desc: "SEBI reviews and issues a launch window (typically 30 days). Approval confirms regulatory compliance — it does not imply a recommendation to invest." },
  { n: '03', title: 'Subscription Opens at ₹10/unit',desc: 'Investors apply during the subscription window. All subscribers get the same fixed entry price of ₹10 per unit regardless of when they apply.' },
  { n: '04', title: 'Subscription Window Closes',    desc: 'Subscriptions close after the NFO period. Allotment of units happens within 5 business days. The corpus is then deployed as per the stated strategy.' },
  { n: '05', title: 'NAV Declared — Fund Goes Live', desc: 'For open-ended funds, regular purchase and redemption begins at market-linked NAV. The fund is now available for ongoing SIP or lump-sum investment.' },
];

const keyFeatures = [
  { label: 'Entry Price',         val: '₹10 / unit',   desc: 'All subscribers enter at the same fixed face value. The low price is not a discount — units are simply new with no track record.' },
  { label: 'Subscription Window', val: '15–30 days',    desc: 'SEBI permits a maximum 30-day window. Most NFOs run 15–21 days. Close-ended NFOs do not reopen after the window.' },
  { label: 'Min Investment',      val: '₹500–₹5,000',  desc: "Minimum subscription varies by scheme — specified in each fund's SID. Most retail-oriented NFOs start at ₹500–₹1,000." },
  { label: 'Lock-In',             val: 'ELSS: 3 years', desc: 'Standard equity NFOs have no lock-in. ELSS NFOs carry a mandatory 3-year lock-in per Section 80C — earliest exit 36 months from unit allotment.' },
];

const nfoTypes = [
  { label: 'Open-Ended NFO',          desc: 'After the subscription period, the fund stays open for ongoing purchase and redemption at NAV. Most equity and debt NFOs are open-ended.', tag: 'Most Common' },
  { label: 'Close-Ended NFO',          desc: 'Fixed maturity — subscriptions accepted only during the NFO period. Units are listed on exchanges for secondary trading after closure.', tag: 'Fixed Term' },
  { label: 'ELSS NFO',                 desc: "New Equity Linked Saving Scheme fund launch. Offers 80C tax deduction up to ₹1.5 lakh/year with a mandatory 3-year lock-in.", tag: 'Tax Saving' },
  { label: 'Sectoral / Thematic NFO', desc: 'Focused on a specific sector (IT, pharma) or theme (ESG, manufacturing). Higher concentration risk — only suited for investors with a clear sectoral conviction.', tag: 'Concentrated' },
];

const onlineSteps = [
  { n: '01', title: 'Log In to Shriram Platform',  desc: 'Log in to the Shriram investor portal or mobile app. Navigate to Mutual Funds and select the Current NFOs section.' },
  { n: '02', title: 'Select the NFO Scheme',        desc: 'Review the scheme objective, AMC track record, and SID summary. Choose the NFO that matches your investment goal and risk profile.' },
  { n: '03', title: 'Enter Investment Amount',      desc: "Enter your investment amount. Minimum is typically ₹500–₹5,000 depending on the scheme's SID. SIP can be set up post-allotment for open-ended NFOs." },
  { n: '04', title: 'Choose Payment Mode',          desc: 'Pay via Net Banking, UPI, or Debit Card. Confirm the transaction after reviewing the order summary and scheme details.' },
  { n: '05', title: 'Receive Allotment Confirmation', desc: 'Allotment confirmation sent via email and SMS within 5 business days after NFO closure. Units appear in your demat account at ₹10/unit.' },
];

const nfoBenefits = [
  "Access to unique investment strategies and asset classes not yet available in existing funds.",
  "Entry at ₹10 face value — a clear, predictable starting NAV for easy return tracking.",
  "Opportunity to invest in emerging themes (EV, defence, manufacturing) at fund launch.",
  "Open-ended NFOs allow SIP setup immediately after allotment — no lock-in for most types.",
  "ELSS NFOs provide Section 80C deduction of up to ₹1.5 lakh with only a 3-year lock-in.",
];

const nfoRisks = [
  "No performance track record — unlike existing funds, there is zero historical return data to evaluate.",
  "Fund manager execution risk — strategy stated in SID may not be implemented as expected.",
  "Sectoral/thematic NFOs carry concentration risk — one sector downturn can hurt significantly.",
  "Most NFOs offer strategies already available via existing funds — the novelty is often overstated.",
  "Exit load of 1% typically applies if redeemed within 1 year — check the SID before investing.",
];

const evalChecklist = [
  { n: '01', label: 'AMC Reputation',  desc: "Choose NFOs from established AMCs — HDFC, SBI, ICICI Prudential, Nippon, Axis. Avoid lesser-known AMCs launching their first fund without a track record." },
  { n: '02', label: 'Fund Objective',  desc: "Read the SID carefully. The NFO strategy must be genuinely unique — not already covered by an existing fund. If a similar fund exists, choose the one with performance data." },
  { n: '03', label: 'Expense Ratio',   desc: "The NFO's stated expense ratio should be competitive vs similar existing funds. A high TER (above 1.5% for equity) erodes long-term returns significantly." },
  { n: '04', label: 'Asset Allocation',desc: 'Understand the benchmark, stock universe, and sectoral concentration. A diversified equity NFO carries far less risk than a thematic NFO in a single niche sector.' },
];

const vsRows = [
  { feature: 'Track Record',       nfo: 'None — brand new fund, zero history',              sip: 'Established fund with 3–5+ year return data' },
  { feature: 'NAV at Entry',       nfo: 'Fixed ₹10 — no real advantage over higher NAV',    sip: 'Current NAV, proportional units allotted' },
  { feature: 'Manager Risk',       nfo: 'Higher — untested strategy and team execution',     sip: 'Known fund manager track record visible' },
  { feature: 'Strategy Clarity',   nfo: 'Stated in SID — must be evaluated before entry',   sip: 'Demonstrated portfolio visible via fact sheets' },
  { feature: 'Lock-In',            nfo: 'ELSS: 3 years; others: none (open-end)',           sip: 'ELSS: 3 years per instalment; others: none' },
  { feature: 'Best For',           nfo: 'Unique strategy not in any existing fund',          sip: 'Regular disciplined wealth building over 5–10 years' },
];

const taxRows = [
  { type: 'Equity NFO — under 12 months',  rate: '20% flat (STCG)',                           note: 'Post-Budget 2024 rate' },
  { type: 'Equity NFO — over 12 months',   rate: '12.5% on gains above ₹1.25 lakh (LTCG)',   note: 'No indexation benefit' },
  { type: 'Debt NFO — under 24 months',    rate: 'As per income slab',                         note: 'Post April 2023 — no LTCG benefit for debt funds' },
  { type: 'Debt NFO — over 24 months',     rate: 'As per income slab',                         note: 'Indexation removed from April 2023' },
  { type: 'ELSS NFO',                       rate: '12.5% LTCG on gains above ₹1.25 lakh',     note: '3-year mandatory lock-in; 80C benefit up to ₹1.5 lakh' },
];

const faqs = [
  { q: 'What is an NFO in mutual funds?',
    a: "An NFO (New Fund Offer) is the initial launch of a new mutual fund scheme by an Asset Management Company. Like an IPO for shares, an NFO lets investors subscribe at ₹10 per unit during a limited window — after which the fund is managed and NAV moves with portfolio performance." },
  { q: 'Is it better to invest in an NFO or an existing mutual fund?',
    a: "For most investors, existing funds with established track records are lower risk. An NFO makes sense only if it offers a genuinely unique strategy not covered by any existing fund. The ₹10 NAV is NOT an advantage — what matters is future performance, not the entry price." },
  { q: 'What is the minimum investment in an NFO?',
    a: "Most NFOs allow a minimum of ₹500–₹5,000 for lump sum and ₹500 per instalment for SIP. The exact minimum amount is specified in each scheme's SID (Scheme Information Document)." },
  { q: 'Can I invest in an NFO via SIP?',
    a: "You can subscribe during the NFO period. Once the fund is open-ended and operational, you can set up regular SIPs just like any other mutual fund. Close-ended NFOs do not allow SIPs after the NFO closes." },
  { q: 'Is NFO better than existing mutual funds?',
    a: "Not necessarily. An NFO only makes sense if the fund strategy is unique and cannot be replicated by existing funds. Never invest in an NFO simply because the NAV is ₹10 — that offers no mathematical advantage over a fund with a NAV of ₹100 or ₹500." },
  { q: 'How do I apply for an NFO through Shriram?',
    a: "Log in to the Shriram platform, navigate to Mutual Funds, and look for the active NFO section. Select the scheme, choose your amount, and complete payment via your linked bank account. Units are allotted at ₹10 after the NFO closes." },
];
---

<BaseLayout
  title="NFO Mutual Fund Guide 2026 — New Fund Offer India | Shriram"
  description="Complete guide to NFO mutual fund investments in India 2026. Learn how NFOs work, types, how to evaluate and invest, and tax rules — with Shriram Financial Services."
>

  <!-- ══ 1. HERO ══════════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-inner">
      <h1>Complete Guide to <span class="g">NFO in Mutual Funds 2026</span></h1>
      <p class="lead">India's mutual fund landscape is growing rapidly, and New Fund Offers (NFOs) are at the heart of this expansion. From what NFOs are and how they work, to evaluating them before investing — this comprehensive guide covers everything for Indian retail and HNI investors.</p>
      <div class="cta-row">
        <a class="btn-gold" href="/about/open-demat-account/">Start Investing</a>
      </div>
      <div class="hero-feats">
        <div class="feats">
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;₹10 per unit entry</span></div>
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;SEBI-approved only</span></div>
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;0% commission (Direct)</span></div>
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;Compare vs existing funds</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 2. WHAT IS NFO ════════════════════════════════════════════════ -->
  <section class="section stack" id="sec-what" style="background:var(--sec-light);gap:48px">
    <div class="stack" style="gap:16px">
      <p class="sec-title">What is NFO? — New Fund Offer</p>
      <p class="sec-lead">An NFO (New Fund Offer) is the first-ever subscription offer for a mutual fund scheme launched by an AMC. Similar to an IPO in the stock market, it allows investors to buy units of a new scheme at a fixed price — typically ₹10 per unit — during a limited subscription window.</p>
      <p class="sec-lead">NFOs are regulated by SEBI under the SEBI Mutual Fund Regulations. The subscription period generally lasts 1–30 days, after which the scheme either closes (close-ended) or opens for regular SIP and lump-sum investment (open-ended). The ₹10 entry price is simply a starting point — it carries no mathematical advantage over a fund at a higher NAV.</p>
    </div>
    <div class="row-2">
      <div class="card">
        <p class="card-h">NFO Full Form in Mutual Funds</p>
        <p class="card-p">NFO stands for New Fund Offer. It is the initial launch period during which an AMC offers units of a new scheme to the public for the first time. The price is fixed at ₹10 per unit during this window — regardless of when you subscribe.</p>
      </div>
      <div class="card">
        <p class="card-h">NFO vs IPO — Key Difference</p>
        <p class="card-p">An IPO lists existing shares of a company on an exchange. An NFO creates a brand-new mutual fund scheme. Both have a fixed-price subscription window, but in an NFO there is no secondary price discovery — everyone gets ₹10 per unit.</p>
      </div>
    </div>
  </section>

  <!-- ══ 3. HOW NFO WORKS ══════════════════════════════════════════════ -->
  <section class="section stack" id="sec-how" style="background:var(--sec-tint);gap:48px">
    <div class="stack" style="gap:16px">
      <p class="sec-title">How NFO Works (Similar to IPO)</p>
      <p class="sec-lead">Every NFO goes through a five-stage regulatory and subscription process governed by SEBI. Understanding this sequence helps you time your entry correctly and avoid common mistakes.</p>
    </div>
    <div class="num-grid">
      {nfoSteps.map(s => (
        <div class="num-item">
          <span class="num-n">{s.n}</span>
          <h4>{s.title}</h4>
          <p>{s.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ══ 4. KEY FEATURES ══════════════════════════════════════════════ -->
  <section class="section stack" id="sec-features" style="background:var(--sec-light);gap:48px">
    <div class="stack" style="gap:16px">
      <p class="sec-title">Key Features of NFO</p>
      <p class="sec-lead">Four defining characteristics distinguish an NFO from investing in an existing mutual fund — understanding these helps you set the right expectations before subscribing.</p>
    </div>
    <div class="cat-grid cat-4">
      {keyFeatures.map(f => (
        <div class="cat metric-cat">
          <span class="metric-val">{f.val}</span>
          <h4>{f.label}</h4>
          <p>{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ══ 5. TYPES OF NFOS ══════════════════════════════════════════════ -->
  <section class="section stack" id="sec-types" style="background:var(--sec-tint);gap:48px">
    <div class="stack" style="gap:16px">
      <p class="sec-title">Types of NFOs</p>
      <p class="sec-lead">Not all NFOs are the same. Understanding each type helps you choose one aligned with your investment horizon, risk profile, and tax goals.</p>
    </div>
    <div class="cat-grid cat-4">
      {nfoTypes.map(t => (
        <div class="cat">
          <span class="nfo-tag">{t.tag}</span>
          <h4>{t.label}</h4>
          <p>{t.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ══ 6. HOW TO INVEST ══════════════════════════════════════════════ -->
  <section class="section stack" id="sec-invest" style="background:var(--sec-light);gap:48px">
    <div class="stack" style="gap:16px">
      <p class="sec-title">How to Invest in NFO</p>
      <p class="sec-lead">Five simple steps to subscribe to an active NFO through the Shriram platform. The entire process is digital, paperless, and takes under 10 minutes if your KYC is complete.</p>
    </div>
    <div class="num-grid">
      {onlineSteps.map(s => (
        <div class="num-item">
          <span class="num-n">{s.n}</span>
          <h4>{s.title}</h4>
          <p>{s.desc}</p>
        </div>
      ))}
    </div>
    <div class="row-2">
      <div class="card">
        <p class="card-h">Offline Process</p>
        <p class="card-p">Visit your nearest Shriram branch or the AMC office. Collect the NFO application form, fill in personal and investment details, and submit with a cheque or DD payable to the fund scheme name. Collect your acknowledgement receipt.</p>
      </div>
      <div class="card">
        <p class="card-h">Documents Required</p>
        <div class="check-list" style="margin-top:4px">
          {[
            'PAN card — mandatory for investments above ₹50,000',
            'Aadhaar or government-issued photo ID',
            'Address proof (Aadhaar, Passport, or Utility Bill)',
            'Cancelled cheque or bank passbook',
            'eKYC via SEBI-registered KRA (done digitally on the app)',
          ].map((item, i) => (
            <>
              {i > 0 && <div class="check-sep"></div>}
              <div class="check-row"><span class="ck">✓</span><p class="tx">{item}</p></div>
            </>
          ))}
        </div>
      </div>
    </div>
    <a class="btn-gold" href="/about/open-demat-account/" style="align-self:center">Start Investing</a>
  </section>

  <!-- ══ 7. BENEFITS & RISKS ════════════════════════════════════════ -->
  <section class="section stack" id="sec-benrisk" style="background:var(--sec-tint);gap:48px">
    <div class="stack" style="gap:16px">
      <p class="sec-title">NFO Benefits &amp; Risks</p>
      <p class="sec-lead">Every investment carries a risk-reward profile. Here is a balanced view before you subscribe to any NFO — weigh both sides carefully before committing capital.</p>
    </div>
    <div class="row-2">
      <div class="card">
        <p class="card-h">Benefits</p>
        <div class="check-list">
          {nfoBenefits.map((item, i) => (
            <>
              {i > 0 && <div class="check-sep"></div>}
              <div class="check-row"><span class="ck">✓</span><p class="tx">{item}</p></div>
            </>
          ))}
        </div>
      </div>
      <div class="card risk-disc-card">
        <p class="card-h" style="color:var(--olive-deep)">Risks to Understand</p>
        <div class="check-list">
          {nfoRisks.map((item, i) => (
            <>
              {i > 0 && <div class="check-sep"></div>}
              <div class="check-row"><span class="ck" style="color:#c84444">✗</span><p class="tx">{item}</p></div>
            </>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 8. HOW TO EVALUATE ════════════════════════════════════════════ -->
  <section class="section stack" id="sec-eval" style="background:var(--sec-light);gap:48px">
    <div class="stack" style="gap:16px">
      <p class="sec-title">How to Evaluate an NFO Before Investing</p>
      <p class="sec-lead">Since NFOs lack historical data, use this four-point framework from Shriram Financial Services before committing capital to any new fund offer.</p>
    </div>
    <div class="cat-grid cat-4">
      {evalChecklist.map(e => (
        <div class="cat risk-cat">
          <span class="num-n" style="font-size:36px">{e.n}</span>
          <h4>{e.label}</h4>
          <p>{e.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ══ 9. NFO vs SIP ═════════════════════════════════════════════════ -->
  <section class="section stack" id="sec-vs" style="background:var(--sec-tint);gap:48px">
    <div class="stack" style="gap:16px">
      <p class="sec-title">NFO vs Existing Mutual Fund (SIP)</p>
      <p class="sec-lead">Choosing between an NFO and an existing fund is one of the most common investor questions. This comparison will help you decide when an NFO genuinely adds value versus when an existing fund is the better choice.</p>
    </div>
    <div class="t-scroll">
      <div class="table t3">
        <div class="cell th"><p>Factor</p></div>
        <div class="cell th"><p>NFO (New Fund)</p></div>
        <div class="cell th"><p>Existing Fund (SIP)</p></div>
        {vsRows.map(r => (
          <>
            <div class="cell tb"><p class="k">{r.feature}</p></div>
            <div class="cell tb"><p class="v">{r.nfo}</p></div>
            <div class="cell tb"><p class="v">{r.sip}</p></div>
          </>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 10. NFO TAXATION ══════════════════════════════════════════════ -->
  <section class="section stack" id="sec-tax" style="background:var(--sec-light);gap:48px">
    <div class="stack" style="gap:16px">
      <p class="sec-title">NFO Taxation</p>
      <p class="sec-lead">NFO taxation follows the same rules as existing mutual funds of the same category. Tax rates depend on the fund type (equity vs debt) and your holding period from the date of unit allotment.</p>
    </div>
    <div class="t-scroll">
      <div class="table t3">
        <div class="cell th"><p>Fund Type &amp; Holding Period</p></div>
        <div class="cell th"><p>Tax Rate</p></div>
        <div class="cell th"><p>Notes</p></div>
        {taxRows.map(r => (
          <>
            <div class="cell tb"><p class="k">{r.type}</p></div>
            <div class="cell tb"><p class="v">{r.rate}</p></div>
            <div class="cell tb"><p class="v">{r.note}</p></div>
          </>
        ))}
      </div>
    </div>
    <p style="font-size:13px;color:var(--muted-2)">Tax rules are subject to change. Consult a SEBI-registered tax adviser for personalised tax planning on mutual fund investments.</p>
  </section>

  <!-- ══ 11. FAQ ═══════════════════════════════════════════════════════ -->
  <section class="faq-wrap">
    <div class="faq-cols">
      <div class="faq-left">
        <h2 class="faq-title">Frequently asked<br>questions.</h2>
        <div class="faq-acc" role="list">
          {faqs.map(f => (
            <details class="faq-item" role="listitem">
              <summary class="faq-sum">
                <span class="qt">{f.q}</span>
                <svg class="faq-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="8" y1="3" x2="8" y2="13"/><line x1="3" y1="8" x2="13" y2="8" class="faq-h"/></svg>
              </summary>
              <div class="qa"><p>{f.a}</p></div>
            </details>
          ))}
        </div>
      </div>
      <div class="faq-side">
        <img src="/images/advisor-avatar.png" alt="" class="usr-img" width="140" height="140">
        <div class="side-in">
          <div class="side-tx">
            <h4>Ready to Invest in NFOs?</h4>
            <p>Get timely NFO alerts, fund analysis, and expert guidance — open your Shriram account and invest at ₹10/unit before the window closes.</p>
          </div>
          <a class="btn-gold" href="/about/open-demat-account/" style="align-self:flex-start">Start Investing</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 12. FINAL CTA ════════════════════════════════════════════════ -->
  <section class="cta-sec" style="background:var(--sec-light)">
    <div class="cta-box">
      <h2 class="cta-h">Invest in the <span class="g">Next NFO with Shriram</span></h2>
      <p class="cta-sub">Timely NFO alerts · Expert analysis · ₹10/unit entry · SEBI-regulated · 40+ years of trust.</p>
      <div class="cta-row">
        <a class="btn-gold" href="/about/open-demat-account/">Open Account &amp; Invest</a>
        <a class="btn-ghost-dark" href="/about/support/">Talk to an RM</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  :root {
    --sec-light: #fef8ee;
    --sec-tint: #f6efe1;
    --card: #fffdf8;
    --card-border: #e1e0db;
    --card-border-soft: rgba(28,28,22,.13);
    --row-line: rgba(28,28,22,.08);
    --olive-title: #2e3914;
    --olive-head: #2d3813;
    --olive-deep: #1b2010;
    --ink: #1c1c16;
    --ink-2: #46463c;
    --ink-3: #595959;
    --muted: #73736a;
    --muted-2: #9a9a8e;
    --gold-2: #f2b83f;
    --gold-btn: #f3b83f;
    --olive-ink: #2e3914;
    --green: #009d58;
    --pad: clamp(20px, 8vw, 144px);
    --container-pad: 32px;
    --section-y: 72px;
    --cta-w: 220px;
  }
  *, *::before, *::after { box-sizing: border-box; }
  a { color: inherit; text-decoration: none; }
  p { line-height: 1.5; }

  .section { padding: var(--section-y) var(--pad); display: flex; flex-direction: column; justify-content: center; }
  .stack { display: flex; flex-direction: column; }
  .sec-title { font-weight: 400; font-size: 40px; color: var(--olive-title); text-transform: capitalize; line-height: 1.5; }
  .sec-lead  { font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.6; }
  .card-h    { font-weight: 500; font-size: 20px; color: var(--ink); line-height: 1.5; }
  .card-p    { font-weight: 400; font-size: 16px; color: var(--muted); line-height: 1.5; }

  .hero { padding: 0 var(--pad); display: flex; flex-direction: column; justify-content: center; overflow: hidden; background: radial-gradient(125% 210% at 100% -8%, #4f583b 0%, #363a2c 50%, #1d1d1d 100%); }
  .hero-inner { padding: clamp(80px,12vw,140px) 0 clamp(48px,6vw,80px); display: flex; flex-direction: column; }
  .hero h1   { font-weight: 500; font-size: 40px; color: #fff; line-height: 1.5; max-width: 860px; }
  .hero h1 .g { color: var(--gold-2); }
  .hero .lead { margin-top: 32px; font-size: 18px; line-height: 1.5; color: rgba(255,255,255,.74); max-width: 640px; }
  .cta-row   { margin-top: 40px; display: flex; flex-wrap: wrap; gap: 14px; align-items: center; }
  .hero-feats { margin-top: 40px; }
  .feats { display: flex; flex-wrap: wrap; align-items: center; gap: 14px 16px; max-width: 760px; padding-top: 36px; border-top: 1px solid rgba(255,255,255,.16); }
  .feat  { display: flex; gap: 10px; align-items: center; }
