---
import BaseLayout from '../../layouts/BaseLayout.astro';

const etfTypes = [
  { label: 'Index ETFs', desc: 'Track benchmark indices like NIFTY 50, SENSEX, NIFTY Next 50. Low cost, broad diversification, and zero manager risk.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6"><path d="M3 3v18h18"/><path d="m7 12 4-4 4 4 4-4"/></svg>` },
  { label: 'Gold ETFs', desc: 'Invest in physical gold stored in vaults. Each unit = 1 gram of gold. No storage hassle, no purity risk, tradeable like stocks.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6"><circle cx="12" cy="12" r="9"/><path d="M9 9.5h1.5a1.5 1.5 0 0 1 0 3H9v3m3-6v6"/></svg>` },
  { label: 'Sectoral ETFs', desc: 'Track sector-specific indices: Bank Nifty, NIFTY IT, NIFTY Pharma, NIFTY FMCG. Concentrated exposure to a single industry.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>` },
  { label: 'Debt ETFs', desc: 'Track fixed-income indices (government securities, corporate bonds). Lower volatility than equity ETFs, better liquidity than bond funds.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M8 9h8M8 13h5"/></svg>` },
  { label: 'International ETFs', desc: 'Exposure to global markets (US S&P 500, Nasdaq 100, MSCI World) through India-listed ETFs. Currency diversification built in.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6"><circle cx="12" cy="12" r="9"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>` },
  { label: 'Smart Beta ETFs', desc: 'Factor-based strategies (Momentum, Low Volatility, Quality, Equal Weight) that go beyond simple index replication.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>` },
];

const vsRows = [
  { feature: 'Trading', etf: 'Real-time throughout the day (like stocks)', mf: 'Once per day at end-of-day NAV' },
  { feature: 'Minimum Investment', etf: 'Price of 1 unit (as low as ₹30)', mf: '₹500 (SIP) or ₹1,000 (lump sum)' },
  { feature: 'Expense Ratio', etf: '0.04% to 0.40% (very low)', mf: '0.5% to 2.5% (higher for active funds)' },
  { feature: 'Manager Risk', etf: 'None (passive, index-tracking)', mf: 'High for active funds; none for index funds' },
  { feature: 'Dividends', etf: 'Paid directly to investor or reinvested', mf: 'Dividend option or growth option' },
  { feature: 'Tax Efficiency', etf: 'More tax-efficient (no internal churn)', mf: 'Less efficient for active funds (internal trading)' },
  { feature: 'Demat Account', etf: 'Required', mf: 'Not required (can invest via AMC directly)' },
];

const steps = [
  { n: '01', title: 'Open Demat & Trading Account', desc: 'ETFs are bought and sold like stocks on NSE/BSE. You need an active Demat + trading account with Shriram.' },
  { n: '02', title: 'Research ETFs', desc: 'Compare ETFs by expense ratio (TER), tracking error, liquidity (daily volumes), and underlying index. Lower tracking error = better replication.' },
  { n: '03', title: 'Place a Buy Order', desc: 'Place a market or limit order for the ETF on NSE/BSE during market hours (9:15 AM – 3:30 PM). ETFs settle T+1.' },
  { n: '04', title: 'Monitor & Rebalance', desc: 'Track NAV vs market price. Set up price alerts. Rebalance your ETF portfolio periodically to maintain target asset allocation.' },
];

const risks = [
  { label: 'Tracking Error', desc: 'Small gaps between the ETF\'s return and the index it tracks can erode performance over time. Lower tracking error = better index replication.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>` },
  { label: 'Liquidity Risk', desc: 'Sectoral and debt ETFs can have thin trading volumes and wide bid-ask spreads, making large trades expensive. Stick to high-volume ETFs for easier entry and exit.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6"><path d="M3 3v18h18"/><path d="m7 14 4-5 4 3 4-6"/></svg>` },
  { label: 'Market Risk', desc: 'Equity ETFs fall when the market falls — there is no active downside buffer. Use debt or hybrid ETFs to balance overall portfolio risk.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6"><path d="m3 3 18 18M3 12c0 5 3.6 9 9 9s9-4 9-9"/><path d="M12 3a9 9 0 0 1 9 9"/></svg>` },
  { label: 'Currency Risk', desc: 'International ETFs embed currency risk. If the INR appreciates against USD, your INR-denominated returns from a US ETF drop even if the underlying index rose.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6"><circle cx="12" cy="12" r="9"/><path d="M12 8v4M12 16h.01"/></svg>` },
];

const faqs = [
  { q: 'What is the difference between ETF and index mutual fund?', a: 'ETFs trade intraday on exchanges like stocks; index mutual funds can only be bought/sold once per day at NAV. ETFs have lower expense ratios but require a Demat account and incur brokerage. Index funds are simpler for SIP-based investors.' },
  { q: 'Is a Demat account required to buy ETFs?', a: 'Yes. ETFs trade on NSE and BSE just like shares — you need an active Demat + trading account. Open one with Shriram and access all ETF categories alongside your equity portfolio.' },
  { q: 'What is tracking error in ETFs?', a: 'Tracking error is the gap between the ETF\'s return and its benchmark index. Lower is better — the best NIFTY 50 ETFs maintain tracking errors below 0.05% per year.' },
  { q: 'Can I start a SIP in an ETF?', a: 'ETFs don\'t support traditional auto-debit SIPs like mutual funds. You can manually buy units monthly, or use Shriram\'s systematic ETF purchase features where available.' },
  { q: 'How are ETF dividends handled?', a: 'Most NIFTY 50 and Gold ETFs in India reinvest dividends into the NAV (growth option). Some ETFs pay dividends directly to investors when underlying holdings declare them.' },
];
---

<BaseLayout
  title="ETF Investment India — Buy Index Gold ETF NSE BSE | Shriram"
  description="Buy Index ETFs, Gold ETFs, and international ETFs on NSE & BSE. Ultra-low expense ratios, real-time pricing, and flat ₹20 brokerage. Start ETF investing today."
>

  <section class="relative overflow-hidden bg-[var(--color-dark-800)]">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[560px] w-[560px] rounded-full bg-[var(--color-brand)]/10 blur-3xl"></div>
    <div class="site-wrap relative py-16 lg:py-28">
      <p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-brand)]">Exchange Traded Funds</p>
      <h1 class="mt-4 max-w-3xl text-[32px] font-bold leading-tight text-white lg:text-[40px]" style="font-family:var(--font-display)">
        Trade ETFs — Diversify Your<br class="hidden sm:block"> Portfolio Instantly
      </h1>
      <p class="mt-5 max-w-2xl text-[15px] leading-relaxed text-white/60 lg:text-[17px]">
        Access Index ETFs, Gold ETFs, Sector ETFs, Debt ETFs, and International ETFs on NSE and BSE. Real-time pricing, ultra-low expense ratios, and the simplicity of stock trading.
      </p>
      <div class="mt-7 grid grid-cols-2 gap-x-6 gap-y-3 sm:flex sm:gap-8">
        {[['Real-time trading'],['Lowest expense ratios'],['NSE & BSE listed'],['All categories covered']].map(([l]) => (<div class="flex items-center gap-2 text-[13px] font-medium text-white/70"><span class="h-1.5 w-1.5 rounded-full bg-[var(--color-brand)]"></span>{l}</div>))}
      </div>
      <div class="mt-9 flex flex-wrap gap-3">
        <a href="/about/open-demat-account/" class="btn-primary">Start Trading ETFs</a>
        <a href="/about/support/" class="inline-flex h-12 w-[220px] items-center justify-center rounded-[6px] border border-white/25 text-[14px] font-medium text-white transition-colors hover:bg-white/10">Talk to RM</a>
      </div>
    </div>
  </section>

  <section class="bg-white py-16 lg:py-24">
    <div class="site-wrap">
      <div class="equity-reveal">
        <p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-brand)]">Types</p>
        <h2 class="mt-3 text-[28px] font-bold text-[var(--color-ink)] lg:text-[38px]" style="font-family:var(--font-display)">Types of ETFs Available in India</h2>
        <p class="mt-4 max-w-3xl text-[15px] text-[var(--color-muted)]">The Indian ETF market has grown to ₹7+ lakh crore in AUM. Here are the major categories you can access through Shriram.</p>
      </div>
      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {etfTypes.map((e, i) => (<div class="equity-reveal product-card-light flex flex-col gap-3 p-6" style={`animation-delay:${i*50}ms`}><div class="flex h-11 w-11 items-center justify-center rounded-[10px] bg-[var(--color-dark-olive)] text-[var(--color-brand)]" set:html={e.icon} /><h3 class="text-[15px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{e.label}</h3><p class="text-[13px] leading-relaxed text-[var(--color-muted)]">{e.desc}</p></div>))}
      </div>
    </div>
  </section>

  <section class="bg-[#f8f6f1] py-16 lg:py-24">
    <div class="site-wrap">
      <div class="equity-reveal text-center">
        <p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-brand)]">Getting Started</p>
        <h2 class="mt-3 text-[28px] font-bold text-[var(--color-ink)] lg:text-[38px]" style="font-family:var(--font-display)">How to Start Investing in ETFs</h2>
      </div>
      <div class="equity-reveal mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {steps.map((s, i) => (<div class="relative rounded-[20px] border border-[var(--color-warm-border)] bg-white p-7" style={`animation-delay:${i*60}ms`}><span class="flex h-10 w-10 items-center justify-center rounded-full bg-[var(--color-dark-olive)] text-[13px] font-bold text-[var(--color-brand)]">{s.n}</span>{i < steps.length - 1 && <span class="absolute -right-3 top-9 hidden lg:flex"><svg viewBox="0 0 12 12" fill="none" stroke="var(--color-brand)" stroke-width="2" class="h-3 w-3"><path d="M2 6h8M6 2l4 4-4 4"/></svg></span>}<h3 class="mt-4 text-[15px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{s.title}</h3><p class="mt-2 text-[13px] leading-relaxed text-[var(--color-muted)]">{s.desc}</p></div>))}
      </div>
    </div>
  </section>

  <section class="bg-white py-16 lg:py-24">
    <div class="site-wrap">
      <div class="equity-reveal">
        <p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-brand)]">Comparison</p>
        <h2 class="mt-3 text-[28px] font-bold text-[var(--color-ink)] lg:text-[38px]" style="font-family:var(--font-display)">ETF vs Mutual Funds</h2>
      </div>
      <div class="equity-reveal mt-10 overflow-hidden rounded-[20px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto"><table class="w-full text-[14px]">
          <thead><tr class="bg-[var(--color-dark-olive)]"><th class="px-6 py-4 text-left text-[12px] font-semibold uppercase tracking-wide text-white/70">Feature</th><th class="px-6 py-4 text-left text-[12px] font-semibold uppercase tracking-wide text-[var(--color-brand)]">ETF</th><th class="px-6 py-4 text-left text-[12px] font-semibold uppercase tracking-wide text-[var(--color-brand)]">Index Mutual Fund</th></tr></thead>
          <tbody class="divide-y divide-[var(--color-n400)]">{vsRows.map((r,i) => (<tr class={i%2===0?'bg-white':'bg-[#f8f6f1]'}><td class="px-6 py-4 font-semibold text-[var(--color-ink)]">{r.feature}</td><td class="px-6 py-4 text-[var(--color-muted)]">{r.etf}</td><td class="px-6 py-4 text-[var(--color-muted)]">{r.mf}</td></tr>))}</tbody>
        </table></div>
      </div>
    </div>
  </section>

  <section class="bg-[#f8f6f1] py-16 lg:py-24">
    <div class="site-wrap">
      <div class="equity-reveal"><p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-brand)]">Know Before You Trade</p><h2 class="mt-3 text-[28px] font-bold text-[var(--color-ink)] lg:text-[38px]" style="font-family:var(--font-display)">Risks of ETF Investing</h2></div>
      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {risks.map((r, i) => (<div class="equity-reveal product-card-light flex flex-col gap-4 p-7" style={`animation-delay:${i*60}ms`}><div class="flex h-12 w-12 items-center justify-center rounded-[12px] bg-[#fef4e6] text-[var(--color-brand-deep)]" set:html={r.icon} /><h3 class="text-[16px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{r.label}</h3><p class="text-[13px] leading-relaxed text-[var(--color-muted)]">{r.desc}</p></div>))}
      </div>
    </div>
  </section>

  <section class="bg-white py-16 lg:py-24">
    <div class="site-wrap">
      <div class="equity-reveal"><p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-brand)]">FAQ</p><h2 class="mt-3 text-[28px] font-bold text-[var(--color-ink)] lg:text-[38px]" style="font-family:var(--font-display)">Frequently Asked Questions</h2></div>
      <div class="equity-reveal mt-10 divide-y divide-[var(--color-n400)] overflow-hidden rounded-[24px] border border-[var(--color-n400)] bg-white">
        {faqs.map(item => (<details class="eq-faq group"><summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5 hover:bg-[var(--color-n100)]"><span class="text-[15px] font-medium text-[var(--color-ink)]">{item.q}</span><span class="grid h-7 w-7 shrink-0 place-items-center rounded-full border border-[var(--color-n400)] transition-transform group-open:rotate-45"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" class="h-3 w-3"><path d="M6 2v8M2 6h8"/></svg></span></summary><div class="border-t border-[var(--color-n400)] bg-[var(--color-n100)] px-6 py-5"><p class="text-[14px] leading-relaxed text-[var(--color-muted)]">{item.a}</p></div></details>))}
      </div>
    </div>
  </section>

  <section class="bg-[var(--color-dark-800)] py-16 lg:py-20">
    <div class="site-wrap">
      <div class="equity-reveal flex flex-col items-center gap-6 text-center lg:flex-row lg:items-center lg:justify-between lg:text-left">
        <div>
          <h2 class="text-[28px] font-bold text-white lg:text-[36px]" style="font-family:var(--font-display)">Start Building Your ETF Portfolio</h2>
          <p class="mt-3 max-w-lg text-[15px] text-white/55">Access all ETF categories on NSE & BSE with flat ₹20 brokerage, real-time pricing, and expert portfolio guidance.</p>
        </div>
        <div class="flex shrink-0 flex-col gap-3 sm:flex-row">
          <a href="/about/open-demat-account/" class="inline-flex h-12 w-[220px] items-center justify-center rounded-[6px] bg-[var(--color-brand)] text-[14px] font-semibold text-[#202318] hover:bg-[var(--color-brand-hover)]">Open Demat Account →</a>
          <a href="/about/support/" class="inline-flex h-12 w-[220px] items-center justify-center rounded-[6px] border border-white/20 text-[14px] font-medium text-white hover:bg-white/10">Talk to an RM</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .equity-reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.65s cubic-bezier(0.22,1,0.36,1), transform 0.65s cubic-bezier(0.22,1,0.36,1); }
  .equity-reveal.in-view { opacity: 1; transform: translateY(0); }
</style>
<script>
  const obs = new IntersectionObserver(entries => { entries.forEach(e => { if (e.isIntersecting) { const el = e.target as HTMLElement; setTimeout(() => el.classList.add('in-view'), parseInt(el.style.animationDelay)||0); obs.unobserve(el); } }); }, { threshold: 0.10 });
  document.querySelectorAll('.equity-reveal').forEach(el => obs.observe(el));
  document.querySelectorAll<HTMLDetailsElement>('.eq-faq').forEach(d => { d.addEventListener('toggle', () => { if (d.open) document.querySelectorAll<HTMLDetailsElement>('.eq-faq').forEach(o => { if (o !== d) o.removeAttribute('open'); }); }); });
</script>
