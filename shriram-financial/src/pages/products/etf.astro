---
import BaseLayout from '../../layouts/BaseLayout.astro';

const etfTypes = [
  { label: 'Index ETFs', desc: 'Track benchmark indices like NIFTY 50, SENSEX, NIFTY Next 50. Low cost, broad diversification, and zero manager risk.' },
  { label: 'Gold ETFs', desc: 'Invest in physical gold stored in vaults. Each unit = 1 gram of gold. No storage hassle, no purity risk, tradeable like stocks.' },
  { label: 'Sectoral ETFs', desc: 'Track sector-specific indices: Bank Nifty, NIFTY IT, NIFTY Pharma, NIFTY FMCG. Concentrated exposure to a single industry.' },
  { label: 'Debt ETFs', desc: 'Track fixed-income indices (government securities, corporate bonds). Lower volatility than equity ETFs, better liquidity than bond funds.' },
  { label: 'International ETFs', desc: 'Exposure to global markets (US S&P 500, Nasdaq 100, MSCI World) through India-listed ETFs. Currency diversification built in.' },
  { label: 'Smart Beta ETFs', desc: 'Factor-based strategies (Momentum, Low Volatility, Quality, Equal Weight) that go beyond simple index replication.' },
];

const vsRows = [
  { feature: 'Trading', etf: 'Real-time throughout the day (like stocks)', mf: 'Once per day at end-of-day NAV' },
  { feature: 'Minimum Investment', etf: 'Price of 1 unit (as low as ₹30)', mf: '₹500 (SIP) or ₹1,000 (lump sum)' },
  { feature: 'Expense Ratio', etf: '0.04% to 0.40% (very low)', mf: '0.5% to 2.5% (higher for active funds)' },
  { feature: 'Manager Risk', etf: 'None (passive, index-tracking)', mf: 'High for active funds; none for index funds' },
  { feature: 'Dividends', etf: 'Paid directly to investor or reinvested', mf: 'Dividend option or growth option' },
  { feature: 'Tax Efficiency', etf: 'More tax-efficient (no internal churn)', mf: 'Less efficient for active funds (internal trading)' },
  { feature: 'Demat Account', etf: 'Required', mf: 'Not required (can invest via AMC directly)' },
];

const steps = [
  { n: '01', title: 'Open Demat Account', desc: 'Open with Shriram — 100% online, paperless, 10 minutes.' },
  { n: '02', title: 'Search ETF Ticker', desc: 'Search by ETF code on NSE/BSE (e.g., NIFTYBEES, GOLDBEES).' },
  { n: '03', title: 'Place Buy Order', desc: 'Market or limit order — just like buying a stock.' },
  { n: '04', title: 'Units Credited', desc: 'ETF units credited to your Demat account on T+1 settlement.' },
];

const risks = [
  { n: '01', label: 'Tracking Error', desc: 'Small gaps between the ETF\'s return and the index it tracks can erode performance over time. Lower tracking error = better index replication.' },
  { n: '02', label: 'Liquidity Risk', desc: 'Sectoral and debt ETFs can have thin trading volumes and wide bid-ask spreads, making large trades expensive. Stick to high-volume ETFs for easier entry and exit.' },
  { n: '03', label: 'Market Risk', desc: 'Equity ETFs fall when the market falls — there is no active downside buffer. Use debt or hybrid ETFs to balance overall portfolio risk.' },
  { n: '04', label: 'Low AUM Risk', desc: 'ETFs with AUM below ₹100 Cr may be wound up by the AMC. Always check AUM before investing.' },
];

const faqs = [
  { q: 'What is an ETF in simple terms?', a: 'An ETF is a basket of securities (stocks, bonds, gold) that trades on NSE/BSE like a single stock. It passively tracks an index and has very low annual fees.' },
  { q: 'What is the minimum investment in an ETF?', a: 'You can buy a single unit of an ETF. Most Nifty 50 ETFs are priced between ₹200–₹300 per unit. GOLDBEES is priced around ₹50–₹60 per unit.' },
  { q: 'Can I do SIP in ETF?', a: 'Yes, but unlike mutual fund SIPs, ETF SIPs require a manual buy order each month. There is no auto-debit facility for ETF SIPs.' },
  { q: 'What is tracking error in ETF?', a: 'Tracking error is the difference between the ETF\'s returns and the benchmark index returns. A lower tracking error means the ETF mirrors its index more accurately.' },
  { q: 'Is ETF better than mutual fund?', a: 'ETFs have lower costs and real-time trading. Mutual funds offer automated SIP and professional management. ETFs are better for cost-conscious passive investors; active MFs suit those wanting stock selection.' },
  { q: 'How is ETF taxed?', a: 'Equity ETFs are taxed at 20% STCG (held under 12 months) and 12.5% LTCG on gains above ₹1.25L. Gold ETFs are taxed at slab rate for STCG and 12.5% for LTCG after 24 months.' },
  { q: 'What is the difference between Nifty 50 ETF and Nifty 50 Index Fund?', a: 'Both track the Nifty 50. ETFs trade on exchange in real time; index funds transact at end-of-day NAV. Both have similar low expense ratios.' },
  { q: 'Is a Demat account required for ETF?', a: 'Yes. ETF units are held in your Demat account like shares.' },
  { q: 'What is AUM in ETF?', a: 'AUM (Assets Under Management) is the total value of all units in the ETF. Higher AUM generally means better liquidity on the exchange.' },
  { q: 'What is a Gold ETF?', a: 'A Gold ETF tracks the domestic gold price. 1 unit ≈ 0.01 grams of 99.5% pure gold. You invest in gold without physical storage risk.' },
];
---

<BaseLayout
  title="ETF in India — Invest in Exchange Traded Funds | Shriram"
  description="Invest in ETF in India on NSE &amp; BSE. Nifty 50 ETF, Gold ETF, Debt ETF, Sectoral ETF. Zero delivery brokerage. SEBI-registered. Start ETF investing today with Shriram."
>

  <!-- ══ S1. HERO ══════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[var(--color-dark-800)] py-[100px] lg:py-[120px]">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[560px] w-[560px] rounded-full bg-[var(--color-brand)]/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-32 left-0 h-80 w-80 rounded-full bg-[var(--color-brand)]/5 blur-3xl"></div>
    <div class="site-wrap relative">
      <p class="equity-reveal text-[14px] font-medium tracking-[.04em] text-[var(--color-brand)]">Exchange Traded Funds</p>
      <h1 class="equity-reveal mt-[22px] max-w-[880px] text-[clamp(32px,4vw,52px)] font-bold leading-[1.06] text-white" style="font-family:var(--font-display)">
        Invest in <span class="text-[var(--color-brand)]">ETF in India</span> — Exchange Traded Funds on NSE &amp; BSE
      </h1>
      <p class="equity-reveal mt-[26px] max-w-[600px] text-[18px] leading-relaxed text-white/70">
        Buy Nifty 50 ETFs, Gold ETFs, Debt ETFs, and Sectoral ETFs with zero delivery brokerage. SEBI-registered broker. Start ETF investing in India today.
      </p>
      <div class="equity-reveal mt-[38px] flex flex-wrap gap-[14px]">
        <a href="/about/open-demat-account/" class="btn-primary">Open Demat Account</a>
        <a href="/about/open-demat-account/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Start Investing in ETFs</a>
      </div>
      <div class="equity-reveal mt-[54px] flex flex-wrap gap-x-9 gap-y-3 border-t border-white/15 pt-9">
        {['✓ SEBI-registered', '✓ Zero delivery brokerage', '✓ 100+ ETFs on NSE/BSE', '✓ Real-time trading'].map(f => (
          <span class="text-[15px] font-medium text-white/90">{f}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S2. WHAT IS AN ETF ════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          What is an <span class="text-[var(--color-brand)]">ETF?</span> — Meaning &amp; Definition
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">An ETF (Exchange Traded Fund) is a basket of securities that trades on NSE/BSE like a stock, while tracking an underlying index or asset.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Feature</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">ETF</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Explanation</th>
              </tr>
            </thead>
            <tbody>
              {[
                { feature: 'Trading', etf: 'Real-time on NSE/BSE', explanation: 'Buy/sell anytime during market hours' },
                { feature: 'Benchmark', etf: 'Tracks Nifty 50, Gold, etc.', explanation: 'NAV mirrors underlying index' },
                { feature: 'Expense Ratio', etf: '0.05–0.50%', explanation: 'Much lower than active mutual funds' },
                { feature: 'Min Investment', etf: 'Price of 1 unit (~₹50–₹500)', explanation: 'No minimum lot size for most ETFs' },
                { feature: 'Demat Required', etf: 'Yes', explanation: 'Units held in Demat account' },
              ].map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.feature}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.etf}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.explanation}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S3. HOW ETFS WORK ═════════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How <span class="text-[var(--color-brand)]">ETFs Work</span> — Creation &amp; Redemption Mechanism
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">ETFs are created and redeemed by Authorised Participants (APs) who keep the ETF price in line with its NAV.</p>
      </div>
      <div class="equity-reveal steps-grid overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        {[
          { n: '01', title: 'AP Creates Units', desc: 'Authorised Participant assembles the index basket and submits to the AMC.' },
          { n: '02', title: 'AMC Issues Units', desc: 'AMC creates ETF units and delivers them to the AP.' },
          { n: '03', title: 'Listed on Exchange', desc: 'Units are listed and traded on NSE/BSE at real-time market price.' },
          { n: '04', title: 'Redemption', desc: 'AP can redeem large blocks for the underlying basket, keeping ETF price close to iNAV.' },
        ].map(s => (
          <div class="px-[30px] py-[34px]">
            <div class="mb-[22px] font-display text-[34px] font-normal leading-none text-[var(--color-brand)]">{s.n}</div>
            <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">{s.title}</h4>
            <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S4. TYPES OF ETFS ═════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Types of <span class="text-[var(--color-brand)]">ETFs</span> Available in India — All Categories
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">7 ETF categories available on Indian exchanges.</p>
      </div>
      <div class="equity-reveal cat-grid">
        {[
          { label: 'Equity ETF', desc: 'Track stock market indices like Nifty 50, Sensex, Nifty Midcap.' },
          { label: 'Gold ETF', desc: 'Track domestic gold price. 1 unit ≈ 1/100th gram of 99.5% pure gold.' },
          { label: 'Silver ETF', desc: 'Track domestic silver price. Trade on NSE/BSE.' },
          { label: 'Debt / Bond ETF', desc: 'Track G-Sec or corporate bond indices. Lower risk.' },
          { label: 'Sectoral ETF', desc: 'Track sectors: banking (BANKBEES), IT, pharma, consumption.' },
          { label: 'International ETF', desc: 'Track global indices: Nasdaq 100, S&P 500 from India.' },
          { label: 'Smart Beta ETF', desc: 'Track factor-based indices: low volatility, equal weight, quality.' },
        ].map(t => (
          <div class="product-card-light px-[28px] py-[32px]">
            <h3 class="mb-[10px] text-[18px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{t.label}</h3>
            <p class="text-[14px] leading-relaxed text-[var(--color-muted)]">{t.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S5. ETF VS MUTUAL FUND ════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          <span class="text-[var(--color-brand)]">ETF vs Mutual Fund</span> — Key Differences
        </h2>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Feature</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">ETF</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Mutual Fund</th>
              </tr>
            </thead>
            <tbody>
              {[
                { feature: 'Trading', etf: 'Real-time on exchange', mf: 'End-of-day at NAV' },
                { feature: 'Expense Ratio', etf: '0.05–0.50%', mf: '0.50–2.00% (active funds)' },
                { feature: 'SIP Availability', etf: 'Manual trigger', mf: 'Auto-debit SIP' },
                { feature: 'Demat Required', etf: 'Yes', mf: 'No (MF direct)' },
                { feature: 'Minimum Investment', etf: 'Price of 1 unit', mf: '₹500 per instalment' },
                { feature: 'Transparency', etf: 'Portfolio disclosed daily', mf: 'Monthly portfolio disclosure' },
                { feature: 'Tax Treatment', etf: 'Same as equity MF', mf: 'Same as equity MF' },
                { feature: 'Fund Manager Risk', etf: 'No (passive)', mf: 'Yes (for active funds)' },
              ].map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.feature}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.etf}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.mf}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S6. HOW TO INVEST IN ETFS ════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How to <span class="text-[var(--color-brand)]">Invest in ETFs</span> — Step by Step
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Six steps from account opening to buying your first ETF unit.</p>
      </div>
      <div class="equity-reveal steps-grid overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        {steps.map(s => (
          <div class="px-[30px] py-[34px]">
            <div class="mb-[22px] font-display text-[34px] font-normal leading-none text-[var(--color-brand)]">{s.n}</div>
            <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">{s.title}</h4>
            <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">{s.desc}</p>
          </div>
        ))}
      </div>
      <div class="equity-reveal mt-[34px] text-center">
        <a href="/about/open-demat-account/" class="btn-primary">Open Demat &amp; Start Buying ETFs</a>
      </div>
    </div>
  </section>

  <!-- ══ S7. ETF SIP ═══════════════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          ETF SIP — Can You Do <span class="text-[var(--color-brand)]">Systematic Investment</span> in an ETF?
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Yes — but ETF SIPs work differently from mutual fund SIPs.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Feature</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">ETF SIP</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Mutual Fund SIP</th>
              </tr>
            </thead>
            <tbody>
              {[
                { feature: 'Execution', etf: 'Manual buy on exchange each month', mf: 'Auto-debit via AMC' },
                { feature: 'Automation', etf: 'Requires manual action', mf: 'Fully automated' },
                { feature: 'Price', etf: 'Real-time market price', mf: 'End-of-day NAV' },
                { feature: 'SIP Start', etf: 'No auto-SIP mandate', mf: 'One-time mandate setup' },
                { feature: 'Best For', etf: 'Active investors who want control', mf: 'Passive investors who want automation' },
              ].map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.feature}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.etf}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.mf}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S8. ETF RETURNS CALCULATOR ═══════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          ETF <span class="text-[var(--color-brand)]">Returns Calculator</span> — Estimate Wealth Growth
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Use our return calculator to project your ETF investment growth.</p>
      </div>
      <div class="equity-reveal mx-auto max-w-[640px]">
        <div class="product-card-light px-[28px] py-[32px] text-center">
          <h3 class="mb-[10px] text-[22px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">ETF Return Estimator</h3>
          <p class="mb-[24px] text-[15px] leading-relaxed text-[var(--color-muted)]">Input your monthly amount, tenure, and expected CAGR. Project your wealth with passive ETF investing.</p>
          <a href="/calculators/sip/" class="btn-primary">Calculate My Returns →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S9. ETF CHARGES ═══════════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          ETF Charges &amp; <span class="text-[var(--color-brand)]">Expense Ratio</span> — What You Actually Pay
        </h2>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Charge</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Amount</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Notes</th>
              </tr>
            </thead>
            <tbody>
              {[
                { charge: 'Expense Ratio (TER)', amount: '0.05–0.50% per annum', notes: 'Deducted from NAV daily — no separate payment' },
                { charge: 'Brokerage', amount: '₹0 delivery / ₹20 intraday', notes: 'Shriram flat fee' },
                { charge: 'STT', amount: '0.1% on sell (delivery)', notes: 'Government tax' },
                { charge: 'GST', amount: '18% on brokerage', notes: 'On brokerage amount only' },
                { charge: 'DP Charges', amount: '₹15.93 per scrip on sell', notes: 'CDSL charge' },
                { charge: 'Impact Cost', amount: '0.01–0.10%', notes: 'Bid-ask spread on exchange' },
                { charge: 'Active MF (comparison)', amount: '1.50–2.00% TER', notes: 'Much higher annual cost' },
              ].map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.charge}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.amount}</td>
