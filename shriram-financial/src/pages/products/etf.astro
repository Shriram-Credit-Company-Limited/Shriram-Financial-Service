---
import BaseLayout from '../../layouts/BaseLayout.astro';

const etfTypes = [
  { label: 'Index ETFs', desc: 'Track benchmark indices like NIFTY 50, SENSEX, NIFTY Next 50. Low cost, broad diversification, and zero manager risk.' },
  { label: 'Gold ETFs', desc: 'Invest in physical gold stored in vaults. Each unit = 1 gram of gold. No storage hassle, no purity risk, tradeable like stocks.' },
  { label: 'Sectoral ETFs', desc: 'Track sector-specific indices: Bank Nifty, NIFTY IT, NIFTY Pharma, NIFTY FMCG. Concentrated exposure to a single industry.' },
  { label: 'Debt ETFs', desc: 'Track fixed-income indices (government securities, corporate bonds). Lower volatility than equity ETFs, better liquidity than bond funds.' },
  { label: 'International ETFs', desc: 'Exposure to global markets (US S&P 500, Nasdaq 100, MSCI World) through India-listed ETFs. Currency diversification built in.' },
  { label: 'Smart Beta ETFs', desc: 'Factor-based strategies (Momentum, Low Volatility, Quality, Equal Weight) that go beyond simple index replication.' },
];

const vsRows = [
  { feature: 'Trading', etf: 'Real-time throughout the day (like stocks)', mf: 'Once per day at end-of-day NAV' },
  { feature: 'Minimum Investment', etf: 'Price of 1 unit (as low as ₹30)', mf: '₹500 (SIP) or ₹1,000 (lump sum)' },
  { feature: 'Expense Ratio', etf: '0.04% to 0.40% (very low)', mf: '0.5% to 2.5% (higher for active funds)' },
  { feature: 'Manager Risk', etf: 'None (passive, index-tracking)', mf: 'High for active funds; none for index funds' },
  { feature: 'Dividends', etf: 'Paid directly to investor or reinvested', mf: 'Dividend option or growth option' },
  { feature: 'Tax Efficiency', etf: 'More tax-efficient (no internal churn)', mf: 'Less efficient for active funds (internal trading)' },
  { feature: 'Demat Account', etf: 'Required', mf: 'Not required (can invest via AMC directly)' },
];

const steps = [
  { n: '01', title: 'Open Demat & Trading Account', desc: 'ETFs are bought and sold like stocks on NSE/BSE. You need an active Demat + trading account with Shriram.' },
  { n: '02', title: 'Research ETFs', desc: 'Compare ETFs by expense ratio (TER), tracking error, liquidity (daily volumes), and underlying index. Lower tracking error = better replication.' },
  { n: '03', title: 'Place a Buy Order', desc: 'Place a market or limit order for the ETF on NSE/BSE during market hours (9:15 AM – 3:30 PM). ETFs settle T+1.' },
  { n: '04', title: 'Monitor & Rebalance', desc: 'Track NAV vs market price. Set up price alerts. Rebalance your ETF portfolio periodically to maintain target asset allocation.' },
];

const risks = [
  { n: '01', label: 'Tracking Error', desc: 'Small gaps between the ETF\'s return and the index it tracks can erode performance over time. Lower tracking error = better index replication.' },
  { n: '02', label: 'Liquidity Risk', desc: 'Sectoral and debt ETFs can have thin trading volumes and wide bid-ask spreads, making large trades expensive. Stick to high-volume ETFs for easier entry and exit.' },
  { n: '03', label: 'Market Risk', desc: 'Equity ETFs fall when the market falls — there is no active downside buffer. Use debt or hybrid ETFs to balance overall portfolio risk.' },
  { n: '04', label: 'Currency Risk', desc: 'International ETFs embed currency risk. If the INR appreciates against USD, your INR-denominated returns from a US ETF drop even if the underlying index rose.' },
];

const faqs = [
  { q: 'What is the difference between ETF and index mutual fund?', a: 'ETFs trade intraday on exchanges like stocks; index mutual funds can only be bought/sold once per day at NAV. ETFs have lower expense ratios but require a Demat account and incur brokerage. Index funds are simpler for SIP-based investors.' },
  { q: 'Is a Demat account required to buy ETFs?', a: 'Yes. ETFs trade on NSE and BSE just like shares — you need an active Demat + trading account. Open one with Shriram and access all ETF categories alongside your equity portfolio.' },
  { q: 'What is tracking error in ETFs?', a: 'Tracking error is the gap between the ETF\'s return and its benchmark index. Lower is better — the best NIFTY 50 ETFs maintain tracking errors below 0.05% per year.' },
  { q: 'Can I start a SIP in an ETF?', a: 'ETFs don\'t support traditional auto-debit SIPs like mutual funds. You can manually buy units monthly, or use Shriram\'s systematic ETF purchase features where available.' },
  { q: 'How are ETF dividends handled?', a: 'Most NIFTY 50 and Gold ETFs in India reinvest dividends into the NAV (growth option). Some ETFs pay dividends directly to investors when underlying holdings declare them.' },
];
---

<BaseLayout
  title="ETF in India — Buy Index Gold ETF NSE BSE | Shriram"
  description="Invest in ETF in India — Index ETFs, Gold ETFs, and international ETFs on NSE &amp; BSE. Ultra-low expense ratios, real-time pricing, and flat ₹20 brokerage. Start today."
>

  <!-- ══ 1. HERO ═══════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[var(--color-dark-800)]">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[560px] w-[560px] rounded-full bg-[var(--color-brand)]/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-32 left-0 h-80 w-80 rounded-full bg-[var(--color-brand)]/5 blur-3xl"></div>
    <div class="site-wrap relative py-[120px]">
      <p class="equity-reveal text-[14px] font-medium tracking-[.04em] text-[var(--color-brand)]">Exchange Traded Funds</p>
      <h1 class="equity-reveal mt-[22px] max-w-[880px] text-[clamp(32px,4vw,52px)] font-bold leading-[1.06] text-white" style="font-family:var(--font-display)">
        Invest in <span class="text-[var(--color-brand)]">ETF in India</span> — Diversify Your Portfolio Instantly
      </h1>
      <p class="equity-reveal mt-[26px] max-w-[600px] text-[18px] leading-relaxed text-white/70">
        Access Index ETFs, Gold ETFs, Sector ETFs, Debt ETFs, and International ETFs on NSE and BSE. Real-time pricing, ultra-low expense ratios, and the simplicity of stock trading.
      </p>
      <div class="equity-reveal mt-[38px] flex flex-wrap gap-[14px]">
        <a href="/about/open-demat-account/" class="btn-primary">Start Trading ETFs</a>
        <a href="/about/support/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Talk to RM</a>
      </div>
      <div class="equity-reveal mt-[54px] flex flex-wrap gap-x-9 gap-y-3 border-t border-white/15 pt-9">
        {['✓ Real-time trading', '✓ Lowest expense ratios', '✓ NSE & BSE listed', '✓ All categories covered'].map(f => (
          <span class="text-[15px] font-medium text-white/90">
            <span class="mr-2 text-[var(--color-brand)]">{f.slice(0,1)}</span>{f.slice(1)}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 2. WHAT ARE ETFS ══════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto grid max-w-[1000px] items-start gap-[72px] lg:grid-cols-[5fr_7fr]">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Types of ETFs Available <span class="text-[var(--color-brand)]">in India</span>
        </h2>
        <div class="space-y-5 text-[17px] leading-relaxed text-[var(--color-muted)]">
          <p>An ETF (Exchange Traded Fund) is a basket of securities that trades on a stock exchange just like an individual share. It combines the diversification of a mutual fund with the real-time liquidity of stocks.</p>
          <p>The Indian ETF market has grown to ₹7+ lakh crore in AUM. Here are the major categories you can access through Shriram.</p>
        </div>
      </div>
      <div class="equity-reveal mx-auto mt-[76px] max-w-[1000px] border-t border-[var(--color-n400)] pt-[60px]">
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {etfTypes.map((e, i) => (
            <div class="product-card-light flex flex-col gap-3 p-6" style={`animation-delay:${i*50}ms`}>
              <h3 class="text-[15px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{e.label}</h3>
              <p class="text-[13px] leading-relaxed text-[var(--color-muted)]">{e.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 3. HOW TO START ════════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How to Start <span class="text-[var(--color-brand)]">Investing in ETFs</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Four steps from account setup to your first ETF purchase — and ongoing portfolio management.</p>
      </div>
      <div class="equity-reveal steps-grid overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        {steps.map(s => (
          <div class="px-[30px] py-[34px]">
            <div class="mb-[22px] font-display text-[34px] font-normal leading-none text-[var(--color-brand)]">{s.n}</div>
            <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">{s.title}</h4>
            <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 4. ETF VS MUTUAL FUNDS ════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          ETF vs <span class="text-[var(--color-brand)]">Mutual Funds</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Compare ETFs with index mutual funds across the factors that matter most to investors.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto"><table class="w-full text-[15.5px]">
          <thead><tr class="bg-[var(--color-dark-olive)]"><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Feature</th><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">ETF</th><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Index Mutual Fund</th></tr></thead>
          <tbody>{vsRows.map((r,i) => (<tr class={i%2===0?'bg-white':'bg-[#f8f6f1]'}><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.feature}</td><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.etf}</td><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.mf}</td></tr>))}</tbody>
        </table></div>
      </div>
    </div>
  </section>

  <!-- ══ 5. RISKS ════════════════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Risks of <span class="text-[var(--color-brand)]">ETF Investing</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Understand what can move against you before you commit capital.</p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {risks.map(r => (
          <div class="equity-reveal rounded-[18px] bg-[var(--color-dark-800)] p-[36px]">
            <div class="mb-[18px] text-[48px] font-bold leading-none text-[var(--color-brand)]/25">{r.n}</div>
            <h4 class="mb-3 text-[20px] font-medium text-white" style="font-family:var(--font-display)">{r.label}</h4>
            <p class="text-[14.5px] leading-relaxed text-white/60">{r.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 5b. ETF SIP ════════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          ETF SIP — Can You Do Systematic <span class="text-[var(--color-brand)]">Investment in an ETF?</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">ETFs don't support traditional auto-debit SIPs like mutual funds — but there are effective workarounds for disciplined monthly investing.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Feature</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">ETF SIP (Manual)</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Mutual Fund SIP</th>
              </tr>
            </thead>
            <tbody>
              {[
                { label: 'Auto-Debit', etf: 'Not available (manual purchase required)', mf: 'Yes — automated monthly debit' },
                { label: 'Price Execution', etf: 'Live market price (can use limit orders)', mf: 'End-of-day NAV — no control over entry price' },
                { label: 'Minimum Amount', etf: 'Price of 1 unit (can be as low as ₹30)', mf: 'Usually ₹500/month' },
                { label: 'Expense Ratio', etf: '0.04–0.40% (very low)', mf: '0.1–2.5% (varies)' },
                { label: 'Demat Account', etf: 'Required', mf: 'Optional (can invest via AMC)' },
                { label: 'Best For', etf: 'Cost-conscious, active investors comfortable with manual buying', mf: 'Investors who prefer automation and simplicity' },
              ].map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.label}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.etf}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.mf}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 5c. ETF PORTFOLIO CONSTRUCTION ════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          ETF Portfolio <span class="text-[var(--color-brand)]">Construction</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Two model portfolios — for beginners starting simple and advanced investors seeking core-satellite diversification.</p>
      </div>
      <div class="equity-reveal grid gap-6 sm:grid-cols-2">
        <div class="product-card-light p-[34px]">
          <div class="mb-4 inline-flex rounded-full bg-[var(--color-brand)]/15 px-4 py-1.5 text-[12px] font-bold uppercase tracking-wide text-[var(--color-dark-olive)]">Beginner Portfolio</div>
          <h3 class="mb-4 text-[22px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">The 3-ETF Portfolio</h3>
          <p class="mb-5 text-[14px] text-[var(--color-muted)]">A simple, low-cost portfolio covering the three major asset classes. Rebalance once a year.</p>
          <div class="space-y-3">
            {[
              { etf: 'Nifty 50 ETF', alloc: '60%', role: 'Core equity growth engine' },
              { etf: 'Gold ETF', alloc: '20%', role: 'Inflation hedge & safe haven' },
              { etf: 'Nifty 5-Year Debt ETF', alloc: '20%', role: 'Stability & income' },
            ].map(p => (
              <div class="flex items-center justify-between rounded-[10px] border border-[var(--color-n400)] px-4 py-3">
                <div>
                  <div class="text-[13px] font-semibold text-[var(--color-ink)]">{p.etf}</div>
                  <div class="text-[11px] text-[var(--color-muted)]">{p.role}</div>
                </div>
                <span class="text-[18px] font-bold text-[var(--color-dark-olive)]">{p.alloc}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="product-card-light p-[34px]">
          <div class="mb-4 inline-flex rounded-full bg-[var(--color-brand)]/15 px-4 py-1.5 text-[12px] font-bold uppercase tracking-wide text-[var(--color-dark-olive)]">Advanced Portfolio</div>
          <h3 class="mb-4 text-[22px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">Core-Satellite Portfolio</h3>
          <p class="mb-5 text-[14px] text-[var(--color-muted)]">A structured blend of passive core holdings and tactical satellite positions for enhanced returns.</p>
          <div class="space-y-3">
            {[
              { etf: 'Nifty 50 ETF (Core)', alloc: '40%', role: 'Broad market base' },
              { etf: 'Nifty Next 50 ETF', alloc: '15%', role: 'Mid-to-large cap growth' },
              { etf: 'Nasdaq 100 ETF', alloc: '10%', role: 'Global tech satellite' },
              { etf: 'Nifty Bank ETF', alloc: '10%', role: 'Sectoral satellite' },
              { etf: 'Gold ETF', alloc: '15%', role: 'Safe haven' },
              { etf: 'Short Duration Debt ETF', alloc: '10%', role: 'Stability buffer' },
            ].map(p => (
              <div class="flex items-center justify-between rounded-[10px] border border-[var(--color-n400)] px-4 py-3">
                <div>
                  <div class="text-[13px] font-semibold text-[var(--color-ink)]">{p.etf}</div>
                  <div class="text-[11px] text-[var(--color-muted)]">{p.role}</div>
                </div>
                <span class="text-[18px] font-bold text-[var(--color-dark-olive)]">{p.alloc}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 6. FAQ ════════════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Frequently Asked <span class="text-[var(--color-brand)]">Questions</span>
        </h2>
      </div>
      <div class="equity-reveal mx-auto max-w-[840px] border-t border-[var(--color-n400)]">
        {faqs.map(item => (
          <details class="eq-faq group border-b border-[var(--color-n400)]">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-5 py-[26px] px-2">
              <span class="text-[18px] font-semibold text-[var(--color-ink)]">{item.q}</span>
              <span class="shrink-0 text-[22px] leading-none text-[var(--color-brand)] transition-transform duration-300 group-open:rotate-45">+</span>
            </summary>
            <div class="overflow-hidden px-2 pb-0 text-[16px] leading-relaxed text-[var(--color-muted)] transition-all duration-300 group-open:pb-[28px]">
              <p class="max-w-[680px]">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 7. FINAL CTA ══════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal overflow-hidden rounded-[22px] bg-[var(--color-dark-800)] px-[60px] py-[64px] text-center">
        <h3 class="mx-auto max-w-[560px] text-[38px] font-bold leading-[1.12] text-white" style="font-family:var(--font-display)">Start Building Your ETF Portfolio</h3>
        <p class="mx-auto mt-[18px] max-w-[480px] text-[17px] leading-relaxed text-white/70">Access all ETF categories on NSE & BSE with flat ₹20 brokerage, real-time pricing, and expert portfolio guidance.</p>
        <div class="mt-[34px] flex flex-wrap justify-center gap-[14px]">
          <a href="/about/open-demat-account/" class="btn-primary">Open Demat Account</a>
          <a href="/about/support/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Talk to an RM</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .equity-reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s cubic-bezier(0.22, 0.61, 0.36, 1), transform 0.7s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .equity-reveal.in-view { opacity: 1; transform: none; }

  .steps-grid { display: grid; grid-template-columns: repeat(2, 1fr); }
  .steps-grid > * { border-right: 1px solid var(--color-n400); border-bottom: 1px solid var(--color-n400); }
  .steps-grid > *:nth-child(2n) { border-right: 0; }
  .steps-grid > *:nth-last-child(-n+2) { border-bottom: 0; }
  @media (min-width: 1024px) {
    .steps-grid { grid-template-columns: repeat(4, 1fr); }
    .steps-grid > * { border-right: 1px solid var(--color-n400); border-bottom: 0; }
    .steps-grid > *:last-child { border-right: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .equity-reveal { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).classList.add('in-view');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.10 });
  document.querySelectorAll('.equity-reveal').forEach(el => obs.observe(el));

  document.querySelectorAll<HTMLDetailsElement>('.eq-faq').forEach(d => {
    d.addEventListener('toggle', () => {
      if (d.open) document.querySelectorAll<HTMLDetailsElement>('.eq-faq').forEach(o => { if (o !== d) o.removeAttribute('open'); });
    });
  });
</script>
