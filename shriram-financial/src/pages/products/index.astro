---
import BaseLayout from '../../layouts/BaseLayout.astro';

const tradeCards = [
  { title: 'Equity Trading Made Easy', desc: 'Buy and sell shares across NSE & BSE with expert stock recommendations, real-time market data, and zero brokerage on delivery trades.', href: '/products/equity/' },
  { title: 'Derivatives', desc: 'Trade Futures & Options on NSE & BSE. Hedge your portfolio or capitalise on short-term opportunities with SEBI-registered research.', href: '/products/derivative/' },
  { title: 'Invest in Commodities', desc: 'Diversify your portfolio with gold, silver, crude oil, and agricultural commodity products on MCX & NCDEX.', href: '/products/commodities/' },
  { title: 'Forex Trading Simplified', desc: 'Trade USD/INR, EUR/INR, and other currency pairs with competitive spreads and real-time market insights.', href: '/products/currency/' },
  { title: 'Margin Trading Facility', desc: 'Amplify your buying power with MTF — borrow funds to purchase more shares and maximise your investing potential.', href: '/products/loans/' },
];

const investCards = [
  { title: 'Mutual Funds', desc: 'Compare 3,000+ Mutual Funds and invest in Direct Plans with 0% commission. Start SIP from ₹500/month.', href: '/products/mutual-funds/' },
  { title: 'New Fund Offers (NFO)', desc: 'Get first-mover advantage on newly launched mutual fund schemes at initial NAV pricing.', href: '/products/mutual-funds/' },
  { title: 'Exchange Traded Funds (ETF)', desc: 'Trade diversified ETFs with low expense ratios, instant liquidity, and real-time pricing on NSE & BSE.', href: '/products/etf/' },
  { title: 'Initial Public Offerings (IPO)', desc: 'Stay updated and apply for IPOs across NSE & BSE — invest in companies as they debut on the stock market.', href: '/products/ipo/' },
  { title: 'Bonds & Debentures', desc: 'Invest in government and corporate bonds for stable, predictable fixed-income returns with lower risk.', href: '/products/fd/' },
  { title: 'Fixed Deposits', desc: 'Secure guaranteed returns with fixed deposits from trusted partner financial institutions. Up to 8.5% p.a.', href: '/products/fd/' },
  { title: 'National Pension Scheme (NPS)', desc: 'Build a tax-efficient retirement corpus with government-backed NPS. Save up to ₹2 lakh in annual tax deductions.', href: '/products/nps/' },
  { title: 'Global Investing', desc: 'Access international markets and invest in top US stocks and global ETFs from your Indian account.', href: '/products/global-investing/' },
];

const borrowCards = [
  { title: 'Loan Against Mutual Funds', desc: 'Access instant liquidity by pledging your mutual fund holdings as collateral — without redeeming your investments.', href: '/products/lamf/' },
  { title: 'Loan Against Stocks', desc: 'Leverage your equity portfolio to borrow at competitive interest rates — your shares stay invested while you access cash.', href: '/products/las/' },
];

const stages = [
  { num: '01', name: 'Trade',   pills: ['Equity', 'F&O', 'Commodities'],          dot: { cx: 239, cy: 68  } },
  { num: '02', name: 'Invest',  pills: ['MF', 'IPO', 'Bonds', 'FD'],              dot: { cx: 241, cy: 374 } },
  { num: '03', name: 'Earn',    pills: ['Interest', 'Dividends'],                  dot: { cx: 183, cy: 224 } },
  { num: '04', name: 'Grow',    pills: ['ETFs', 'NPS', 'SIPs'],                   dot: { cx: 567, cy: 68  } },
  { num: '05', name: 'Borrow',  pills: ['LAMF', 'LAS', 'Personal Loans'],         dot: { cx: 627, cy: 224 } },
  { num: '06', name: 'Protect', pills: ['Insurance', 'Term Plans'],                dot: { cx: 565, cy: 374 } },
];

const faqs = [
  {
    q: 'What is a Demat Account?',
    a: 'A Demat Account holds your financial shares, mutual funds, and bonds safely in an electronic format. It is mandatory for trading in the Indian stock market.',
  },
  {
    q: 'What are the benefits of a Demat Account?',
    a: 'A Demat account completely eliminates the risk of theft, loss, or damage to physical paper certificates. It enables instant, one-click online buying and selling of shares, reduces paperwork, and ensures all your investments are visible in one secure place.',
  },
  {
    q: 'What are the brokerage charges for options trading with Shriram Securities?',
    a: 'Brokerage charges for options trading are structured to be competitive and straightforward. Shriram Securities charges a flat fee of ₹20 per executed order for options trading. To further understand and calculate the total costs, including brokerage, taxes, and other fees, you can use the Brokerage Calculator. This tool helps you estimate the net profit or loss on your trades by accounting for all applicable charges.',
  },
  {
    q: 'Are there any charges associated with the Demat Account?',
    a: 'Account opening and Annual Maintenance Charges (AMC) are ₹0 for both Trading and Demat Accounts. Standard SEBI and exchange-mandated statutory charges (STT, exchange transaction charges, GST, SEBI fees) apply to all trades as per regulations.',
  },
  {
    q: 'What is Intraday brokerage and Option brokerage?',
    a: 'Intraday brokerage is the small fee charged when you buy and sell a stock on the exact same day. Option brokerage is a fixed flat fee (like our standard ₹20 per order) charged for trading in options contracts, regardless of how big or small the transaction volume is.',
  },
  {
    q: 'Can I have multiple Demat Accounts?',
    a: 'Yes, absolutely! Legally, you can open more than one Demat account in India, provided they are opened with different stockbrokers. However, you can only link one Demat account to your primary trading account at a time.',
  },
  {
    q: 'Is a Demat Account mandatory for applying for an IPO?',
    a: 'Yes. When a new company lists on the share market, its digital shares must be deposited directly into an electronic account. Therefore, you must have an active Demat account to apply for and receive shares in an IPO.',
  },
];
---

<BaseLayout
  title="Product Suite — Trade, Invest & Borrow | Shriram Financial Services"
  description="Explore all investment and trading products from Shriram Financial Services — equity, derivatives, mutual funds, IPO, NPS, ETF, loans, and more."
>

  <!-- ── Hero ─────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-inner">
      <h1>Everything You Need to <span class="g">Grow Your Wealth</span></h1>
      <p class="lead">Trade, Invest and Borrow — explore our comprehensive suite of financial products and services, all in one place.</p>
      <div class="cta"><a class="btn-gold" href="/about/open-demat-account/">Open Demat Account</a></div>
    </div>
  </section>

  <!-- ── All Products ──────────────────────────────────────────────── -->
  <section class="bg-[#f8f6f1] py-16 lg:py-24">
    <div class="site-wrap">
      <h2 class="text-[24px] font-semibold text-[var(--color-ink)] lg:text-[30px]" style="font-family:var(--font-display)">
        All Products
      </h2>

      <!-- Trade -->
      <div class="mt-12 lg:mt-14">
        <div class="mb-5">
          <span class="inline-flex h-6 items-center rounded-full bg-[var(--color-dark-olive)]/10 px-3 text-[11px] font-bold uppercase tracking-widest text-[var(--color-dark-olive)]">Trade</span>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {tradeCards.map(p => (
            <a href={p.href} class="product-card">
              <div class="product-card-body">
                <h4 class="product-card-title">{p.title}</h4>
                <p class="product-card-desc">{p.desc}</p>
              </div>
              <span class="product-card-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Invest -->
      <div class="mt-12 lg:mt-14">
        <div class="mb-5">
          <span class="inline-flex h-6 items-center rounded-full bg-[var(--color-dark-olive)]/10 px-3 text-[11px] font-bold uppercase tracking-widest text-[var(--color-dark-olive)]">Invest</span>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {investCards.map(p => (
            <a href={p.href} class="product-card">
              <div class="product-card-body">
                <h4 class="product-card-title">{p.title}</h4>
                <p class="product-card-desc">{p.desc}</p>
              </div>
              <span class="product-card-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Featured Offerings (Borrow) -->
      <div class="mt-12 lg:mt-14">
        <div class="mb-5">
          <span class="inline-flex h-6 items-center rounded-full bg-[var(--color-dark-olive)]/10 px-3 text-[11px] font-bold uppercase tracking-widest text-[var(--color-dark-olive)]">Featured Offerings</span>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {borrowCards.map(p => (
            <a href={p.href} class="product-card">
              <div class="product-card-body">
                <h4 class="product-card-title">{p.title}</h4>
                <p class="product-card-desc">{p.desc}</p>
              </div>
              <span class="product-card-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── Six Financial Stages, One Orbit ──────────────────────────── -->
  <section class="overflow-hidden bg-[#1d1d1d] py-16 lg:py-24">
    <div class="site-wrap">
      <div class="mb-10 lg:mb-14">
        <h2 class="text-[24px] font-semibold text-white lg:text-[32px]" style="font-family:var(--font-display)">
          Six Financial Stages, One Orbit.
        </h2>
        <p class="mt-3 max-w-2xl text-[15px] leading-relaxed text-white/50">
          Every financial move you make — trading, building, borrowing, protecting — happens in one connected place. Click any stage to explore.
        </p>
      </div>

      <div class="grid items-center gap-8 lg:grid-cols-2 lg:gap-12">

        <!-- Left: stage list -->
        <div class="rounded-[20px] bg-white/[0.03] p-2">
          {stages.map(s => (
            <div class="stage-row relative flex cursor-pointer items-center justify-between gap-4 overflow-hidden rounded-[14px] border border-transparent px-5 py-4 transition-colors" data-stage={s.num}>
              <div class="shrink-0">
                <p class="stage-num mb-0.5 text-[10px] font-bold uppercase tracking-widest">{s.num}</p>
                <p class="stage-name text-[15px] font-semibold">{s.name}</p>
              </div>
              <div class="flex flex-wrap justify-end gap-1.5">
                {s.pills.map(pill => (
                  <span class="stage-pill rounded-full px-2.5 py-0.5 text-[11px] font-medium">{pill}</span>
                ))}
              </div>
              <span class="stage-progress"></span>
            </div>
          ))}
        </div>

        <!-- Right: orbit canvas -->
        <div class="mx-auto w-full max-w-[520px] lg:max-w-none">
          <canvas id="orbit-canvas" class="block w-full" style="aspect-ratio:1/1" aria-hidden="true"></canvas>
        </div>

      </div>
    </div>
  </section>

  <!-- ── General Questions (FAQ) ───────────────────────────────────── -->
  <section class="faq-wrap" id="sec-faq" style="background:var(--sec-tint)">
    <div class="faq-cols">
      <div class="faq-left">
        <h2 class="faq-title">General Questions</h2>
        <div class="faq-acc">
          {faqs.map((item, i) => (
            <div class={`faq-item${i === 0 ? ' open' : ''}`}>
              <button class="faq-q" type="button">
                <span class="qt">{item.q}</span>
                <span class="faq-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none">
                    <line class="v" x1="12" y1="5" x2="12" y2="19" stroke="#404040" stroke-width="2" stroke-linecap="round"/>
                    <line x1="5" y1="12" x2="19" y2="12" stroke="#404040" stroke-width="2" stroke-linecap="round"/>
                  </svg>
                </span>
              </button>
              <div class="qa-wrap">
                <div class="qa"><p>{item.a}</p></div>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="faq-side">
        <div class="usr" aria-hidden="true">
          <svg viewBox="0 0 128 144" fill="none" xmlns="http://www.w3.org/2000/svg" width="128" height="144">
            <circle cx="64" cy="48" r="32" stroke="#2d3813" stroke-width="2"/>
            <path d="M8 144c0-30.928 25.072-56 56-56s56 25.072 56 56" stroke="#2d3813" stroke-width="2"/>
          </svg>
        </div>
        <div class="side-in">
          <div class="side-tx">
            <h3>Still Have Questions?</h3>
            <p>Book a free 15-minute discovery call with a friendly wealth expert. We'll answer your doubts, help you understand your risk comfort, and show you how a dedicated advisor can fast-track your wealth creation.</p>
          </div>
          <a class="btn-gold" href="/about/support/">Book A Discovery Call</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Final CTA ─────────────────────────────────────────────────── -->
  <section class="cta-sec" id="sec-final-cta" style="background:var(--sec-light)">
    <div class="cta-box">
      <div class="ct-tt">
        <h3>Your New Gateway to the Stock Market</h3>
        <p class="ct-sub">Open a free Demat account in under 10 minutes — zero delivery brokerage, SEBI-registered research, and a dedicated advisor.</p>
      </div>
      <a class="btn-gold" href="/about/open-demat-account/">Open Free Demat Account</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Product Card v7 — Figma 314-8577 hover ── */
  .product-card {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 24px;
    background: #fff;
    border: 1px solid var(--color-warm-border);
    border-radius: 16px;
    text-decoration: none;
    min-height: 130px;
    transition: background 0.25s ease, border-color 0.25s ease;
  }
  .product-card:hover {
    background: #f5f0e8;
    border-color: #2e3914;
  }
  .product-card-body { flex: 1; }
  .product-card-title {
    font-size: 16px;
    font-weight: 600;
    color: var(--color-ink);
    font-family: var(--font-display);
    line-height: 1.3;
  }
  .product-card-desc {
    margin-top: 8px;
    font-size: 13px;
    line-height: 1.6;
    color: var(--color-muted);
  }
  .product-card-arrow {
    flex-shrink: 0;
    align-self: center;
    font-size: 18px;
    color: var(--color-ink);
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  .product-card:hover .product-card-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── Stage rows ── */
  .stage-num  { color: rgba(255,255,255,0.22); }
  .stage-name { color: rgba(255,255,255,0.46); transition: color 0.3s; }
  .stage-pill { color: rgba(255,255,255,0.26); background: rgba(255,255,255,0.05); }

  .stage-row { transition: background 0.3s, border-color 0.3s; }
  .stage-row.is-active { border-color: rgba(243,184,63,0.28); background: rgba(243,184,63,0.07); }
  .stage-row.is-active .stage-num  { color: var(--color-brand); }
  .stage-row.is-active .stage-name { color: #ffffff; }
  .stage-row.is-active .stage-pill { background: rgba(243,184,63,0.12); color: rgba(243,184,63,0.82); }

  /* Progress bar */
  .stage-progress {
    position: absolute;
    bottom: 0; left: 14px; right: 14px;
    height: 1.5px;
    background: var(--color-brand);
    border-radius: 9999px;
    width: 0;
    opacity: 0;
  }
  @keyframes stage-fill {
    from { width: 0; opacity: 0.8; }
    to   { width: calc(100% - 28px); opacity: 0.8; }
  }
</style>

<script>
  // FAQ button accordion — one open at a time
  document.querySelectorAll('.faq-acc').forEach(acc => {
    acc.querySelectorAll('.faq-item').forEach(item => {
      const btn = item.querySelector('.faq-q');
      if (!btn) return;
      btn.addEventListener('click', () => {
        const isOpen = item.classList.contains('open');
        acc.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
        if (!isOpen) item.classList.add('open');
      });
    });
  });

  // ── Orbit: shared state, auto-cycle, progress bars ───────────────
  const STAGES = ['01','02','03','04','05','06'];
  const CYCLE_MS = 2800;
  let orbitActive = STAGES[0];
  let cycleIdx = 0;
  const stageRows = Array.from(document.querySelectorAll('.stage-row'));

  function setActive(num) {
    orbitActive = num;
    stageRows.forEach(row => {
      const on = row.dataset.stage === num;
      row.classList.toggle('is-active', on);
      const bar = row.querySelector('.stage-progress');
      if (!bar) return;
      // Restart CSS animation cleanly
      bar.style.animation = 'none';
      void bar.offsetWidth;
      bar.style.animation = on ? `stage-fill ${CYCLE_MS}ms linear forwards` : 'none';
    });
  }

  function startCycle() {
    return setInterval(() => {
      cycleIdx = (cycleIdx + 1) % STAGES.length;
      setActive(STAGES[cycleIdx]);
    }, CYCLE_MS);
  }

  let cycleTimer = startCycle();

  stageRows.forEach(el => el.addEventListener('click', () => {
    clearInterval(cycleTimer);
    cycleIdx = STAGES.indexOf(el.dataset.stage);
    setActive(el.dataset.stage);
    cycleTimer = startCycle();
  }));

  setActive(STAGES[0]);

  // ── Orbit canvas — 3D perspective solar system ───────────────────
  (function () {
    const canvas = document.getElementById('orbit-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const DPR = Math.min(window.devicePixelRatio || 1, 2);
    const L = 700;
    canvas.width = L * DPR; canvas.height = L * DPR;
    ctx.scale(DPR, DPR);

    const cx = L / 2, cy = L / 2;
    const OR = L * 0.41;
    const IR = L * 0.25;
    const DEG = Math.PI / 180;
    const ELEV = 28 * DEG;
    const sinE = Math.sin(ELEV);

    function proj(angle, r) {
      const oz = Math.sin(angle) * r;
      return { x: cx + Math.cos(angle) * r, y: cy + oz * sinE, depth: oz };
    }

    const stars = Array.from({ length: 150 }, () => ({
      x: Math.random() * L, y: Math.random() * L,
      r: Math.random() * 1.3 + 0.2,
      a: Math.random() * 0.32 + 0.06,
    }));

    const planets = [
      { stage:'01', name:'Trade',   r:OR, a:270*DEG, spd:0.30*DEG },
      { stage:'04', name:'Grow',    r:OR, a: 90*DEG, spd:0.30*DEG },
      { stage:'02', name:'Invest',  r:OR, a:200*DEG, spd:0.30*DEG },
      { stage:'06', name:'Protect', r:OR, a: 20*DEG, spd:0.30*DEG },
      { stage:'03', name:'Earn',    r:IR, a:180*DEG, spd:0.50*DEG },
      { stage:'05', name:'Borrow',  r:IR, a:  0*DEG, spd:0.50*DEG },
    ];

    let frame = 0;

    function drawRing(r) {
      const steps = 90;
      ctx.beginPath();
      for (let i = 0; i <= steps; i++) {
        const a = Math.PI + Math.PI * (i / steps);
        const p = proj(a, r);
        i === 0 ? ctx.moveTo(p.x, p.y) : ctx.lineTo(p.x, p.y);
      }
      ctx.setLineDash([4, 9]); ctx.lineWidth = 1;
      ctx.strokeStyle = 'rgba(255,255,255,0.06)'; ctx.stroke();
      ctx.beginPath();
      for (let i = 0; i <= steps; i++) {
        const a = Math.PI * (i / steps);
        const p = proj(a, r);
        i === 0 ? ctx.moveTo(p.x, p.y) : ctx.lineTo(p.x, p.y);
      }
      ctx.strokeStyle = 'rgba(255,255,255,0.20)'; ctx.stroke();
      ctx.setLineDash([]);
    }

    function draw() {
      frame++;
      ctx.clearRect(0, 0, L, L);

      stars.forEach(s => {
        ctx.beginPath(); ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255,255,255,${s.a})`; ctx.fill();
      });

      [OR, IR].forEach(r => drawRing(r));

      planets.forEach(p => { p.a += p.spd; });
      const sorted = [...planets].sort((a, b) => proj(a.a, a.r).depth - proj(b.a, b.r).depth);

      sorted.forEach(p => {
        const pos = proj(p.a, p.r);
        const isActive = p.stage === orbitActive; // reads module-scope var

        const dn    = (pos.depth / p.r + 1) / 2;
        const scale = 0.50 + 0.60 * dn;
        const alpha = 0.40 + 0.60 * dn;
        const dotR  = (isActive ? 11 : 7) * scale;

        if (isActive) {
          const pg = ctx.createRadialGradient(pos.x, pos.y, 0, pos.x, pos.y, dotR * 5.5);
          pg.addColorStop(0,   `rgba(243,184,63,${0.60 * alpha})`);
          pg.addColorStop(0.4, `rgba(243,184,63,${0.18 * alpha})`);
          pg.addColorStop(1,   'rgba(243,184,63,0)');
          ctx.fillStyle = pg; ctx.beginPath(); ctx.arc(pos.x, pos.y, dotR * 5.5, 0, Math.PI * 2); ctx.fill();
          const pr = 0.5 + 0.5 * Math.sin(frame * 0.09);
          ctx.beginPath(); ctx.arc(pos.x, pos.y, dotR * (2.2 + pr), 0, Math.PI * 2);
          ctx.strokeStyle = `rgba(243,184,63,${0.50 * (1 - pr) * alpha})`; ctx.lineWidth = 1.2; ctx.stroke();
        } else {
          const ig = ctx.createRadialGradient(pos.x, pos.y, 0, pos.x, pos.y, dotR * 3);
          ig.addColorStop(0, `rgba(255,255,255,${0.09 * alpha})`);
          ig.addColorStop(1, 'rgba(255,255,255,0)');
          ctx.fillStyle = ig; ctx.beginPath(); ctx.arc(pos.x, pos.y, dotR * 3, 0, Math.PI * 2); ctx.fill();
        }

        const hl = ctx.createRadialGradient(
          pos.x - dotR * 0.32, pos.y - dotR * 0.32, dotR * 0.04,
          pos.x, pos.y, dotR
        );
        if (isActive) {
          hl.addColorStop(0,    `rgba(255,225,140,${alpha})`);
          hl.addColorStop(0.45, `rgba(243,184,63,${0.92 * alpha})`);
          hl.addColorStop(1,    `rgba(170,110,10,${0.45 * alpha})`);
        } else {
          hl.addColorStop(0,    `rgba(245,248,255,${0.90 * alpha})`);
          hl.addColorStop(0.45, `rgba(175,185,215,${0.65 * alpha})`);
          hl.addColorStop(1,    `rgba(90,100,145,${0.20 * alpha})`);
        }
        ctx.beginPath(); ctx.arc(pos.x, pos.y, dotR, 0, Math.PI * 2);
        ctx.fillStyle = hl; ctx.fill();

        const lp    = proj(p.a, p.r + dotR + 20);
        const align = lp.x > cx + 20 ? 'left' : (lp.x < cx - 20 ? 'right' : 'center');
        const base  = lp.y > pos.y + 2 ? 'top'  : (lp.y < pos.y - 2 ? 'bottom' : 'middle');
        ctx.fillStyle = isActive
          ? `rgba(243,184,63,${Math.min(1, 0.88 * alpha + 0.12)})`
          : `rgba(255,255,255,${0.25 + 0.32 * dn})`;
        ctx.font = `${isActive ? '700' : '500'} ${Math.round(11 + 2 * dn)}px Inter,system-ui,sans-serif`;
        ctx.textAlign = align; ctx.textBaseline = base;
        ctx.fillText(p.name, lp.x, lp.y);
      });

      requestAnimationFrame(draw);
    }

    draw();
  })();
</script>
