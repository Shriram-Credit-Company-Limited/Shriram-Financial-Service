---
import BaseLayout from '../../layouts/BaseLayout.astro';

const tradeCards = [
  { title: 'Equity Trading Made Easy', desc: 'Buy and sell shares across NSE & BSE with expert stock recommendations, real-time market data, and zero brokerage on delivery trades.', href: '/products/equity/' },
  { title: 'Derivatives', desc: 'Trade Futures & Options on NSE & BSE. Hedge your portfolio or capitalise on short-term opportunities with SEBI-registered research.', href: '/products/derivative/' },
  { title: 'Invest in Commodities', desc: 'Diversify your portfolio with gold, silver, crude oil, and agricultural commodity products on MCX & NCDEX.', href: '/products/commodities/' },
  { title: 'Forex Trading Simplified', desc: 'Trade USD/INR, EUR/INR, and other currency pairs with competitive spreads and real-time market insights.', href: '/products/currency/' },
  { title: 'Margin Trading Facility', desc: 'Amplify your buying power with MTF — borrow funds to purchase more shares and maximise your investing potential.', href: '/products/loans/' },
];

const investCards = [
  { title: 'Mutual Funds', desc: 'Compare 3,000+ Mutual Funds and invest in Direct Plans with 0% commission. Start SIP from ₹500/month.', href: '/products/mutual-funds/' },
  { title: 'New Fund Offers (NFO)', desc: 'Get first-mover advantage on newly launched mutual fund schemes at initial NAV pricing.', href: '/products/mutual-funds/' },
  { title: 'Exchange Traded Funds (ETF)', desc: 'Trade diversified ETFs with low expense ratios, instant liquidity, and real-time pricing on NSE & BSE.', href: '/products/etf/' },
  { title: 'Initial Public Offerings (IPO)', desc: 'Stay updated and apply for IPOs across NSE & BSE — invest in companies as they debut on the stock market.', href: '/products/ipo/' },
  { title: 'Bonds & Debentures', desc: 'Invest in government and corporate bonds for stable, predictable fixed-income returns with lower risk.', href: '/products/fd/' },
  { title: 'Fixed Deposits', desc: 'Secure guaranteed returns with fixed deposits from trusted partner financial institutions. Up to 8.5% p.a.', href: '/products/fd/' },
  { title: 'National Pension Scheme (NPS)', desc: 'Build a tax-efficient retirement corpus with government-backed NPS. Save up to ₹2 lakh in annual tax deductions.', href: '/products/nps/' },
  { title: 'Global Investing', desc: 'Access international markets and invest in top US stocks and global ETFs from your Indian account.', href: '/products/global-investing/' },
];

const borrowCards = [
  { title: 'Loan Against Mutual Funds', desc: 'Access instant liquidity by pledging your mutual fund holdings as collateral — without redeeming your investments.', href: '/products/loans/' },
  { title: 'Loan Against Securities', desc: 'Leverage your equity and bond portfolio to borrow at competitive interest rates when you need liquidity fast.', href: '/products/loans/' },
];

const stages = [
  { num: '01', name: 'Trade', desc: 'Execute equity, F&O, commodity and currency trades with research-backed precision and dedicated RM support.', pills: ['Equity', 'F&O', 'Commodities', 'Currency'], dot: { cx: 239, cy: 68 } },
  { num: '02', name: 'Invest', desc: 'Build wealth through mutual funds, IPOs, ETFs, and bonds — systematically, commission-free, and with expert guidance.', pills: ['Mutual Funds', 'IPO', 'Bonds', 'Fixed Deposits'], dot: { cx: 241, cy: 374 } },
  { num: '03', name: 'Earn', desc: 'Generate passive income through dividends, interest payments, and yield-based financial instruments.', pills: ['Dividends', 'Interest', 'REITs'], dot: { cx: 183, cy: 224 } },
  { num: '04', name: 'Grow', desc: 'Compound your returns over time with tax-efficient and long-horizon strategies curated by our experts.', pills: ['ETFs', 'NPS', 'SIPs', 'PMS'], dot: { cx: 567, cy: 68 } },
  { num: '05', name: 'Borrow', desc: 'Access short-term liquidity by leveraging your existing investments as collateral — without breaking your portfolio.', pills: ['LAMF', 'LAS', 'MTF'], dot: { cx: 627, cy: 224 } },
  { num: '06', name: 'Protect', desc: 'Secure your financial future with insurance products designed for long-term investors and their families.', pills: ['Term Insurance', 'Health Cover'], dot: { cx: 565, cy: 374 } },
];

const faqs = [
  {
    q: 'What is a Demat Account?',
    a: 'A Demat Account holds your financial shares, mutual funds, and bonds safely in an electronic format. It is mandatory for trading in the Indian stock market.',
  },
  {
    q: 'What are the benefits of a Demat Account?',
    a: 'A Demat account completely eliminates the risk of theft, loss, or damage to physical paper certificates. It enables instant, one-click online buying and selling of shares, reduces paperwork, and ensures all your investments are visible in one secure place.',
  },
  {
    q: 'What are the brokerage charges for options trading with Shriram Securities?',
    a: 'Brokerage charges for options trading are structured to be competitive and straightforward. Shriram Securities charges a flat fee of ₹20 per executed order for options trading. To further understand and calculate the total costs, including brokerage, taxes, and other fees, you can use the Brokerage Calculator. This tool helps you estimate the net profit or loss on your trades by accounting for all applicable charges.',
  },
  {
    q: 'Are there any charges associated with the Demat Account?',
    a: 'Account opening and Annual Maintenance Charges (AMC) are ₹0 for both Trading and Demat Accounts. Standard SEBI and exchange-mandated statutory charges (STT, exchange transaction charges, GST, SEBI fees) apply to all trades as per regulations.',
  },
  {
    q: 'What is Intraday brokerage and Option brokerage?',
    a: 'Intraday brokerage is the small fee charged when you buy and sell a stock on the exact same day. Option brokerage is a fixed flat fee (like our standard ₹20 per order) charged for trading in options contracts, regardless of how big or small the transaction volume is.',
  },
  {
    q: 'Can I have multiple Demat Accounts?',
    a: 'Yes, absolutely! Legally, you can open more than one Demat account in India, provided they are opened with different stockbrokers. However, you can only link one Demat account to your primary trading account at a time.',
  },
  {
    q: 'Is a Demat Account mandatory for applying for an IPO?',
    a: 'Yes. When a new company lists on the share market, its digital shares must be deposited directly into an electronic account. Therefore, you must have an active Demat account to apply for and receive shares in an IPO.',
  },
];
---

<BaseLayout
  title="Product Suite — Trade, Invest & Borrow | Shriram Financial Services"
  description="Explore all investment and trading products from Shriram Financial Services — equity, derivatives, mutual funds, IPO, NPS, ETF, loans, and more."
>

  <!-- ── Hero ─────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden" style="background: radial-gradient(ellipse 132% 312% at 117% -4%, #4F583B 0%, #3F4733 14%, #363A2C 25%, #2a2d23 38%, #1d1d1d 55%, #1d1d1d 100%);">
    <div class="site-wrap relative z-10 py-16 lg:py-24">
      <nav class="mb-6 flex items-center gap-2 text-[12px] text-white/40" aria-label="Breadcrumb">
        <a href="/" class="transition-colors hover:text-white/70">Home</a>
        <span aria-hidden="true">›</span>
        <span class="text-white/60">Products</span>
      </nav>
      <p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-brand)]">Product Suite</p>
      <h1 class="mt-3 max-w-3xl text-[32px] font-bold leading-tight text-white lg:text-[40px]" style="font-family:var(--font-display)">
        Everything You Need to Grow Your Wealth
      </h1>
      <p class="mt-4 max-w-xl text-[15px] leading-relaxed text-white/60 lg:text-[16px]">
        Trade, Invest and Borrow — explore our comprehensive list of financial products and services, all in one place.
      </p>
    </div>
  </section>

  <!-- ── All Products ──────────────────────────────────────────────── -->
  <section class="bg-[#f8f6f1] py-16 lg:py-24">
    <div class="site-wrap">
      <h2 class="text-[24px] font-semibold text-[var(--color-ink)] lg:text-[30px]" style="font-family:var(--font-display)">
        All Products
      </h2>

      <!-- Trade -->
      <div class="mt-12 lg:mt-14">
        <div class="mb-5 flex items-center gap-3">
          <span class="inline-flex h-6 items-center rounded-full bg-[var(--color-dark-olive)]/10 px-3 text-[11px] font-bold uppercase tracking-widest text-[var(--color-dark-olive)]">Trade</span>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {tradeCards.map(p => (
            <a href={p.href} class="product-card group">
              <h4 class="product-card-title">{p.title}</h4>
              <p class="product-card-desc">{p.desc}</p>
              <span class="product-card-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Invest -->
      <div class="mt-12 lg:mt-14">
        <div class="mb-5 flex items-center gap-3">
          <span class="inline-flex h-6 items-center rounded-full bg-[var(--color-dark-olive)]/10 px-3 text-[11px] font-bold uppercase tracking-widest text-[var(--color-dark-olive)]">Invest</span>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {investCards.map(p => (
            <a href={p.href} class="product-card group">
              <h4 class="product-card-title">{p.title}</h4>
              <p class="product-card-desc">{p.desc}</p>
              <span class="product-card-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Borrow -->
      <div class="mt-12 lg:mt-14">
        <div class="mb-5 flex items-center gap-3">
          <span class="inline-flex h-6 items-center rounded-full bg-[var(--color-dark-olive)]/10 px-3 text-[11px] font-bold uppercase tracking-widest text-[var(--color-dark-olive)]">Borrow</span>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {borrowCards.map(p => (
            <a href={p.href} class="product-card group">
              <h4 class="product-card-title">{p.title}</h4>
              <p class="product-card-desc">{p.desc}</p>
              <span class="product-card-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── Six Financial Stages, One Orbit ──────────────────────────── -->
  <section class="overflow-hidden bg-[#1d1d1d] py-16 lg:py-24">
    <div class="site-wrap">
      <div class="mb-12 lg:mb-16">
        <p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-brand)]">Your Wealth Journey</p>
        <h2 class="mt-3 text-[24px] font-semibold text-white lg:text-[30px]" style="font-family:var(--font-display)">
          Six Financial Stages, One Orbit
        </h2>
        <p class="mt-3 max-w-xl text-[15px] leading-relaxed text-white/55">
          Every investor's journey passes through these six stages. We support you across all of them.
        </p>
      </div>

      <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-12">

        <!-- Left: stage accordion -->
        <div id="stages-accord">
          {stages.map((s, i) => (
            <div class="stage-item border-b border-white/10 py-5 cursor-pointer" data-stage={s.num}>
              <div class="flex items-center gap-4">
                <span class="stage-num shrink-0 text-[13px] font-bold text-white/30">{s.num}</span>
                <span class="stage-name text-[18px] font-semibold text-white/55">{s.name}</span>
                <svg class="stage-chevron ml-auto h-4 w-4 shrink-0 text-white/30 transition-transform duration-200" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6l4 4 4-4"/></svg>
              </div>
              <div class="stage-body mt-3 pl-[38px]">
                <p class="text-[14px] leading-relaxed text-white/55">{s.desc}</p>
                <div class="mt-3 flex flex-wrap gap-2">
                  {s.pills.map(pill => (
                    <span class="inline-flex h-6 items-center rounded-full border border-white/15 px-3 text-[11px] font-medium text-white/55">{pill}</span>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- Right: SVG orbit -->
        <div class="flex items-center justify-center">
          <svg viewBox="0 0 840 448" class="w-full max-w-[480px]" aria-hidden="true" id="orbit-svg">
            <!-- Outer dashed circle -->
            <circle cx="407" cy="224" r="224" stroke="rgba(255,255,255,0.12)" stroke-width="1" stroke-dasharray="5 5" fill="none"/>
            <!-- Inner dashed ellipse -->
            <ellipse cx="407" cy="224" rx="224" ry="151" stroke="rgba(255,255,255,0.12)" stroke-width="1" stroke-dasharray="5 5" fill="none"/>
            <!-- Center glow ring -->
            <circle cx="407" cy="224" r="93.5" fill="rgba(243,184,63,0.07)" stroke="rgba(243,184,63,0.22)" stroke-width="1"/>
            <!-- Center label -->
            <text x="407" y="219" text-anchor="middle" fill="rgba(255,255,255,0.85)" font-size="13" font-weight="600">Your</text>
            <text x="407" y="236" text-anchor="middle" fill="rgba(255,255,255,0.85)" font-size="13" font-weight="600">Wealth</text>

            <!-- Stage dot groups -->
            {stages.map(s => (
              <g class="orbit-stage" data-stage={s.num}>
                <circle cx={s.dot.cx} cy={s.dot.cy} r="28" class="orbit-dot" fill="rgba(255,255,255,0.04)" stroke="rgba(255,255,255,0.18)" stroke-width="1.5"/>
                <text x={s.dot.cx} y={s.dot.cy - 4} text-anchor="middle" class="orbit-label-num" fill="rgba(255,255,255,0.35)" font-size="9">{s.num}</text>
                <text x={s.dot.cx} y={s.dot.cy + 9} text-anchor="middle" class="orbit-label-name" fill="rgba(255,255,255,0.50)" font-size="9" font-weight="500">{s.name}</text>
              </g>
            ))}
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- ── General Questions ─────────────────────────────────────────── -->
  <section class="bg-white py-16 lg:py-24">
    <div class="site-wrap">
      <h2 class="text-[24px] font-semibold text-[var(--color-ink)] lg:text-[30px]" style="font-family:var(--font-display)">
        General <span class="text-[var(--color-brand)]">Questions</span>
      </h2>

      <div class="mt-10 grid gap-8 lg:grid-cols-[1fr_1.4fr] lg:gap-12">

        <!-- CTA card -->
        <div class="flex flex-col justify-between rounded-[24px] bg-[var(--color-dark-olive)] p-8 lg:p-10">
          <div class="h-32 w-32 rounded-full border border-white/10 opacity-20 lg:h-48 lg:w-48"></div>
          <div class="mt-8">
            <h3 class="text-[22px] font-semibold leading-snug text-white lg:text-[26px]" style="font-family:var(--font-display)">
              Still Have Questions?
            </h3>
            <p class="mt-3 text-[14px] leading-relaxed text-white/60">
              Book a free 15-minute discovery call with a friendly wealth expert. We will answer your doubts, help you understand your risk comfort, and show you how a dedicated advisor can fast-track your wealth creation.
            </p>
            <a href="/about/support/" class="mt-6 inline-flex h-11 w-[220px] items-center justify-center rounded-[6px] bg-[var(--color-brand)] text-[13px] font-semibold text-[#202318] transition-colors hover:bg-[var(--color-brand-hover)]">
              Book a Discovery Call
            </a>
          </div>
        </div>

        <!-- FAQ accordion -->
        <div class="flex flex-col gap-2" id="ps-faq-accord">
          {faqs.map((item) => (
            <details class="group overflow-hidden rounded-[12px] border border-[var(--color-n400)] bg-white">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 lg:px-6 lg:py-5">
                <span class="text-[14px] font-medium text-[var(--color-n900)] lg:text-[15px]">{item.q}</span>
                <span class="grid h-6 w-6 shrink-0 place-items-center rounded-full border border-[var(--color-n400)] text-[var(--color-n700)] transition-transform group-open:rotate-45">
                  <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" class="h-3 w-3"><path d="M6 2v8M2 6h8"/></svg>
                </span>
              </summary>
              <div class="border-t border-[var(--color-n400)] bg-[var(--color-n100)] px-5 py-4 lg:px-6">
                <p class="text-[14px] leading-relaxed text-[var(--color-muted)]">{item.a}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA Band ──────────────────────────────────────────────────── -->
  <section class="site-wrap pb-20">
    <div class="relative overflow-hidden rounded-[24px] p-10 lg:p-14" style="background: radial-gradient(ellipse 132% 312% at 117% -4%, #4F583B 0%, #3F4733 14%, #363A2C 25%, #2a2d23 38%, #1d1d1d 55%, #1d1d1d 100%);">
      <div class="relative flex flex-col items-start justify-between gap-6 md:flex-row md:items-center">
        <div>
          <h2 class="text-[22px] font-bold text-white lg:text-[28px]" style="font-family:var(--font-display)">
            We are now your new gateway to the Stock Market!
          </h2>
          <p class="mt-2 max-w-md text-[14px] text-white/60">
            Open a free Demat account in under 10 minutes — zero delivery brokerage, SEBI-registered research, and a dedicated advisor.
          </p>
        </div>
        <a href="/about/open-demat-account/" class="inline-flex h-12 shrink-0 items-center justify-center rounded-[6px] bg-[var(--color-brand)] px-8 text-[13px] font-semibold text-[#202318] transition-all hover:bg-[var(--color-brand-hover)]">
          Open Free Demat Account
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Product Card v7 */
  .product-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 24px;
    background: #fff;
    border: 1px solid var(--color-warm-border);
    border-radius: 16px;
    text-decoration: none;
    min-height: 130px;
    transition: background 0.22s ease, border-color 0.22s ease, transform 0.22s ease;
  }
  .product-card:hover {
    background: var(--color-dark-olive);
    border-color: var(--color-dark-olive);
    transform: translateY(-2px);
  }
  .product-card-title {
    font-size: 16px;
    font-weight: 600;
    color: var(--color-ink);
    font-family: var(--font-display);
    line-height: 1.3;
    transition: color 0.22s ease;
  }
  .product-card:hover .product-card-title { color: var(--color-brand); }
  .product-card-desc {
    font-size: 13px;
    line-height: 1.6;
    color: var(--color-muted);
    flex: 1;
    transition: color 0.22s ease;
  }
  .product-card:hover .product-card-desc { color: rgba(255,255,255,0.65); }
  .product-card-arrow {
    font-size: 15px;
    color: var(--color-brand);
    display: block;
    transition: transform 0.22s ease;
  }
  .product-card:hover .product-card-arrow { transform: translateX(4px); }

  /* Stage accordion */
  .stage-body { display: none; }
  .stage-item.is-active .stage-num  { color: var(--color-brand); }
  .stage-item.is-active .stage-name { color: #fff; }
  .stage-item.is-active .stage-chevron { transform: rotate(180deg); color: var(--color-brand); }
  .stage-item.is-active .stage-body { display: block; }

  /* Orbit SVG */
  .orbit-dot { transition: fill 0.25s ease, stroke 0.25s ease; }
  .orbit-label-num, .orbit-label-name { transition: fill 0.25s ease; }
  .orbit-stage.is-active .orbit-dot { fill: rgba(243,184,63,0.18); stroke: rgba(243,184,63,0.65); stroke-width: 1.5px; }
  .orbit-stage.is-active .orbit-label-num { fill: rgba(243,184,63,0.85); }
  .orbit-stage.is-active .orbit-label-name { fill: rgba(243,184,63,0.90); }
</style>

<script>
  // FAQ accordion — only one open at a time
  const faqAccord = document.getElementById('ps-faq-accord');
  faqAccord?.querySelectorAll('details').forEach(d => {
    d.addEventListener('toggle', () => {
      if (d.open) {
        faqAccord.querySelectorAll('details').forEach(o => { if (o !== d) o.removeAttribute('open'); });
      }
    });
  });

  // Stage accordion + orbit highlight sync
  const stageItems = document.querySelectorAll('.stage-item');
  const orbitStages = document.querySelectorAll('.orbit-stage');

  function activateStage(num) {
    stageItems.forEach(el => el.classList.toggle('is-active', el.dataset.stage === num));
    orbitStages.forEach(el => el.classList.toggle('is-active', el.dataset.stage === num));
  }

  stageItems.forEach(el => {
    el.addEventListener('click', () => activateStage(el.dataset.stage));
  });

  // Activate first stage on load
  activateStage('01');
</script>
