---
import BaseLayout from '../../layouts/BaseLayout.astro';

const markets = [
  { region: 'United States', indices: 'S&P 500, Nasdaq 100, Dow Jones', desc: "The world's largest and most liquid market. Access Apple, Microsoft, Amazon, NVIDIA, and thousands of global category leaders with deep research coverage.", icon: '🇺🇸' },
  { region: 'Europe',        indices: 'FTSE 100, DAX, CAC 40, STOXX 50', desc: 'Established multinationals in luxury, automotive, pharma, and banking. Built-in currency diversification across EUR, GBP, and CHF.', icon: '🇪🇺' },
  { region: 'Asia Pacific',  indices: 'Hang Seng, Nikkei 225, MSCI Asia', desc: 'Chinese tech, Japanese precision manufacturing, and South Korean semiconductors — high-growth markets with distinct economic cycles from India.', icon: '🌏' },
];

const howItWorks = [
  { label: 'LRS (Liberalised Remittance Scheme)',  desc: "Remit up to USD 250,000 per financial year for overseas investment under FEMA's LRS. Funds go to your foreign brokerage account or via India-based fund-of-funds." },
  { label: 'India-Listed Global Funds',             desc: 'The simplest route — buy Nasdaq 100 ETFs or S&P 500 index funds listed on Indian exchanges. No LRS needed; invest like any domestic mutual fund.' },
  { label: 'Direct Foreign Stock Platform',         desc: 'Buy fractional US shares (Apple, NVIDIA, Berkshire) directly via LRS-linked platforms. More flexibility for individual stock-pickers.' },
];

const steps = [
  { n: '01', title: 'Choose Your Route',                     desc: 'Decide between India-listed international ETFs/funds (no LRS, simplest) or a direct foreign stock account (LRS required, more flexibility).' },
  { n: '02', title: 'Complete KYC & Currency Exchange',      desc: 'For LRS-based investing, submit Form A2 to your bank and complete FEMA compliance. For India-listed funds, standard KYC through Shriram is sufficient.' },
  { n: '03', title: 'Select Markets & Instruments',          desc: 'Choose geographic markets, index funds, ETFs, or specific stocks. Our research desk provides guidance on US and international market opportunities.' },
  { n: '04', title: 'Monitor Global Portfolio',              desc: 'Track your international positions alongside domestic holdings on the Antara app. Set FX rate alerts and portfolio rebalancing reminders.' },
];

const risks = [
  { label: 'Currency Risk',             desc: 'Returns in USD or EUR convert to INR on exit. If INR strengthens, your rupee returns fall even if the underlying stock rose.' },
  { label: 'Regulatory Risk',           desc: 'RBI and SEBI periodically revise LRS limits and fund-of-fund structures. A regulatory change can restrict overseas investment or affect existing holdings.' },
  { label: 'Market & Geopolitical Risk',desc: "Trade wars, sanctions, and foreign central bank policy drive international markets — factors outside India-based investors' control." },
  { label: 'TCS on Remittance',         desc: "LRS remittances above ₹7 lakh/year attract 20% TCS under Section 206C(1G). It's refundable via ITR, but creates temporary cash flow drag." },
];

const regGuide = [
  {
    title: 'LRS — Liberalised Remittance Scheme',
    points: [
      'All Indian residents can remit up to USD 250,000 (~₹2.08 crore) per financial year',
      'Covers overseas investment, education, travel, and property purchase',
      'Remittance above ₹7 lakh/year attracts 20% TCS (refundable via ITR filing)',
      'Submit Form A2 with your authorised dealer bank for each remittance',
    ]
  },
  {
    title: 'FEMA 1999 Compliance',
    points: [
      'FEMA governs all cross-border capital flows for Indian residents',
      'Overseas investment in securities is a "capital account transaction" permitted under FEMA',
      'OTC forex trading (offshore brokers) is a FEMA violation — punishable by penalty',
      'Keep proof of all overseas investments and file Schedule FA in your ITR',
    ]
  },
  {
    title: 'RBI Guidelines',
    points: [
      'RBI approves and monitors LRS remittances through authorised dealer banks',
      'No RBI approval needed for individual LRS investments up to USD 250,000',
      'RBI can revise LRS limits — check rbi.org.in for current guidelines',
      'NRIs have separate FEMA permissions and cannot use LRS',
    ]
  },
];

const faqs = [
  { q: 'Can Indian residents invest in US stocks?',                        a: 'Yes — two routes: (1) India-listed international ETFs/funds, no LRS needed; (2) Direct US stock investment via a foreign brokerage linked to an LRS-compliant Indian bank, allowing fractional shares.' },
  { q: 'What is the LRS limit for investing abroad?',                      a: "Under FEMA's LRS, Indian residents can remit up to USD 250,000 (~₹2.08 crore) per financial year for overseas investment. Remittances above ₹7 lakh attract 20% TCS, refundable via ITR." },
  { q: 'How are international investment returns taxed in India?',         a: 'Direct LRS holdings: short-term gains (under 2 years) taxed per slab; long-term gains (2+ years) at 12.5%. India-listed international ETFs are taxed as debt funds — per slab for both short and long term (from April 2023).' },
  { q: 'Is investing in international markets risky for Indian investors?', a: "Global diversification reduces overall portfolio correlation — US and Indian markets don't always move together. Currency, geopolitical, and regulatory risks are additional. A 10–20% allocation via India-listed international ETFs suits most retail investors." },
];
---

<BaseLayout
  title="Global Investing from India — US Stocks S&amp;P 500 International ETFs | Shriram"
  description="Start global investing from India in US stocks, S&amp;P 500, and Nasdaq 100 via LRS or India-listed international ETFs. FEMA-compliant, expert-guided. Start today."
>

  <!-- ══ HERO ═══════════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-inner">
      <h1><span class="g">Global Investing from India</span> — US Stocks, ETFs &amp; More</h1>
      <p class="lead">Diversify beyond India. Access S&amp;P 500, Nasdaq 100, and global leaders like Apple, NVIDIA, and Microsoft — with expert guidance and LRS-compliant processes from Shriram Financial Services.</p>
      <div class="cta-row">
        <a class="btn-gold" href="/about/open-demat-account/">Start Global Investing</a>
        <a class="btn-ghost" href="/about/support/">Talk to RM</a>
      </div>
      <ul class="feats">
        {['USD 250,000 LRS limit', 'No LRS for India-listed ETFs', 'Expert global research', 'Currency & FX guidance'].map(f => (
          <li class="feat"><span class="tk">✓</span><span class="lb">{f}</span></li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ══ WHAT IS GLOBAL INVESTING? ═════════════════════════════════ -->
  <section class="section auto" style="background:var(--sec-light)">
    <div class="def-row">
      <p class="sec-title">What is <span class="g">Global Investing?</span></p>
      <div class="def-body">
        <p>Global investing means allocating a portion of your portfolio to financial assets outside India — primarily US stocks, international ETFs, global mutual funds (fund-of-funds), or direct foreign securities — to benefit from global economic growth and currency diversification.</p>
        <p>For Indian investors, global investing is legally permitted under FEMA's Liberalised Remittance Scheme (LRS) — up to USD 250,000 (~₹2.1 crore) per financial year. A simpler route requires no LRS at all: India-listed international ETFs and fund-of-funds track global indices like the S&amp;P 500 and Nasdaq 100 and are bought like any domestic mutual fund.</p>
      </div>
    </div>
    <div class="cat-grid" style="margin-top:64px;grid-template-columns:repeat(3,1fr)">
      {[
        { title: 'Why Diversify Globally?',  desc: 'Indian markets (Nifty 50) and US markets (S&P 500) are not correlated — when one falls, the other often holds. A 10–20% global allocation smooths overall portfolio volatility.' },
        { title: 'Currency Hedge',            desc: 'The Indian rupee has historically depreciated ~4% per year against the USD. Investing in USD-denominated assets provides a natural hedge against INR weakness.' },
        { title: 'Access to Global Leaders', desc: "India has no equivalent of Apple, NVIDIA, Microsoft, or Amazon. Global investing lets you own the world's most innovative companies — unavailable on Indian exchanges." },
      ].map((c, i) => (
        <div class="cat" style={i===2?'border-right:0':''}>
          <h4>{c.title}</h4>
          <p>{c.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ══ MARKETS YOU CAN ACCESS ════════════════════════════════════ -->
  <section class="section" style="background:var(--sec-tint)">
    <p class="sec-title">Markets You <span class="g">Can Access</span></p>
    <p class="sec-lead" style="margin-top:16px">From Silicon Valley tech giants to European luxury brands and Asian semiconductor leaders, global diversification is now accessible to every Indian investor.</p>
    <div class="cat-grid" style="margin-top:48px;grid-template-columns:repeat(3,1fr)">
      {markets.map((m, i) => (
        <div class="cat" style={i===2?'border-right:0':''}>
          <div class="mkt-head">
            <span class="mkt-icon">{m.icon}</span>
            <div>
              <h4 style="margin-bottom:4px">{m.region}</h4>
              <p class="mkt-idx">{m.indices}</p>
            </div>
          </div>
          <p>{m.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ══ WAYS TO INVEST ════════════════════════════════════════════ -->
  <section class="section" style="background:var(--sec-light)">
    <p class="sec-title">Ways to Invest <span class="g">Internationally from India</span></p>
    <p class="sec-lead" style="margin-top:16px">Three routes — from the simplest (no LRS needed) to full direct stock access via the liberalised remittance scheme.</p>
    <div class="way-list" style="margin-top:48px">
      {howItWorks.map((h, i) => (
        <div class="way-item">
          <div class="way-num">{i + 1}</div>
          <div>
            <p class="way-title">{h.label}</p>
            <p class="way-desc">{h.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ══ GLOBAL INVESTING vs INDIA INVESTING ═══════════════════════ -->
  <section class="section" style="background:var(--sec-tint)">
    <p class="sec-title">Global Investing vs <span class="g">Indian Investing</span></p>
    <p class="sec-lead" style="margin-top:16px">How do US and Indian markets compare across returns, risk, currency, and access? Use this to decide your right allocation.</p>
    <div class="t-wrap" style="margin-top:48px">
      <div class="t-scroll">
        <table>
          <thead><tr>
            <th>Factor</th><th class="hl">US Markets (S&amp;P 500)</th><th>Indian Markets (Nifty 50)</th>
          </tr></thead>
          <tbody>
            {[
              { factor: '10-Year CAGR (USD / INR)',      us: '~12–14% USD CAGR',                              india: '~11–13% INR CAGR' },
              { factor: 'Currency',                      us: 'USD — appreciates vs INR (avg ~4%/yr)',          india: 'INR — depreciates vs USD historically' },
              { factor: 'Volatility',                    us: 'Lower (deepest market globally)',                india: 'Higher (emerging market premium)' },
              { factor: 'Sectors Represented',           us: 'Tech, AI, Healthcare, Consumer, Financials',    india: 'Financials, IT, Energy, FMCG, Industrials' },
              { factor: 'Liquidity',                     us: 'Extremely high — $30T+ market cap',             india: 'High — but smaller universe' },
              { factor: 'Correlation with Indian Stocks',us: 'Low-to-moderate (diversification benefit)',     india: 'Full — no diversification within India' },
              { factor: 'Recommended Allocation',        us: '10–30% of total equity portfolio',             india: '70–90% of total equity portfolio' },
            ].map(r => (
              <tr>
                <td class="k">{r.factor}</td><td class="hl">{r.us}</td><td>{r.india}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ══ HOW TO START ══════════════════════════════════════════════ -->
  <section class="section" style="background:var(--sec-light)">
    <p class="sec-title">How to Start <span class="g">Global Investing</span></p>
    <p class="sec-lead" style="margin-top:16px">Four steps from choosing your route to monitoring your international portfolio.</p>
    <div class="steps" style="margin-top:48px">
      {steps.map((s, i, arr) => (<>
        <div class="step">
          <div class="num">{s.n}</div>
          <h4>{s.title}</h4>
          <p>{s.desc}</p>
        </div>
        {i < arr.length - 1 && <div class="step-div"></div>}
      </>))}
    </div>
  </section>

  <!-- ══ US STOCKS FOR INDIANS — DEEP DIVE ════════════════════════ -->
  <section class="section" style="background:var(--sec-tint)">
    <p class="sec-title">US Stocks for Indians — <span class="g">What You Need to Know</span></p>
    <p class="sec-lead" style="margin-top:16px">From opening a foreign brokerage account to understanding fractional shares — here's the complete guide.</p>
    <div class="cat-grid" style="margin-top:48px">
      {[
        { title: 'Fractional Shares',      desc: "Buy a fraction of expensive US stocks like Amazon (₹1,50,000+) or Google. Many platforms allow investments from as little as $1, making global giants accessible to all." },
        { title: 'Top US Sectors',         desc: "Technology (Apple, NVIDIA, Microsoft), Healthcare (Pfizer, UnitedHealth), Consumer (Amazon, Meta), Financials (JPMorgan). Pick sectors India doesn't offer." },
        { title: 'S&P 500 vs Nasdaq 100', desc: 'S&P 500 covers the 500 largest US companies (diversified). Nasdaq 100 concentrates on top 100 tech/growth stocks (higher risk, higher growth potential). Most beginners start with S&P 500.' },
        { title: 'Dividend vs Growth',     desc: 'US dividend stocks (Coca-Cola, J&J, AT&T) yield 2–5% USD annually — useful for USD income. Growth stocks (Tesla, NVIDIA) pay no dividend but offer capital appreciation.' },
      ].map((c, i) => (
        <div class="cat" style={i===3?'border-right:0':''}>
          <h4>{c.title}</h4>
          <p>{c.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ══ GLOBAL MUTUAL FUNDS & ETFS ════════════════════════════════ -->
  <section class="section" style="background:var(--sec-light)">
    <p class="sec-title">Global Mutual Funds &amp; <span class="g">International ETFs</span></p>
    <p class="sec-lead" style="margin-top:16px">The simplest way to invest globally from India — no LRS, no forex conversion, same process as buying a domestic mutual fund.</p>
    <div class="t-wrap" style="margin-top:48px">
      <div class="t-scroll">
        <table>
          <thead><tr>
            <th>Fund Type</th><th class="hl">What It Tracks</th><th>LRS Required?</th><th>Tax Treatment</th>
          </tr></thead>
          <tbody>
            {[
              { type: 'India-listed S&P 500 ETF',        tracks: 'Top 500 US companies',                   lrs: 'No',                    tax: 'As per slab (debt fund rules)' },
              { type: 'India-listed Nasdaq 100 ETF',     tracks: 'Top 100 US tech/growth stocks',          lrs: 'No',                    tax: 'As per slab' },
              { type: 'International Fund-of-Funds',     tracks: 'Global ETFs via feeder structure',       lrs: 'No',                    tax: 'As per slab' },
              { type: 'Direct US Stock (LRS)',            tracks: 'Individual US stocks/ETFs',              lrs: 'Yes (up to $250K/yr)',  tax: 'STCG/LTCG + US WHT' },
              { type: 'Regional Funds (Europe, Asia)',   tracks: 'European or Asian markets',              lrs: 'No',                    tax: 'As per slab' },
            ].map(r => (
              <tr>
                <td class="k">{r.type}</td><td class="hl">{r.tracks}</td><td>{r.lrs}</td><td>{r.tax}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
    <a class="btn-gold" href="/about/open-demat-account/" style="align-self:center;margin-top:32px">Start with India-listed International ETFs</a>
  </section>

  <!-- ══ RISKS OF GLOBAL INVESTING ════════════════════════════════ -->
  <section class="section" style="background:var(--sec-tint)">
    <p class="sec-title">Risks of <span class="g">Global Investing</span></p>
    <p class="sec-lead" style="margin-top:16px">Understand what can move against you before you commit capital to international markets.</p>
    <div class="cat-grid" style="margin-top:48px">
      {risks.map((r, i) => (
        <div class="cat-dark" style={i===3?'border-right:0':''}>
          <h4>{r.label}</h4>
          <p>{r.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ══ TAXATION OF GLOBAL INVESTMENTS ═══════════════════════════ -->
  <section class="section" style="background:var(--sec-light)">
    <p class="sec-title">Taxation of <span class="g">Global Investments</span></p>
    <p class="sec-lead" style="margin-top:16px">Tax treatment depends on your route — direct LRS investing vs India-listed international funds. Both India and source-country taxes may apply.</p>
    <div class="t-wrap" style="margin-top:48px">
      <div class="t-scroll">
        <table>
          <thead><tr>
            <th>Tax Head</th><th class="hl">Direct US Stocks (LRS)</th><th>India-Listed Intl ETF/Fund</th>
          </tr></thead>
          <tbody>
            {[
              { head: 'US Dividend Withholding Tax',                         lrs: '25% (15% with DTAA benefit — file W-8BEN)',              india: 'Not applicable (fund handles it)' },
              { head: 'STCG (under 2 years — LRS; under 3 years — India)', lrs: 'As per income tax slab',                                 india: 'As per income tax slab' },
              { head: 'LTCG (2+ years — LRS; 3+ years — India funds)',     lrs: '12.5% (no indexation from FY2024)',                      india: 'As per slab (no indexation from Apr 2023)' },
              { head: 'DTAA Benefit',                                        lrs: 'India-US DTAA allows credit for US tax paid',            india: 'Managed at fund level — transparent to investor' },
              { head: 'TCS on LRS Remittance',                              lrs: '20% TCS above ₹7 lakh/year (refundable via ITR)',        india: 'No TCS (domestic investment)' },
            ].map(r => (
              <tr>
                <td class="k">{r.head}</td><td class="hl">{r.lrs}</td><td>{r.india}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ══ REGULATORY GUIDE ══════════════════════════════════════════ -->
  <section class="section" style="background:var(--sec-tint)">
    <p class="sec-title">Regulatory Guide — <span class="g">LRS, FEMA &amp; RBI Rules</span></p>
    <p class="sec-lead" style="margin-top:16px">Everything Indian residents need to know to invest globally in a legal and FEMA-compliant manner.</p>
    <div class="cat-grid" style="margin-top:48px;grid-template-columns:repeat(3,1fr)">
      {regGuide.map((c, i) => (
        <div class="cat" style={i===2?'border-right:0':''}>
          <h4>{c.title}</h4>
          <ul class="reg-list">
            {c.points.map(p => (
              <li><span class="tk">→</span><span>{p}</span></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- ══ CALCULATORS & TOOLS ══════════════════════════════════════ -->
  <section class="section" style="background:var(--sec-light)">
    <p class="sec-title">Global Investing <span class="g">Calculators &amp; Tools</span></p>
    <p class="sec-lead" style="margin-top:16px">Estimate your global portfolio returns, currency impact, and tax before investing a single rupee.</p>
    <div class="cat-grid" style="margin-top:48px;grid-template-columns:repeat(3,1fr)">
      {[
        { title: 'Currency Impact Calculator', desc: 'See how INR/USD movements affect your actual returns in rupee terms. A 10% USD appreciation adds ~10% to your INR return on top of the underlying stock gain.', cta: 'Calculate Currency Impact', href: '/calculators/sip/' },
        { title: 'US vs India Return Comparison', desc: 'Compare S&P 500 CAGR vs Nifty 50 CAGR over 5, 10, and 20-year periods with INR adjustment. Understand the real diversification benefit in rupee-adjusted terms.', cta: 'Compare Returns', href: '/calculators/sip/' },
        { title: 'LRS Tax (TCS) Calculator', desc: 'Estimate your 20% TCS liability on LRS remittances above ₹7 lakh. Know your temporary cash outflow and when to expect the refund via ITR.', cta: 'Estimate TCS', href: '/calculators/sip/' },
      ].map((c, i) => (
        <div class="cat" style={i===2?'border-right:0':''}>
          <h4>{c.title}</h4>
          <p>{c.desc}</p>
          <a href={c.href} class="cat-cta">{c.cta} →</a>
        </div>
      ))}
    </div>
  </section>

  <!-- ══ FAQ ════════════════════════════════════════════════════════ -->
  <section class="faq-wrap" id="sec-faq">
    <div class="faq-cols">
      <div class="faq-left">
        <p class="faq-title">Frequently Asked <span class="g">Questions</span></p>
        <ul class="faq-acc">
          {faqs.map(item => (
            <li class="faq-item">
              <details>
                <summary class="faq-sum">
                  <span class="qt">{item.q}</span>
                  <svg class="faq-icon faq-v" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="2" x2="8" y2="14"/><line x1="2" y1="8" x2="14" y2="8"/></svg>
                  <svg class="faq-icon faq-h" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><line x1="2" y1="8" x2="14" y2="8"/></svg>
                </summary>
                <div class="qa"><p>{item.a}</p></div>
              </details>
            </li>
          ))}
        </ul>
      </div>
      <div class="faq-side">
        <img src="/images/advisor-avatar.png" alt="Financial advisor" class="usr-img" />
        <div class="side-in">
          <div class="side-tx">
            <h4>Still got questions?</h4>
            <p>Our global investing specialists will guide you through LRS compliance, fund selection, and tax planning.</p>
          </div>
          <a class="btn-gold" href="/about/support/">Book a Call</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ FINAL CTA ══════════════════════════════════════════════════ -->
  <section class="cta-sec" style="background:var(--sec-tint)">
    <div class="cta-box">
      <p class="cta-h">Go Global with <span class="g">Shriram Financial Services</span></p>
      <p class="cta-sub">Access US stocks, global ETFs, and international funds — expert-guided, FEMA-compliant, and fully digital.</p>
      <div class="cta-row" style="margin-top:0;justify-content:center">
        <a class="btn-gold" href="/about/open-demat-account/">Start Investing</a>
        <a class="btn-dark" href="/about/support/">Talk to an RM</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  :root {
    --sec-light:#fef8ee; --sec-tint:#f6efe1;
    --card:#fffdf8; --card-border:#e1e0db; --card-border-soft:rgba(28,28,22,.13); --row-line:rgba(28,28,22,.08);
    --olive-title:#2e3914; --olive-head:#2d3813; --olive-deep:#1b2010;
    --ink:#1c1c16; --ink-2:#46463c; --ink-3:#595959; --muted:#73736a;
    --gold:#e0a82e; --gold-2:#f2b83f; --gold-btn:#f3b83f; --gold-ink:#231a06; --olive-ink:#2e3914; --green:#009d58;
    --pad:clamp(20px,8vw,144px); --section-y:72px; --cta-w:220px;
  }
  *, *::before, *::after { box-sizing: border-box; }
  a { color: inherit; text-decoration: none; }
  p { line-height: 1.5; margin: 0; }
  ul { list-style: none; padding: 0; margin: 0; }

  .section { padding: var(--section-y) var(--pad); min-height: 100vh; min-height: 100dvh; display: flex; flex-direction: column; justify-content: center; }
  .section.auto { min-height: 0; }
  .sec-title { font-weight: 400; font-size: 40px; color: var(--olive-title); line-height: 1.4; max-width: 860px; }
  .sec-lead  { font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.5; max-width: 640px; }
  .g { color: var(--gold-2); }

  .hero { padding: 0 var(--pad); display: flex; flex-direction: column; justify-content: center; overflow: hidden; background: radial-gradient(125% 210% at 100% -8%, #4f583b 0%, #363a2c 50%, #1d1d1d 100%); }
  .hero-inner { padding: clamp(80px,12vw,140px) 0 clamp(48px,6vw,80px); display: flex; flex-direction: column; }
  .hero h1 { font-weight: 500; font-size: 40px; color: #fff; line-height: 1.5; max-width: 860px; }
  .hero .lead { margin-top: 32px; font-weight: 400; font-size: 18px; line-height: 1.5; color: rgba(255,255,255,.74); max-width: 600px; }
  .cta-row { margin-top: 40px; display: flex; flex-wrap: wrap; gap: 14px; align-items: center; }
