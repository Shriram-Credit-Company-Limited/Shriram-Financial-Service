---
import BaseLayout from '../../layouts/BaseLayout.astro';

const markets = [
  { region: 'United States', indices: 'S&P 500, Nasdaq 100, Dow Jones', desc: 'The world\'s largest and most liquid market. Access Apple, Microsoft, Amazon, NVIDIA, and thousands of global category leaders with deep research coverage.', icon: '🇺🇸' },
  { region: 'Europe', indices: 'FTSE 100, DAX, CAC 40, STOXX 50', desc: 'Established multinationals in luxury, automotive, pharma, and banking. Built-in currency diversification across EUR, GBP, and CHF.', icon: '🇪🇺' },
  { region: 'Asia Pacific', indices: 'Hang Seng, Nikkei 225, MSCI Asia', desc: 'Chinese tech, Japanese precision manufacturing, and South Korean semiconductors — high-growth markets with distinct economic cycles from India.', icon: '🌏' },
];

const howItWorks = [
  { label: 'LRS (Liberalised Remittance Scheme)', desc: 'Remit up to USD 250,000 per financial year for overseas investment under FEMA\'s LRS. Funds go to your foreign brokerage account or via India-based fund-of-funds.' },
  { label: 'India-Listed Global Funds', desc: 'The simplest route — buy Nasdaq 100 ETFs or S&P 500 index funds listed on Indian exchanges. No LRS needed; invest like any domestic mutual fund.' },
  { label: 'Direct Foreign Stock Platform', desc: 'Buy fractional US shares (Apple, NVIDIA, Berkshire) directly via LRS-linked platforms. More flexibility for individual stock-pickers.' },
];

const steps = [
  { n: '01', title: 'Choose Your Route', desc: 'Decide between India-listed international ETFs/funds (no LRS, simplest) or a direct foreign stock account (LRS required, more flexibility).' },
  { n: '02', title: 'Complete KYC & Currency Exchange', desc: 'For LRS-based investing, submit Form A2 to your bank and complete FEMA compliance. For India-listed funds, standard KYC through Shriram is sufficient.' },
  { n: '03', title: 'Select Markets & Instruments', desc: 'Choose geographic markets, index funds, ETFs, or specific stocks. Our research desk provides guidance on US and international market opportunities.' },
  { n: '04', title: 'Monitor Global Portfolio', desc: 'Track your international positions alongside domestic holdings on the Antara app. Set FX rate alerts and portfolio rebalancing reminders.' },
];

const risks = [
  { n: '01', label: 'Currency Risk', desc: 'Returns in USD or EUR convert to INR on exit. If INR strengthens, your rupee returns fall even if the underlying stock rose.' },
  { n: '02', label: 'Regulatory Risk', desc: 'RBI and SEBI periodically revise LRS limits and fund-of-fund structures. A regulatory change can restrict overseas investment or affect existing holdings.' },
  { n: '03', label: 'Market & Geopolitical Risk', desc: 'Trade wars, sanctions, and foreign central bank policy drive international markets — factors outside India-based investors\' control.' },
  { n: '04', label: 'TCS on Remittance', desc: 'LRS remittances above ₹7 lakh/year attract 20% TCS under Section 206C(1G). It\'s refundable via ITR, but creates temporary cash flow drag.' },
];

const faqs = [
  { q: 'Can Indian residents invest in US stocks?', a: 'Yes — two routes: (1) India-listed international ETFs/funds, no LRS needed; (2) Direct US stock investment via a foreign brokerage linked to an LRS-compliant Indian bank, allowing fractional shares.' },
  { q: 'What is the LRS limit for investing abroad?', a: 'Under FEMA\'s LRS, Indian residents can remit up to USD 250,000 (~₹2.08 crore) per financial year for overseas investment. Remittances above ₹7 lakh attract 20% TCS, refundable via ITR.' },
  { q: 'How are international investment returns taxed in India?', a: 'Direct LRS holdings: short-term gains (under 2 years) taxed per slab; long-term gains (2+ years) at 12.5%. India-listed international ETFs are taxed as debt funds — per slab for both short and long term (from April 2023).' },
  { q: 'Is investing in international markets risky for Indian investors?', a: 'Global diversification reduces overall portfolio correlation — US and Indian markets don\'t always move together. Currency, geopolitical, and regulatory risks are additional. A 10–20% allocation via India-listed international ETFs suits most retail investors.' },
];
---

<BaseLayout
  title="Global Investing from India — US Stocks S&amp;P 500 International ETFs | Shriram"
  description="Start global investing from India in US stocks, S&amp;P 500, and Nasdaq 100 via LRS or India-listed international ETFs. FEMA-compliant, expert-guided. Start today."
>

  <!-- ══ 1. HERO ═══════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[var(--color-dark-800)]">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[560px] w-[560px] rounded-full bg-[var(--color-brand)]/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-32 left-0 h-80 w-80 rounded-full bg-[var(--color-brand)]/5 blur-3xl"></div>
    <div class="site-wrap relative py-[120px]">
      <p class="equity-reveal text-[14px] font-medium tracking-[.04em] text-[var(--color-brand)]">Global Investing</p>
      <h1 class="equity-reveal mt-[22px] max-w-[880px] text-[clamp(32px,4vw,52px)] font-bold leading-[1.06] text-white" style="font-family:var(--font-display)">
        <span class="text-[var(--color-brand)]">Global Investing from India</span> — US Stocks, ETFs &amp; More
      </h1>
      <p class="equity-reveal mt-[26px] max-w-[600px] text-[18px] leading-relaxed text-white/70">
        Diversify beyond India. Access S&P 500, Nasdaq 100, and global leaders like Apple, NVIDIA, and Microsoft — with expert guidance and LRS-compliant processes from Shriram Financial Services.
      </p>
      <div class="equity-reveal mt-[38px] flex flex-wrap gap-[14px]">
        <a href="/about/open-demat-account/" class="btn-primary">Start Global Investing</a>
        <a href="/about/support/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Talk to RM</a>
      </div>
      <div class="equity-reveal mt-[54px] flex flex-wrap gap-x-9 gap-y-3 border-t border-white/15 pt-9">
        {['✓ USD 250,000 LRS limit', '✓ No LRS for India-listed ETFs', '✓ Expert global research', '✓ Currency & FX guidance'].map(f => (
          <span class="text-[15px] font-medium text-white/90">
            <span class="mr-2 text-[var(--color-brand)]">{f.slice(0,1)}</span>{f.slice(1)}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 2. WHAT IS GLOBAL INVESTING? ═════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto grid max-w-[1000px] items-start gap-[72px] lg:grid-cols-[5fr_7fr]">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          What is <span class="text-[var(--color-brand)]">Global Investing?</span>
        </h2>
        <div class="space-y-5 text-[17px] leading-relaxed text-[var(--color-muted)]">
          <p>Global investing means allocating a portion of your portfolio to financial assets outside India — primarily US stocks, international ETFs, global mutual funds (fund-of-funds), or direct foreign securities — to benefit from global economic growth and currency diversification.</p>
          <p>For Indian investors, global investing is legally permitted under FEMA's Liberalised Remittance Scheme (LRS) — up to USD 250,000 (~₹2.1 crore) per financial year. A simpler route requires no LRS at all: India-listed international ETFs and fund-of-funds track global indices like the S&P 500 and Nasdaq 100 and are bought like any domestic mutual fund.</p>
        </div>
      </div>
      <div class="equity-reveal mx-auto mt-[64px] max-w-[1000px] grid gap-5 sm:grid-cols-3">
        {[
          { label: 'Why Diversify Globally?', desc: 'Indian markets (Nifty 50) and US markets (S&P 500) are not correlated — when one falls, the other often holds. A 10–20% global allocation smooths overall portfolio volatility.', tag: 'Diversification' },
          { label: 'Currency Hedge', desc: 'The Indian rupee has historically depreciated ~4% per year against the USD. Investing in USD-denominated assets provides a natural hedge against INR weakness.', tag: 'INR Protection' },
          { label: 'Access to Global Leaders', desc: 'India has no equivalent of Apple, NVIDIA, Microsoft, or Amazon. Global investing lets you own the world\'s most innovative companies — unavailable on Indian exchanges.', tag: 'Global Exposure' },
        ].map((c, i) => (
          <div class="equity-reveal product-card-light flex flex-col gap-3 p-[30px]" style={`animation-delay:${i*80}ms`}>
            <span class="inline-flex w-fit rounded-full bg-[var(--color-brand)]/15 px-3 py-1 text-[11px] font-bold uppercase tracking-wide text-[var(--color-dark-olive)]">{c.tag}</span>
            <h3 class="text-[19px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{c.label}</h3>
            <p class="text-[13px] leading-relaxed text-[var(--color-muted)]">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 3. MARKETS YOU CAN ACCESS ═════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto grid max-w-[1000px] items-start gap-[72px] lg:grid-cols-[5fr_7fr]">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Markets You <span class="text-[var(--color-brand)]">Can Access</span>
        </h2>
        <div class="space-y-5 text-[17px] leading-relaxed text-[var(--color-muted)]">
          <p>Global investing opens access to world-class companies and economies beyond India — reducing portfolio concentration and capturing growth from the world's strongest markets.</p>
          <p>From Silicon Valley tech giants to European luxury brands and Asian semiconductor leaders, global diversification is now accessible to every Indian investor.</p>
        </div>
      </div>
      <div class="equity-reveal mx-auto mt-[76px] max-w-[1000px] border-t border-[var(--color-n400)] pt-[60px]">
        <div class="grid gap-5 sm:grid-cols-3">
          {markets.map((m, i) => (
            <div class="product-card-light flex flex-col gap-4 p-[34px]" style={`animation-delay:${i*80}ms`}>
              <div class="flex items-center gap-3">
                <span class="text-[32px]">{m.icon}</span>
                <div>
                  <h3 class="text-[17px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{m.region}</h3>
                  <p class="text-[12px] font-medium text-[var(--color-brand-deep)]">{m.indices}</p>
                </div>
              </div>
              <p class="text-[13px] leading-relaxed text-[var(--color-muted)]">{m.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 3. WAYS TO INVEST ══════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Ways to Invest <span class="text-[var(--color-brand)]">Internationally from India</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Three routes — from the simplest (no LRS needed) to full direct stock access via the liberalised remittance scheme.</p>
      </div>
      <div class="equity-reveal space-y-4">
        {howItWorks.map((h, i) => (
          <div class="flex items-start gap-5 rounded-[20px] border border-[var(--color-warm-border)] bg-white p-7">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[var(--color-dark-olive)] text-[12px] font-bold text-[var(--color-brand)]">{i+1}</span>
            <div>
              <h3 class="text-[16px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{h.label}</h3>
              <p class="mt-2 text-[13px] leading-relaxed text-[var(--color-muted)]">{h.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 4b. GLOBAL INVESTING VS INDIA INVESTING ════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Global Investing vs <span class="text-[var(--color-brand)]">Indian Investing</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">How do US and Indian markets compare across returns, risk, currency, and access? Use this to decide your right allocation.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[24px] py-[16px] text-left text-[13px] font-semibold text-white">Factor</th>
                <th class="px-[24px] py-[16px] text-left text-[13px] font-semibold text-[var(--color-brand)]">US Markets (S&P 500)</th>
                <th class="px-[24px] py-[16px] text-left text-[13px] font-semibold text-[var(--color-brand)]">Indian Markets (Nifty 50)</th>
              </tr>
            </thead>
            <tbody>
              {[
                { factor: '10-Year CAGR (USD / INR)', us: '~12–14% USD CAGR', india: '~11–13% INR CAGR' },
                { factor: 'Currency', us: 'USD — appreciates vs INR (avg ~4%/yr)', india: 'INR — depreciates vs USD historically' },
                { factor: 'Volatility', us: 'Lower (deepest market globally)', india: 'Higher (emerging market premium)' },
                { factor: 'Sectors Represented', us: 'Tech, AI, Healthcare, Consumer, Financials', india: 'Financials, IT, Energy, FMCG, Industrials' },
                { factor: 'Liquidity', us: 'Extremely high — $30T+ market cap', india: 'High — but smaller universe' },
                { factor: 'Correlation with Indian Stocks', us: 'Low-to-moderate (diversification benefit)', india: 'Full — no diversification within India' },
                { factor: 'Recommended Allocation', us: '10–30% of total equity portfolio', india: '70–90% of total equity portfolio' },
              ].map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[var(--color-n100)]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[24px] py-[14px] font-semibold text-[var(--color-ink)]">{r.factor}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[24px] py-[14px] text-[var(--color-muted)]">{r.us}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[24px] py-[14px] text-[var(--color-muted)]">{r.india}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 5. HOW TO START ════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How to Start <span class="text-[var(--color-brand)]">Global Investing</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Four steps from choosing your route to monitoring your international portfolio.</p>
      </div>
      <div class="equity-reveal steps-grid overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        {steps.map(s => (
          <div class="px-[30px] py-[34px]">
            <div class="mb-[22px] font-display text-[34px] font-normal leading-none text-[var(--color-brand)]">{s.n}</div>
            <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">{s.title}</h4>
            <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 5b. US STOCKS FOR INDIANS — DEEP DIVE ════════════════════ -->
  <section class="bg-[var(--color-n100)] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          US Stocks for Indians — <span class="text-[var(--color-brand)]">What You Need to Know</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">From opening a foreign brokerage account to understanding fractional shares — here's the complete guide.</p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { title: 'Fractional Shares', desc: 'Buy a fraction of expensive US stocks like Amazon (₹1,50,000+) or Google. Many platforms allow investments from as little as $1, making global giants accessible to all.', tag: 'Low Minimums' },
          { title: 'Top US Sectors', desc: 'Technology (Apple, NVIDIA, Microsoft), Healthcare (Pfizer, UnitedHealth), Consumer (Amazon, Meta), Financials (JPMorgan). Pick sectors India doesn\'t offer.', tag: 'Sector Access' },
          { title: 'S&P 500 vs Nasdaq 100', desc: 'S&P 500 covers the 500 largest US companies (diversified). Nasdaq 100 concentrates on top 100 tech/growth stocks (higher risk, higher growth potential). Most beginners start with S&P 500.', tag: 'Index Choice' },
          { title: 'Dividend Stocks vs Growth', desc: 'US dividend stocks (Coca-Cola, J&J, AT&T) yield 2–5% USD annually — useful for USD income. Growth stocks (Tesla, NVIDIA) pay no dividend but offer capital appreciation.', tag: 'Strategy' },
        ].map((c, i) => (
          <div class="equity-reveal product-card-light flex flex-col gap-3 p-[28px]" style={`animation-delay:${i*80}ms`}>
            <span class="inline-flex w-fit rounded-full bg-[var(--color-brand)]/15 px-3 py-1 text-[11px] font-bold uppercase tracking-wide text-[var(--color-dark-olive)]">{c.tag}</span>
            <h3 class="text-[18px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{c.title}</h3>
            <p class="text-[13px] leading-relaxed text-[var(--color-muted)]">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 5c. GLOBAL MUTUAL FUNDS & ETFS ═══════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Global Mutual Funds & <span class="text-[var(--color-brand)]">International ETFs</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">The simplest way to invest globally from India — no LRS, no forex conversion, same process as buying a domestic mutual fund.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[24px] py-[16px] text-left text-[13px] font-semibold text-white">Fund Type</th>
                <th class="px-[24px] py-[16px] text-left text-[13px] font-semibold text-[var(--color-brand)]">What It Tracks</th>
                <th class="px-[24px] py-[16px] text-left text-[13px] font-semibold text-[var(--color-brand)]">LRS Required?</th>
                <th class="px-[24px] py-[16px] text-left text-[13px] font-semibold text-[var(--color-brand)]">Tax Treatment</th>
              </tr>
            </thead>
            <tbody>
              {[
                { type: 'India-listed S&P 500 ETF', tracks: 'Top 500 US companies', lrs: 'No', tax: 'As per slab (debt fund rules)' },
                { type: 'India-listed Nasdaq 100 ETF', tracks: 'Top 100 US tech/growth stocks', lrs: 'No', tax: 'As per slab' },
                { type: 'International Fund-of-Funds', tracks: 'Global ETFs via feeder structure', lrs: 'No', tax: 'As per slab' },
                { type: 'Direct US Stock (LRS)', tracks: 'Individual US stocks/ETFs', lrs: 'Yes (up to $250K/yr)', tax: 'STCG/LTCG + US WHT' },
                { type: 'Regional Funds (Europe, Asia)', tracks: 'European or Asian markets', lrs: 'No', tax: 'As per slab' },
              ].map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[var(--color-n100)]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[24px] py-[14px] font-semibold text-[var(--color-ink)]">{r.type}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[24px] py-[14px] text-[var(--color-muted)]">{r.tracks}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[24px] py-[14px] text-[var(--color-muted)]">{r.lrs}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[24px] py-[14px] text-[var(--color-muted)]">{r.tax}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
      <div class="equity-reveal mt-[32px] text-center">
        <a href="/about/open-demat-account/" class="btn-primary">Start with India-listed International ETFs</a>
      </div>
    </div>
  </section>

  <!-- ══ 6. RISKS ════════════════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Risks of <span class="text-[var(--color-brand)]">Global Investing</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Understand what can move against you before you commit capital to international markets.</p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {risks.map(r => (
          <div class="equity-reveal rounded-[18px] bg-[var(--color-dark-800)] p-[36px]">
            <div class="mb-[18px] text-[48px] font-bold leading-none text-[var(--color-brand)]/25">{r.n}</div>
            <h4 class="mb-3 text-[20px] font-medium text-white" style="font-family:var(--font-display)">{r.label}</h4>
            <p class="text-[14.5px] leading-relaxed text-white/60">{r.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 5b. TAXATION OF GLOBAL INVESTMENTS ════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Taxation of <span class="text-[var(--color-brand)]">Global Investments</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Tax treatment depends on your route — direct LRS investing vs India-listed international funds. Both India and source-country taxes may apply.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[24px] py-[16px] text-left text-[13px] font-semibold text-white">Tax Head</th>
                <th class="px-[24px] py-[16px] text-left text-[13px] font-semibold text-[var(--color-brand)]">Direct US Stocks (LRS)</th>
