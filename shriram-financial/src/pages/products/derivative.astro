---
import BaseLayout from '../../layouts/BaseLayout.astro';

const types = [
  { label: 'Futures Contracts', desc: 'A binding agreement to buy or sell an asset at a set price on a future date. Both parties are obligated to fulfil the contract at expiry.' },
  { label: 'Options Contracts', desc: 'The right — not the obligation — to buy or sell at a strike price before expiry. Buyers risk only the premium paid; upside is unlimited for calls.' },
];

const eligibility = [
  'Indian resident individual or entity (HUF, firm, company)',
  'Valid PAN Card and active trading + Demat account',
  'F&O segment activation on your trading account (SEBI mandate)',
  'Bank account with sufficient margin balance',
  'For NRI: RBI-approved broker and NRE/NRO bank account',
];

const documents = [
  'PAN Card (mandatory for all account types)',
  'Address Proof — Aadhaar / Passport / Utility Bill',
  'Bank Account Proof — cancelled cheque or statement',
  'Income proof — 6-month bank statement or ITR (for F&O segment activation)',
];

const steps = [
  { n: '01', title: 'Open & Activate Trading Account', desc: 'Open a Demat + trading account and request F&O segment activation. Shriram enables this 100% digitally.' },
  { n: '02', title: 'Add Margin to Your Account', desc: 'Transfer funds to meet the SPAN + Exposure margin requirement. F&O requires upfront margin collateral.' },
  { n: '03', title: 'Select Underlying & Expiry', desc: 'Choose your index (NIFTY, BANKNIFTY) or stock, select the expiry date (weekly or monthly), and strike price.' },
  { n: '04', title: 'Place Your F&O Order', desc: 'Buy or write (sell) futures or options contracts through our platform and monitor P&L in real time.' },
];

const chargeRows = [
  { label: 'Brokerage', futures: '₹20 per executed order', options: '₹20 per executed order' },
  { label: 'STT', futures: '0.0125% on sell side (contracts)', options: '0.125% on sell side (premium)' },
  { label: 'GST', futures: '18% on brokerage + charges', options: '18% on brokerage + charges' },
  { label: 'Exchange Charges', futures: '0.00235% (NSE)', options: '0.053% (NSE)' },
  { label: 'SEBI Turnover Fee', futures: '₹10 per crore', options: '₹10 per crore' },
];

const strategies = [
  { label: 'Long Call', desc: 'Buy a call option when you expect the price to rise. Maximum loss is limited to the premium paid.', type: 'Bullish' },
  { label: 'Bull Put Spread', desc: 'Sell a higher-strike put, buy a lower-strike put. Profit if the underlying stays above the sold strike.', type: 'Bullish' },
  { label: 'Long Put', desc: 'Buy a put option when you expect the price to fall. Ideal for hedging an existing long position.', type: 'Bearish' },
  { label: 'Iron Condor', desc: 'Sell an OTM call spread and OTM put spread simultaneously. Profits in a low-volatility, range-bound market.', type: 'Neutral' },
];

const risks = [
  { n: '01', label: 'Leverage Risk', desc: 'F&O positions are leveraged — a small adverse move in the underlying can result in losses far exceeding the initial margin deposited.' },
  { n: '02', label: 'Expiry Risk', desc: 'Options lose time value rapidly as they approach expiry (theta decay). Positions left unmanaged near expiry can expire worthless.' },
  { n: '03', label: 'Volatility Risk', desc: 'Sharp, unexpected volatility events (gap openings, news events) can trigger margin calls or cause large overnight losses in open futures positions.' },
  { n: '04', label: 'Liquidity Risk', desc: 'Out-of-the-money contracts, particularly in individual stocks, may have very low open interest — making it difficult to exit at a fair price.' },
];

const faqs = [
  { q: 'What is the difference between Futures and Options?', a: 'Futures obligate both buyer and seller to transact at expiry. Options give the buyer the right — not the obligation — to buy (call) or sell (put). Options buyers risk only the premium; futures traders risk margin losses.' },
  { q: 'How much capital do I need to start F&O trading?', a: 'Buying a NIFTY/BANKNIFTY options lot needs ₹5,000–₹20,000 in premium. Futures require ₹50,000–₹2,00,000 in SPAN + Exposure margin per lot, depending on the underlying.' },
  { q: 'Is F&O income taxed differently from equity?', a: 'Yes — F&O P&L is business income (non-speculative), not capital gains. File ITR-3, offset losses against other business income, and carry forward losses for 8 years.' },
  { q: 'What is "writing" an option?', a: 'Writing (selling) an option earns you the premium upfront but creates an obligation to fulfil the contract if exercised. Writers profit when the option expires worthless; naked call writers face unlimited downside.' },
  { q: 'How does margin work in F&O?', a: 'SEBI requires SPAN + Exposure margin upfront. SPAN covers worst-case one-day losses; Exposure adds a buffer. Fall below the required margin and your broker may square off positions.' },
  { q: 'Can I trade F&O on any stock?', a: 'No. SEBI approves roughly 180+ stocks for F&O trading based on liquidity, market cap, and volatility. Index derivatives (NIFTY, BANKNIFTY, FINNIFTY) are the most liquid instruments available.' },
];
---

<BaseLayout
  title="F&O Trading India — Futures Options NSE | Shriram Financial"
  description="Trade futures and options on NSE with expert advisory, margin calculators, and real-time analytics. SEBI-registered. Flat ₹20/order. Activate F&O segment today."
>

  <!-- ══ 1. HERO ═══════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[var(--color-dark-800)]">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[560px] w-[560px] rounded-full bg-[var(--color-brand)]/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-32 left-0 h-80 w-80 rounded-full bg-[var(--color-brand)]/5 blur-3xl"></div>
    <div class="site-wrap relative py-[120px]">
      <p class="equity-reveal text-[14px] font-medium tracking-[.04em] text-[var(--color-brand)]">Derivatives</p>
      <h1 class="equity-reveal mt-[22px] max-w-[880px] text-[clamp(32px,4vw,52px)] font-bold leading-[1.06] text-white" style="font-family:var(--font-display)">
        Trade Smarter with <span class="text-[var(--color-brand)]">Futures &amp; Options</span>
      </h1>
      <p class="equity-reveal mt-[26px] max-w-[600px] text-[18px] leading-relaxed text-white/70">
        Access NSE and BSE derivative markets with advanced analytics, SEBI-registered research, and dedicated risk management support from Shriram Financial Services.
      </p>
      <div class="equity-reveal mt-[38px] flex flex-wrap gap-[14px]">
        <a href="/about/open-demat-account/" class="btn-primary">Activate F&O Segment</a>
        <a href="/about/support/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Talk to RM</a>
      </div>
      <div class="equity-reveal mt-[54px] flex flex-wrap gap-x-9 gap-y-3 border-t border-white/15 pt-9">
        {['✓ SEBI-registered', '✓ Flat ₹20/order', '✓ Real-time analytics', '✓ Expert RM support'].map(f => (
          <span class="text-[15px] font-medium text-white/90">
            <span class="mr-2 text-[var(--color-brand)]">{f.slice(0,1)}</span>{f.slice(1)}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 2. WHAT ARE DERIVATIVES ════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto grid max-w-[1000px] items-start gap-[72px] lg:grid-cols-[5fr_7fr]">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          What Are <span class="text-[var(--color-brand)]">Derivatives?</span>
        </h2>
        <div class="space-y-5 text-[17px] leading-relaxed text-[var(--color-muted)]">
          <p>A derivative is a financial contract whose value is derived from an underlying asset — such as stocks, indices, commodities, or currencies. In India, derivatives are traded on NSE and BSE and are regulated by SEBI.</p>
          <p>Derivatives are used for hedging existing positions, speculating on price movements, or arbitraging price differences across markets.</p>
        </div>
      </div>
      <div class="equity-reveal mx-auto mt-[76px] max-w-[1000px] border-t border-[var(--color-n400)] pt-[60px]">
        <h3 class="mb-[10px] text-[26px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">Core Derivative Types</h3>
        <p class="mb-[34px] max-w-[680px] text-[16px] text-[var(--color-muted)]">Two major instrument types cover most of the derivative market activity in India.</p>
        <div class="grid gap-5 sm:grid-cols-2">
          {types.map(t => (
            <div class="product-card-light p-[34px]">
              <h4 class="mb-[10px] text-[22px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">{t.label}</h4>
              <p class="text-[15px] leading-relaxed text-[var(--color-muted)]">{t.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 3. ELIGIBILITY & DOCUMENTS ════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Eligibility &amp; <span class="text-[var(--color-brand)]">Documents Required</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Everything you need to qualify and activate your F&O segment.</p>
      </div>
      <div class="equity-reveal grid gap-6 sm:grid-cols-2">
        <div class="product-card-light p-[34px]">
          <h4 class="mb-6 text-[22px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">Eligibility Criteria</h4>
          <ul class="space-y-4">
            {eligibility.map(item => (
              <li class="flex items-start gap-[14px] border-b border-[var(--color-n400)]/50 pb-4 last:border-0 last:pb-0">
                <span class="shrink-0 text-[15px] font-bold leading-[1.7] text-[var(--color-brand)]">✓</span>
                <span class="text-[15.5px] text-[var(--color-muted)]">{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="product-card-light p-[34px]">
          <h4 class="mb-6 text-[22px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">Documents Required</h4>
          <ul class="space-y-4">
            {documents.map(item => (
              <li class="flex items-start gap-[14px] border-b border-[var(--color-n400)]/50 pb-4 last:border-0 last:pb-0">
                <span class="shrink-0 text-[15px] font-bold leading-[1.7] text-[var(--color-brand)]">✓</span>
                <span class="text-[15.5px] text-[var(--color-muted)]">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 4. HOW TO START ════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How to <span class="text-[var(--color-brand)]">Start Trading F&amp;O</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Four steps from account setup to your first futures or options trade.</p>
      </div>
      <div class="equity-reveal steps-grid overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        {steps.map(s => (
          <div class="px-[30px] py-[34px]">
            <div class="mb-[22px] font-display text-[34px] font-normal leading-none text-[var(--color-brand)]">{s.n}</div>
            <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">{s.title}</h4>
            <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 5. CHARGES ════════════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Brokerage &amp; <span class="text-[var(--color-brand)]">Charges</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">A full breakdown of trading costs across futures and options segments.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead><tr class="bg-[var(--color-dark-olive)]">
              <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Charge Type</th>
              <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Futures</th>
              <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Options</th>
            </tr></thead>
            <tbody>
              {chargeRows.map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.label}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.futures}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.options}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 6. STRATEGIES ══════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Popular F&amp;O <span class="text-[var(--color-brand)]">Strategies</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Match your market outlook — bullish, bearish, or neutral — to the right options strategy.</p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {strategies.map((s, i) => (
          <div class="equity-reveal product-card-light flex flex-col gap-3 p-7" style={`animation-delay:${i*60}ms`}>
            <span class="inline-flex w-fit rounded-full bg-[var(--color-brand)]/15 px-3 py-1 text-[11px] font-bold uppercase tracking-wide text-[var(--color-brand-deep)]">{s.type}</span>
            <h3 class="text-[16px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{s.label}</h3>
            <p class="text-[13px] leading-relaxed text-[var(--color-muted)]">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 7. RISKS ════════════════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Risks of Trading <span class="text-[var(--color-brand)]">Derivatives</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Understand what can move against you before you commit capital.</p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {risks.map(r => (
          <div class="equity-reveal rounded-[18px] bg-[var(--color-dark-800)] p-[36px]">
            <div class="mb-[18px] text-[48px] font-bold leading-none text-[var(--color-brand)]/25">{r.n}</div>
            <h4 class="mb-3 text-[20px] font-medium text-white" style="font-family:var(--font-display)">{r.label}</h4>
            <p class="text-[14.5px] leading-relaxed text-white/60">{r.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 8. FAQ ══════════════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Frequently Asked <span class="text-[var(--color-brand)]">Questions</span>
        </h2>
      </div>
      <div class="equity-reveal mx-auto max-w-[840px] border-t border-[var(--color-n400)]">
        {faqs.map(item => (
          <details class="eq-faq group border-b border-[var(--color-n400)]">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-5 py-[26px] px-2">
              <span class="text-[18px] font-semibold text-[var(--color-ink)]">{item.q}</span>
              <span class="shrink-0 text-[22px] leading-none text-[var(--color-brand)] transition-transform duration-300 group-open:rotate-45">+</span>
            </summary>
            <div class="overflow-hidden px-2 pb-0 text-[16px] leading-relaxed text-[var(--color-muted)] transition-all duration-300 group-open:pb-[28px]">
              <p class="max-w-[680px]">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 9. FINAL CTA ══════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal overflow-hidden rounded-[22px] bg-[var(--color-dark-800)] px-[60px] py-[64px] text-center">
        <h3 class="mx-auto max-w-[560px] text-[38px] font-bold leading-[1.12] text-white" style="font-family:var(--font-display)">Start Trading Futures &amp; Options Today</h3>
        <p class="mx-auto mt-[18px] max-w-[480px] text-[17px] leading-relaxed text-white/70">Activate F&O on your Shriram account in minutes. Access research-backed recommendations and trade with confidence.</p>
        <div class="mt-[34px] flex flex-wrap justify-center gap-[14px]">
          <a href="/about/open-demat-account/" class="btn-primary">Activate F&O →</a>
          <a href="/about/support/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Talk to an RM</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .equity-reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s cubic-bezier(0.22, 0.61, 0.36, 1), transform 0.7s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .equity-reveal.in-view { opacity: 1; transform: none; }

  .steps-grid { display: grid; grid-template-columns: repeat(2, 1fr); }
  .steps-grid > * { border-right: 1px solid var(--color-n400); border-bottom: 1px solid var(--color-n400); }
  .steps-grid > *:nth-child(2n) { border-right: 0; }
  .steps-grid > *:nth-last-child(-n+2) { border-bottom: 0; }
  @media (min-width: 1024px) {
    .steps-grid { grid-template-columns: repeat(4, 1fr); }
    .steps-grid > * { border-right: 1px solid var(--color-n400); border-bottom: 0; }
    .steps-grid > *:last-child { border-right: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .equity-reveal { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).classList.add('in-view');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.10 });
  document.querySelectorAll('.equity-reveal').forEach(el => obs.observe(el));

  document.querySelectorAll<HTMLDetailsElement>('.eq-faq').forEach(d => {
    d.addEventListener('toggle', () => {
      if (d.open) document.querySelectorAll<HTMLDetailsElement>('.eq-faq').forEach(o => { if (o !== d) o.removeAttribute('open'); });
    });
  });
</script>
