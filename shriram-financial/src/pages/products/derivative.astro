---
import BaseLayout from '../../layouts/BaseLayout.astro';

const advantageItems = [
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`, title: 'Hedging & Risk Management', desc: 'Protect your equity portfolio against market downturns using index put options or futures as a hedge.' },
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m7 14 4-4 4 4 4-4"/></svg>`, title: 'Leverage Your Capital', desc: 'Control a large position with a fraction of the capital required in the cash market. Initial margin is typically 8–22% of contract value.' },
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`, title: 'Income Generation', desc: 'Sell covered calls or cash-secured puts to earn regular premium income on your existing portfolio.' },
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 18 10 11 16 16 25 7"/><polyline points="19 7 25 7 25 13"/></svg>`, title: 'Price Discovery', desc: 'F&O markets reflect future expectations, acting as a leading indicator for spot markets and helping informed decision-making.' },
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="6" height="14" rx="1"/><rect x="9" y="3" width="6" height="18" rx="1"/><rect x="16" y="10" width="6" height="11" rx="1"/></svg>`, title: 'High Liquidity', desc: 'NIFTY and BANKNIFTY options are among the most liquid instruments globally — tight spreads and deep order books at all times.' },
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 14l-4-4 4-4"/><path d="M5 10h11a4 4 0 0 1 0 8h-1"/></svg>`, title: 'Low Transaction Costs', desc: 'Flat ₹20 per executed order brokerage — no percentage-based fees. Statutory charges (STT, exchange fee) are standard across all brokers.' },
];

const limitationItems = [
  { q: 'Leverage Risk', a: 'F&O positions are leveraged — a small adverse move in the underlying can result in losses far exceeding the initial margin deposited. Always use stop-losses and size positions appropriately.' },
  { q: 'Time Decay (Theta)', a: 'Options lose time value as they approach expiry. Theta decay accelerates in the final week before expiry, making it difficult for option buyers to recover unless the underlying moves significantly.' },
  { q: 'Complexity', a: 'F&O requires understanding of Greeks (Delta, Theta, Vega, Gamma), margin mechanics, and strategy construction. It is not suitable for beginners without adequate education and practice.' },
  { q: 'Margin Calls', a: 'If the market moves against your position, your broker may issue a margin call requiring you to top up your account. Failure to add funds within the stipulated time results in forced square-off of positions.' },
  { q: 'Counterparty Risk (Exchange-Managed)', a: 'Derivatives traded on NSE/BSE are settled by clearing corporations (NSCCL/ICCL), virtually eliminating direct counterparty risk — but OTC derivatives carry this risk fully.' },
  { q: 'Volatility Risk', a: 'Sharp, unexpected volatility events — gap openings, earnings surprises, macro news — can cause large overnight losses on open futures positions or in short options portfolios.' },
];

const typeItems = [
  { label: 'Index Futures',       tag: 'Futures',   tagClass: 'futures',   desc: 'Trade NIFTY 50, BANKNIFTY, FINNIFTY futures. Cash-settled on expiry every Thursday.' },
  { label: 'Stock Futures',       tag: 'Futures',   tagClass: 'futures',   desc: 'Futures contracts on 180+ SEBI-approved stocks. Physical delivery on monthly expiry.' },
  { label: 'Index Options',       tag: 'Options',   tagClass: 'options',   desc: 'Call & put options on NIFTY/BANKNIFTY. Most liquid derivative instruments in India.' },
  { label: 'Stock Options',       tag: 'Options',   tagClass: 'options',   desc: 'Options on individual stocks with monthly expiry. Lower liquidity than index options.' },
  { label: 'Currency Derivatives',tag: 'Currency',  tagClass: 'currency',  desc: 'Trade USD-INR, EUR-INR, GBP-INR pairs on NSE/BSE. Used by importers, exporters, and speculators.' },
  { label: 'Commodity Derivatives',tag:'Commodity', tagClass: 'commodity', desc: 'Futures & options on gold, silver, crude oil, and agri commodities — traded on MCX and NCDEX.' },
];

const steps = [
  { n: '1', title: 'Open a Trading Account', desc: 'Register with Shriram Financial Services and open a Demat + Trading account digitally in under 10 minutes — 100% paperless.' },
  { n: '2', title: 'Activate F&O Segment', desc: 'Request F&O segment activation from your account dashboard. Submit 6-month bank statement or ITR as income proof if required by SEBI guidelines.' },
  { n: '3', title: 'Add Margin to Your Account', desc: 'Transfer funds to cover SPAN + Exposure margin. F&O positions require upfront margin collateral — check the margin requirement for your chosen contract.' },
  { n: '4', title: 'Place Your First Order', desc: 'Select your underlying (NIFTY / BANKNIFTY / stock), expiry date, strike price, and order type. Start with buying options to limit downside to the premium paid.' },
];

const fovRows = [
  { feature: 'Obligation',       futures: 'Both buyer and seller must settle at expiry', options: 'Buyer has a right only; seller is obligated' },
  { feature: 'Premium / Cost',   futures: 'No premium — margin-based',                  options: 'Buyer pays premium upfront' },
  { feature: 'Max Loss (Buyer)', futures: 'Unlimited (mark-to-market daily)',            options: 'Limited to premium paid' },
  { feature: 'Max Loss (Seller)',futures: 'Unlimited',                                   options: 'Unlimited for naked positions' },
  { feature: 'Capital Required', futures: 'Higher (SPAN + Exposure margin)',             options: 'Lower (premium amount for buyers)' },
  { feature: 'Best For',         futures: 'Strong directional bets, portfolio hedging',  options: 'Hedging, income strategies, speculation' },
  { feature: 'Time Decay',       futures: 'No time decay',                               options: 'Theta erodes option value daily' },
];

const risks = [
  { label: 'Leverage Risk',   desc: 'A small adverse price move can produce losses far exceeding initial margin. Manage position sizing strictly.' },
  { label: 'Time Decay',      desc: 'Options lose time value daily (theta). Buyers must be right on direction, magnitude, AND timing.' },
  { label: 'Volatility Risk', desc: 'Gap openings, earnings events, and macro shocks can cause large overnight losses in open futures positions.' },
  { label: 'Margin Calls',    desc: 'Adverse moves trigger margin calls. Failure to add funds leads to forced square-off of positions.' },
];

const marginRows = [
  { type: 'SPAN Margin',          purpose: 'Covers worst-case 1-day loss based on VaR (Value at Risk) model', range: '5–15% of contract value' },
  { type: 'Exposure Margin',      purpose: 'Additional buffer against extreme intraday volatility',             range: '3–7% of contract value' },
  { type: 'Total Required Margin',purpose: 'SPAN + Exposure — the amount you must have upfront',               range: '8–22% of contract value' },
];

const strategies = [
  { label: 'Long Call',       type: 'Bullish', typeClass: 'bullish', desc: 'Buy a call option. Profit if underlying rises above strike + premium. Max loss = premium paid.' },
  { label: 'Bull Call Spread',type: 'Bullish', typeClass: 'bullish', desc: 'Buy a lower strike call, sell a higher strike call. Limits both profit and loss. Lower cost than outright call.' },
  { label: 'Long Put',        type: 'Bearish', typeClass: 'bearish', desc: 'Buy a put option. Profit if underlying falls below strike. Ideal hedge for existing equity positions.' },
  { label: 'Iron Condor',     type: 'Neutral', typeClass: 'neutral', desc: 'Sell OTM call spread + OTM put spread. Profits in range-bound markets. Maximum profit = net premium received.' },
];

const faqs = [
  { q: 'What is derivatives trading in India?', a: 'Derivatives trading involves contracts whose value is derived from an underlying asset — a stock, index, commodity, or currency. In India, retail traders primarily trade Futures and Options (F&O) on NSE and BSE. India is now one of the largest derivative markets globally by volume.' },
  { q: 'What is the difference between Futures and Options?', a: 'Futures obligate both buyer and seller to transact at the agreed price on expiry. Options give the buyer the right — not the obligation — to buy (call) or sell (put) at a strike price. Options buyers risk only the premium paid; futures traders risk mark-to-market losses daily.' },
  { q: 'How much capital do I need to start F&O trading?', a: 'Buying one NIFTY/BANKNIFTY options lot needs ₹5,000–₹20,000 in premium. Futures require ₹50,000–₹2,00,000 in SPAN + Exposure margin per lot depending on the underlying. Start with options buying to limit risk.' },
  { q: 'Is F&O income taxed differently from equity?', a: 'Yes — F&O P&L is treated as non-speculative business income, not capital gains. You must file ITR-3, can offset F&O losses against other business income, and carry forward losses for up to 8 years.' },
  { q: 'What is "writing" or "selling" an option?', a: 'Writing (selling) an option earns you the premium upfront but creates an obligation to fulfil the contract if the buyer exercises it. Sellers profit when the option expires worthless; naked call writers face theoretically unlimited downside.' },
  { q: 'How does margin work in F&O?', a: 'SEBI requires SPAN + Exposure margin upfront for every F&O position. SPAN covers worst-case one-day losses; Exposure adds a buffer for extreme volatility. If your margin falls below the required level, your broker may square off positions automatically.' },
  { q: 'Can I trade F&O on any stock?', a: 'No. SEBI approves approximately 180+ stocks for F&O trading based on liquidity, market capitalisation, and volatility. Index derivatives (NIFTY, BANKNIFTY, FINNIFTY) are the most liquid instruments available.' },
  { q: 'What are options Greeks and why do they matter?', a: 'Greeks measure an option\'s sensitivity to various market factors. Delta: sensitivity to price change. Theta: time decay per day. Vega: sensitivity to volatility changes. Gamma: rate of change of Delta. Understanding Greeks is essential for advanced options strategies.' },
  { q: 'What is the lot size for NIFTY futures?', a: 'The current NIFTY lot size is 75 units per contract. BANKNIFTY lot size is 35 units. Lot sizes are revised periodically by NSE based on the underlying value to maintain minimum contract value thresholds.' },
  { q: 'What is weekly vs monthly expiry in options?', a: 'NIFTY and BANKNIFTY have weekly expiry contracts (every Thursday) in addition to monthly contracts (last Thursday of the month). Weekly options have lower premiums but higher theta decay, making them more suitable for short-term directional plays.' },
  { q: 'Can NRIs trade derivatives in India?', a: 'NRIs can trade derivatives in India through RBI-approved routes using NRE/NRO accounts, subject to specific FEMA regulations. They must use a SEBI-registered broker with NRI trading facilities. Please contact our support team for NRI-specific guidance.' },
  { q: 'What is an Iron Condor strategy?', a: 'An Iron Condor is a neutral options strategy where you sell an OTM call spread and an OTM put spread simultaneously. It profits when the underlying stays within a defined range till expiry. Maximum profit is the net premium received; maximum loss is capped.' },
];
---

<BaseLayout
  title="Derivatives Trading India — Futures &amp; Options (F&amp;O) | Shriram"
  description="Trade derivatives in India — futures &amp; options on NSE &amp; BSE. SEBI-registered. Flat ₹20/order. Expert F&amp;O advisory, margin guidance, and dedicated research. Activate F&amp;O today."
>

  <!-- ══ 1. HERO ══════════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-inner">
      <h1>Trade Derivatives <span class="g">with Confidence</span></h1>
      <p class="lead">Access Futures &amp; Options on India's trusted platform — Shriram Financial Services. SEBI-registered, flat ₹20/order, with expert F&amp;O research from Day 1.</p>
      <div class="cta-row">
        <a class="btn-gold" href="/about/open-demat-account/">Open Demat Account</a>
        <a class="btn-ghost" href="/about/open-demat-account/">Activate F&amp;O Segment</a>
      </div>
      <div class="hero-feats">
        <div class="feats">
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;SEBI-registered</span></div>
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;Flat ₹20/order</span></div>
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;NSE &amp; BSE F&amp;O</span></div>
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;Expert F&amp;O advisory</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 2. WHAT IS DERIVATIVES TRADING ══════════════════════════════ -->
  <section class="section stack" id="sec-about" style="background:var(--sec-light);gap:56px">
    <div class="stack" style="gap:16px">
      <p class="sec-title">What is Derivatives Trading?</p>
      <p class="sec-lead">Derivatives trading involves financial contracts whose value is derived from an underlying asset — such as stocks, indices, commodities, or currencies. In the Indian market, these instruments are pivotal for both institutional and retail traders, enabling sophisticated risk management and speculative positioning.</p>
      <p class="sec-lead" style="margin-top:8px">A derivative contract represents an agreement between a buyer and a seller to trade an asset at a predetermined price on a future date. For retail investors in India, derivatives are predominantly traded on the NSE and BSE through Futures and Options (F&amp;O), making India one of the largest derivative markets globally — with high daily volume and robust regulatory oversight by SEBI.</p>
    </div>
    <div class="term-grid">
      {[
        { label: 'Underlying Asset', val: 'The stock, index, commodity, or currency the contract is based on (e.g. NIFTY, RELIANCE, GOLD).' },
        { label: 'Expiry Date',      val: 'Date the contract terminates. Weekly: every Thursday. Monthly: last Thursday of the month.' },
        { label: 'Lot Size',         val: 'Minimum number of units per contract — e.g. 75 units for NIFTY, 35 for BANKNIFTY.' },
        { label: 'Strike Price / Premium', val: 'Strike is the pre-agreed price for options; premium is the cost paid by the option buyer.' },
      ].map(d => (
        <div class="term">
          <p class="tk-label">{d.label}</p>
          <p class="tk-val">{d.val}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ══ 3. HOW DERIVATIVES TRADING WORKS ════════════════════════════ -->
  <section class="section stack" style="background:var(--sec-tint);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <p class="sec-title">How Derivatives Trading Works</p>
      <p class="sec-lead">Two contract types — each with distinct rights, obligations, and risk profiles.</p>
    </div>
    <div class="row-2">
      <div class="card how-card">
        <h3>Futures Contract</h3>
        <p>A binding agreement to buy or sell an asset at a preset price on expiry. Both parties <strong style="color:var(--ink)">must</strong> honour the contract regardless of the market price. P&amp;L is settled daily via mark-to-market (MTM).</p>
        <ul class="how-list">
          {['Both buyer and seller are obligated','Daily MTM settlement','Higher margin requirement','Unlimited profit and loss potential'].map(pt => <li>{pt}</li>)}
        </ul>
      </div>
      <div class="card how-card">
        <h3>Options Contract</h3>
        <p>The <strong style="color:var(--ink)">right — not the obligation</strong> — to buy (Call) or sell (Put) at a strike price before expiry. The buyer pays a premium; the seller (writer) collects it but takes on the obligation.</p>
        <ul class="how-list">
          {['Buyer has a right, not obligation','Maximum loss = premium paid (buyer)','Seller faces potentially unlimited risk','Weekly and monthly expiry cycles'].map(pt => <li>{pt}</li>)}
        </ul>
      </div>
    </div>
    <div class="example-box">
      <p><strong>Worked Example:</strong> You expect NIFTY to rise from 24,000 to 24,500. You buy a NIFTY 24,200 Call at ₹150 premium (lot size: 75 units). Total cost = ₹150 × 75 = <strong>₹11,250</strong>. If NIFTY closes at 24,600, intrinsic value = ₹400 → profit = (₹400 − ₹150) × 75 = <strong>₹18,750</strong>. If NIFTY falls, your maximum loss is the ₹11,250 premium paid.</p>
    </div>
  </section>

  <!-- ══ 4. TYPES OF DERIVATIVES ═════════════════════════════════════ -->
  <section class="section stack" style="background:var(--sec-light);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <p class="sec-title">Types of Derivatives</p>
      <p class="sec-lead">Derivatives available to Indian retail investors span indices, stocks, currencies, and commodities.</p>
    </div>
    <div class="cat-grid cat-3">
      {typeItems.map(t => (
        <div class="cat">
          <h4>{t.label}</h4>
          <p>{t.desc}</p>
        </div>
      ))}
    </div>
    <a class="btn-gold" href="/about/open-demat-account/" style="align-self:center">Open Demat Account</a>
  </section>

  <!-- ══ 5. ADVANTAGES ════════════════════════════════════════════════ -->
  <section class="section stack" style="background:var(--sec-tint);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <p class="sec-title">Advantages of Derivatives Trading</p>
      <p class="sec-lead">When used with discipline and the right strategy, derivatives offer unique advantages unavailable in the equity cash market.</p>
    </div>
    <div class="adv-grid">
      {advantageItems.map(a => (
        <div class="card adv-card">
          <p class="card-h">{a.title}</p>
          <p class="card-p">{a.desc}</p>
        </div>
      ))}
    </div>
    <a class="btn-gold" href="/about/open-demat-account/" style="align-self:center">Open Demat Account</a>
  </section>

  <!-- ══ 6. LIMITATIONS ══════════════════════════════════════════════ -->
  <section class="section stack" style="background:var(--sec-light);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <p class="sec-title">Limitations to Be Aware</p>
      <p class="sec-lead">Derivatives carry significant risks. Understanding these limitations is essential before trading F&amp;O.</p>
    </div>
    <div class="faq-acc lim-acc">
      {limitationItems.map((item, i) => (
        <div class={`faq-item${i === 0 ? ' open' : ''}`}>
          <div class="q">
            <span class="qt">{item.q}</span>
            <div class="qa-wrap"><div class="qa"><p>{item.a}</p></div></div>
          </div>
          <span class="faq-icon">
            <svg viewBox="0 0 24 24" fill="none">
              <line class="v" x1="12" y1="5" x2="12" y2="19" stroke="#404040" stroke-width="2" stroke-linecap="round"/>
              <line x1="5" y1="12" x2="19" y2="12" stroke="#404040" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </span>
        </div>
      ))}
    </div>
    <a class="btn-gold" href="/about/support/" style="align-self:center">Read Risk Disclosure</a>
  </section>

  <!-- ══ 7. HOW TO TRADE DERIVATIVES ════════════════════════════════ -->
  <section class="section stack" style="background:var(--sec-tint);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <p class="sec-title">How to Trade Derivatives</p>
      <p class="sec-lead">Three prerequisites you must have before placing your first F&amp;O order on NSE or BSE.</p>
    </div>
    <div class="row-3">
      {[
        { n:'1', label:'F&O Account Activated', desc:'Request F&O segment activation on your Shriram trading account. This is a one-time, digital process.' },
        { n:'2', label:'Sufficient Margin',      desc:'Maintain SPAN + Exposure margin in your account at all times. Your broker will alert you if the balance drops.' },
        { n:'3', label:'Strategy Knowledge',     desc:'Start with buying options (limited risk = premium paid) before moving to selling or complex multi-leg strategies.' },
      ].map(c => (
        <div class="card">
          <p class="card-h">{c.label}</p>
          <p class="card-p">{c.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ══ 8. START YOUR F&O JOURNEY ═══════════════════════════════════ -->
  <section class="section stack" style="background:var(--sec-light);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <p class="sec-title">Start Your F&amp;O Trading Journey</p>
      <p class="sec-lead">Four simple steps to go from zero to your first derivatives trade — fully online, no branch visit needed.</p>
    </div>
    <div class="steps">
      {steps.map((s, i) => (
        <>
          {i > 0 && <div class="step-div"></div>}
          <div class="step">
            <div class="st-body"><h4>{s.title}</h4><p>{s.desc}</p></div>
          </div>
        </>
      ))}
    </div>
    <a class="btn-gold" href="/about/open-demat-account/" style="align-self:center">Open Demat Account</a>
  </section>

  <!-- ══ 9. FUTURES VS OPTIONS ════════════════════════════════════════ -->
  <section class="section stack" style="background:var(--sec-tint);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <p class="sec-title">Futures vs Options — Key Differences</p>
      <p class="sec-lead">Choose the right instrument based on your strategy, capital available, and risk appetite.</p>
    </div>
    <div class="t-scroll">
      <div class="table t3 bordered">
        <div class="cell th"><p>Feature</p></div>
        <div class="cell th"><p>Futures</p></div>
        <div class="cell th"><p>Options</p></div>
        {fovRows.map(r => (
          <>
            <div class="cell tb"><p class="k">{r.feature}</p></div>
            <div class="cell tb"><p class="v">{r.futures}</p></div>
            <div class="cell tb"><p class="v">{r.options}</p></div>
          </>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 10. RISKS ════════════════════════════════════════════════════ -->
  <section class="section stack" style="background:var(--sec-light);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <p class="sec-title">Risks in Derivatives Trading</p>
      <p class="sec-lead">Understand these risks before activating your F&amp;O segment. Knowledge is your first line of defence.</p>
    </div>
    <div class="risks">
      {risks.map(r => (
        <div class="risk"><h4>{r.label}</h4><p>{r.desc}</p></div>
      ))}
    </div>
    <a class="btn-gold" href="/about/support/" style="align-self:center">Check Risk Disclosure</a>
  </section>

  <!-- ══ 11. MARGIN ═══════════════════════════════════════════════════ -->
  <section class="section stack" style="background:var(--sec-tint);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <p class="sec-title">Margin in Derivatives — SPAN &amp; Exposure</p>
      <p class="sec-lead">SEBI mandates two margin components for every F&amp;O position. Know what you need before you trade.</p>
    </div>
    <div class="t-scroll">
      <div class="table t3 bordered">
        <div class="cell th"><p>Margin Type</p></div>
        <div class="cell th"><p>Purpose</p></div>
        <div class="cell th"><p>Typical Range</p></div>
        {marginRows.map(r => (
          <>
            <div class="cell tb"><p class="k">{r.type}</p></div>
            <div class="cell tb"><p class="v">{r.purpose}</p></div>
            <div class="cell tb"><p class="v" style="color:var(--olive-head);font-weight:500">{r.range}</p></div>
          </>
        ))}
      </div>
    </div>
    <div class="example-box">
      <p><strong>Example:</strong> NIFTY Futures (1 lot = 75 units × ₹24,000 spot = ₹18L notional value). SPAN + Exposure ~12% → <strong>₹2.16L margin required</strong> per lot. Always verify current margins on NSE or via your broker's margin calculator before taking positions.</p>
    </div>
    <a class="btn-gold" href="/about/open-demat-account/" style="align-self:center">Calculate Your Margin</a>
  </section>

  <!-- ══ 12. POPULAR STRATEGIES ═══════════════════════════════════════ -->
  <section class="section stack" style="background:var(--sec-light);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <p class="sec-title">Popular Derivatives Strategies</p>
      <p class="sec-lead">From simple directional plays to sophisticated multi-leg strategies — match your strategy to your market view.</p>
    </div>
    <div class="strat-grid">
      {strategies.map(s => (
        <div class="card strat-card">
          <span class={`strat-tag strat-${s.typeClass}`}>{s.type}</span>
          <p class="card-h">{s.label}</p>
          <p class="card-p">{s.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ══ 13. FAQ ══════════════════════════════════════════════════════ -->
  <section class="faq-wrap" id="sec-faq" style="background:var(--sec-tint)">
    <div class="faq-cols">
      <div class="faq-left">
        <p class="faq-title">General Questions</p>
        <div class="faq-acc">
          {faqs.map((item, i) => (
            <div class={`faq-item${i === 0 ? ' open' : ''}`}>
              <div class="q">
                <span class="qt">{item.q}</span>
                <div class="qa-wrap"><div class="qa"><p>{item.a}</p></div></div>
              </div>
              <span class="faq-icon">
                <svg viewBox="0 0 24 24" fill="none">
                  <line class="v" x1="12" y1="5" x2="12" y2="19" stroke="#404040" stroke-width="2" stroke-linecap="round"/>
                  <line x1="5" y1="12" x2="19" y2="12" stroke="#404040" stroke-width="2" stroke-linecap="round"/>
                </svg>
              </span>
            </div>
          ))}
        </div>
      </div>
      <div class="faq-side">
        <div class="usr" aria-hidden="true">
          <img src="/user-icon.png" alt="" />
        </div>
        <div class="side-in">
          <div class="side-tx">
            <h4>Need A Clearer Direction?</h4>
            <p>Let's get in touch on a 15-minute call where we would be able to answer any questions you may have. Our Advisor will additionally help map your wealth mix and demonstrate what a dedicated advisor would do differently.</p>
          </div>
          <a class="btn-gold" href="/about/support/">Book A Discovery Call</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 14. FINAL CTA ════════════════════════════════════════════════ -->
  <section class="cta-sec" style="background:var(--sec-light)">
    <div class="cta-box">
      <div class="ct-tt">
        <h3>Open F&amp;O Account — Flat ₹20 Per Order</h3>
        <p class="ct-sub">SEBI-registered. Expert F&amp;O research. Dedicated risk management support.</p>
      </div>
      <div style="display:flex;flex-wrap:wrap;gap:14px;justify-content:center">
        <a class="btn-gold" href="/about/open-demat-account/">Open F&amp;O Account</a>
        <a class="btn-outline" href="/about/support/">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  :root {
    --page:#fcf8ef; --sec-light:#fef8ee; --sec-tint:#f6efe1; --card:#fffdf8;
    --card-border:#e1e0db; --row-line:rgba(28,28,22,.08);
    --olive-title:#2e3914; --olive-head:#2d3813; --olive-deep:#1b2010;
    --ink:#1c1c16; --ink-2:#46463c; --ink-3:#595959; --muted:#73736a;
    --gold:#e0a82e; --gold-2:#f2b83f; --gold-btn:#f3b83f; --olive-ink:#2e3914;
    --pad:clamp(20px,8vw,144px); --container-pad:32px; --section-y:72px; --cta-w:220px;
  }
  *,*::before,*::after{box-sizing:border-box}
  a{color:inherit;text-decoration:none}
  p{line-height:1.5}

  .section{padding:var(--section-y) var(--pad);min-height:100vh;min-height:100dvh;display:flex;flex-direction:column;justify-content:center}
  #sec-about{min-height:0}
  .stack{display:flex;flex-direction:column}

  .sec-title{font-weight:400;font-size:40px;color:var(--olive-title);text-transform:capitalize;line-height:1.5}
  .sec-lead{font-weight:400;font-size:16px;color:var(--ink-3);line-height:1.5}
  .card-h{font-weight:500;font-size:20px;color:var(--ink);line-height:1.5}
  .card-p{font-weight:400;font-size:16px;color:var(--muted);line-height:1.5}

  .card{background:var(--card);border:1px solid var(--card-border);border-radius:24px;padding:var(--container-pad);display:flex;flex-direction:column;gap:16px}

  /* Hero */
  .hero{padding:0 var(--pad);display:flex;flex-direction:column;justify-content:center;overflow:hidden;background:radial-gradient(125% 210% at 100% -8%,#4f583b 0%,#363a2c 50%,#1d1d1d 100%)}
  .hero-inner{padding:clamp(80px,12vw,140px) 0 clamp(48px,6vw,80px);display:flex;flex-direction:column}
  .eyebrow{font-weight:500;font-size:14px;color:var(--gold-2);letter-spacing:.04em;line-height:1.5;margin-bottom:16px}
  .hero h1{font-weight:500;font-size:40px;color:#fff;line-height:1.5;max-width:860px}
  .hero h1 .g{color:var(--gold-2)}
  .hero .lead{margin-top:32px;font-weight:400;font-size:18px;line-height:1.5;color:rgba(255,255,255,.74);max-width:600px}
  .cta-row{margin-top:40px;display:flex;flex-wrap:wrap;gap:14px;align-items:center}
  .hero-feats{margin-top:40px}
  .feats{display:flex;flex-wrap:wrap;align-items:center;gap:14px 16px;max-width:760px;padding-top:36px;border-top:1px solid rgba(255,255,255,.16)}
  .feat{display:flex;gap:10px;align-items:center}
  .feat .tk{color:var(--gold-2);font-weight:500;font-size:15px;width:13px}
  .feat .lb{color:rgba(255,255,255,.9);font-weight:500;font-size:16px;line-height:1.5;white-space:nowrap}

  /* Buttons */
  .btn-gold{background:var(--gold-btn);height:40px;width:var(--cta-w);border-radius:4px;display:inline-flex;align-items:center;justify-content:center;padding:7px 20px;font-weight:500;font-size:12px;color:var(--olive-ink);white-space:nowrap;transition:opacity .2s}
  .btn-gold:hover{opacity:.88}
  .btn-ghost{height:40px;border-radius:9px;border:1px solid rgba(255,255,255,.4);display:inline-flex;align-items:center;justify-content:center;padding:7px 26px;font-weight:600;font-size:15px;color:#fff;transition:border-color .2s}
  .btn-ghost:hover{border-color:#fff}
  .btn-outline{height:40px;border-radius:9px;border:1px solid var(--card-border);display:inline-flex;align-items:center;justify-content:center;padding:7px 26px;font-weight:600;font-size:14px;color:var(--ink);transition:border-color .2s}
  .btn-outline:hover{border-color:var(--gold)}

  /* Layout */
  .row-2{display:flex;gap:32px;align-items:stretch}
  .row-2 .card{flex:1 0 0;min-width:0}
  .row-3{display:flex;gap:24px;align-items:stretch}
  .row-3 .card{flex:1 0 0;min-width:0}

  /* Icon box */
  .icon-box{width:48px;height:48px;border-radius:12px;background:var(--olive-deep);color:var(--gold-2);display:flex;align-items:center;justify-content:center;flex:none}
  .icon-box svg{width:22px;height:22px}

  /* Terminology grid */
  .term-grid{border:1px solid var(--card-border);border-radius:24px;overflow:hidden;display:grid;grid-template-columns:repeat(2,1fr);background:var(--card)}
  .term{padding:22px 28px;border-right:1px solid var(--card-border);border-bottom:1px solid var(--card-border);display:flex;flex-direction:column;gap:8px}
  .term:nth-child(2n){border-right:0}
  .term:nth-child(n+3){border-bottom:0}
  .tk-label{font-weight:700;font-size:12px;text-transform:uppercase;letter-spacing:.05em;color:var(--olive-deep)}
  .tk-val{font-size:14px;color:var(--muted);line-height:1.5}

  /* How-works contract cards */
  .how-card{gap:16px}
  .how-card h3{font-weight:500;font-size:24px;color:var(--ink);line-height:1.5}
  .how-card>p{font-weight:400;font-size:16px;color:var(--muted);line-height:1.5}
  .how-list{list-style:none;display:flex;flex-direction:column;gap:10px;padding:0;margin:0}
  .how-list li{display:flex;gap:10px;align-items:flex-start;font-size:14px;color:var(--muted);line-height:1.5}
  .how-list li::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--gold-2);flex:none;margin-top:7px}

  /* Example box */
  .example-box{background:var(--card);border:1px solid var(--card-border);border-left:3px solid var(--gold-2);border-radius:12px;padding:28px}
  .example-box p{font-size:14px;color:var(--ink);line-height:1.6}

  /* Cat grid */
  .cat-grid{border:1px solid var(--card-border);border-radius:24px;overflow:hidden;display:grid;grid-template-columns:repeat(4,1fr);background:var(--card)}
  .cat-grid.cat-3{grid-template-columns:repeat(3,1fr)}
  .cat{background:var(--card);padding:var(--container-pad);display:flex;flex-direction:column;gap:12px;border-right:1px solid var(--card-border);border-bottom:1px solid var(--card-border)}
  .cat-3 .cat:nth-child(3n){border-right:0}
  .cat-3 .cat:nth-child(n+4){border-bottom:0}
  .cat h4{font-weight:500;font-size:20px;color:var(--ink);line-height:1.5}
  .cat p{font-weight:400;font-size:16px;color:var(--muted);line-height:1.5}
  .dtype-tag{display:inline-flex;border-radius:99px;padding:3px 12px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.03em;width:fit-content}
  .dtype-futures{background:#e8f3ff;color:#1a5caa}
  .dtype-options{background:rgba(240,185,63,.2);color:var(--olive-head)}
  .dtype-currency{background:#edf6ee;color:#1a6e2e}
  .dtype-commodity{background:#f3ede8;color:#7a3a12}

  /* Advantages grid */
  .adv-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
  .adv-card{gap:16px}

  /* Limitations accordion (reuses faq-item styles) */
  .lim-acc{border-radius:24px;overflow:hidden;display:flex;flex-direction:column;gap:2px}

  /* Steps */
  .steps{background:var(--card);border:1px solid var(--card-border);border-radius:24px;overflow:hidden;display:flex;align-items:stretch;width:100%}
  .step{flex:1 0 0;min-width:0;padding:var(--container-pad);display:flex;flex-direction:column;gap:16px}
  .step .num{font-weight:400;font-size:32px;line-height:34px;color:var(--gold)}
  .step .st-body{display:flex;flex-direction:column;gap:12px}
  .step h4{font-weight:500;font-size:20px;color:var(--ink);line-height:1.5}
  .step p{font-weight:400;font-size:16px;color:var(--ink-3);line-height:1.5}
  .step-div{width:1px;align-self:stretch;background:var(--card-border);flex:none}

  /* Tables */
  .t-scroll{width:100%;overflow-x:auto;-webkit-overflow-scrolling:touch}
  .table{background:var(--card);border-radius:24px;overflow:hidden;display:grid}
  .table.bordered{border:1px solid var(--card-border)}
  .t3{grid-template-columns:repeat(3,minmax(0,1fr))}
  .cell{padding:16px 24px;display:flex;align-items:center;justify-content:center;text-align:center}
  .cell p{flex:1 0 0;min-width:0;font-size:16px;line-height:1.5;overflow-wrap:break-word}
  .th{background:var(--olive-head)}
  .th p{font-weight:600;color:#fff}
  .tb{border-top:1px solid var(--row-line)}
  .tb .k{font-weight:600;color:var(--ink)}
  .tb .v{font-weight:400;color:var(--ink-2)}

  /* Risk cards */
  .risks{display:flex;gap:24px;align-items:stretch}
  .risk{flex:1 0 0;min-width:0;background:var(--card);border:1px solid var(--card-border);border-radius:24px;padding:var(--container-pad);display:flex;flex-direction:column;gap:12px}
  .risk h4{font-weight:500;font-size:20px;color:var(--ink);line-height:1.5}
  .risk p{font-weight:400;font-size:16px;color:var(--ink-3);line-height:1.5}

  /* Strategy cards */
  .strat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px}
  .strat-card{gap:16px}
  .strat-tag{display:inline-flex;border-radius:99px;padding:3px 12px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.03em;width:fit-content}
  .strat-bullish{background:#edf6ee;color:#1a6e2e}
  .strat-bearish{background:#fdecea;color:#b71c1c}
  .strat-neutral{background:rgba(240,185,63,.2);color:var(--olive-head)}

  /* FAQ */
  .faq-wrap{padding:158px var(--pad);min-height:100vh;min-height:100dvh;display:flex;flex-direction:column;justify-content:center}
  .faq-cols{display:flex;gap:48px;align-items:stretch}
  .faq-left{flex:1 0 0;min-width:0;display:flex;flex-direction:column;gap:48px}
  .faq-title{font-weight:400;font-size:40px;color:var(--olive-title);text-transform:capitalize;line-height:1.5;white-space:nowrap}
  .faq-acc{border-radius:24px;overflow:hidden;display:flex;flex-direction:column;gap:2px;width:100%}
  .faq-item{background:var(--card);padding:24px;display:flex;gap:40px;align-items:flex-start;cursor:pointer}
  .faq-item .q{flex:1 0 0;min-width:0;display:flex;flex-direction:column}
  .faq-item .qt{font-weight:500;font-size:14px;color:#333;line-height:1.5}
  .qa-wrap{display:grid;grid-template-rows:0fr;transition:grid-template-rows .38s cubic-bezier(.4,0,.2,1)}
  .faq-item.open .qa-wrap{grid-template-rows:1fr}
  .qa{overflow:hidden;min-height:0}
  .qa p{padding-top:16px;font-weight:400;font-size:14px;color:#404040;line-height:1.5}
  .faq-icon{width:24px;height:24px;flex:none}
  .faq-icon svg{display:block;width:24px;height:24px}
  .faq-icon svg .v{transform-box:fill-box;transform-origin:center;transition:transform .38s cubic-bezier(.4,0,.2,1),opacity .38s ease}
  .faq-item.open .faq-icon svg .v{transform:scaleY(0);opacity:0}
  .faq-side{width:464px;flex:none;background:var(--card);border:1px solid var(--card-border);border-radius:24px;padding:var(--container-pad);display:flex;flex-direction:column;gap:40px;justify-content:flex-end;position:relative;overflow:hidden}
  .usr{position:absolute;left:var(--container-pad);top:64px;width:130.667px;height:147px;opacity:.1}
  .usr img{display:block;width:100%;height:100%;object-fit:contain}
  .side-in{display:flex;flex-direction:column;gap:32px;position:relative}
  .side-tx{display:flex;flex-direction:column;gap:8px;color:#222320}
  .side-tx h4{font-weight:500;font-size:20px;line-height:28px;letter-spacing:-.45px}
  .side-tx p{font-weight:400;font-size:14px;line-height:22px;letter-spacing:-.15px}

  /* CTA */
  .cta-sec{padding:var(--section-y) var(--pad)}
  .cta-box{border-radius:22px;padding:64px 60px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:32px;text-align:center}
  .ct-tt{display:flex;flex-direction:column;align-items:center;gap:16px;color:var(--olive-deep)}
  .cta-box h3{font-weight:500;font-size:38px;line-height:42.56px;letter-spacing:-.76px}
  .ct-sub{font-weight:400;font-size:17px;line-height:28.05px;color:var(--ink-2)}

  /* Responsive */
  @media(max-width:1024px){
    .adv-grid{grid-template-columns:repeat(2,1fr)}
    .strat-grid{grid-template-columns:repeat(2,1fr)}
    .risks{flex-wrap:wrap}
    .risk{flex:1 1 calc(50% - 12px)}
    .faq-side .usr{display:none}
  }
  @media(max-width:900px){
    .steps{flex-direction:column}
    .step-div{display:none}
    .step{border-bottom:1px solid var(--card-border)}
    .step:last-child{border-bottom:0}
    .row-2{flex-direction:column}
    .row-3{flex-direction:column}
    .faq-cols{flex-direction:column}
    .faq-side{width:100%}
    .faq-title{white-space:normal}
  }
  @media(max-width:768px){
    :root{--pad:16px;--container-pad:24px;--section-y:56px}
    .faq-wrap{padding:128px var(--pad)}
    .hero-inner{padding:80px 0 48px}
    .hero h1{font-size:clamp(28px,7vw,40px)}
    .hero .lead{font-size:16px}
    .sec-title,.faq-title{font-size:clamp(28px,7vw,40px)}
    .cell{padding:12px 6px}
    .cta-box{padding:48px}
    .cta-box h3{font-size:clamp(24px,6.4vw,38px);line-height:1.2}
    .ct-sub{font-size:15px;line-height:1.6}
    .term-grid{grid-template-columns:1fr}
    .term{border-right:0;border-bottom:1px solid var(--card-border)!important}
    .term:last-child{border-bottom:0!important}
  }
  @media(max-width:560px){
    .cat-3{grid-template-columns:1fr!important}
    .cat-3 .cat{border-right:0!important;border-bottom:1px solid var(--card-border)!important}
    .cat-3 .cat:last-child{border-bottom:0!important}
    .adv-grid{grid-template-columns:1fr}
    .strat-grid{grid-template-columns:1fr}
    .risk{flex:1 1 100%}
  }
  @media(prefers-reduced-motion:reduce){
    .qa-wrap,.faq-icon svg .v{transition:none}
  }
</style>

<script>
  document.querySelectorAll('.faq-item').forEach(function(it) {
    (it as HTMLElement).addEventListener('click', function() {
      it.classList.toggle('open');
    });
  });
</script>
