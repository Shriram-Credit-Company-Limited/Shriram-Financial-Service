---
import BaseLayout from '../../layouts/BaseLayout.astro';

const advantageItems = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Hedging & Risk Management',
    desc: 'Protect your equity portfolio against market downturns using index put options or futures as a hedge.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M3 3v18h18"/><path d="m7 14 4-4 4 4 4-4"/></svg>`,
    title: 'Leverage Your Capital',
    desc: 'Control a large position with a fraction of the capital required in the cash market. Initial margin is typically 8–22% of contract value.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`,
    title: 'Income Generation',
    desc: 'Sell covered calls or cash-secured puts to earn regular premium income on your existing portfolio.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><polyline points="3 18 10 11 16 16 25 7"/><polyline points="19 7 25 7 25 13"/></svg>`,
    title: 'Price Discovery',
    desc: 'F&O markets reflect future expectations, acting as a leading indicator for spot markets and helping informed decision-making.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><rect x="2" y="7" width="6" height="14" rx="1"/><rect x="9" y="3" width="6" height="18" rx="1"/><rect x="16" y="10" width="6" height="11" rx="1"/></svg>`,
    title: 'High Liquidity',
    desc: 'NIFTY and BANKNIFTY options are among the most liquid instruments globally — tight spreads and deep order books at all times.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M9 14l-4-4 4-4"/><path d="M5 10h11a4 4 0 0 1 0 8h-1"/></svg>`,
    title: 'Low Transaction Costs',
    desc: 'Flat ₹20 per executed order brokerage — no percentage-based fees. Statutory charges (STT, exchange fee) are standard across all brokers.',
  },
];

const limitationItems = [
  { q: 'Leverage Risk', a: 'F&O positions are leveraged — a small adverse move in the underlying can result in losses far exceeding the initial margin deposited. Always use stop-losses and size positions appropriately.' },
  { q: 'Time Decay (Theta)', a: 'Options lose time value as they approach expiry. Theta decay accelerates in the final week before expiry, making it difficult for option buyers to recover unless the underlying moves significantly.' },
  { q: 'Complexity', a: 'F&O requires understanding of Greeks (Delta, Theta, Vega, Gamma), margin mechanics, and strategy construction. It is not suitable for beginners without adequate education and practice.' },
  { q: 'Margin Calls', a: 'If the market moves against your position, your broker may issue a margin call requiring you to top up your account. Failure to add funds within the stipulated time results in forced square-off of positions.' },
  { q: 'Counterparty Risk (Exchange-Managed)', a: 'Derivatives traded on NSE/BSE are settled by clearing corporations (NSCCL/ICCL), virtually eliminating direct counterparty risk — but OTC derivatives carry this risk fully.' },
  { q: 'Volatility Risk', a: 'Sharp, unexpected volatility events — gap openings, earnings surprises, macro news — can cause large overnight losses on open futures positions or in short options portfolios.' },
];

const typeItems = [
  { label: 'Index Futures', tag: 'Futures', desc: 'Trade NIFTY 50, BANKNIFTY, FINNIFTY futures. Cash-settled on expiry every Thursday.' },
  { label: 'Stock Futures', tag: 'Futures', desc: 'Futures contracts on 180+ SEBI-approved stocks. Physical delivery on monthly expiry.' },
  { label: 'Index Options', tag: 'Options', desc: 'Call & put options on NIFTY/BANKNIFTY. Most liquid derivative instruments in India.' },
  { label: 'Stock Options', tag: 'Options', desc: 'Options on individual stocks with monthly expiry. Lower liquidity than index options.' },
  { label: 'Currency Derivatives', tag: 'Currency', desc: 'Trade USD-INR, EUR-INR, GBP-INR pairs on NSE/BSE. Used by importers, exporters, and speculators.' },
  { label: 'Commodity Derivatives', tag: 'Commodity', desc: 'Futures & options on gold, silver, crude oil, and agri commodities — traded on MCX and NCDEX.' },
];

const tagColors: Record<string, string> = {
  Futures:   'bg-[#e8f3ff] text-[#1a5caa]',
  Options:   'bg-[var(--color-brand)]/15 text-[var(--color-brand-deep)]',
  Currency:  'bg-[#edf6ee] text-[#1a6e2e]',
  Commodity: 'bg-[#f3ede8] text-[#7a3a12]',
};

const steps = [
  { n: '01', title: 'Open a Trading Account', desc: 'Register with Shriram Financial Services and open a Demat + Trading account digitally in under 10 minutes — 100% paperless.' },
  { n: '02', title: 'Activate F&O Segment', desc: 'Request F&O segment activation from your account dashboard. Submit 6-month bank statement or ITR as income proof if required by SEBI guidelines.' },
  { n: '03', title: 'Add Margin to Your Account', desc: 'Transfer funds to cover SPAN + Exposure margin. F&O positions require upfront margin collateral — check the margin requirement for your chosen contract.' },
  { n: '04', title: 'Place Your First Order', desc: 'Select your underlying (NIFTY / BANKNIFTY / stock), expiry date, strike price, and order type. Start with buying options to limit downside to the premium paid.' },
];

const faqs = [
  { q: 'What is derivatives trading in India?', a: 'Derivatives trading involves contracts whose value is derived from an underlying asset — a stock, index, commodity, or currency. In India, retail traders primarily trade Futures and Options (F&O) on NSE and BSE. India is now one of the largest derivative markets globally by volume.' },
  { q: 'What is the difference between Futures and Options?', a: 'Futures obligate both buyer and seller to transact at the agreed price on expiry. Options give the buyer the right — not the obligation — to buy (call) or sell (put) at a strike price. Options buyers risk only the premium paid; futures traders risk mark-to-market losses daily.' },
  { q: 'How much capital do I need to start F&O trading?', a: 'Buying one NIFTY/BANKNIFTY options lot needs ₹5,000–₹20,000 in premium. Futures require ₹50,000–₹2,00,000 in SPAN + Exposure margin per lot depending on the underlying. Start with options buying to limit risk.' },
  { q: 'Is F&O income taxed differently from equity?', a: 'Yes — F&O P&L is treated as non-speculative business income, not capital gains. You must file ITR-3, can offset F&O losses against other business income, and carry forward losses for up to 8 years.' },
  { q: 'What is "writing" or "selling" an option?', a: 'Writing (selling) an option earns you the premium upfront but creates an obligation to fulfil the contract if the buyer exercises it. Sellers profit when the option expires worthless; naked call writers face theoretically unlimited downside.' },
  { q: 'How does margin work in F&O?', a: 'SEBI requires SPAN + Exposure margin upfront for every F&O position. SPAN covers worst-case one-day losses; Exposure adds a buffer for extreme volatility. If your margin falls below the required level, your broker may square off positions automatically.' },
  { q: 'Can I trade F&O on any stock?', a: 'No. SEBI approves approximately 180+ stocks for F&O trading based on liquidity, market capitalisation, and volatility. Index derivatives (NIFTY, BANKNIFTY, FINNIFTY) are the most liquid instruments available.' },
  { q: 'What are options Greeks and why do they matter?', a: 'Greeks measure an option\'s sensitivity to various market factors. Delta: sensitivity to price change. Theta: time decay per day. Vega: sensitivity to volatility changes. Gamma: rate of change of Delta. Understanding Greeks is essential for advanced options strategies.' },
  { q: 'What is the lot size for NIFTY futures?', a: 'The current NIFTY lot size is 75 units per contract. BANKNIFTY lot size is 35 units. Lot sizes are revised periodically by NSE based on the underlying value to maintain minimum contract value thresholds.' },
  { q: 'What is weekly vs monthly expiry in options?', a: 'NIFTY and BANKNIFTY have weekly expiry contracts (every Thursday) in addition to monthly contracts (last Thursday of the month). Weekly options have lower premiums but higher theta decay, making them more suitable for short-term directional plays.' },
  { q: 'Can NRIs trade derivatives in India?', a: 'NRIs can trade derivatives in India through RBI-approved routes using NRE/NRO accounts, subject to specific FEMA regulations. They must use a SEBI-registered broker with NRI trading facilities. Please contact our support team for NRI-specific guidance.' },
  { q: 'What is an Iron Condor strategy?', a: 'An Iron Condor is a neutral options strategy where you sell an OTM call spread and an OTM put spread simultaneously. It profits when the underlying stays within a defined range till expiry. Maximum profit is the net premium received; maximum loss is capped.' },
];
---

<BaseLayout
  title="Derivatives Trading India — Futures &amp; Options (F&amp;O) | Shriram"
  description="Trade derivatives in India — futures &amp; options on NSE &amp; BSE. SEBI-registered. Flat ₹20/order. Expert F&amp;O advisory, margin guidance, and dedicated research. Activate F&amp;O today."
>

  <!-- ══ S1. HERO ══════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[var(--color-dark-800)] py-[100px] lg:py-[120px]">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[560px] w-[560px] rounded-full bg-[var(--color-brand)]/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-32 left-0 h-80 w-80 rounded-full bg-[var(--color-brand)]/5 blur-3xl"></div>
    <div class="site-wrap relative">
      <p class="equity-reveal text-[14px] font-medium tracking-[.04em] text-[var(--color-brand)]">Derivatives</p>
      <h1 class="equity-reveal mt-[22px] max-w-[860px] text-[clamp(32px,4vw,54px)] font-bold leading-[1.06] text-white" style="font-family:var(--font-display)">
        Trade Derivatives <span class="text-[var(--color-brand)]">with Confidence</span>
      </h1>
      <p class="equity-reveal mt-[26px] max-w-[580px] text-[18px] leading-relaxed text-white/70">
        Access Futures &amp; Options on India's trusted platform — Shriram Financial Services. SEBI-registered, flat ₹20/order, with expert F&amp;O research from Day 1.
      </p>
      <div class="equity-reveal mt-[38px] flex flex-wrap gap-[14px]">
        <a href="/about/open-demat-account/" class="btn-primary">Open Demat Account</a>
        <a href="/about/open-demat-account/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Activate F&amp;O Segment</a>
      </div>
      <div class="equity-reveal mt-[54px] flex flex-wrap gap-x-9 gap-y-3 border-t border-white/15 pt-9">
        {['✓ SEBI-registered', '✓ Flat ₹20/order', '✓ NSE & BSE F&O', '✓ Expert F&O advisory'].map(f => (
          <span class="text-[15px] font-medium text-white/90">{f}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S2. WHAT IS DERIVATIVES TRADING ══════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[52px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          What is <span class="text-[var(--color-brand)]">Derivatives Trading?</span>
        </h2>
      </div>

      <div class="equity-reveal mx-auto max-w-[860px] space-y-[22px] text-[17px] leading-[1.75] text-[var(--color-muted)]">
        <p>Derivatives trading involves financial contracts whose value is derived from an underlying asset — such as stocks, indices, commodities, or currencies. In the Indian market context, these instruments are pivotal for both institutional and retail traders, enabling sophisticated risk management and speculative positioning.</p>
        <p>A derivative contract represents an agreement between a buyer and a seller to trade an asset at a predetermined price on a future date. This mechanism provides a layer of certainty for businesses managing input costs while offering liquid opportunities for market participants to profit from price movements without owning the underlying asset.</p>
        <p>For retail investors in India, derivatives are predominantly traded on the NSE and BSE through Futures and Options (F&amp;O). These segments have seen explosive growth, making India one of the largest derivative markets globally — characterised by high daily volume and robust regulatory oversight by SEBI.</p>
      </div>

      <div class="equity-reveal mt-[48px] overflow-hidden rounded-[14px] border border-[var(--color-n400)] bg-[#f8f6f1]">
        <div class="grid divide-y divide-[var(--color-n400)] sm:grid-cols-2 sm:divide-x sm:divide-y-0">
          {[
            { label: 'Underlying Asset', val: 'The stock, index, commodity, or currency the contract is based on (e.g. NIFTY, RELIANCE, GOLD).' },
            { label: 'Expiry Date', val: 'Date the contract terminates. Weekly: every Thursday. Monthly: last Thursday of the month.' },
            { label: 'Lot Size', val: 'Minimum number of units per contract — e.g. 75 units for NIFTY, 35 for BANKNIFTY.' },
            { label: 'Strike Price / Premium', val: 'Strike is the pre-agreed price for options; premium is the cost paid by the option buyer.' },
          ].map(d => (
            <div class="px-[28px] py-[22px]">
              <p class="mb-[6px] text-[13px] font-bold uppercase tracking-wide text-[var(--color-dark-olive)]">{d.label}</p>
              <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">{d.val}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="equity-reveal mt-[44px] text-center">
        <a href="/products/equity/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-[var(--color-n400)] px-[26px] text-[15px] font-semibold text-[var(--color-ink)] transition-colors hover:border-[var(--color-brand)]">Explore Futures &amp; Options →</a>
      </div>
    </div>
  </section>

  <!-- ══ S3. HOW DERIVATIVES TRADING WORKS ════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[52px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How <span class="text-[var(--color-brand)]">Derivatives Trading</span> Works
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Two contract types — each with distinct rights, obligations, and risk profiles.</p>
      </div>

      <div class="equity-reveal grid gap-5 sm:grid-cols-2">
        <div class="product-card-light px-[32px] py-[36px]">
          <div class="mb-[18px] flex h-[52px] w-[52px] items-center justify-center rounded-[14px] bg-[var(--color-dark-olive)] text-[var(--color-brand)]">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          </div>
          <h3 class="mb-[12px] text-[22px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">Futures Contract</h3>
          <p class="text-[15px] leading-relaxed text-[var(--color-muted)]">A binding agreement to buy or sell an asset at a preset price on expiry. Both parties <strong class="text-[var(--color-ink)]">must</strong> honour the contract regardless of the market price. P&amp;L is settled daily via mark-to-market (MTM).</p>
          <ul class="mt-[18px] space-y-[8px]">
            {['Both buyer and seller are obligated', 'Daily MTM settlement', 'Higher margin requirement', 'Unlimited profit and loss potential'].map(p => (
              <li class="flex items-start gap-[10px] text-[13.5px] text-[var(--color-muted)]">
                <span class="mt-[6px] h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--color-brand)]"></span>
                {p}
              </li>
            ))}
          </ul>
        </div>

        <div class="product-card-light px-[32px] py-[36px]">
          <div class="mb-[18px] flex h-[52px] w-[52px] items-center justify-center rounded-[14px] bg-[var(--color-dark-olive)] text-[var(--color-brand)]">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 class="mb-[12px] text-[22px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">Options Contract</h3>
          <p class="text-[15px] leading-relaxed text-[var(--color-muted)]">The <strong class="text-[var(--color-ink)]">right — not the obligation</strong> — to buy (Call) or sell (Put) at a strike price before expiry. The buyer pays a premium; the seller (writer) collects it but takes on the obligation.</p>
          <ul class="mt-[18px] space-y-[8px]">
            {['Buyer has a right, not obligation', 'Maximum loss = premium paid (buyer)', 'Seller faces potentially unlimited risk', 'Weekly and monthly expiry cycles'].map(p => (
              <li class="flex items-start gap-[10px] text-[13.5px] text-[var(--color-muted)]">
                <span class="mt-[6px] h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--color-brand)]"></span>
                {p}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div class="equity-reveal mt-[36px] rounded-[14px] border border-[var(--color-n400)] bg-white px-[32px] py-[24px]">
        <p class="text-[14.5px] leading-relaxed text-[var(--color-ink)]">
          <strong>Worked Example:</strong> You expect NIFTY to rise from 24,000 to 24,500. You buy a NIFTY 24,200 Call at ₹150 premium (lot size: 75 units). Total cost = ₹150 × 75 = <strong>₹11,250</strong>. If NIFTY closes at 24,600, intrinsic value = ₹400 → profit = (₹400 − ₹150) × 75 = <strong>₹18,750</strong>. If NIFTY falls, your maximum loss is the ₹11,250 premium paid.
        </p>
      </div>
    </div>
  </section>

  <!-- ══ S4. TYPES OF DERIVATIVES ═════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[52px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Types of <span class="text-[var(--color-brand)]">Derivatives</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Derivatives available to Indian retail investors span indices, stocks, currencies, and commodities.</p>
      </div>

      <div class="equity-reveal grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {typeItems.map(t => (
          <div class="product-card-light px-[28px] py-[32px]">
            <span class={`mb-[14px] inline-flex rounded-full px-3 py-1 text-[11px] font-bold uppercase tracking-wide ${tagColors[t.tag]}`}>{t.tag}</span>
            <h3 class="mb-[10px] text-[18px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{t.label}</h3>
            <p class="text-[14px] leading-relaxed text-[var(--color-muted)]">{t.desc}</p>
          </div>
        ))}
      </div>

      <div class="equity-reveal mt-[44px] text-center">
        <a href="/products/equity/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-[var(--color-n400)] px-[26px] text-[15px] font-semibold text-[var(--color-ink)] transition-colors hover:border-[var(--color-brand)]">Explore Futures &amp; Options →</a>
      </div>
    </div>
  </section>

  <!-- ══ S5. ADVANTAGES ═══════════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[52px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Advantages of <span class="text-[var(--color-brand)]">Derivatives Trading</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">When used with discipline and the right strategy, derivatives offer unique advantages unavailable in the equity cash market.</p>
      </div>

      <div class="equity-reveal grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {advantageItems.map(a => (
          <div class="product-card-light px-[28px] py-[32px]">
            <div class="mb-[16px] flex h-[48px] w-[48px] items-center justify-center rounded-[12px] bg-[var(--color-dark-olive)] text-[var(--color-brand)]" set:html={a.icon} />
            <h3 class="mb-[10px] text-[18px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{a.title}</h3>
            <p class="text-[14px] leading-relaxed text-[var(--color-muted)]">{a.desc}</p>
          </div>
        ))}
      </div>

      <div class="equity-reveal mt-[44px] text-center">
        <a href="/about/open-demat-account/" class="btn-primary">Open Demat Account</a>
      </div>
    </div>
  </section>

  <!-- ══ S6. LIMITATIONS TO BE AWARE ══════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[52px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Limitations to <span class="text-[var(--color-brand)]">Be Aware</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Derivatives carry significant risks. Understanding these limitations is essential before trading F&amp;O.</p>
      </div>

      <div class="equity-reveal mx-auto max-w-[860px] divide-y divide-[var(--color-n400)] overflow-hidden rounded-[20px] border border-[var(--color-n400)] bg-white">
        {limitationItems.map(item => (
          <details class="limit-faq group">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5 hover:bg-[var(--color-n100)]">
              <span class="text-[16px] font-semibold text-[var(--color-ink)]">{item.q}</span>
              <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full border border-[var(--color-n400)] text-[18px] leading-none text-[var(--color-brand)] transition-transform duration-300 group-open:rotate-45">+</span>
            </summary>
            <div class="border-t border-[var(--color-n400)] bg-[var(--color-n100)] px-6 py-5">
              <p class="text-[14px] leading-relaxed text-[var(--color-muted)]">{item.a}</p>
            </div>
          </details>
        ))}
      </div>

      <div class="equity-reveal mt-[44px] text-center">
        <a href="/about/support/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-[var(--color-n400)] px-[26px] text-[15px] font-semibold text-[var(--color-ink)] transition-colors hover:border-[var(--color-brand)]">Read Risk Disclosure →</a>
      </div>
    </div>
  </section>

  <!-- ══ S7. HOW TO TRADE DERIVATIVES ════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[52px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How to <span class="text-[var(--color-brand)]">Trade Derivatives</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Three prerequisites you must have before placing your first F&amp;O order on NSE or BSE.</p>
      </div>

      <div class="equity-reveal grid gap-5 sm:grid-cols-3">
        {[
