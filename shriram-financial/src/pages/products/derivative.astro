---
import BaseLayout from '../../layouts/BaseLayout.astro';

const types = [
  { label: 'Futures Contracts', desc: 'A binding agreement to buy or sell an asset at a set price on a future date. Both parties are obligated to fulfil the contract at expiry.' },
  { label: 'Options Contracts', desc: 'The right — not the obligation — to buy or sell at a strike price before expiry. Buyers risk only the premium paid; upside is unlimited for calls.' },
];

const eligibility = [
  'Indian resident individual or entity (HUF, firm, company)',
  'Valid PAN Card and active trading + Demat account',
  'F&O segment activation on your trading account (SEBI mandate)',
  'Bank account with sufficient margin balance',
  'For NRI: RBI-approved broker and NRE/NRO bank account',
];

const documents = [
  'PAN Card (mandatory for all account types)',
  'Address Proof — Aadhaar / Passport / Utility Bill',
  'Bank Account Proof — cancelled cheque or statement',
  'Income proof — 6-month bank statement or ITR (for F&O segment activation)',
];

const steps = [
  { n: '01', title: 'Open Trading Account', desc: 'Register with Shriram. Open a Demat + Trading account digitally in 10 minutes.' },
  { n: '02', title: 'Activate F&O Segment', desc: 'Request F&O segment activation. Submit income proof if required.' },
  { n: '03', title: 'Add Margin', desc: 'Transfer funds for SPAN + Exposure margin. F&O requires upfront margin collateral.' },
  { n: '04', title: 'Place Your Order', desc: 'Select underlying (NIFTY/BANKNIFTY/stock), expiry, strike price, and execute.' },
];

const chargeRows = [
  { label: 'Brokerage', futures: '₹20 per executed order', options: '₹20 per executed order' },
  { label: 'STT', futures: '0.0125% on sell side (contracts)', options: '0.125% on sell side (premium)' },
  { label: 'GST', futures: '18% on brokerage + charges', options: '18% on brokerage + charges' },
  { label: 'Exchange Charges', futures: '0.00235% (NSE)', options: '0.053% (NSE)' },
  { label: 'SEBI Turnover Fee', futures: '₹10 per crore', options: '₹10 per crore' },
];

const strategies = [
  { label: 'Long Call', desc: 'Buy a call option. Profit if underlying rises above strike + premium. Max loss = premium.', type: 'Bullish' },
  { label: 'Bull Call Spread', desc: 'Buy lower strike call, sell higher strike call. Limited profit, limited loss.', type: 'Bullish' },
  { label: 'Long Put', desc: 'Buy a put option. Hedge existing equity holdings. Max loss = premium paid.', type: 'Bearish' },
  { label: 'Iron Condor', desc: 'Sell OTM call & put spreads. Profit in range-bound markets with low volatility.', type: 'Neutral' },
];

const risks = [
  { n: '01', label: 'Leverage Risk', desc: 'F&O positions are leveraged — a small adverse move in the underlying can result in losses far exceeding the initial margin deposited.' },
  { n: '02', label: 'Expiry Risk', desc: 'Options lose time value rapidly as they approach expiry (theta decay). Positions left unmanaged near expiry can expire worthless.' },
  { n: '03', label: 'Volatility Risk', desc: 'Sharp, unexpected volatility events (gap openings, news events) can trigger margin calls or cause large overnight losses in open futures positions.' },
  { n: '04', label: 'Liquidity Risk', desc: 'Out-of-the-money contracts, particularly in individual stocks, may have very low open interest — making it difficult to exit at a fair price.' },
];

const faqs = [
  { q: 'What is the difference between Futures and Options?', a: 'Futures obligate both buyer and seller to transact at expiry. Options give the buyer the right — not the obligation — to buy (call) or sell (put). Options buyers risk only the premium; futures traders risk margin losses.' },
  { q: 'How much capital do I need to start F&O trading?', a: 'Buying a NIFTY/BANKNIFTY options lot needs ₹5,000–₹20,000 in premium. Futures require ₹50,000–₹2,00,000 in SPAN + Exposure margin per lot, depending on the underlying.' },
  { q: 'Is F&O income taxed differently from equity?', a: 'Yes — F&O P&L is business income (non-speculative), not capital gains. File ITR-3, offset losses against other business income, and carry forward losses for 8 years.' },
  { q: 'What is "writing" an option?', a: 'Writing (selling) an option earns you the premium upfront but creates an obligation to fulfil the contract if exercised. Writers profit when the option expires worthless; naked call writers face unlimited downside.' },
  { q: 'How does margin work in F&O?', a: 'SEBI requires SPAN + Exposure margin upfront. SPAN covers worst-case one-day losses; Exposure adds a buffer. Fall below the required margin and your broker may square off positions.' },
  { q: 'Can I trade F&O on any stock?', a: 'No. SEBI approves roughly 180+ stocks for F&O trading based on liquidity, market cap, and volatility. Index derivatives (NIFTY, BANKNIFTY, FINNIFTY) are the most liquid instruments available.' },
  { q: 'What is the minimum capital for F&O trading?', a: 'Buying one NIFTY options lot needs ₹5,000–₹20,000 premium. Futures require ₹1–₹2 lakh SPAN + Exposure margin per lot. Start with options buying to limit risk.' },
  { q: 'How is F&O income taxed?', a: 'F&O P&L is treated as non-speculative business income — not capital gains. File ITR-3. You can offset F&O losses against other business income and carry forward losses for 8 years.' },
];
---

<BaseLayout
  title="Derivatives Trading India — Futures &amp; Options (F&amp;O) on NSE | Shriram"
  description="Trade derivatives in India — futures &amp; options on NSE &amp; BSE. SEBI-registered. Flat ₹20/order. Expert F&amp;O advisory, margin calculator, strategies. Activate F&amp;O account today."
>

  <!-- ══ S1. HERO ══════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[var(--color-dark-800)] py-[100px] lg:py-[120px]">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[560px] w-[560px] rounded-full bg-[var(--color-brand)]/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-32 left-0 h-80 w-80 rounded-full bg-[var(--color-brand)]/5 blur-3xl"></div>
    <div class="site-wrap relative">
      <p class="equity-reveal text-[14px] font-medium tracking-[.04em] text-[var(--color-brand)]">Derivatives</p>
      <h1 class="equity-reveal mt-[22px] max-w-[880px] text-[clamp(32px,4vw,52px)] font-bold leading-[1.06] text-white" style="font-family:var(--font-display)">
        <span class="text-[var(--color-brand)]">Derivatives Trading</span> India — Futures &amp; Options (F&amp;O) on NSE
      </h1>
      <p class="equity-reveal mt-[26px] max-w-[600px] text-[18px] leading-relaxed text-white/70">
        Trade futures and options on NSE &amp; BSE. Flat ₹20/order. SEBI-registered. Expert F&amp;O research and dedicated risk management support.
      </p>
      <div class="equity-reveal mt-[38px] flex flex-wrap gap-[14px]">
        <a href="/about/open-demat-account/" class="btn-primary">Open F&amp;O Account</a>
        <a href="/about/open-demat-account/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Activate F&amp;O Segment</a>
      </div>
      <div class="equity-reveal mt-[54px] flex flex-wrap gap-x-9 gap-y-3 border-t border-white/15 pt-9">
        {['✓ SEBI-registered', '✓ Flat ₹20/order', '✓ NSE & BSE F&O', '✓ Expert F&O advisory'].map(f => (
          <span class="text-[15px] font-medium text-white/90">{f}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S2. WHAT IS DERIVATIVES TRADING ══════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          What is <span class="text-[var(--color-brand)]">Derivatives Trading?</span> — Meaning &amp; Basics
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">A derivative is a financial contract whose value derives from an underlying asset — a stock, index, commodity, or currency.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Feature</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Description</th>
              </tr>
            </thead>
            <tbody>
              {[
                { feature: 'Underlying', desc: 'The asset the contract is based on (NIFTY, RELIANCE, GOLD)' },
                { feature: 'Expiry', desc: 'Date the contract terminates (weekly: every Thursday; monthly: last Thursday)' },
                { feature: 'Lot Size', desc: 'Minimum number of units per contract' },
                { feature: 'Strike Price', desc: 'Pre-agreed price for options contracts' },
                { feature: 'Premium', desc: 'Price paid by options buyer to the seller' },
              ].map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.feature}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.desc}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S3. HOW DERIVATIVES TRADING WORKS ════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How <span class="text-[var(--color-brand)]">Derivatives Trading</span> Works — Mechanism
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Derivatives trade on two types of contracts — with clear rights and obligations for each party.</p>
      </div>
      <div class="equity-reveal grid gap-5 sm:grid-cols-2">
        <div class="product-card-light px-[28px] py-[32px]">
          <h3 class="mb-[12px] text-[22px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">Futures Contract</h3>
          <p class="text-[15px] leading-relaxed text-[var(--color-muted)]">Binding agreement to buy/sell at a preset price on expiry. Both parties MUST honour the contract. P&amp;L is daily marked-to-market.</p>
        </div>
        <div class="product-card-light px-[28px] py-[32px]">
          <h3 class="mb-[12px] text-[22px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">Options Contract</h3>
          <p class="text-[15px] leading-relaxed text-[var(--color-muted)]">Right — NOT obligation — to buy (call) or sell (put) at strike price before expiry. Buyer risks only the premium paid.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S4. TYPES OF DERIVATIVES ═════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Types of <span class="text-[var(--color-brand)]">Derivatives</span> — Futures, Options &amp; More
        </h2>
      </div>
      <div class="equity-reveal cat-grid">
        {[
          { label: 'Index Futures', desc: 'Trade NIFTY 50, BANKNIFTY, FINNIFTY futures. Settle in cash.' },
          { label: 'Stock Futures', desc: 'Futures contracts on ~180+ SEBI-approved stocks.' },
          { label: 'Index Options', desc: 'Call & put options on NIFTY/BANKNIFTY. Most liquid market in India.' },
          { label: 'Stock Options', desc: 'Options on individual stocks. Lower liquidity than index options.' },
        ].map(t => (
          <div class="product-card-light px-[28px] py-[32px]">
            <h3 class="mb-[10px] text-[18px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{t.label}</h3>
            <p class="text-[14px] leading-relaxed text-[var(--color-muted)]">{t.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S5. ADVANTAGES ═══════════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Advantages of <span class="text-[var(--color-brand)]">Derivatives Trading</span>
        </h2>
      </div>
      <div class="equity-reveal grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { label: 'Hedging', desc: 'Protect your equity portfolio against market downturns using index put options.' },
          { label: 'Leverage', desc: 'Control a large position with a fraction of the capital (initial margin requirement).' },
          { label: 'Income Generation', desc: 'Sell covered calls or cash-secured puts to earn regular premium income.' },
          { label: 'Price Discovery', desc: 'F&O markets reflect future expectations — a leading indicator for spot markets.' },
        ].map(a => (
          <div class="product-card-light px-[28px] py-[32px]">
            <h3 class="mb-[10px] text-[18px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{a.label}</h3>
            <p class="text-[14px] leading-relaxed text-[var(--color-muted)]">{a.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S6. DISADVANTAGES ════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Disadvantages of <span class="text-[var(--color-brand)]">Derivatives Trading</span>
        </h2>
      </div>
      <div class="equity-reveal grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { n: '01', label: 'Leverage Risk', desc: 'Small adverse price move → losses exceeding initial margin. Manage position sizing.' },
          { n: '02', label: 'Time Decay', desc: 'Options lose value as expiry approaches (theta). Buyers must be right on direction AND timing.' },
          { n: '03', label: 'Complexity', desc: 'F&O requires understanding Greeks (Delta, Theta, Vega). Not suitable for beginners.' },
          { n: '04', label: 'Margin Calls', desc: 'Adverse moves trigger margin calls — forced square-off if you cannot add funds.' },
        ].map(d => (
          <div class="bg-[var(--color-dark-800)] rounded-[14px] p-[28px] text-white">
            <div class="mb-[14px] text-[36px] font-bold leading-none text-[var(--color-brand)]">{d.n}</div>
            <h4 class="mb-[10px] text-[18px] font-medium text-white" style="font-family:var(--font-display)">{d.label}</h4>
            <p class="text-[13.5px] leading-relaxed text-white/65">{d.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S7. HOW TO TRADE DERIVATIVES ════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How to <span class="text-[var(--color-brand)]">Trade Derivatives</span> — Getting Started
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Three things you need before placing your first F&amp;O order.</p>
      </div>
      <div class="equity-reveal grid gap-5 sm:grid-cols-3">
        {[
          { label: 'F&O Account Activated', desc: 'Request F&O segment activation on your Shriram trading account.' },
          { label: 'Sufficient Margin', desc: 'Maintain SPAN + Exposure margin in your account at all times.' },
          { label: 'Understanding Strategies', desc: 'Start with buying options (limited risk) before selling or writing.' },
        ].map(c => (
          <div class="product-card-light px-[28px] py-[32px]">
            <h3 class="mb-[10px] text-[18px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{c.label}</h3>
            <p class="text-[14px] leading-relaxed text-[var(--color-muted)]">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S8. STEPS TO START ════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Steps to Start <span class="text-[var(--color-brand)]">Derivatives Trading</span> — Account Opening
        </h2>
      </div>
      <div class="equity-reveal steps-grid overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        {steps.map(s => (
          <div class="px-[30px] py-[34px]">
            <div class="mb-[22px] font-display text-[34px] font-normal leading-none text-[var(--color-brand)]">{s.n}</div>
            <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">{s.title}</h4>
            <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S9. FUTURES VS OPTIONS ════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          <span class="text-[var(--color-brand)]">Futures vs Options</span> — Key Differences
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Choose the right instrument based on your strategy, capital, and risk appetite.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Feature</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Futures</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Options</th>
              </tr>
            </thead>
            <tbody>
              {[
                { feature: 'Obligation', futures: 'Must buy/sell at expiry', options: 'Right only (buyer), obligation (seller)' },
                { feature: 'Premium', futures: 'No premium — margin based', options: 'Buyer pays premium upfront' },
                { feature: 'Max Loss (Buyer)', futures: 'Unlimited (mark-to-market)', options: 'Limited to premium paid' },
                { feature: 'Max Loss (Seller)', futures: 'Unlimited', options: 'Unlimited (for naked positions)' },
                { feature: 'Use Case', futures: 'Directional bets, hedging', options: 'Hedging, income, speculative' },
                { feature: 'Capital Required', futures: 'Higher (SPAN margin)', options: 'Lower (premium amount)' },
              ].map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.feature}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.futures}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.options}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S10. RISKS ════════════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Risks in <span class="text-[var(--color-brand)]">Derivatives Trading</span>
        </h2>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {risks.map(r => (
          <div class="equity-reveal product-card-light px-[28px] py-[32px]">
            <div class="mb-[14px] text-[36px] font-bold leading-none text-[var(--color-brand)]/40">{r.n}</div>
            <h4 class="mb-[10px] text-[18px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{r.label}</h4>
            <p class="text-[13.5px] leading-relaxed text-[var(--color-muted)]">{r.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S11. MARGIN IN DERIVATIVES ═══════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Margin in Derivatives — <span class="text-[var(--color-brand)]">SPAN &amp; Exposure</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">SEBI requires two components of margin for every F&amp;O position.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Margin Type</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Purpose</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Typical Range</th>
              </tr>
            </thead>
            <tbody>
              {[
                { type: 'SPAN Margin', purpose: 'Covers worst-case 1-day loss based on VaR', range: '5–15% of contract value' },
                { type: 'Exposure Margin', purpose: 'Buffer against extreme volatility', range: '3–7% of contract value' },
                { type: 'Total Margin', purpose: 'SPAN + Exposure = what you need upfront', range: '8–22% of contract value' },
              ].map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.type}</td>
