---
import BaseLayout from '../../layouts/BaseLayout.astro';

const mfTypes = [
  { tag: 'High Growth', label: 'Equity Funds', desc: 'Invest primarily in stocks. 5+ year horizon. Highest return potential — large-cap, mid-cap, small-cap, and flexi-cap options.' },
  { tag: 'Low Risk', label: 'Debt Funds', desc: 'Invest in bonds, G-Secs, and money market instruments. 1–3 year horizon. Stable returns — better post-tax than FD for higher tax brackets.' },
  { tag: 'Balanced', label: 'Hybrid Funds', desc: 'Mix of equity and debt — balanced risk-return. Balanced Advantage Funds dynamically adjust allocation based on market valuations.' },
  { tag: 'Low Cost', label: 'Index Funds', desc: 'Passively track Nifty 50, Sensex, or other indices. Expense ratios as low as 0.1%. Outperform most active large-cap funds over 10+ years.' },
  { tag: 'Tax Saving', label: 'ELSS Funds', desc: '3-year lock-in. Invest up to ₹1.5L per year and claim deduction under Section 80C. Shortest lock-in among all 80C instruments.' },
  { tag: 'Park Cash', label: 'Liquid Funds', desc: 'Invest in instruments maturing within 91 days. Earn 6–7% p.a. on idle cash with same-day or T+1 redemption — better than a savings account.' },
];

const howWorksSteps = [
  { n: '1', title: 'You invest money', desc: 'Transfer funds via SIP or lumpsum. Your money is pooled with other investors.' },
  { n: '2', title: 'Fund manager invests', desc: 'Buys equities, bonds, or instruments per the fund\'s stated mandate and SEBI category.' },
  { n: '3', title: 'NAV calculated daily', desc: 'Total assets minus liabilities, divided by outstanding units = today\'s NAV.' },
  { n: '4', title: 'You redeem at NAV', desc: 'Units are redeemed at the current NAV. Gains or losses are credited to your account.' },
];

const sipRows = [
  { feature: 'Timing Risk',           sip: 'Low — averages entry price',        ls: 'High — market timing critical' },
  { feature: 'Min Investment',        sip: '₹500/month',                        ls: '₹1,000 one-time' },
  { feature: 'Investment Discipline', sip: 'Auto-debit = automatic',            ls: 'Manual decision each time' },
  { feature: 'Best For',              sip: 'Salaried investors',                ls: 'Bonus / idle surplus' },
  { feature: 'Bear Market Benefit',   sip: 'Better returns — lower avg cost',   ls: 'Full downside exposure' },
];

const investModes = [
  { n: '1', label: 'SWP', sub: 'Systematic Withdrawal Plan', desc: 'Withdraw a fixed amount monthly from your mutual fund. Provides regular income — ideal for retirement or supplementing salary.' },
  { n: '2', label: 'STP', sub: 'Systematic Transfer Plan', desc: 'Transfer a fixed amount monthly from a liquid fund to an equity fund. Reduces lump-sum timing risk while staying invested.' },
  { n: '3', label: 'Lump Sum', sub: 'One-Time Investment', desc: 'One-time large investment. Best when markets are at low valuations or when you have a sudden surplus like a bonus or inheritance.' },
];

const risks = [
  { label: 'Market Risk',        desc: 'Equity fund NAVs fall in market downturns. Mitigate by staying invested for 5+ years.' },
  { label: 'Fund Manager Risk',  desc: 'Active funds depend on manager decisions. A change in manager can shift risk-return profile.' },
  { label: 'Concentration Risk', desc: 'Sectoral funds fall sharply if their sector underperforms. Diversify across fund categories.' },
  { label: 'Liquidity Risk',     desc: 'Some debt funds hold illiquid securities. Check exit load and lock-in before investing.' },
];

const taxRows = [
  { fundType: 'Equity MF',  stcg: '20% flat',                  ltcg: '12.5% above ₹1.25L',    holding: '12 months (LTCG)' },
  { fundType: 'Debt MF',    stcg: 'As per income slab',        ltcg: 'As per slab (no indexation)', holding: '24 months (LTCG)' },
  { fundType: 'ELSS',       stcg: 'N/A (3-yr lock-in)',        ltcg: '12.5% above ₹1.25L',    holding: '3-year lock-in applies' },
  { fundType: 'Hybrid MF',  stcg: '20% flat (equity-oriented)', ltcg: '12.5% above ₹1.25L',   holding: '12 months (LTCG)' },
];

const howInvestSteps = [
  { n: '1', title: 'Create your account',          desc: 'Visit way2wealth.com or download the app. Enter your mobile number and email to register.' },
  { n: '2', title: 'Complete KYC',                 desc: 'Upload Aadhaar and PAN. Video KYC or Aadhaar OTP-based eKYC takes under 3 minutes.' },
  { n: '3', title: 'Choose your fund',             desc: 'Use the fund screener to filter by category, risk, and returns. Compare direct vs regular plans.' },
  { n: '4', title: 'Start SIP or invest lumpsum',  desc: 'Set your amount, frequency, and mandate via UPI or net banking. First unit allotted same day.' },
];

const faqs = [
  { q: 'Is mutual fund investment safe?', a: 'Mutual funds are regulated by SEBI and are not guaranteed products. They carry market risk, but diversification and long-term investing significantly reduce risk. Debt funds carry lower risk than equity funds.' },
  { q: 'What is NAV and how does it affect my investment?', a: 'NAV = (Total Assets − Liabilities) ÷ Units Outstanding, calculated daily after market close. You buy and sell units at the NAV applicable on your transaction date. A higher NAV does not mean a fund is expensive — what matters is its growth rate over time.' },
  { q: 'Can I withdraw money from a mutual fund anytime?', a: 'Open-ended mutual funds allow redemption on any business day at the applicable NAV. ELSS funds have a 3-year lock-in. Some debt funds have exit loads if redeemed before the minimum holding period — always check before investing.' },
  { q: 'What is the difference between Direct and Regular plans?', a: 'Direct plans are bought from the AMC without a distributor — lower expense ratio, higher returns. Regular plans pay commission to distributors — higher TER. Shriram offers Direct Plans at zero commission.' },
  { q: 'Can I start a SIP with ₹500?', a: 'Yes. Most funds allow SIPs from ₹500/month. Set up auto-debit SIPs on the Antara app — no paperwork, instant activation, cancel anytime.' },
  { q: 'Is mutual fund investment safe compared to FD?', a: 'Equity mutual funds are market-linked and not capital-guaranteed like FDs. Over 5–10 years, equity funds have historically delivered higher inflation-adjusted returns. Debt funds have lower risk but carry interest rate and credit risk.' },
  { q: 'What is the ELSS lock-in period?', a: 'ELSS funds have a mandatory 3-year lock-in from the date of each SIP instalment. After the lock-in, you can hold or redeem. ELSS qualifies for ₹1.5L deduction under Section 80C — the shortest lock-in among all 80C instruments.' },
];
---

<BaseLayout
  title="Invest in Mutual Funds — Trusted by 1M+ Investors | Shriram"
  description="Grow your wealth with India's best mutual funds. SEBI-registered, 25+ years of expertise, ₹18,000 Cr+ AUM. Start your SIP in under 5 minutes — no paperwork, fully online."
>

  <!-- ══ 1. HERO ══════════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-inner">
      <h1>Invest in <span class="g">Mutual Funds</span> — Trusted by 1M+ Investors</h1>
      <p class="lead">Grow your wealth with India's best mutual funds. SEBI-registered, 30+ years of expertise, and ₹18,000 Cr+ AUM. Start your SIP in under 5 minutes — no paperwork, fully online.</p>
      <div class="cta-row">
        <a class="btn-gold" href="/about/open-demat-account/">Invest Now</a>
        <a class="btn-ghost" href="/calculators/sip/">Calculate SIP Returns</a>
      </div>
      <div class="hero-feats">
        <div class="feats">
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;SEBI-registered</span></div>
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;30+ years of trust</span></div>
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;₹18,000 Cr+ AUM</span></div>
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;1M+ investors</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 2. WHAT IS A MUTUAL FUND ════════════════════════════════════ -->
  <section class="section stack" id="sec-about" style="background:var(--sec-light);gap:56px">
    <div class="stack" style="gap:16px">
      <p class="sec-title">What is a Mutual Fund?</p>
      <p class="sec-lead">A mutual fund is a SEBI-regulated investment vehicle that pools money from multiple investors to purchase a diversified portfolio of stocks, bonds, or other securities. A professional fund manager makes investment decisions on behalf of all investors.</p>
    </div>
    <div class="row-3">
      <div class="card">
        <p class="card-h">Pooled Investment</p>
        <p class="card-p">Thousands of investors pool capital, giving each access to a diversified portfolio they couldn't build alone.</p>
      </div>
      <div class="card">
        <p class="card-h">Professional Management</p>
        <p class="card-p">A SEBI-registered fund manager makes buy/sell decisions based on the fund's stated investment objective and market research.</p>
      </div>
      <div class="card">
        <p class="card-h">SEBI-regulated</p>
        <p class="card-p">All mutual funds in India are regulated by SEBI and offered by AMFI-registered AMCs under strict disclosure and compliance norms.</p>
      </div>
    </div>
  </section>

  <!-- ══ 3. HOW MUTUAL FUNDS WORK ════════════════════════════════════ -->
  <section class="section stack" style="background:var(--sec-tint);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <p class="sec-title">How Mutual Funds Work</p>
      <p class="sec-lead">When you invest, you purchase units of a fund at the current Net Asset Value (NAV). The NAV changes daily based on the market value of underlying securities.</p>
    </div>
    <div class="steps">
      {howWorksSteps.map((s, i) => (
        <>
          {i > 0 && <div class="step-div"></div>}
          <div class="step">
            <div class="st-body"><h4>{s.title}</h4><p>{s.desc}</p></div>
          </div>
        </>
      ))}
    </div>
    <a class="btn-gold" href="/about/open-demat-account/" style="align-self:center">Start Investing</a>
  </section>

  <!-- ══ 4. TYPES OF MUTUAL FUNDS ════════════════════════════════════ -->
  <section class="section stack" style="background:var(--sec-light);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <p class="sec-title">Types of Mutual Funds in India</p>
      <p class="sec-lead">SEBI classifies mutual funds into five broad categories. Each serves a different investment goal, risk profile, and time horizon.</p>
    </div>
    <div class="cat-grid cat-3">
      {mfTypes.map(t => (
        <div class="cat">
          <h4>{t.label}</h4>
          <p>{t.desc}</p>
        </div>
      ))}
    </div>
    <a class="btn-gold" href="/about/open-demat-account/" style="align-self:center">Start Investing</a>
  </section>

  <!-- ══ 5. SIP ═══════════════════════════════════════════════════════ -->
  <section class="section stack" style="background:var(--sec-tint);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <p class="sec-title">SIP — Systematic Investment Plan</p>
      <p class="sec-lead">A SIP lets you invest a fixed amount every month in a mutual fund. It removes the need to time the market and builds wealth through rupee cost averaging over time.</p>
    </div>
    <div class="t-scroll">
      <div class="table t3 bordered">
        <div class="cell th"><p>Feature</p></div>
        <div class="cell th"><p>SIP</p></div>
        <div class="cell th"><p>Lump Sum</p></div>
        {sipRows.map(r => (
          <>
            <div class="cell tb"><p class="k">{r.feature}</p></div>
            <div class="cell tb"><p class="v">{r.sip}</p></div>
            <div class="cell tb"><p class="v">{r.ls}</p></div>
          </>
        ))}
      </div>
    </div>
    <a class="btn-gold" href="/calculators/sip/" style="align-self:center">Calculate SIP Returns</a>
  </section>

  <!-- ══ 6. CALCULATORS & TOOLS ═══════════════════════════════════════ -->
  <section class="section stack" style="background:var(--sec-light);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <p class="sec-title">Mutual Fund Calculators &amp; Tools</p>
      <p class="sec-lead">Use our free calculators to estimate returns, plan withdrawals, and compare strategies — before you invest a single rupee.</p>
    </div>
    <div class="row-3">
      <div class="card calc-card">
        <p class="card-h">SIP Calculator</p>
        <p class="card-p">Estimate how your monthly SIP grows over 1–30 years with compounding.</p>
        <a class="calc-link" href="/calculators/sip/">Calculate Now →</a>
      </div>
      <div class="card calc-card">
        <p class="card-h">Lump Sum Calculator</p>
        <p class="card-p">Calculate the future value of a one-time investment at any expected return rate.</p>
        <a class="calc-link" href="/calculators/lumpsum/">Calculate Now →</a>
      </div>
      <div class="card calc-card">
        <p class="card-h">ELSS Tax Calculator</p>
        <p class="card-p">See how much tax you can save under Section 80C with an ELSS investment.</p>
        <a class="calc-link" href="/calculators/sip/">Calculate Now →</a>
      </div>
    </div>
  </section>

  <!-- ══ 7. SWP / STP / LUMP SUM ═════════════════════════════════════ -->
  <section class="section stack" style="background:var(--sec-tint);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <p class="sec-title">SWP, STP &amp; Lump Sum — Other Investment Modes</p>
      <p class="sec-lead">Beyond SIP, there are three more investment modes suited for different financial stages and goals.</p>
    </div>
    <div class="steps">
      {investModes.map((m, i) => (
        <>
          {i > 0 && <div class="step-div"></div>}
          <div class="step">
            <div class="st-body">
              <h4>{m.label}</h4>
              <p class="mode-sub">{m.sub}</p>
              <p>{m.desc}</p>
            </div>
          </div>
        </>
      ))}
    </div>
  </section>

  <!-- ══ 8. RISKS & RISKOMETER ════════════════════════════════════════ -->
  <section class="section stack" style="background:var(--sec-light);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <p class="sec-title">Mutual Fund Risks &amp; Riskometer</p>
      <p class="sec-lead">All mutual funds carry some degree of risk. SEBI mandates every fund to display a riskometer — a standardised risk scale from Low to Very High — so investors can assess suitability before investing.</p>
    </div>
    <div class="riskometer">
      <div class="risk-bar">
        <div class="rb rb-1">Low</div>
        <div class="rb rb-2">Mod. Low</div>
        <div class="rb rb-3">Moderate</div>
        <div class="rb rb-4">Mod. High</div>
        <div class="rb rb-5">High</div>
      </div>
      <div class="risk-funds">
        <div class="rf">Overnight, Liquid, Money Market</div>
        <div class="rf">Short Duration, Banking &amp; PSU Debt</div>
        <div class="rf">Hybrid, Balanced Advantage</div>
        <div class="rf">Large Cap, ELSS, Index Funds</div>
        <div class="rf">Mid Cap, Small Cap, Sectoral</div>
      </div>
    </div>
    <div class="risks">
      {risks.map(r => (
        <div class="risk"><h4>{r.label}</h4><p>{r.desc}</p></div>
      ))}
    </div>
  </section>

  <!-- ══ 9. TAX BENEFITS ══════════════════════════════════════════════ -->
  <section class="section stack" style="background:var(--sec-tint);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <p class="sec-title">Tax Benefits of Mutual Funds</p>
      <p class="sec-lead">Mutual fund taxation in India depends on the fund type and holding period. ELSS funds offer the highest tax advantage — a deduction of up to ₹1.5 lakh under Section 80C.</p>
    </div>
    <div class="t-scroll">
      <div class="table t4 bordered">
        <div class="cell th"><p>Fund Type</p></div>
        <div class="cell th"><p>Short-Term (STCG)</p></div>
        <div class="cell th"><p>Long-Term (LTCG)</p></div>
        <div class="cell th"><p>Holding Period</p></div>
        {taxRows.map(r => (
          <>
            <div class="cell tb"><p class="k">{r.fundType}</p></div>
            <div class="cell tb"><p class="v">{r.stcg}</p></div>
            <div class="cell tb"><p class="v">{r.ltcg}</p></div>
            <div class="cell tb"><p class="v">{r.holding}</p></div>
          </>
        ))}
      </div>
    </div>
    <p style="font-size:13px;color:var(--muted);text-align:center;margin-top:-24px">* As per Budget 2025-26. Consult a tax advisor before investing.</p>
  </section>

  <!-- ══ 10. HOW TO INVEST ONLINE ═════════════════════════════════════ -->
  <section class="section stack" style="background:var(--sec-light);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <p class="sec-title">How to Invest in Mutual Funds Online</p>
      <p class="sec-lead">Investing via Shriram is fully digital — no branch visit, no paperwork. Complete your KYC once and access thousands of funds instantly.</p>
    </div>
    <div class="steps">
      {howInvestSteps.map((s, i) => (
        <>
          {i > 0 && <div class="step-div"></div>}
          <div class="step">
            <div class="st-body"><h4>{s.title}</h4><p>{s.desc}</p></div>
          </div>
        </>
      ))}
    </div>
    <a class="btn-gold" href="/about/open-demat-account/" style="align-self:center">Start Investing</a>
  </section>

  <!-- ══ 11. FAQ ══════════════════════════════════════════════════════ -->
  <section class="faq-wrap" id="sec-faq" style="background:var(--sec-tint)">
    <div class="faq-cols">
      <div class="faq-left">
        <p class="faq-title">General Questions</p>
        <div class="faq-acc">
          {faqs.map((item, i) => (
            <details class="faq-item">
              <summary class="faq-sum">
                <span class="qt">{item.q}</span>
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="faq-icon">
                  <path d="M2 8h12"/>
                  <path class="faq-v" d="M8 2v12"/>
                </svg>
              </summary>
              <div class="qa"><p>{item.a}</p></div>
            </details>
          ))}
        </div>
      </div>
      <div class="faq-side">
        <div class="usr" aria-hidden="true">
          <svg viewBox="0 0 120 135" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <circle cx="60" cy="37" r="29"/>
            <path d="M0 135a60 60 0 0 1 120 0H0z"/>
          </svg>
        </div>
        <div class="side-in">
          <div class="side-tx">
            <h4>Need A Clearer Direction?</h4>
            <p>Let's get in touch on a 15-minute call where we would be able to answer any questions you may have. Our Advisor will additionally help map your wealth mix and demonstrate what a dedicated advisor would do differently.</p>
          </div>
          <a class="btn-gold" href="/about/support/">Book A Discovery Call</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 12. FINAL CTA ════════════════════════════════════════════════ -->
  <section class="cta-sec" style="background:var(--sec-light)">
    <div class="cta-box" style="background:var(--olive-deep)">
      <div class="ct-tt" style="color:#fff">
        <h3>Start Your SIP in Mutual Funds Today</h3>
        <p class="ct-sub" style="color:rgba(255,255,255,.74)">SEBI-registered. ₹18,000 Cr+ AUM. 1M+ investors trust us. Start your SIP in under 5 minutes — no paperwork, fully online.</p>
      </div>
      <div style="display:flex;flex-wrap:wrap;gap:14px;justify-content:center">
        <a class="btn-gold" href="/about/open-demat-account/">Invest Now</a>
        <a class="btn-ghost" href="/calculators/sip/">Calculate SIP Returns</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  :root {
    --page:#fcf8ef; --sec-light:#fef8ee; --sec-tint:#f6efe1; --card:#fffdf8;
    --card-border:#e1e0db; --card-border-soft:rgba(28,28,22,.13); --row-line:rgba(28,28,22,.08);
    --olive-title:#2e3914; --olive-head:#2d3813; --olive-deep:#1b2010;
    --ink:#1c1c16; --ink-2:#46463c; --ink-3:#595959; --muted:#73736a;
    --gold:#e0a82e; --gold-2:#f2b83f; --gold-btn:#f3b83f; --olive-ink:#2e3914;
    --green:#009d58;
    --pad:clamp(20px,8vw,144px); --container-pad:32px; --section-y:72px; --cta-w:220px;
  }
  *,*::before,*::after{box-sizing:border-box}
  a{color:inherit;text-decoration:none}
  p{line-height:1.5}

  .section{padding:var(--section-y) var(--pad);min-height:100vh;min-height:100dvh;display:flex;flex-direction:column;justify-content:center}
  #sec-about{min-height:0}
  .stack{display:flex;flex-direction:column}

  .sec-title{font-weight:400;font-size:40px;color:var(--olive-title);text-transform:capitalize;line-height:1.5}
  .sec-lead{font-weight:400;font-size:16px;color:var(--ink-3);line-height:1.5}
  .card-h{font-weight:500;font-size:20px;color:var(--ink);line-height:1.5}
  .card-p{font-weight:400;font-size:16px;color:var(--muted);line-height:1.5}

  .card{background:var(--card);border:1px solid var(--card-border);border-radius:24px;padding:var(--container-pad);display:flex;flex-direction:column;gap:16px}

  /* Hero */
  .hero{padding:0 var(--pad);display:flex;flex-direction:column;justify-content:center;overflow:hidden;background:radial-gradient(125% 210% at 100% -8%,#4f583b 0%,#363a2c 50%,#1d1d1d 100%)}
  .hero-inner{padding:clamp(80px,12vw,140px) 0 clamp(48px,6vw,80px);display:flex;flex-direction:column}
  .hero h1{font-weight:500;font-size:40px;color:#fff;line-height:1.5;max-width:860px}
  .hero h1 .g{color:var(--gold-2)}
  .hero .lead{margin-top:32px;font-weight:400;font-size:18px;line-height:1.5;color:rgba(255,255,255,.74);max-width:600px}
  .cta-row{margin-top:40px;display:flex;flex-wrap:wrap;gap:14px;align-items:center}
  .hero-feats{margin-top:40px}
  .feats{display:flex;flex-wrap:wrap;align-items:center;gap:14px 16px;max-width:760px;padding-top:36px;border-top:1px solid rgba(255,255,255,.16)}
  .feat{display:flex;gap:10px;align-items:center}
  .feat .tk{color:var(--gold-2);font-weight:500;font-size:15px;width:13px}
  .feat .lb{color:rgba(255,255,255,.9);font-weight:500;font-size:16px;line-height:1.5;white-space:nowrap}

  /* Buttons */
  .btn-gold{background:var(--gold-btn);height:40px;width:var(--cta-w);border-radius:4px;display:inline-flex;align-items:center;justify-content:center;padding:7px 20px;font-weight:500;font-size:12px;color:var(--olive-ink);white-space:nowrap;transition:opacity .2s}
  .btn-gold:hover{opacity:.88}
  .btn-ghost{height:40px;border-radius:9px;border:1px solid rgba(255,255,255,.4);display:inline-flex;align-items:center;justify-content:center;padding:7px 26px;font-weight:600;font-size:15px;color:#fff;transition:border-color .2s}
  .btn-ghost:hover{border-color:#fff}
  .btn-outline{height:40px;border-radius:9px;border:1px solid var(--card-border);display:inline-flex;align-items:center;justify-content:center;padding:7px 26px;font-weight:600;font-size:14px;color:var(--ink);transition:border-color .2s}
  .btn-outline:hover{border-color:var(--gold)}

  /* 3-col row */
  .row-3{display:flex;gap:24px;align-items:stretch}
  .row-3 .card{flex:1 0 0;min-width:0}

  /* Icon box */
  .icon-box{width:48px;height:48px;border-radius:12px;background:var(--olive-deep);color:var(--gold-2);display:flex;align-items:center;justify-content:center;flex:none}

  /* Calc card link */
