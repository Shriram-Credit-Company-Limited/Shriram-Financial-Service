---
import BaseLayout from '../../layouts/BaseLayout.astro';

const fundTypes = [
  { label: 'Equity Funds', desc: 'Invest primarily in stocks. Best for long-term wealth creation over 5+ years. Include large-cap, mid-cap, small-cap, and flexi-cap variants.' },
  { label: 'Debt Funds', desc: 'Invest in bonds, government securities, and money market instruments. Lower risk, stable returns. Suitable for 1–3 year horizons.' },
  { label: 'Hybrid Funds', desc: 'Blend of equity and debt. Balanced advantage funds adjust the ratio dynamically based on market valuations.' },
  { label: 'Index Funds', desc: 'Passively track a benchmark index (NIFTY 50, SENSEX). Very low expense ratios. No fund manager risk.' },
  { label: 'ELSS (Tax Saving)', desc: 'Equity Linked Saving Scheme with 3-year lock-in. Eligible for ₹1.5 lakh deduction under Section 80C with highest return potential among 80C options.' },
  { label: 'Liquid Funds', desc: 'Invest in instruments with up to 91-day maturity. Ideal for parking surplus cash. Better returns than savings accounts with same-day redemption.' },
  { label: 'Sectoral / Thematic', desc: 'Focus on specific sectors (IT, pharma, banking) or themes (ESG, consumption). Higher concentration risk but strong outperformance in bull cycles.' },
  { label: 'International Funds', desc: 'Invest in global markets (US, China, Europe) through funds-of-funds. Portfolio diversification across geographies and currencies.' },
];

const sipVsLumpsum = [
  { feature: 'Timing Risk', sip: 'Low — averages market entry (rupee cost averaging)', lump: 'High — market timing matters significantly' },
  { feature: 'Capital Required', sip: 'As low as ₹500/month', lump: 'Typically ₹1,000 or more at once' },
  { feature: 'Discipline', sip: 'High — automated regular investing', lump: 'Requires manual decision for each investment' },
  { feature: 'Best For', sip: 'Salaried investors with regular income', lump: 'Investors with idle surplus (bonuses, FD maturity)' },
  { feature: 'Returns in Bull Market', sip: 'Moderate — gradual entry misses early rally', lump: 'High — full exposure from day one' },
  { feature: 'Returns in Bear Market', sip: 'Better — lower average cost from dips', lump: 'Lower — exposed to full downside immediately' },
];

const taxRows = [
  { feature: 'Holding Period (Equity MF)', stcg: 'Up to 12 months', ltcg: 'More than 12 months' },
  { feature: 'Tax Rate (Equity MF)', stcg: '20% flat', ltcg: '12.5% (above ₹1.25 lakh exemption)' },
  { feature: 'Holding Period (Debt MF)', stcg: 'Up to 24 months', ltcg: 'More than 24 months' },
  { feature: 'Tax Rate (Debt MF)', stcg: 'As per income tax slab', ltcg: 'As per income tax slab (no indexation from Apr 2023)' },
];

const steps = [
  { n: '01', title: 'Open a Demat Account', desc: 'A Demat account is needed to invest in direct mutual funds. Open one with Shriram in under 10 minutes — paperless KYC.' },
  { n: '02', title: 'Complete KYC', desc: 'One-time KYC using Aadhaar OTP on the SEBI-registered platform. Required for all mutual fund investments in India.' },
  { n: '03', title: 'Choose Your Fund', desc: 'Use Shriram\'s fund comparison and screener tools to select the right fund based on your goal, risk profile, and time horizon.' },
  { n: '04', title: 'Invest via SIP or Lump Sum', desc: 'Start a SIP with as little as ₹500/month or invest a lump sum. Track NAV, returns, and portfolio health on the Antara app.' },
];

const risks = [
  { n: '01', label: 'Market Risk', desc: 'Equity fund NAVs fall when markets decline. Short-term volatility is normal; stay invested for 5+ years to ride it out.' },
  { n: '02', label: 'Fund Manager Risk', desc: 'Active funds depend on the fund manager\'s decisions. A change in manager or strategy can shift the fund\'s risk-return profile unexpectedly.' },
  { n: '03', label: 'Concentration Risk', desc: 'Sectoral and thematic funds can sharply underperform if their focused sector falls out of favour. Diversify across categories to manage this.' },
  { n: '04', label: 'Expense Ratio', desc: 'Annual fund fees (TER) reduce net returns. Direct plans have lower TERs than regular plans — always compare before investing.' },
];

const faqs = [
  { q: 'What is the difference between Direct and Regular mutual fund plans?', a: 'Direct plans are bought from the AMC without a distributor, so the expense ratio is lower and returns are higher over time. Shriram Financial Services offers Direct Plans at zero commission.' },
  { q: 'Can I start a SIP with ₹500 per month?', a: 'Yes. Most funds allow SIPs from ₹500/month. Set up auto-debit SIPs across any fund in minutes on the Antara app.' },
  { q: 'How is mutual fund NAV calculated?', a: 'NAV = (Total Assets − Liabilities) ÷ Units Outstanding, calculated daily after market close. If you buy at ₹50 NAV and sell at ₹75, your gross return is 50% (before exit load and taxes).' },
  { q: 'What is an exit load in mutual funds?', a: 'Exit load is a redemption fee charged if you exit before the specified holding period — typically 1% for equity funds within 1 year. ELSS funds have no exit load; the 3-year lock-in applies instead.' },
  { q: 'Is mutual fund investment safe compared to fixed deposits?', a: 'Equity mutual funds carry market risk and are not capital-guaranteed like FDs. Over 5–10 years, they have historically delivered far higher inflation-adjusted returns. Debt funds carry lower risk but still have interest rate and credit risk.' },
];
---

<BaseLayout
  title="Invest in Mutual Funds India 2026 — 0% Commission Direct Plans | Shriram"
  description="Invest in mutual funds in India 2026. Browse 3,000+ direct schemes with 0% commission, SIP from ₹500, and expert research. Start mutual fund investment today."
>

  <!-- ══ 1. HERO ═══════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[var(--color-dark-800)]">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[560px] w-[560px] rounded-full bg-[var(--color-brand)]/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-32 left-0 h-80 w-80 rounded-full bg-[var(--color-brand)]/5 blur-3xl"></div>
    <div class="site-wrap relative py-[120px]">
      <p class="equity-reveal text-[14px] font-medium tracking-[.04em] text-[var(--color-brand)]">Mutual Funds</p>
      <h1 class="equity-reveal mt-[22px] max-w-[880px] text-[clamp(32px,4vw,52px)] font-bold leading-[1.06] text-white" style="font-family:var(--font-display)">
        Invest in <span class="text-[var(--color-brand)]">Mutual Funds India 2026</span> with Zero Commission
      </h1>
      <p class="equity-reveal mt-[26px] max-w-[600px] text-[18px] leading-relaxed text-white/70">
        Browse 3,000+ direct mutual fund schemes across all categories. Start a SIP from ₹500, track NAV daily, and let expert-curated research guide your selections.
      </p>
      <div class="equity-reveal mt-[38px] flex flex-wrap gap-[14px]">
        <a href="/about/open-demat-account/" class="btn-primary">Start Investing in MF</a>
        <a href="/about/support/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Talk to RM</a>
      </div>
      <div class="equity-reveal mt-[54px] flex flex-wrap gap-x-9 gap-y-3 border-t border-white/15 pt-9">
        {['✓ 0% commission (Direct Plans)', '✓ SIP from ₹500/month', '✓ 3,000+ fund schemes', '✓ SEBI-registered platform'].map(f => (
          <span class="text-[15px] font-medium text-white/90">
            <span class="mr-2 text-[var(--color-brand)]">{f.slice(0,1)}</span>{f.slice(1)}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 2. WHAT ARE MUTUAL FUNDS ══════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto grid max-w-[1000px] items-start gap-[72px] lg:grid-cols-[5fr_7fr]">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          What Are <span class="text-[var(--color-brand)]">Mutual Funds?</span>
        </h2>
        <div class="space-y-5 text-[17px] leading-relaxed text-[var(--color-muted)]">
          <p>A mutual fund pools money from thousands of investors and invests it in a diversified portfolio of stocks, bonds, or other securities — managed by a professional fund manager.</p>
          <p>In India, mutual funds are regulated by SEBI and offered by Asset Management Companies (AMCs). Every fund is classified under a SEBI-defined category, making comparison straightforward.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 3. TYPES OF MUTUAL FUNDS ══════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Types of <span class="text-[var(--color-brand)]">Mutual Funds</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">SEBI classifies mutual funds into equity, debt, hybrid, and solution-oriented categories. Each serves a different purpose in a diversified portfolio.</p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {fundTypes.map((f, i) => (
          <div class="equity-reveal product-card-light flex flex-col gap-3 p-6" style={`animation-delay:${i*40}ms`}>
            <h3 class="text-[15px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{f.label}</h3>
            <p class="text-[13px] leading-relaxed text-[var(--color-muted)]">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 4. HOW TO START ════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How to <span class="text-[var(--color-brand)]">Start Investing</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Four simple steps from account opening to your first SIP — fully digital and paperless.</p>
      </div>
      <div class="equity-reveal steps-grid overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        {steps.map(s => (
          <div class="px-[30px] py-[34px]">
            <div class="mb-[22px] font-display text-[34px] font-normal leading-none text-[var(--color-brand)]">{s.n}</div>
            <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">{s.title}</h4>
            <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 5. SIP VS LUMP SUM ════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          SIP vs <span class="text-[var(--color-brand)]">Lump Sum</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Which is right for you? Compare the two approaches across the factors that matter most.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto"><table class="w-full text-[15.5px]">
          <thead><tr class="bg-[var(--color-dark-olive)]"><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Feature</th><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">SIP</th><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Lump Sum</th></tr></thead>
          <tbody>{sipVsLumpsum.map((r,i) => (<tr class={i%2===0?'bg-white':'bg-[#f8f6f1]'}><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.feature}</td><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.sip}</td><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.lump}</td></tr>))}</tbody>
        </table></div>
      </div>
    </div>
  </section>

  <!-- ══ 6. TAXATION ════════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Tax on <span class="text-[var(--color-brand)]">Mutual Fund Returns</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">How short-term and long-term capital gains are treated for equity and debt fund investors.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto"><table class="w-full text-[15.5px]">
          <thead><tr class="bg-[var(--color-dark-olive)]"><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Feature</th><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Short Term (STCG)</th><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Long Term (LTCG)</th></tr></thead>
          <tbody>{taxRows.map((r,i) => (<tr class={i%2===0?'bg-white':'bg-[#f8f6f1]'}><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.feature}</td><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.stcg}</td><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.ltcg}</td></tr>))}</tbody>
        </table></div>
      </div>
    </div>
  </section>

  <!-- ══ 7. RISKS ════════════════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Risks of <span class="text-[var(--color-brand)]">Mutual Fund Investing</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Understand what can move against you before you commit capital.</p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {risks.map(r => (
          <div class="equity-reveal rounded-[18px] bg-[var(--color-dark-800)] p-[36px]">
            <div class="mb-[18px] text-[48px] font-bold leading-none text-[var(--color-brand)]/25">{r.n}</div>
            <h4 class="mb-3 text-[20px] font-medium text-white" style="font-family:var(--font-display)">{r.label}</h4>
            <p class="text-[14.5px] leading-relaxed text-white/60">{r.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 7b. SIP / SWP / STP / LUMP SUM COMPARISON ══════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          SIP, SWP, STP &amp; <span class="text-[var(--color-brand)]">Lump Sum — What's the Difference?</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Four investment modes — each suited to a different goal, income pattern, or market condition.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Feature</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">SIP</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">SWP</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">STP</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Lump Sum</th>
              </tr>
            </thead>
            <tbody>
              {[
                { label: 'Meaning', sip: 'Invest fixed amount regularly', swp: 'Withdraw fixed amount regularly', stp: 'Transfer between funds periodically', lump: 'One-time full investment' },
                { label: 'Who It Suits', sip: 'Salaried investors', swp: 'Retirees seeking income', stp: 'Investors shifting from debt to equity', lump: 'Investors with surplus capital' },
                { label: 'Min. Amount', sip: '₹500/month', swp: 'Usually ₹500/withdrawal', stp: '₹500/transfer', lump: '₹1,000 one time' },
                { label: 'Market Timing Risk', sip: 'Low (averaged entry)', swp: 'Moderate (NAV at redemption)', stp: 'Low (phased shift)', lump: 'High (single entry point)' },
                { label: 'Best Market Condition', sip: 'Volatile or rising', swp: 'Any (steady income need)', stp: 'After lump sum idle in liquid fund', lump: 'Low market or confident bull view' },
              ].map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.label}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.sip}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.swp}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.stp}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.lump}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 7c. BEST MUTUAL FUNDS INDIA 2026 ══════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Best Mutual Funds in <span class="text-[var(--color-brand)]">India 2026</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Indicative category-wise performance. Past returns are not a guarantee of future performance. Consult your RM for personalised fund selection.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Category</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Example Fund Type</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">1Y Returns*</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">3Y Returns*</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">5Y Returns*</th>
              </tr>
            </thead>
            <tbody>
              {[
                { cat: 'Large Cap Equity', type: 'Nifty 50 Index / Large Cap', y1: '12–16%', y3: '14–18%', y5: '13–17%' },
                { cat: 'Flexi Cap Equity', type: 'Flexi Cap / Multi Cap', y1: '14–20%', y3: '15–20%', y5: '15–19%' },
                { cat: 'ELSS (Tax Saving)', type: 'Equity Linked Saving Scheme', y1: '14–18%', y3: '14–19%', y5: '14–18%' },
                { cat: 'Hybrid / Balanced', type: 'Balanced Advantage Fund', y1: '9–13%', y3: '10–14%', y5: '10–14%' },
                { cat: 'Short Duration Debt', type: 'Short Duration Debt Fund', y1: '6–8%', y3: '6–7.5%', y5: '6–7%' },
                { cat: 'Liquid Fund', type: 'Liquid / Overnight Fund', y1: '6.5–7%', y3: '6–6.5%', y5: '5.5–6%' },
              ].map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.cat}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.type}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-medium text-[var(--color-dark-olive)]">{r.y1}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-medium text-[var(--color-dark-olive)]">{r.y3}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-medium text-[var(--color-dark-olive)]">{r.y5}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
      <p class="mt-4 text-center text-[13px] text-[var(--color-muted)]">*Indicative category range. Actual fund returns vary. Source: AMFI / NAV data. Not investment advice.</p>
    </div>
  </section>

  <!-- ══ 7d. MUTUAL FUND CALCULATORS ════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Mutual Fund <span class="text-[var(--color-brand)]">Calculators</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Plan your investments with our free calculators — estimate SIP corpus, lump sum growth, and SWP withdrawals.</p>
      </div>
      <div class="equity-reveal grid gap-5 sm:grid-cols-3">
        {[
          { title: 'SIP Calculator', desc: 'Estimate the future value of your monthly SIP investments over 5, 10, or 20 years at expected returns.', href: '/calculators/sip/', cta: 'Calculate SIP Returns' },
