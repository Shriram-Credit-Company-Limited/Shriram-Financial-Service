    .risk{flex:1 1 100%}
  }
  @media(prefers-reduced-motion:reduce){
    .faq-v{transition:none}
  }
</style>

<script>
  /* FAQ accordion — one open at a time */
  document.querySelectorAll('.faq-acc').forEach(function(acc) {
    acc.querySelectorAll('details').forEach(function(d) {
      d.addEventListener('toggle', function() {
        if ((d as HTMLDetailsElement).open) {
          acc.querySelectorAll<HTMLDetailsElement>('details').forEach(function(other) {
            if (other !== d) other.removeAttribute('open');
          });
        }
      });
    });
  });
</script>
