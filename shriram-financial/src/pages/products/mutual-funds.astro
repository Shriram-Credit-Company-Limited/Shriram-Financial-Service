---
import BaseLayout from '../../layouts/BaseLayout.astro';

const fundTypes = [
  { label: 'Equity Funds', desc: 'Invest primarily in stocks. Best for long-term wealth creation over 5+ years. Include large-cap, mid-cap, small-cap, and flexi-cap variants.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6"><path d="M3 3v18h18"/><path d="m7 12 4-4 4 4 4-4"/></svg>` },
  { label: 'Debt Funds', desc: 'Invest in bonds, government securities, and money market instruments. Lower risk, stable returns. Suitable for 1–3 year horizons.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M8 9h8M8 13h5"/></svg>` },
  { label: 'Hybrid Funds', desc: 'Blend of equity and debt. Balanced advantage funds adjust the ratio dynamically based on market valuations.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6"><circle cx="12" cy="12" r="9"/><path d="M12 3v9l6 3"/></svg>` },
  { label: 'Index Funds', desc: 'Passively track a benchmark index (NIFTY 50, SENSEX). Very low expense ratios. No fund manager risk.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6"><path d="M3 3v18h18"/><path d="m7 16 4-4 4 4 4-4"/></svg>` },
  { label: 'ELSS (Tax Saving)', desc: 'Equity Linked Saving Scheme with 3-year lock-in. Eligible for ₹1.5 lakh deduction under Section 80C with highest return potential among 80C options.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 1 0 0 7h5a3.5 3.5 0 1 1 0 7H6"/></svg>` },
  { label: 'Liquid Funds', desc: 'Invest in instruments with up to 91-day maturity. Ideal for parking surplus cash. Better returns than savings accounts with same-day redemption.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 0v10m0 0l5 3m-5-3l-5 3"/></svg>` },
  { label: 'Sectoral / Thematic', desc: 'Focus on specific sectors (IT, pharma, banking) or themes (ESG, consumption). Higher concentration risk but strong outperformance in bull cycles.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>` },
  { label: 'International Funds', desc: 'Invest in global markets (US, China, Europe) through funds-of-funds. Portfolio diversification across geographies and currencies.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6"><circle cx="12" cy="12" r="9"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>` },
];

const sipVsLumpsum = [
  { feature: 'Timing Risk', sip: 'Low — averages market entry (rupee cost averaging)', lump: 'High — market timing matters significantly' },
  { feature: 'Capital Required', sip: 'As low as ₹500/month', lump: 'Typically ₹1,000 or more at once' },
  { feature: 'Discipline', sip: 'High — automated regular investing', lump: 'Requires manual decision for each investment' },
  { feature: 'Best For', sip: 'Salaried investors with regular income', lump: 'Investors with idle surplus (bonuses, FD maturity)' },
  { feature: 'Returns in Bull Market', sip: 'Moderate — gradual entry misses early rally', lump: 'High — full exposure from day one' },
  { feature: 'Returns in Bear Market', sip: 'Better — lower average cost from dips', lump: 'Lower — exposed to full downside immediately' },
];

const taxRows = [
  { feature: 'Holding Period (Equity MF)', stcg: 'Up to 12 months', ltcg: 'More than 12 months' },
  { feature: 'Tax Rate (Equity MF)', stcg: '20% flat', ltcg: '12.5% (above ₹1.25 lakh exemption)' },
  { feature: 'Holding Period (Debt MF)', stcg: 'Up to 24 months', ltcg: 'More than 24 months' },
  { feature: 'Tax Rate (Debt MF)', stcg: 'As per income tax slab', ltcg: 'As per income tax slab (no indexation from Apr 2023)' },
];

const steps = [
  { n: '01', title: 'Open a Demat Account', desc: 'A Demat account is needed to invest in direct mutual funds. Open one with Shriram in under 10 minutes — paperless KYC.' },
  { n: '02', title: 'Complete KYC', desc: 'One-time KYC using Aadhaar OTP on the SEBI-registered platform. Required for all mutual fund investments in India.' },
  { n: '03', title: 'Choose Your Fund', desc: 'Use Shriram\'s fund comparison and screener tools to select the right fund based on your goal, risk profile, and time horizon.' },
  { n: '04', title: 'Invest via SIP or Lump Sum', desc: 'Start a SIP with as little as ₹500/month or invest a lump sum. Track NAV, returns, and portfolio health on the Antara app.' },
];

const risks = [
  { label: 'Market Risk', desc: 'Equity mutual funds are subject to market risk. NAVs can fall when the broader market declines, especially in the short term.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6"><path d="m3 3 18 18M3 12c0 5 3.6 9 9 9s9-4 9-9"/><path d="M12 3a9 9 0 0 1 9 9"/></svg>` },
  { label: 'Fund Manager Risk', desc: 'Actively managed funds depend on fund manager decisions. A change in fund manager or strategy can impact returns unpredictably.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>` },
  { label: 'Concentration Risk', desc: 'Sectoral and thematic funds with concentrated exposures can significantly underperform if that sector or theme falls out of favour.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6"><circle cx="12" cy="12" r="9"/><path d="M12 8v4M12 16h.01"/></svg>` },
  { label: 'Expense Ratio', desc: 'Annual fund management fees (TER) reduce your net returns. Direct plans have lower TERs than regular plans. Always compare expense ratios before investing.', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-6 w-6"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 1 0 0 7h5a3.5 3.5 0 1 1 0 7H6"/></svg>` },
];

const faqs = [
  { q: 'What is the difference between Direct and Regular mutual fund plans?', a: 'Direct plans are bought directly from the AMC (no distributor). Regular plans are bought through a distributor/agent who earns a commission from the AMC — this is embedded in the expense ratio. Direct plans have lower expense ratios and therefore higher returns over time. Shriram Financial Services offers Direct Plans with zero commission.' },
  { q: 'Can I start a SIP with ₹500 per month?', a: 'Yes. Most mutual funds allow SIPs starting from ₹500 per month. Some funds like small-cap and international funds may have higher minimums. With Shriram\'s platform, you can set up auto-debit SIPs across any fund with a few taps on the Antara app.' },
  { q: 'How is mutual fund NAV calculated?', a: 'NAV (Net Asset Value) is calculated daily after market close: NAV = (Total Assets - Liabilities) / Number of Units Outstanding. When you buy a mutual fund at NAV ₹50 and sell when NAV is ₹75, your return is 50% (excluding exit load and taxes).' },
  { q: 'What is an exit load in mutual funds?', a: 'Exit load is a fee charged when you redeem units before a specified holding period. Most equity funds charge 1% exit load if redeemed within 1 year of purchase. Liquid funds have a graded exit load for the first 7 days. ELSS funds have no exit load (3-year mandatory lock-in instead).' },
  { q: 'Is mutual fund investment safe compared to fixed deposits?', a: 'Mutual funds (especially equity funds) carry market risk and are not capital-guaranteed like bank FDs. However, over 5–10 year periods, equity mutual funds have historically delivered significantly higher inflation-adjusted returns than FDs. Debt mutual funds carry lower risk than equity funds but still have interest rate and credit risk.' },
];
---

<BaseLayout
  title="Mutual Funds — Invest in Direct Plans with Zero Commission | Shriram Financial Services"
  description="Invest in 3,000+ direct mutual fund schemes with zero commission, SIP starting ₹500, and expert research from Shriram Financial Services."
>

  <section class="relative overflow-hidden bg-[var(--color-dark-800)]">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[560px] w-[560px] rounded-full bg-[var(--color-brand)]/10 blur-3xl"></div>
    <div class="site-wrap relative py-16 lg:py-28">
      <p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-brand)]">Mutual Funds</p>
      <h1 class="mt-4 max-w-3xl text-[32px] font-bold leading-tight text-white lg:text-[40px]" style="font-family:var(--font-display)">
        Invest in Mutual Funds<br class="hidden sm:block"> with Zero Commission
      </h1>
      <p class="mt-5 max-w-2xl text-[15px] leading-relaxed text-white/60 lg:text-[17px]">
        Browse 3,000+ direct mutual fund schemes across all categories. Start a SIP from ₹500, track NAV daily, and let expert-curated research guide your selections.
      </p>
      <div class="mt-7 grid grid-cols-2 gap-x-6 gap-y-3 sm:flex sm:gap-8">
        {[['0% commission (Direct Plans)'],['SIP from ₹500/month'],['3,000+ fund schemes'],['SEBI-registered platform']].map(([l]) => (<div class="flex items-center gap-2 text-[13px] font-medium text-white/70"><span class="h-1.5 w-1.5 rounded-full bg-[var(--color-brand)]"></span>{l}</div>))}
      </div>
      <div class="mt-9 flex flex-wrap gap-3">
        <a href="/about/open-demat-account/" class="btn-primary">Start Investing in MF</a>
        <a href="/about/support/" class="inline-flex h-12 w-[220px] items-center justify-center rounded-[6px] border border-white/25 text-[14px] font-medium text-white transition-colors hover:bg-white/10">Talk to RM</a>
      </div>
    </div>
  </section>

  <section class="bg-white py-16 lg:py-24">
    <div class="site-wrap">
      <div class="equity-reveal">
        <p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-brand)]">Fund Categories</p>
        <h2 class="mt-3 text-[28px] font-bold text-[var(--color-ink)] lg:text-[38px]" style="font-family:var(--font-display)">Types of Mutual Funds</h2>
        <p class="mt-4 max-w-3xl text-[15px] text-[var(--color-muted)]">SEBI classifies mutual funds into equity, debt, hybrid, and solution-oriented categories. Each serves a different purpose in a diversified portfolio.</p>
      </div>
      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {fundTypes.map((f, i) => (<div class="equity-reveal product-card-light flex flex-col gap-3 p-6" style={`animation-delay:${i*40}ms`}><div class="flex h-11 w-11 items-center justify-center rounded-[10px] bg-[var(--color-dark-olive)] text-[var(--color-brand)]" set:html={f.icon} /><h3 class="text-[15px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{f.label}</h3><p class="text-[13px] leading-relaxed text-[var(--color-muted)]">{f.desc}</p></div>))}
      </div>
    </div>
  </section>

  <section class="bg-[#f8f6f1] py-16 lg:py-24">
    <div class="site-wrap">
      <div class="equity-reveal text-center">
        <p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-brand)]">Getting Started</p>
        <h2 class="mt-3 text-[28px] font-bold text-[var(--color-ink)] lg:text-[38px]" style="font-family:var(--font-display)">How to Start Investing in Mutual Funds</h2>
      </div>
      <div class="equity-reveal mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {steps.map((s, i) => (<div class="relative rounded-[20px] border border-[var(--color-warm-border)] bg-white p-7" style={`animation-delay:${i*60}ms`}><span class="flex h-10 w-10 items-center justify-center rounded-full bg-[var(--color-dark-olive)] text-[13px] font-bold text-[var(--color-brand)]">{s.n}</span>{i < steps.length - 1 && <span class="absolute -right-3 top-9 hidden lg:flex"><svg viewBox="0 0 12 12" fill="none" stroke="var(--color-brand)" stroke-width="2" class="h-3 w-3"><path d="M2 6h8M6 2l4 4-4 4"/></svg></span>}<h3 class="mt-4 text-[15px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{s.title}</h3><p class="mt-2 text-[13px] leading-relaxed text-[var(--color-muted)]">{s.desc}</p></div>))}
      </div>
    </div>
  </section>

  <section class="bg-white py-16 lg:py-24">
    <div class="site-wrap">
      <div class="equity-reveal">
        <p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-brand)]">Strategy</p>
        <h2 class="mt-3 text-[28px] font-bold text-[var(--color-ink)] lg:text-[38px]" style="font-family:var(--font-display)">SIP vs Lump Sum — Which Is Right for You?</h2>
      </div>
      <div class="equity-reveal mt-10 overflow-hidden rounded-[20px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto"><table class="w-full text-[14px]">
          <thead><tr class="bg-[var(--color-dark-olive)]"><th class="px-6 py-4 text-left text-[12px] font-semibold uppercase tracking-wide text-white/70">Feature</th><th class="px-6 py-4 text-left text-[12px] font-semibold uppercase tracking-wide text-[var(--color-brand)]">SIP</th><th class="px-6 py-4 text-left text-[12px] font-semibold uppercase tracking-wide text-[var(--color-brand)]">Lump Sum</th></tr></thead>
          <tbody class="divide-y divide-[var(--color-n400)]">{sipVsLumpsum.map((r,i) => (<tr class={i%2===0?'bg-white':'bg-[#f8f6f1]'}><td class="px-6 py-4 font-semibold text-[var(--color-ink)]">{r.feature}</td><td class="px-6 py-4 text-[var(--color-muted)]">{r.sip}</td><td class="px-6 py-4 text-[var(--color-muted)]">{r.lump}</td></tr>))}</tbody>
        </table></div>
      </div>
    </div>
  </section>

  <section class="bg-[#f8f6f1] py-16 lg:py-24">
    <div class="site-wrap">
      <div class="equity-reveal">
        <p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-brand)]">Taxation</p>
        <h2 class="mt-3 text-[28px] font-bold text-[var(--color-ink)] lg:text-[38px]" style="font-family:var(--font-display)">Tax on Mutual Fund Returns</h2>
      </div>
      <div class="equity-reveal mt-10 overflow-hidden rounded-[20px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto"><table class="w-full text-[14px]">
          <thead><tr class="bg-[var(--color-dark-olive)]"><th class="px-6 py-4 text-left text-[12px] font-semibold uppercase tracking-wide text-white/70">Feature</th><th class="px-6 py-4 text-left text-[12px] font-semibold uppercase tracking-wide text-[var(--color-brand)]">Short Term (STCG)</th><th class="px-6 py-4 text-left text-[12px] font-semibold uppercase tracking-wide text-[var(--color-brand)]">Long Term (LTCG)</th></tr></thead>
          <tbody class="divide-y divide-[var(--color-n400)]">{taxRows.map((r,i) => (<tr class={i%2===0?'bg-white':'bg-[#f8f6f1]'}><td class="px-6 py-4 font-semibold text-[var(--color-ink)]">{r.feature}</td><td class="px-6 py-4 text-[var(--color-muted)]">{r.stcg}</td><td class="px-6 py-4 text-[var(--color-muted)]">{r.ltcg}</td></tr>))}</tbody>
        </table></div>
      </div>
    </div>
  </section>

  <section class="bg-white py-16 lg:py-24">
    <div class="site-wrap">
      <div class="equity-reveal"><p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-brand)]">Know Before You Invest</p><h2 class="mt-3 text-[28px] font-bold text-[var(--color-ink)] lg:text-[38px]" style="font-family:var(--font-display)">Risks of Mutual Fund Investing</h2></div>
      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {risks.map((r, i) => (<div class="equity-reveal product-card-light flex flex-col gap-4 p-7" style={`animation-delay:${i*60}ms`}><div class="flex h-12 w-12 items-center justify-center rounded-[12px] bg-[#fef4e6] text-[var(--color-brand-deep)]" set:html={r.icon} /><h3 class="text-[16px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{r.label}</h3><p class="text-[13px] leading-relaxed text-[var(--color-muted)]">{r.desc}</p></div>))}
      </div>
    </div>
  </section>

  <section class="bg-[#f8f6f1] py-16 lg:py-24">
    <div class="site-wrap">
      <div class="equity-reveal"><p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-brand)]">FAQ</p><h2 class="mt-3 text-[28px] font-bold text-[var(--color-ink)] lg:text-[38px]" style="font-family:var(--font-display)">Frequently Asked Questions</h2></div>
      <div class="equity-reveal mt-10 divide-y divide-[var(--color-n400)] overflow-hidden rounded-[24px] border border-[var(--color-n400)] bg-white">
        {faqs.map(item => (<details class="eq-faq group"><summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5 hover:bg-[var(--color-n100)]"><span class="text-[15px] font-medium text-[var(--color-ink)]">{item.q}</span><span class="grid h-7 w-7 shrink-0 place-items-center rounded-full border border-[var(--color-n400)] transition-transform group-open:rotate-45"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" class="h-3 w-3"><path d="M6 2v8M2 6h8"/></svg></span></summary><div class="border-t border-[var(--color-n400)] bg-[var(--color-n100)] px-6 py-5"><p class="text-[14px] leading-relaxed text-[var(--color-muted)]">{item.a}</p></div></details>))}
      </div>
    </div>
  </section>

  <section class="bg-[var(--color-dark-800)] py-16 lg:py-20">
    <div class="site-wrap">
      <div class="equity-reveal flex flex-col items-center gap-6 text-center lg:flex-row lg:items-center lg:justify-between lg:text-left">
        <div>
          <h2 class="text-[28px] font-bold text-white lg:text-[36px]" style="font-family:var(--font-display)">Start Your Mutual Fund Journey Today</h2>
          <p class="mt-3 max-w-lg text-[15px] text-white/55">Open a free Demat account and invest in 3,000+ direct mutual funds with zero commission and expert advisory guidance.</p>
        </div>
        <div class="flex shrink-0 flex-col gap-3 sm:flex-row">
          <a href="/about/open-demat-account/" class="inline-flex h-12 w-[220px] items-center justify-center rounded-[6px] bg-[var(--color-brand)] text-[14px] font-semibold text-[#202318] hover:bg-[var(--color-brand-hover)]">Start Investing →</a>
          <a href="/about/support/" class="inline-flex h-12 w-[220px] items-center justify-center rounded-[6px] border border-white/20 text-[14px] font-medium text-white hover:bg-white/10">Talk to an RM</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .equity-reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.65s cubic-bezier(0.22,1,0.36,1), transform 0.65s cubic-bezier(0.22,1,0.36,1); }
  .equity-reveal.in-view { opacity: 1; transform: translateY(0); }
</style>
<script>
  const obs = new IntersectionObserver(entries => { entries.forEach(e => { if (e.isIntersecting) { const el = e.target as HTMLElement; setTimeout(() => el.classList.add('in-view'), parseInt(el.style.animationDelay)||0); obs.unobserve(el); } }); }, { threshold: 0.10 });
  document.querySelectorAll('.equity-reveal').forEach(el => obs.observe(el));
  document.querySelectorAll<HTMLDetailsElement>('.eq-faq').forEach(d => { d.addEventListener('toggle', () => { if (d.open) document.querySelectorAll<HTMLDetailsElement>('.eq-faq').forEach(o => { if (o !== d) o.removeAttribute('open'); }); }); });
</script>
