  .rb-4{background:#f97316;color:#fff}
  .rb-5{background:#dc2626;color:#fff}
  .risk-funds{display:grid;grid-template-columns:repeat(5,1fr);background:var(--card)}
  .rf{border-right:1px solid var(--card-border);padding:14px 12px;text-align:center;font-size:13px;color:var(--ink-3);line-height:1.4}
  .rf:last-child{border-right:0}

  /* Risk cards */
  .risks{display:flex;gap:24px;align-items:stretch}
