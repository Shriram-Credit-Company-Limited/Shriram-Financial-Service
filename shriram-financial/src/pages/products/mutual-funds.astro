---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Mutual Funds India — Invest Online, 0% Commission | Shriram"
  description="Invest in mutual funds India with 0% commission. Best mutual funds 2026, SIP from ₹500, direct plans, ELSS tax saving. Start online with Shriram Financial Services."
>

  <!-- ══ S1 HERO ════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[var(--color-dark-800)] py-[100px] lg:py-[120px]">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[560px] w-[560px] rounded-full bg-[var(--color-brand)]/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-32 left-0 h-80 w-80 rounded-full bg-[var(--color-brand)]/5 blur-3xl"></div>
    <div class="site-wrap relative">
      <h1 class="equity-reveal mt-0 max-w-[880px] text-[clamp(32px,4vw,52px)] font-bold leading-[1.06] text-white" style="font-family:var(--font-display)">
        Invest in <span class="text-[var(--color-brand)]">Mutual Funds</span> — 0% Commission, Direct Plans
      </h1>
      <p class="equity-reveal mt-[26px] max-w-[600px] text-[18px] leading-relaxed text-white/70">
        5,000+ mutual fund schemes. SIP from ₹500. Direct plans with zero commission. SEBI-registered and AMFI-compliant. Start in 5 minutes — completely paperless.
      </p>
      <div class="equity-reveal mt-[38px] flex flex-wrap gap-[14px]">
        <a href="/about/open-demat-account/" class="btn-primary">Invest Now</a>
        <a href="/about/open-demat-account/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Start SIP</a>
      </div>
      <div class="equity-reveal mt-[54px] flex flex-wrap gap-x-9 gap-y-3 border-t border-white/15 pt-9">
        {['✓ 0% commission', '✓ Direct plans', '✓ 5,000+ funds', '✓ SEBI-registered & AMFI-compliant'].map(f => (
          <span class="text-[15px] font-medium text-white/90">{f}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S2 WHAT ARE MUTUAL FUNDS ══════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          What Are <span class="text-[var(--color-brand)]">Mutual Funds?</span> — Definition &amp; How They Work
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">
          A mutual fund pools money from multiple investors and invests in a diversified portfolio of stocks, bonds, or other securities — managed by a professional fund manager regulated by SEBI. Every rupee you invest is managed by an AMFI-registered Asset Management Company (AMC) under strict SEBI disclosure norms.
        </p>
        <p class="mt-[14px] text-[17px] leading-relaxed text-[var(--color-muted)]">
          Every rupee you invest buys units at the current NAV (Net Asset Value). Your returns reflect how the underlying portfolio performs — and with direct plans at zero commission, more of your returns stay with you.
        </p>
      </div>
      <div class="grid gap-5 sm:grid-cols-3">
        <div class="equity-reveal product-card-light px-[28px] py-[32px]">
          <h3 class="text-[26px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">Pooled Investment</h3>
          <p class="mt-[12px] text-[15px] leading-relaxed text-[var(--color-muted)]">Thousands of investors pool capital, giving each access to a diversified portfolio they couldn't build alone.</p>
        </div>
        <div class="equity-reveal product-card-light px-[28px] py-[32px]">
          <h3 class="text-[26px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">Professional Management</h3>
          <p class="mt-[12px] text-[15px] leading-relaxed text-[var(--color-muted)]">A SEBI-registered fund manager makes buy/sell decisions based on the fund's stated investment objective.</p>
        </div>
        <div class="equity-reveal product-card-light px-[28px] py-[32px]">
          <h3 class="text-[26px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">SEBI-regulated</h3>
          <p class="mt-[12px] text-[15px] leading-relaxed text-[var(--color-muted)]">All mutual funds in India are regulated by SEBI and offered by AMFI-registered AMCs under strict disclosure norms.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S3 HOW MUTUAL FUNDS WORK ══════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How <span class="text-[var(--color-brand)]">Mutual Funds Work</span> — NAV, AUM &amp; Fund Manager
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Understanding three core concepts helps you make better mutual fund investment decisions.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Term</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Meaning</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Why It Matters</th>
              </tr>
            </thead>
            <tbody>
              <tr class="bg-white">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">NAV</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Net Asset Value = portfolio value ÷ total units</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Your buy/sell price per unit, calculated daily</td>
              </tr>
              <tr class="bg-[#f8f6f1]">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">AUM</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Total assets under management by the fund</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Larger AUM = more stability in large-cap funds</td>
              </tr>
              <tr class="bg-white">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">Fund Manager</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Professional managing your money</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Track record, tenure, and investment style matter</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S4 TYPES OF MUTUAL FUNDS ══════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Types of <span class="text-[var(--color-brand)]">Mutual Funds</span> in India — SEBI Categories
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">SEBI classifies mutual funds into clear categories. Choose based on your financial goal, investment horizon, and risk tolerance.</p>
      </div>
      <div class="equity-reveal cat-grid">
        <div class="equity-reveal product-card-light px-[28px] py-[32px]">
          <h3 class="text-[26px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">Equity Funds</h3>
          <p class="mt-[12px] text-[15px] leading-relaxed text-[var(--color-muted)]">Invest primarily in stocks. 5+ year horizon. Highest return potential — large-cap, mid-cap, small-cap, and flexi-cap options.</p>
        </div>
        <div class="product-card-light px-[28px] py-[32px]">
          <h3 class="text-[26px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">Debt Funds</h3>
          <p class="mt-[12px] text-[15px] leading-relaxed text-[var(--color-muted)]">Invest in bonds, G-Secs, and money market instruments. 1–3 year horizon. Lower risk, stable returns — better post-tax than FD for higher tax brackets.</p>
        </div>
        <div class="product-card-light px-[28px] py-[32px]">
          <h3 class="text-[26px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">Hybrid Funds</h3>
          <p class="mt-[12px] text-[15px] leading-relaxed text-[var(--color-muted)]">Mix of equity and debt — balanced risk-return. Balanced Advantage Funds dynamically adjust allocation based on market valuations.</p>
        </div>
        <div class="product-card-light px-[28px] py-[32px]">
          <h3 class="text-[26px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">Index Funds</h3>
          <p class="mt-[12px] text-[15px] leading-relaxed text-[var(--color-muted)]">Passively track Nifty 50, Sensex, or other indices. Expense ratios as low as 0.1%. Outperform most active large-cap funds over 10+ years.</p>
        </div>
        <div class="product-card-light px-[28px] py-[32px]">
          <h3 class="text-[26px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">ELSS (Tax Saving)</h3>
          <p class="mt-[12px] text-[15px] leading-relaxed text-[var(--color-muted)]">3-year lock-in. Invest up to ₹1.5L per year and claim deduction under Section 80C. Shortest lock-in among all 80C instruments.</p>
        </div>
        <div class="product-card-light px-[28px] py-[32px]">
          <h3 class="text-[26px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">Liquid Funds</h3>
          <p class="mt-[12px] text-[15px] leading-relaxed text-[var(--color-muted)]">Invest in instruments maturing within 91 days. Park idle cash earning 6–7% p.a. with same-day or T+1 redemption — better than a savings account.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S5 SIP ═════════════════════════════════════════════════════  -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          <span class="text-[var(--color-brand)]">SIP Investment</span> — Systematic Investment Plan
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">SIP invests a fixed amount every month, automatically averaging your purchase price across market cycles — eliminating the need to time the market.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Feature</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">SIP</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Lump Sum</th>
              </tr>
            </thead>
            <tbody>
              <tr class="bg-white">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">Timing Risk</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Low — averages entry price</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">High — market timing critical</td>
              </tr>
              <tr class="bg-[#f8f6f1]">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">Min Investment</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">₹500/month</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">₹1,000 one-time</td>
              </tr>
              <tr class="bg-white">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">Discipline</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Auto-debit = automatic</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Manual decision each time</td>
              </tr>
              <tr class="bg-[#f8f6f1]">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">Best For</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Salaried investors</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Bonus / idle surplus</td>
              </tr>
              <tr class="bg-white">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">Bear Market</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Better returns — lower avg cost</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Full downside exposure</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
      <div class="equity-reveal mt-[40px] text-center">
        <a href="/calculators/sip/" class="btn-primary">Calculate SIP Returns →</a>
      </div>
    </div>
  </section>

  <!-- ══ S6 SWP, STP & LUMP SUM ════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          SWP, STP &amp; <span class="text-[var(--color-brand)]">Lump Sum</span> — Other Investment Modes
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Different investment modes suit different financial goals and life stages. Understanding when to use each maximises your wealth-building efficiency.</p>
      </div>
      <div class="grid gap-5 sm:grid-cols-3">
        <div class="equity-reveal product-card-light px-[28px] py-[32px]">
          <h3 class="text-[26px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">SWP</h3>
          <p class="mt-[4px] text-[13px] font-semibold text-[var(--color-brand)]">Systematic Withdrawal Plan</p>
          <p class="mt-[12px] text-[15px] leading-relaxed text-[var(--color-muted)]">Withdraw fixed amount monthly from your fund. Ideal for retirement income.</p>
        </div>
        <div class="equity-reveal product-card-light px-[28px] py-[32px]">
          <h3 class="text-[26px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">STP</h3>
          <p class="mt-[4px] text-[13px] font-semibold text-[var(--color-brand)]">Systematic Transfer Plan</p>
          <p class="mt-[12px] text-[15px] leading-relaxed text-[var(--color-muted)]">Transfer monthly from a liquid fund to equity. Reduces lump-sum timing risk.</p>
        </div>
        <div class="equity-reveal product-card-light px-[28px] py-[32px]">
          <h3 class="text-[26px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">Lump Sum</h3>
          <p class="mt-[4px] text-[13px] font-semibold text-[var(--color-brand)]">One-Time Investment</p>
          <p class="mt-[12px] text-[15px] leading-relaxed text-[var(--color-muted)]">One-time large investment. Best when markets are down or you have surplus cash.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S7 BEST MUTUAL FUNDS 2026 ══════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Best <span class="text-[var(--color-brand)]">Mutual Funds</span> in India 2026
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Top-performing funds by category — indicative 3-year and 5-year CAGR ranges. Past performance is not a guarantee of future returns. Consult a financial advisor before investing.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Category</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Fund Type</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">3Y CAGR (approx)</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">5Y CAGR (approx)</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Risk</th>
              </tr>
            </thead>
            <tbody>
              <tr class="bg-white">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">Large Cap</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Nifty 50 Index Fund</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">12–15%</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">13–16%</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Moderate</td>
              </tr>
              <tr class="bg-[#f8f6f1]">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">Mid Cap</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Active Mid Cap Fund</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">18–22%</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">20–25%</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">High</td>
              </tr>
              <tr class="bg-white">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">Small Cap</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Active Small Cap Fund</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">20–28%</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">22–30%</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Very High</td>
              </tr>
              <tr class="bg-[#f8f6f1]">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">Hybrid</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Balanced Advantage Fund</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">10–14%</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">12–15%</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Moderate</td>
              </tr>
              <tr class="bg-white">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">ELSS</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">ELSS Tax Saver Fund</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">14–18%</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">15–20%</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">High</td>
              </tr>
              <tr class="bg-[#f8f6f1]">
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">Debt</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">Short Duration Debt Fund</td>
                <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">6–8%</td>
