---
import BaseLayout from '../../layouts/BaseLayout.astro';

const fdTypes = [
  { label: 'Regular Fixed Deposit', desc: 'Guaranteed interest on a lump-sum investment for a fixed tenure. Choose cumulative (interest at maturity) or non-cumulative (monthly/quarterly payouts).', tag: 'Most Popular' },
  { label: 'Tax-Saving FD (ELSS FD)', desc: '5-year lock-in FD eligible for ₹1.5 lakh deduction under Section 80C. Interest is taxable; no premature withdrawal allowed during the lock-in.', tag: '80C Eligible' },
  { label: 'Senior Citizen FD', desc: 'Extra 0.25%–0.50% interest rate for investors aged 60+. Ideal for generating regular post-retirement income.', tag: 'Age 60+' },
  { label: 'Corporate FD', desc: 'NBFCs like Shriram Finance offer 0.5%–1.5% higher rates than bank FDs. Rated by CRISIL/ICRA — higher yield with assessed credit quality.', tag: 'Higher Yields' },
];

const rateRows = [
  { tenure: '7 – 45 days', general: '3.50%', senior: '4.00%' },
  { tenure: '46 – 179 days', general: '5.50%', senior: '6.00%' },
  { tenure: '180 – 364 days', general: '6.25%', senior: '6.75%' },
  { tenure: '1 – 2 years', general: '7.00%', senior: '7.50%' },
  { tenure: '2 – 3 years', general: '7.15%', senior: '7.65%' },
  { tenure: '3 – 5 years', general: '7.25%', senior: '7.75%' },
  { tenure: 'Above 5 years', general: '7.00%', senior: '7.50%' },
];

const vsRows = [
  { feature: 'Returns', fd: '6.5%–8% p.a. (guaranteed)', equity: '10%–15% (historical, not guaranteed)', mf: '7%–12% (varies by fund type)' },
  { feature: 'Risk', fd: 'Very low (guaranteed capital)', equity: 'High (market-linked)', mf: 'Low to High (depends on fund)' },
  { feature: 'Liquidity', fd: 'Low (premature withdrawal penalty)', equity: 'High (same-day)', mf: 'Medium (T+1 to T+3)' },
  { feature: 'Tax Efficiency', fd: 'Low (TDS on interest)', equity: '12.5% LTCG after ₹1.25L', mf: 'Varies by fund type' },
  { feature: 'Best For', fd: 'Capital protection, regular income', equity: 'Long-term wealth creation', mf: 'Goal-based diversified investing' },
];

const steps = [
  { n: '01', title: 'Choose FD Type & Issuer', desc: 'Select between bank FD, NBFC FD, or corporate FD based on your risk tolerance, tenure, and required interest rate.' },
  { n: '02', title: 'Select Tenure & Payout', desc: 'Choose tenure from 7 days to 10 years. Select cumulative (interest at maturity) or non-cumulative (monthly/quarterly payouts).' },
  { n: '03', title: 'Submit KYC & Apply', desc: 'Submit PAN, Aadhaar, and bank details digitally on the Shriram platform. Application is reviewed and approved in 1–2 days.' },
  { n: '04', title: 'Receive FD Certificate', desc: 'Your FD receipt is issued digitally. Track maturity dates, interest accrual, and renewal options from the Antara app.' },
];

const faqs = [
  { q: 'Is FD interest taxable?', a: 'Yes. Interest is taxed per your slab. TDS at 10% is deducted if annual interest exceeds ₹40,000 (₹50,000 for senior citizens). Submit Form 15G or 15H if your income is below the taxable threshold to avoid TDS.' },
  { q: 'Can I withdraw my FD before maturity?', a: 'Most FDs allow premature withdrawal with a 0.5%–1% interest penalty. Tax-saving (80C) FDs cannot be broken before the 5-year lock-in. Consider a loan against FD as a penalty-free alternative.' },
  { q: 'Is a corporate FD safer than a bank FD?', a: 'Bank FDs are DICGC-insured up to ₹5 lakh. Corporate FDs aren\'t covered but offer higher rates. AAA/AA+ rated NBFCs like Shriram Finance have strong track records — assess the rating before investing.' },
  { q: 'What is the difference between cumulative and non-cumulative FD?', a: 'Cumulative FDs reinvest interest and pay principal + interest at maturity — ideal for wealth building. Non-cumulative FDs pay interest monthly or quarterly — best for regular income seekers like retirees.' },
  { q: 'Can I take a loan against my FD?', a: 'Yes. Borrow up to 70–90% of FD value at 1–2% above the FD rate. Your FD keeps earning interest while you access liquidity — smarter than premature withdrawal.' },
];
---

<BaseLayout
  title="Fixed Deposit in India — Best FD Rates 2025 | Shriram"
  description="Book a fixed deposit in India with up to 8.5% p.a. guaranteed interest. Special senior citizen rates, 80C eligible FD, and flexible tenures. Apply with Shriram today."
>

  <!-- ══ 1. HERO ═══════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[var(--color-dark-800)]">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[560px] w-[560px] rounded-full bg-[var(--color-brand)]/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-32 left-0 h-80 w-80 rounded-full bg-[var(--color-brand)]/5 blur-3xl"></div>
    <div class="site-wrap relative py-[120px]">
      <p class="equity-reveal text-[14px] font-medium tracking-[.04em] text-[var(--color-brand)]">Fixed Deposits</p>
      <h1 class="equity-reveal mt-[22px] max-w-[880px] text-[clamp(32px,4vw,52px)] font-bold leading-[1.06] text-white" style="font-family:var(--font-display)">
        <span class="text-[var(--color-brand)]">Fixed Deposit in India</span> — Earn Guaranteed Returns
      </h1>
      <p class="equity-reveal mt-[26px] max-w-[600px] text-[18px] leading-relaxed text-white/70">
        Invest in Fixed Deposits and earn up to 8.5% p.a. guaranteed interest. Safe, predictable, and flexible — with special rates for senior citizens and 80C tax-saving options.
      </p>
      <div class="equity-reveal mt-[38px] flex flex-wrap gap-[14px]">
        <a href="/about/open-demat-account/" class="btn-primary">Book a Fixed Deposit</a>
        <a href="/about/support/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Talk to RM</a>
      </div>
      <div class="equity-reveal mt-[54px] flex flex-wrap gap-x-9 gap-y-3 border-t border-white/15 pt-9">
        {['✓ Up to 8.5% p.a.', '✓ Capital guaranteed', '✓ Senior citizen extra rate', '✓ 80C eligible FD'].map(f => (
          <span class="text-[15px] font-medium text-white/90">
            <span class="mr-2 text-[var(--color-brand)]">{f.slice(0,1)}</span>{f.slice(1)}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 2. WHAT ARE FDs ════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto grid max-w-[1000px] items-start gap-[72px] lg:grid-cols-[5fr_7fr]">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Types of <span class="text-[var(--color-brand)]">Fixed Deposits</span>
        </h2>
        <div class="space-y-5 text-[17px] leading-relaxed text-[var(--color-muted)]">
          <p>A Fixed Deposit (FD) is a safe, guaranteed-return investment where you deposit a lump sum with a bank or NBFC for a fixed period at a predetermined interest rate.</p>
          <p>Unlike market-linked instruments, FDs offer capital protection and predictable income — making them ideal for conservative investors and short-to-medium-term goals.</p>
        </div>
      </div>
      <div class="equity-reveal mx-auto mt-[76px] max-w-[1000px] border-t border-[var(--color-n400)] pt-[60px]">
        <div class="grid gap-5 sm:grid-cols-2">
          {fdTypes.map((t, i) => (
            <div class="product-card-light flex flex-col gap-3 p-[34px]" style={`animation-delay:${i*60}ms`}>
              <span class="inline-flex w-fit rounded-full bg-[var(--color-brand)]/15 px-3 py-1 text-[11px] font-bold uppercase tracking-wide text-[var(--color-brand-deep)]">{t.tag}</span>
              <h3 class="text-[17px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{t.label}</h3>
              <p class="text-[13px] leading-relaxed text-[var(--color-muted)]">{t.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 3. INTEREST RATES ══════════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          FD Interest <span class="text-[var(--color-brand)]">Rate Structure</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Indicative rates (p.a.). Actual rates may vary. Senior citizens receive an additional 0.50% on all tenures.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto"><table class="w-full text-[15.5px]">
          <thead><tr class="bg-[var(--color-dark-olive)]"><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Tenure</th><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">General Investors</th><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Senior Citizens</th></tr></thead>
          <tbody>{rateRows.map((r,i) => (<tr class={i%2===0?'bg-white':'bg-[#f8f6f1]'}><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.tenure}</td><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.general}</td><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-medium text-[var(--color-dark-olive)]">{r.senior}</td></tr>))}</tbody>
        </table></div>
      </div>
    </div>
  </section>

  <!-- ══ 4. HOW TO OPEN ════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How to Open a <span class="text-[var(--color-brand)]">Fixed Deposit</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Four simple steps from choosing your FD to receiving your digital certificate.</p>
      </div>
      <div class="equity-reveal steps-grid overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        {steps.map(s => (
          <div class="px-[30px] py-[34px]">
            <div class="mb-[22px] font-display text-[34px] font-normal leading-none text-[var(--color-brand)]">{s.n}</div>
            <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">{s.title}</h4>
            <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 5. FD VS EQUITY VS MF ════════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          FD vs Equity vs <span class="text-[var(--color-brand)]">Mutual Funds</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Compare your options across the factors that matter most for your financial goals.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto"><table class="w-full text-[15.5px]">
          <thead><tr class="bg-[var(--color-dark-olive)]"><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Feature</th><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Fixed Deposit</th><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Equity</th><th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Mutual Funds</th></tr></thead>
          <tbody>{vsRows.map((r,i) => (<tr class={i%2===0?'bg-white':'bg-[#f8f6f1]'}><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.feature}</td><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.fd}</td><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.equity}</td><td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.mf}</td></tr>))}</tbody>
        </table></div>
      </div>
    </div>
  </section>

  <!-- ══ 5b. FD INTEREST RATES 2025 COMPARISON ════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          FD Interest Rates 2025 — <span class="text-[var(--color-brand)]">Top Banks Compared</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Indicative rates for 1–3 year tenures. NBFCs like Shriram Finance typically offer 0.5%–1.5% higher than bank FDs. Check the platform for current rates.</p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Bank / NBFC</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">General (1–3yr)</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Senior Citizen</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">DICGC Insured</th>
              </tr>
            </thead>
            <tbody>
              {[
                { bank: 'SBI', general: '6.50–7.50%', senior: '7.00–8.00%', insured: 'Yes (₹5L)' },
                { bank: 'HDFC Bank', general: '7.00–7.75%', senior: '7.50–8.25%', insured: 'Yes (₹5L)' },
                { bank: 'ICICI Bank', general: '6.90–7.75%', senior: '7.40–8.25%', insured: 'Yes (₹5L)' },
                { bank: 'Axis Bank', general: '7.00–7.75%', senior: '7.75–8.50%', insured: 'Yes (₹5L)' },
                { bank: 'Shriram Finance (NBFC)', general: '7.50–8.50%', senior: '8.00–9.00%', insured: 'No (CRISIL rated)' },
              ].map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.bank}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.general}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-medium text-[var(--color-dark-olive)]">{r.senior}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.insured}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
      <p class="mt-4 text-center text-[13px] text-[var(--color-muted)]">*Indicative rates as of mid-2025. Actual rates vary by bank and product. Verify on respective websites.</p>
    </div>
  </section>

  <!-- ══ 5c. PREMATURE WITHDRAWAL & LOAN AGAINST FD ════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          FD Premature Withdrawal &amp; <span class="text-[var(--color-brand)]">Loan Against FD</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">Need money before your FD matures? You have two options — break it early (with a penalty) or borrow against it.</p>
      </div>
      <div class="equity-reveal grid gap-6 sm:grid-cols-2">
        <div class="product-card-light p-[34px]">
          <h3 class="mb-4 text-[22px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">Premature Withdrawal</h3>
          <div class="space-y-4">
            <p class="text-[14px] leading-relaxed text-[var(--color-muted)]">Most FDs allow early withdrawal, but at a cost. Banks deduct 0.5%–1% from the applicable rate to calculate the penalty.</p>
            <div class="rounded-[12px] border border-[var(--color-n400)] bg-[#f8f6f1] p-5">
              <div class="mb-3 text-[13px] font-bold text-[var(--color-ink)]">Example Calculation</div>
              <div class="space-y-1.5 text-[13px] text-[var(--color-muted)]">
                <div><span class="font-medium text-[var(--color-ink)]">FD Booked at:</span> 7.50% p.a. for 3 years</div>
                <div><span class="font-medium text-[var(--color-ink)]">Broken after:</span> 1 year</div>
                <div><span class="font-medium text-[var(--color-ink)]">Rate for 1 year:</span> 7.00% p.a. (original 1-yr rate)</div>
                <div><span class="font-medium text-[var(--color-ink)]">Penalty deducted:</span> 0.50%</div>
                <div class="font-semibold text-[var(--color-dark-olive)]">Effective rate paid: 6.50% p.a.</div>
              </div>
            </div>
            <p class="text-[12px] text-[var(--color-muted)]">Tax-Saving FDs (80C) cannot be broken before the 5-year lock-in period under any circumstances.</p>
          </div>
        </div>
        <div class="product-card-light p-[34px]">
          <h3 class="mb-4 text-[22px] font-medium text-[var(--color-ink)]" style="font-family:var(--font-display)">Loan Against FD</h3>
          <div class="space-y-4">
            <p class="text-[14px] leading-relaxed text-[var(--color-muted)]">A smarter alternative — borrow against your FD while it continues to earn interest.</p>
            <div class="space-y-3">
              {[
                { label: 'Loan Amount', value: 'Up to 70–90% of FD value' },
                { label: 'Loan Interest Rate', value: 'FD rate + 1–2% p.a.' },
                { label: 'Your FD Keeps Earning', value: 'Full interest continues' },
                { label: 'Net Cost', value: 'Only 1–2% over FD rate' },
                { label: 'Processing Fee', value: 'Nil to minimal (most banks)' },
              ].map(d => (
                <div class="flex justify-between border-b border-[var(--color-n400)]/50 pb-2 last:border-0 last:pb-0 text-[13px]">
                  <span class="font-medium text-[var(--color-ink)]">{d.label}</span>
                  <span class="text-[var(--color-muted)]">{d.value}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 6. FAQ ════════════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Frequently Asked <span class="text-[var(--color-brand)]">Questions</span>
        </h2>
      </div>
      <div class="equity-reveal mx-auto max-w-[840px] border-t border-[var(--color-n400)]">
        {faqs.map(item => (
          <details class="eq-faq group border-b border-[var(--color-n400)]">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-5 py-[26px] px-2">
              <span class="text-[18px] font-semibold text-[var(--color-ink)]">{item.q}</span>
              <span class="shrink-0 text-[22px] leading-none text-[var(--color-brand)] transition-transform duration-300 group-open:rotate-45">+</span>
            </summary>
            <div class="overflow-hidden px-2 pb-0 text-[16px] leading-relaxed text-[var(--color-muted)] transition-all duration-300 group-open:pb-[28px]">
              <p class="max-w-[680px]">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 7. FINAL CTA ══════════════════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal overflow-hidden rounded-[22px] bg-[var(--color-dark-800)] px-[60px] py-[64px] text-center">
        <h3 class="mx-auto max-w-[560px] text-[38px] font-bold leading-[1.12] text-white" style="font-family:var(--font-display)">Secure Your Savings with a Fixed Deposit</h3>
        <p class="mx-auto mt-[18px] max-w-[480px] text-[17px] leading-relaxed text-white/70">Book an FD with Shriram Financial Services — up to 8.5% p.a., fully digital, and with special rates for senior citizens.</p>
        <div class="mt-[34px] flex flex-wrap justify-center gap-[14px]">
          <a href="/about/open-demat-account/" class="btn-primary">Book FD Now</a>
          <a href="/about/support/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Talk to an RM</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .equity-reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s cubic-bezier(0.22, 0.61, 0.36, 1), transform 0.7s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .equity-reveal.in-view { opacity: 1; transform: none; }

  .steps-grid { display: grid; grid-template-columns: repeat(2, 1fr); }
  .steps-grid > * { border-right: 1px solid var(--color-n400); border-bottom: 1px solid var(--color-n400); }
  .steps-grid > *:nth-child(2n) { border-right: 0; }
  .steps-grid > *:nth-last-child(-n+2) { border-bottom: 0; }
  @media (min-width: 1024px) {
    .steps-grid { grid-template-columns: repeat(4, 1fr); }
    .steps-grid > * { border-right: 1px solid var(--color-n400); border-bottom: 0; }
    .steps-grid > *:last-child { border-right: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .equity-reveal { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).classList.add('in-view');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.10 });
  document.querySelectorAll('.equity-reveal').forEach(el => obs.observe(el));

  document.querySelectorAll<HTMLDetailsElement>('.eq-faq').forEach(d => {
    d.addEventListener('toggle', () => {
      if (d.open) document.querySelectorAll<HTMLDetailsElement>('.eq-faq').forEach(o => { if (o !== d) o.removeAttribute('open'); });
    });
  });
</script>
