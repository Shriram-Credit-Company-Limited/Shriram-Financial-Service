---
import BaseLayout from '../../layouts/BaseLayout.astro';

const comparisonRows = [
  { feature: 'Investment Type',      fd: 'One-time lump sum',               sa: 'Deposit / withdraw anytime',     rd: 'Fixed monthly instalments' },
  { feature: 'Interest Rate (p.a.)', fd: '6.5–9.4% fixed at deposit',       sa: '2.5–7% variable',                rd: '5.5–8% fixed at opening' },
  { feature: 'Liquidity',            fd: 'Low — penalty on early exit',     sa: 'High — withdraw anytime',        rd: 'Low — premature penalty' },
  { feature: 'Minimum Deposit',      fd: '₹1,000 (varies by bank)',         sa: '₹0–₹10,000 (MAB)',               rd: '₹100/month' },
  { feature: 'Tenure',               fd: '7 days – 10 years',               sa: 'No fixed tenure',                rd: '6 months – 10 years' },
  { feature: 'DICGC Insurance',      fd: 'Up to ₹5 lakh',                  sa: 'Up to ₹5 lakh',                  rd: 'Up to ₹5 lakh' },
  { feature: 'Best For',             fd: 'Lump-sum, goal-based saving',     sa: 'Daily expenses, emergency fund', rd: 'Monthly disciplined savers' },
];

const howItWorks = [
  { n: '1', title: 'Deposit a Lump Sum',  desc: 'Choose your bank or NBFC, decide the amount, and transfer your principal. Minimum deposit typically starts at ₹1,000.' },
  { n: '2', title: 'Lock the Rate',       desc: 'Your interest rate is fixed at deposit — completely unaffected by future market movements or RBI rate revisions.' },
  { n: '3', title: 'Earn Interest',       desc: 'Interest compounds quarterly (cumulative) or pays out monthly / quarterly (non-cumulative) as per your choice.' },
  { n: '4', title: 'Choose Payout',       desc: 'Cumulative: receive everything at maturity. Non-cumulative: receive periodic interest while the principal stays invested.' },
  { n: '5', title: 'Receive at Maturity', desc: 'On maturity, principal and accrued interest are credited to your account. Choose to auto-renew or redeem in full.' },
];

const typeRows = [
  { type: 'Cumulative FD',      interest: 'Compounded, paid at maturity',       tenure: '7 days – 10 years', tax: 'TDS on interest',          best: 'Long-term savings goal' },
  { type: 'Non-Cumulative FD',  interest: 'Monthly / quarterly payouts',         tenure: '7 days – 10 years', tax: 'TDS on interest',          best: 'Regular income needs' },
  { type: 'Tax Saving FD',      interest: '~7% p.a.',                            tenure: '5 years (lock-in)', tax: '₹1.5L deduction u/s 80C', best: 'Tax planning under 80C' },
  { type: 'Senior Citizen FD',  interest: '+0.25–0.50% over general rate',       tenure: 'Same as regular',   tax: 'TDS applies',              best: 'Retired investors' },
  { type: 'NBFC FD (Shriram)',  interest: '8.50–9.40% p.a.',                     tenure: '1–5 years',         tax: 'TDS on interest',          best: 'Higher-rate seekers' },
  { type: 'Flexi FD',           interest: 'FD rate on surplus above threshold',  tenure: 'Ongoing',           tax: 'TDS applies',              best: 'Liquidity + FD returns' },
];

const coreB = [
  'Guaranteed returns — rate locked at deposit, immune to market or rate changes',
  'DICGC-insured up to ₹5 lakh per depositor per bank (bank FDs)',
  'Flexible tenure — 7 days to 10 years to match any financial goal',
  'Loan against FD — borrow up to 90% of value without breaking the deposit',
  'Senior citizen benefit — extra 0.25–0.50% above the general rate',
  'Tax Saving FD qualifies for ₹1.5L deduction under Section 80C',
];

const flexB = [
  'Premature withdrawal with a defined interest penalty',
  'Nomination facility for all depositors',
  'Partial withdrawal facility at select banks',
  'Auto-renewal on maturity at then-prevailing rates',
  'Online account opening — fully paperless, done in minutes',
  'Digital FD receipt accessible at any time',
];

const steps = [
  { n: '1', title: 'Register',       desc: 'Create your Shriram account with your mobile number and email in under 2 minutes.' },
  { n: '2', title: 'Choose an FD',   desc: 'Compare rates, tenures, and institution types. Pick the FD that fits your goal and risk profile.' },
  { n: '3', title: 'Complete KYC',   desc: 'One-time PAN + Aadhaar-based digital KYC. Fully paperless — takes under 5 minutes.' },
  { n: '4', title: 'Add Details',    desc: 'Enter deposit amount, choose your tenure, and select payout type (cumulative or non-cumulative).' },
  { n: '5', title: 'Pay & Confirm',  desc: 'Transfer funds via net banking or UPI. Your digital FD receipt is generated instantly.' },
];

const kycDocs = [
  'PAN card (mandatory)',
  'Aadhaar card for identity verification',
  'Address proof — Aadhaar, Passport, or Utility Bill',
  'Cancelled cheque or recent bank statement',
  'Passport-size photograph (JPEG format)',
];

const setupNeeds = [
  'Valid mobile number linked to Aadhaar',
  'Net banking or UPI for fund transfer',
  'Active bank account in your name',
  'Valid email ID for account confirmation',
];

const faqs = [
  { q: 'Is FD safe in India?', a: 'Bank FDs up to ₹5 lakh per depositor per bank are insured by DICGC — covering both principal and interest. NBFC FDs are not DICGC-insured but are regulated by RBI.' },
  { q: 'Is FD interest taxable?', a: 'Yes. FD interest is added to your total income and taxed at your applicable slab rate. TDS at 10% is deducted if annual interest exceeds ₹40,000 (₹50,000 for senior citizens).' },
  { q: 'Can I break an FD before maturity?', a: 'Yes, with a premature withdrawal penalty of 0.50–1.00% below the applicable interest rate for the period actually held.' },
  { q: 'What is a Tax Saving FD?', a: 'A 5-year lock-in FD eligible for ₹1.5 lakh deduction under Section 80C. The interest earned is fully taxable. Premature withdrawal is not permitted.' },
  { q: 'Cumulative vs non-cumulative FD — what is the difference?', a: 'Cumulative FD pays principal + compounded interest at maturity — ideal for wealth building. Non-cumulative FD pays interest monthly or quarterly while the principal remains invested — suitable for regular income.' },
  { q: 'What is the maximum DICGC insurance amount?', a: 'DICGC insures up to ₹5 lakh per depositor per bank, covering both principal and interest across all accounts held at that bank.' },
  { q: 'Do senior citizens get higher FD rates?', a: 'Yes. Senior citizens aged 60+ receive 0.25–0.50% above the general rate at most banks and NBFCs.' },
  { q: 'Can NRIs invest in FDs in India?', a: 'Yes — through NRE FDs (interest tax-free in India, fully repatriable) or NRO FDs (interest taxable in India). FCNR FDs are denominated in foreign currency.' },
];
---

<BaseLayout
  title="Fixed Deposit in India — Safe, Guaranteed Returns | Shriram"
  description="Open a Fixed Deposit online with Shriram. Compare FD interest rates, calculate your maturity amount, and earn guaranteed returns. DICGC-insured bank FDs and competitive NBFC FD rates."
>

  <!-- ══ 1. HERO ══════════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-left">
        <h1>Fixed Deposit in India — <span class="g">Safe, Assured Growth</span></h1>
        <p class="lead">Open a Fixed Deposit online in minutes and lock in guaranteed returns — unaffected by market swings. DICGC-insured bank FDs and competitive NBFC rates from Shriram.</p>
        <div class="cta-row">
          <a class="btn-gold" href="/about/open-demat-account/">Open Fixed Deposit</a>
        </div>
        <div class="hero-feats">
          <div class="feats">
            {['DICGC-insured (up to ₹5 lakh)', 'RBI regulated', 'SEBI registered', 'Flexible tenure'].map(f => (
              <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;{f}</span></div>
            ))}
          </div>
        </div>
      </div>

      <div class="hero-panel">
        <p class="panel-title">Open Your Fixed Deposit</p>
        <div class="fd-form">
          <div class="fd-field">
            <label>Full Name</label>
            <input type="text" placeholder="Rajesh Kumar" />
          </div>
          <div class="fd-field">
            <label>Mobile Number</label>
            <input type="tel" placeholder="+91 98765 43210" />
          </div>
          <div class="fd-field">
            <label>Email</label>
            <input type="email" placeholder="name@email.com" />
          </div>
          <div class="fd-field">
            <label>City</label>
            <input type="text" placeholder="Chennai" />
          </div>
          <div class="fd-field">
            <label>Preferred Tenure</label>
            <div class="tenure-tabs">
              <button type="button" class="t-tab active" data-tab>1 Yr</button>
              <button type="button" class="t-tab" data-tab>2 Yr</button>
              <button type="button" class="t-tab" data-tab>3 Yr</button>
            </div>
          </div>
          <a class="btn-gold" href="/about/open-demat-account/" style="width:100%;justify-content:center;margin-top:8px">Invest Now</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 2. WHAT IS FD? ═══════════════════════════════════════════════ -->
  <section class="section stack" id="sec-about" style="background:var(--sec-light);gap:56px">
    <div class="stack" style="gap:16px">
      <p class="sec-title">What is a Fixed Deposit?</p>
      <p class="sec-lead">A Fixed Deposit is a savings instrument where you deposit a lump sum at a pre-agreed interest rate for a fixed tenure. Your principal and returns are fully guaranteed — unlike a savings account, the rate is locked for the full tenure so you know your maturity amount on day one.</p>
    </div>
    <div class="stack" style="gap:16px">
      <p class="sub-title">FD vs Savings Account vs Recurring Deposit</p>
      <p class="sub-lead">Choose the right savings instrument — each serves a different financial goal.</p>
    </div>
    <div class="t-scroll">
      <div class="table t4 bordered">
        <div class="cell th"><p>Feature</p></div>
        <div class="cell th hi"><p>Fixed Deposit</p></div>
        <div class="cell th"><p>Savings Account</p></div>
        <div class="cell th"><p>Recurring Deposit</p></div>
        {comparisonRows.map(r => (
          <>
            <div class="cell tb"><p class="k">{r.feature}</p></div>
            <div class="cell tb hi-cell"><p class="v">{r.fd}</p></div>
            <div class="cell tb"><p class="v">{r.sa}</p></div>
            <div class="cell tb"><p class="v">{r.rd}</p></div>
          </>
        ))}
      </div>
    </div>
    <a class="btn-gold" href="/about/open-demat-account/" style="align-self:center">Open Fixed Deposit</a>
  </section>

  <!-- ══ 3. HOW FDS WORK ══════════════════════════════════════════════ -->
  <section class="section stack" id="sec-how" style="background:var(--sec-tint);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <p class="sec-title">How Fixed Deposits Work</p>
      <p class="sec-lead">Fixed deposits mature to the simple sum of capital plus interest — add the power of compounding working for you throughout the tenure.</p>
    </div>

    <div class="steps">
      {howItWorks.map((s, i) => (
        <>
          {i > 0 && <div class="step-div"></div>}
          <div class="step">
            <div class="num">{s.n}</div>
            <div class="st-body">
              <h4>{s.title}</h4>
              <p>{s.desc}</p>
            </div>
          </div>
        </>
      ))}
    </div>

    <div class="row-2">
      <div class="card">
        <p class="card-h">Cumulative FD — Compounding</p>
        <p class="card-p">Interest is reinvested quarterly and compounded throughout the tenure. At maturity, you receive the full principal plus all compounded interest in one lump sum — ideal for building wealth without needing immediate income.</p>
      </div>
      <div class="card">
        <p class="card-h">Non-Cumulative FD — Regular Payouts</p>
        <p class="card-p">Interest is paid out monthly or quarterly while your principal remains fully intact. Ideal for retirees or anyone who needs a predictable income stream — each payout brings regular liquidity without touching the invested corpus.</p>
      </div>
    </div>

    <a class="btn-gold" href="/calculators/fd/" style="align-self:center">Calculate FD Returns</a>
  </section>

  <!-- ══ 4. TYPES OF FDS ══════════════════════════════════════════════ -->
  <section class="section stack" id="sec-types" style="background:var(--sec-light);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <p class="sec-title">Types of Fixed Deposits in India</p>
      <p class="sec-lead">Different FDs serve different goals — income, tax saving, or higher returns. Compare them at a glance.</p>
    </div>
    <div class="t-scroll">
      <div class="table t5 bordered">
        <div class="cell th"><p>FD Type</p></div>
        <div class="cell th"><p>Interest</p></div>
        <div class="cell th"><p>Tenure</p></div>
        <div class="cell th"><p>Tax</p></div>
        <div class="cell th hi"><p>Best For</p></div>
        {typeRows.map(r => (
          <>
            <div class="cell tb"><p class="k">{r.type}</p></div>
            <div class="cell tb"><p class="v">{r.interest}</p></div>
            <div class="cell tb"><p class="v">{r.tenure}</p></div>
            <div class="cell tb"><p class="v">{r.tax}</p></div>
            <div class="cell tb hi-cell"><p class="v">{r.best}</p></div>
          </>
        ))}
      </div>
    </div>
    <a class="btn-gold" href="/about/open-demat-account/" style="align-self:center">Open Fixed Deposit</a>
  </section>

  <!-- ══ 5. FD CALCULATOR ═════════════════════════════════════════════ -->
  <section class="section stack" id="sec-calc" style="background:var(--sec-tint);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <p class="sec-title">FD Calculator</p>
      <p class="sec-lead">Find out exactly how much interest you will earn by investing in a Fixed Deposit for a chosen tenure.</p>
    </div>
    <div class="calc-card">
      <div class="calc-inputs">
        <div class="calc-field">
          <div class="calc-label-row">
            <label for="c-principal">Principal Amount</label>
            <span class="calc-val" id="c-principal-val">₹1,00,000</span>
          </div>
          <input id="c-principal" type="range" min="10000" max="5000000" step="10000" value="100000" class="calc-slider" />
          <div class="calc-range-ends"><span>₹10K</span><span>₹50L</span></div>
        </div>
        <div class="calc-field">
          <div class="calc-label-row">
            <label for="c-rate">Annual Rate (% p.a.)</label>
            <span class="calc-val" id="c-rate-val">8.50%</span>
          </div>
          <input id="c-rate" type="range" min="4" max="10" step="0.05" value="8.50" class="calc-slider" />
          <div class="calc-range-ends"><span>4%</span><span>10%</span></div>
        </div>
        <div class="calc-field">
          <div class="calc-label-row">
            <label for="c-tenure">Tenure</label>
            <span class="calc-val" id="c-tenure-val">2 Years</span>
          </div>
          <input id="c-tenure" type="range" min="1" max="10" step="1" value="2" class="calc-slider" />
          <div class="calc-range-ends"><span>1 Yr</span><span>10 Yr</span></div>
        </div>
      </div>
      <div class="calc-output">
        <div class="donut-wrap">
          <svg class="donut" viewBox="0 0 120 120">
            <circle class="donut-track" cx="60" cy="60" r="50" />
            <circle class="donut-fill" id="c-donut" cx="60" cy="60" r="50" />
          </svg>
          <div class="donut-center">
            <p class="donut-label">Maturity</p>
            <p class="donut-amount" id="c-maturity">₹1,18,197</p>
          </div>
        </div>
        <div class="calc-results">
          <div class="cr-row">
            <span class="cr-dot" style="background:var(--olive-deep)"></span>
            <span class="cr-label">Invested</span>
            <span class="cr-val" id="c-invested">₹1,00,000</span>
          </div>
          <div class="cr-row">
            <span class="cr-dot" style="background:var(--gold-btn)"></span>
            <span class="cr-label">Returns</span>
            <span class="cr-val" id="c-returns">₹18,197</span>
          </div>
          <div class="cr-sep"></div>
          <div class="cr-row total">
            <span class="cr-label">Total Value</span>
            <span class="cr-val" id="c-total">₹1,18,197</span>
          </div>
          <a class="btn-gold" href="/about/open-demat-account/" style="width:100%;justify-content:center;margin-top:8px">Open FD</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 6. FD BENEFITS & FEATURES ═══════════════════════════════════ -->
  <section class="section stack" id="sec-benefits" style="background:var(--sec-light);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <p class="sec-title">FD Benefits &amp; Features</p>
      <p class="sec-lead">What makes Fixed Deposits the cornerstone of safe, predictable, and flexible investing.</p>
    </div>
    <div class="row-2">
      <div class="card check-card">
        <p class="ch-title">Core Benefits</p>
        <div class="check-list">
          {coreB.map((item, i) => (
            <>
              {i > 0 && <div class="check-sep"></div>}
              <div class="check-row"><span class="ck">✓</span><p class="tx">{item}</p></div>
            </>
          ))}
        </div>
      </div>
      <div class="card check-card">
        <p class="ch-title">Added Flexibility</p>
        <div class="check-list">
          {flexB.map((item, i) => (
            <>
              {i > 0 && <div class="check-sep"></div>}
              <div class="check-row"><span class="ck">✓</span><p class="tx">{item}</p></div>
            </>
          ))}
        </div>
      </div>
    </div>
    <a class="btn-gold" href="/about/open-demat-account/" style="align-self:center">Open Fixed Deposit</a>
  </section>

  <!-- ══ 7. PREMATURE WITHDRAWAL & LOAN ══════════════════════════════ -->
  <section class="section stack" id="sec-withdraw" style="background:var(--sec-tint);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <p class="sec-title">Premature Withdrawal &amp; Loan Against FD</p>
      <p class="sec-lead">Two ways to access money before maturity — one breaks the FD, the other keeps it fully intact.</p>
    </div>
    <div class="row-2">
      <div class="card">
        <p class="card-h">Premature Withdrawal</p>
        <p class="card-p">Break your FD before maturity with a penalty — typically 0.50–1.00% below the rate applicable for the period held. Example: ₹1L FD at 8.5% for 2 years, broken at 18 months → earns approximately 7.5–8.0% for the 18-month period only.</p>
      </div>
      <div class="card">
        <p class="card-h">Loan / Overdraft Against FD</p>
        <p class="card-p">Get an overdraft of up to 90% of FD value at FD rate + 1–2%. Your FD continues earning full interest while you use the loan — a smarter alternative to breaking the deposit. Interest is charged only on the drawn amount and days used.</p>
      </div>
    </div>
    <a class="btn-gold" href="/about/open-demat-account/" style="align-self:center">Open Fixed Deposit</a>
  </section>

  <!-- ══ 8. HOW TO OPEN FD ONLINE ═════════════════════════════════════ -->
  <section class="section stack" id="sec-open" style="background:var(--sec-light);gap:56px;align-items:center;justify-content:center">
    <div class="stack" style="gap:16px;width:100%">
      <p class="sec-title">How to Open a Fixed Deposit Online</p>
      <p class="sec-lead">Start in five steps — plus exactly what you'll need to complete your first FD.</p>
    </div>

    <div class="steps">
      {steps.map((s, i) => (
        <>
          {i > 0 && <div class="step-div"></div>}
          <div class="step">
            <div class="num">{s.n}</div>
            <div class="st-body">
              <h4>{s.title}</h4>
              <p>{s.desc}</p>
            </div>
          </div>
        </>
      ))}
    </div>

    <div class="stack" style="gap:32px;width:100%">
      <div class="stack" style="gap:16px">
        <p class="sub-title">Documents &amp; Setup</p>
        <p class="sub-lead">Everything you need to qualify and complete your FD account opening.</p>
      </div>
      <div class="row-2">
        <div class="card check-card">
          <p class="ch-title">KYC Documents Required</p>
          <div class="check-list">
            {kycDocs.map((item, i) => (
              <>
                {i > 0 && <div class="check-sep"></div>}
                <div class="check-row"><span class="ck">✓</span><p class="tx">{item}</p></div>
              </>
            ))}
          </div>
        </div>
        <div class="card check-card">
          <p class="ch-title">What You'll Need to Set Up</p>
          <div class="check-list">
            {setupNeeds.map((item, i) => (
              <>
                {i > 0 && <div class="check-sep"></div>}
                <div class="check-row"><span class="ck">✓</span><p class="tx">{item}</p></div>
              </>
            ))}
          </div>
        </div>
      </div>
    </div>

    <a class="btn-gold" href="/about/open-demat-account/" style="align-self:center">Open FD Account</a>
  </section>

  <!-- ══ 9. DEMAT CTA BANNER ═══════════════════════════════════════════ -->
  <section class="demat-banner">
    <p class="banner-title">Open Your Demat Account Within Minutes</p>
    <p class="banner-sub">Start investing in stocks, mutual funds, FDs and more — with zero paperwork.</p>
    <a class="btn-gold" href="/about/open-demat-account/">Open Demat Account</a>
  </section>

  <!-- ══ 10. FAQ ══════════════════════════════════════════════════════ -->
  <section class="faq-wrap" id="sec-faq">
    <div class="faq-cols">
      <div class="faq-left">
        <p class="faq-title">Fixed Deposit FAQs</p>
        <div class="faq-acc">
          {faqs.map((item) => (
            <details class="faq-item">
              <summary class="faq-sum">
                <span class="qt">{item.q}</span>
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="faq-icon">
                  <path d="M2 8h12"/>
                  <path class="faq-v" d="M8 2v12"/>
                </svg>
              </summary>
              <div class="qa"><p>{item.a}</p></div>
            </details>
          ))}
        </div>
      </div>
      <div class="faq-side">
        <div class="side-in">
          <div class="side-tx">
            <h4>Need a clearer direction?</h4>
            <p>Our FD specialists will help you choose the right tenure, institution, and payout option for your goals.</p>
          </div>
          <a class="btn-gold" href="/about/support/">Schedule a Call</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 11. FINAL CTA ════════════════════════════════════════════════ -->
  <section class="cta-sec" id="sec-final-cta" style="background:var(--sec-light)">
    <div class="cta-box">
      <div class="ct-tt">
        <h3>Open Fixed Deposit Online — Guaranteed Returns</h3>
        <p class="ct-sub">Compare FD rates, open digitally, and start earning safe, predictable returns today with Shriram Financial Services.</p>
      </div>
      <a class="btn-gold" href="/about/open-demat-account/">Open Fixed Deposit</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Design tokens ─────────────────────────────────────────────── */
  :root {
    --page: #fcf8ef;
    --sec-light: #fef8ee;
    --sec-tint: #f6efe1;
    --card: #fffdf8;
    --card-border: #e1e0db;
    --card-border-soft: rgba(28,28,22,.13);
    --row-line: rgba(28,28,22,.08);
    --olive-title: #2e3914;
    --olive-head: #2d3813;
    --olive-deep: #1b2010;
    --ink: #1c1c16;
    --ink-2: #46463c;
    --ink-3: #595959;
    --muted: #73736a;
    --muted-2: #9a9a8e;
    --gold: #e0a82e;
    --gold-2: #f2b83f;
    --gold-btn: #f3b83f;
    --gold-ink: #231a06;
    --olive-ink: #2e3914;
    --green: #009d58;
    --blue: #2f7ef4;
    --pad: clamp(20px, 8vw, 144px);
    --container-pad: 32px;
    --section-y: 72px;
    --cta-w: 220px;
  }

  /* ── Base ────────────────────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; }
  a { color: inherit; text-decoration: none; }
  p { line-height: 1.5; margin: 0; }

  /* ── Section shell ───────────────────────────────────────────────── */
  .section {
    padding: var(--section-y) var(--pad);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .stack { display: flex; flex-direction: column; }

  /* ── Typography ──────────────────────────────────────────────────── */
  .sec-title { font-weight: 400; font-size: 40px; color: var(--olive-title); text-transform: capitalize; line-height: 1.5; }
  .sec-lead  { font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.5; }
  .sub-title { font-weight: 500; font-size: 24px; color: var(--ink); line-height: 1.5; }
  .sub-lead  { font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.5; }
  .card-h    { font-weight: 500; font-size: 20px; color: var(--ink); line-height: 1.5; }
  .card-p    { font-weight: 400; font-size: 16px; color: var(--muted); line-height: 1.5; }
  .g { color: var(--gold-2); }

  /* ── Cards ───────────────────────────────────────────────────────── */
  .card {
    background: var(--card);
    border: 1px solid var(--card-border);
    border-radius: 24px;
    padding: var(--container-pad);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* ── Hero ────────────────────────────────────────────────────────── */
  .hero {
    padding: 0 var(--pad);
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    background: radial-gradient(125% 210% at 100% -8%, #4f583b 0%, #363a2c 50%, #1d1d1d 100%);
  }
  .hero-inner {
    padding: clamp(80px,12vw,140px) 0 clamp(48px,6vw,80px);
    display: flex;
    gap: clamp(40px, 6vw, 80px);
    align-items: flex-start;
  }
  .hero-left { flex: 1 1 0; min-width: 0; display: flex; flex-direction: column; }
  .hero h1 { font-weight: 500; font-size: 40px; color: #fff; line-height: 1.5; max-width: 620px; }
  .hero .lead { margin-top: 32px; font-weight: 400; font-size: 18px; line-height: 1.5; color: rgba(255,255,255,.74); max-width: 520px; }
  .cta-row { margin-top: 40px; display: flex; flex-wrap: wrap; gap: 14px; align-items: center; }
  .hero-feats { margin-top: 40px; }
  .feats { display: flex; flex-wrap: wrap; align-items: center; gap: 14px 16px; max-width: 560px; padding-top: 36px; border-top: 1px solid rgba(255,255,255,.16); }
  .feat { display: flex; gap: 10px; align-items: center; }
  .feat .tk { color: var(--gold-2); font-weight: 500; font-size: 15px; width: 13px; }
  .feat .lb { color: rgba(255,255,255,.9); font-weight: 500; font-size: 16px; line-height: 1.5; white-space: nowrap; }

  /* ── Hero panel (form) ──────────────────────────────────────────── */
  .hero-panel {
    width: min(560px, 100%);
    flex: none;
    background: rgba(255,255,255,.85);
    border: 1px solid rgba(255,255,255,.50);
    border-radius: 24px;
    padding: 32px 40px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    backdrop-filter: blur(20px) saturate(1.6);
    -webkit-backdrop-filter: blur(20px) saturate(1.6);
    box-shadow: 0 8px 40px rgba(0,0,0,.08), inset 0 1px 0 rgba(255,255,255,.60);
    margin-top: clamp(40px,6vw,80px);
  }
  .panel-title { font-weight: 600; font-size: 24px; color: var(--olive-deep); line-height: 1.4; }
  .fd-form { display: flex; flex-direction: column; gap: 14px; }
  .fd-field { display: flex; flex-direction: column; gap: 6px; }
  .fd-field label { font-weight: 500; font-size: 12px; color: var(--olive-head); letter-spacing: .4px; }
  .fd-field input {
    background: #fff;
    border: 1px solid rgba(46,57,20,.18);
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 14px;
    color: var(--ink);
    outline: none;
    transition: border-color .2s;
  }
  .fd-field input::placeholder { color: var(--muted-2); }
  .fd-field input:focus { border-color: var(--gold-2); }
  .tenure-tabs { display: flex; gap: 8px; }
  .t-tab {
    flex: 1;
    background: rgba(46,57,20,.05);
    border: 1px solid rgba(46,57,20,.15);
    border-radius: 8px;
    padding: 8px 4px;
    font-size: 13px;
    font-weight: 500;
    color: var(--ink-2);
    cursor: pointer;
    transition: background .2s, border-color .2s, color .2s;
  }
  .t-tab.active { background: var(--gold-btn); border-color: var(--gold-btn); color: var(--olive-ink); }
  .t-tab:hover:not(.active) { background: rgba(46,57,20,.1); }

  /* ── Buttons ─────────────────────────────────────────────────────── */
  .btn-gold {
    background: var(--gold-btn);
    height: 40px;
    width: var(--cta-w);
    border-radius: 4px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 7px 20px;
    font-weight: 500;
    font-size: 12px;
    color: var(--olive-ink);
    white-space: nowrap;
    transition: opacity .2s;
  }
  .btn-gold:hover { opacity: .88; }

  /* ── Two-card row ────────────────────────────────────────────────── */
  .row-2 { display: flex; gap: 32px; align-items: stretch; }
  .row-2 .card { flex: 1 0 0; min-width: 0; }

  /* ── Steps ───────────────────────────────────────────────────────── */
  .steps {
    background: var(--card);
    border: 1px solid var(--card-border);
    border-radius: 24px;
    overflow: hidden;
    display: flex;
    align-items: stretch;
    width: 100%;
  }
  .step { flex: 1 0 0; min-width: 0; padding: var(--container-pad); display: flex; flex-direction: column; gap: 16px; }
  .step .num { font-weight: 400; font-size: 32px; line-height: 34px; color: var(--gold); }
  .step .st-body { display: flex; flex-direction: column; gap: 12px; }
  .step h4 { font-weight: 500; font-size: 20px; color: var(--ink); line-height: 1.5; }
  .step p  { font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.5; }
  .step-div { width: 1px; align-self: stretch; background: var(--card-border); flex: none; }

  /* ── Checklist cards ─────────────────────────────────────────────── */
  .check-card { flex: 1 0 0; min-width: 0; display: flex; flex-direction: column; gap: 32px; }
  .ch-title   { font-weight: 500; font-size: 20px; color: var(--ink); line-height: 1.5; }
  .check-list { display: flex; flex-direction: column; gap: 24px; }
  .check-row  { display: flex; gap: 14px; align-items: flex-start; }
  .check-row .ck { color: var(--green); font-weight: 700; font-size: 15px; line-height: 25.5px; width: 13px; flex: none; }
  .check-row .tx { flex: 1 0 0; min-width: 0; font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.5; }
  .check-sep  { height: 1px; background: var(--row-line); width: 100%; }

  /* ── Tables ──────────────────────────────────────────────────────── */
  .t-scroll { width: 100%; overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .table    { background: var(--card); border-radius: 24px; overflow: hidden; display: grid; }
  .table.bordered { border: 1px solid var(--card-border); }
  .t4 { grid-template-columns: repeat(4, minmax(0,1fr)); }
  .t5 { grid-template-columns: repeat(5, minmax(0,1fr)); }
  .cell { padding: 16px 24px; display: flex; align-items: center; justify-content: center; text-align: center; }
  .cell p { flex: 1 0 0; min-width: 0; font-size: 16px; line-height: 1.5; overflow-wrap: break-word; }
  .th { background: var(--olive-head); }
  .th p { font-weight: 600; color: #fff; }
  .th.hi p { color: var(--gold-2); }
  .tb { border-top: 1px solid var(--row-line); }
  .tb .k { font-weight: 600; color: var(--ink); }
  .tb .v { font-weight: 400; color: var(--ink-2); }
  .hi-cell { background: rgba(243,184,63,.06); }
  .hi-cell .v { color: var(--olive-title); font-weight: 500; }

  /* ── FD Calculator ───────────────────────────────────────────────── */
  .calc-card {
    background: var(--card);
    border: 1px solid var(--card-border);
    border-radius: 24px;
    padding: var(--container-pad);
    display: flex;
    gap: 48px;
    align-items: flex-start;
  }
  .calc-inputs { flex: 1 1 0; min-width: 0; display: flex; flex-direction: column; gap: 32px; }
  .calc-field { display: flex; flex-direction: column; gap: 10px; }
  .calc-label-row { display: flex; justify-content: space-between; align-items: center; }
  .calc-label-row label { font-weight: 500; font-size: 15px; color: var(--ink); }
  .calc-val { font-weight: 600; font-size: 15px; color: var(--olive-title); }
  .calc-slider {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 4px;
    border-radius: 2px;
    background: var(--card-border);
    outline: none;
    cursor: pointer;
  }
  .calc-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 18px; height: 18px;
    border-radius: 50%;
    background: var(--gold-btn);
    border: 2px solid var(--olive-ink);
    cursor: pointer;
    box-shadow: 0 1px 4px rgba(0,0,0,.18);
  }
  .calc-slider::-moz-range-thumb {
    width: 18px; height: 18px;
    border-radius: 50%;
    background: var(--gold-btn);
    border: 2px solid var(--olive-ink);
    cursor: pointer;
  }
  .calc-range-ends { display: flex; justify-content: space-between; font-size: 12px; color: var(--muted-2); }

  .calc-output { display: flex; flex-direction: column; gap: 24px; align-items: center; flex: none; width: 240px; }
  .donut-wrap { position: relative; width: 160px; height: 160px; }
  .donut { width: 160px; height: 160px; transform: rotate(-90deg); }
  .donut-track { fill: none; stroke: rgba(28,28,22,.1); stroke-width: 16; }
  .donut-fill  { fill: none; stroke: var(--gold-btn); stroke-width: 16; stroke-linecap: round; stroke-dasharray: 0 314; transition: stroke-dasharray .5s ease; }
  .donut-center { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2px; }
  .donut-label  { font-size: 11px; font-weight: 500; color: var(--muted); text-transform: uppercase; letter-spacing: .5px; }
  .donut-amount { font-size: 18px; font-weight: 700; color: var(--olive-title); line-height: 1.3; }

  .calc-results { width: 100%; display: flex; flex-direction: column; gap: 12px; }
  .cr-row { display: flex; align-items: center; gap: 10px; }
  .cr-dot { width: 10px; height: 10px; border-radius: 50%; flex: none; }
  .cr-label { flex: 1 0 0; font-size: 14px; color: var(--ink-3); }
  .cr-val   { font-weight: 600; font-size: 14px; color: var(--ink); }
  .cr-sep { height: 1px; background: var(--row-line); }
  .cr-row.total .cr-label { font-weight: 600; color: var(--ink); }
  .cr-row.total .cr-val   { color: var(--olive-title); font-size: 16px; }

  /* ── Demat CTA Banner ────────────────────────────────────────────── */
  .demat-banner {
    padding: 72px var(--pad);
    background: var(--sec-tint);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
  }
  .banner-title { font-weight: 400; font-size: 40px; color: var(--olive-title); line-height: 1.5; }
  .banner-sub   { font-weight: 400; font-size: 16px; color: var(--ink-3); max-width: 440px; }

  /* ── FAQ ─────────────────────────────────────────────────────────── */
  .faq-wrap { padding: var(--section-y) var(--pad); background: #FFFCF3; display: flex; flex-direction: column; justify-content: center; }
  .faq-cols  { display: flex; gap: 48px; align-items: stretch; }
  .faq-left  { flex: 1 0 0; min-width: 0; display: flex; flex-direction: column; gap: 32px; }
  .faq-title { font-weight: 700; font-size: 38px; color: #222320; line-height: 1.3; }
  .faq-acc   { display: flex; flex-direction: column; gap: 8px; width: 100%; }
  .faq-item  { background: #f8f4e8; border-radius: 0; }
  .faq-item:first-child { border-radius: 24px 24px 0 0; }
  .faq-item:last-child  { border-radius: 0 0 24px 24px; }
  .faq-sum   { display: flex; align-items: flex-start; justify-content: space-between; gap: 40px; padding: 20px 24px; cursor: pointer; list-style: none; }
  .faq-sum::-webkit-details-marker { display: none; }
  .faq-item .qt { font-weight: 500; font-size: 15px; color: #222320; line-height: 1.5; flex: 1; }
  .faq-item[open] .qt { font-weight: 600; }
  .faq-icon  { width: 16px; height: 16px; flex: none; color: #222320; }
  .faq-v     { transition: opacity .28s ease; }
  .faq-item[open] .faq-v { opacity: 0; }
  .qa { padding: 0 24px 20px; }
  .qa p { font-weight: 400; font-size: 14px; color: #5a5a5a; line-height: 1.6; }
  .faq-side {
    width: 300px;
    flex: none;
    background: #4f583b;
    border: 1px solid rgba(255,255,255,.12);
    border-radius: 24px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .side-in  { display: flex; flex-direction: column; gap: 20px; }
  .side-tx  { display: flex; flex-direction: column; gap: 10px; color: #fff; }
  .side-tx h4 { font-weight: 600; font-size: 20px; line-height: 28px; }
  .side-tx p  { font-weight: 400; font-size: 14px; line-height: 1.6; color: rgba(255,255,255,.74); }

  /* ── Final CTA ───────────────────────────────────────────────────── */
  .cta-sec { padding: var(--section-y) var(--pad); }
  .cta-box {
    border-radius: 22px;
    padding: 64px 60px;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 32px; text-align: center;
  }
  .ct-tt { display: flex; flex-direction: column; align-items: center; gap: 16px; color: var(--olive-deep); }
  .cta-box h3 { font-weight: 500; font-size: 38px; line-height: 1.3; letter-spacing: -0.76px; }
  .ct-sub { font-weight: 400; font-size: 17px; line-height: 1.65; color: var(--ink-2); max-width: 480px; }

  /* ── Responsive ──────────────────────────────────────────────────── */
  @media (max-width: 1100px) {
    .hero-panel { width: min(460px, 100%); }
    .calc-card { flex-direction: column; }
    .calc-output { flex-direction: row; width: 100%; justify-content: center; align-items: flex-start; }
    .calc-results { width: auto; flex: 1; }
  }

  @media (max-width: 900px) {
    .hero-inner { flex-direction: column; }
    .hero-panel { width: 100%; margin-top: 0; }
    .steps { flex-direction: column; }
    .step-div { width: auto; height: 1px; background: var(--card-border); }
    .faq-cols { flex-direction: column; }
    .faq-side { width: 100%; }
    .row-2 { flex-direction: column; }
  }

  @media (max-width: 768px) {
    :root { --pad: 16px; --container-pad: 24px; --section-y: 56px; }
    .hero-inner { padding: 80px 0 48px; }
    .hero h1 { font-size: clamp(28px, 7vw, 40px); }
    .hero .lead { font-size: 16px; }
    .sec-title, .faq-title, .banner-title { font-size: clamp(28px, 7vw, 40px); }
    .sub-title { font-size: clamp(20px, 5.4vw, 24px); }
    .sec-lead, .sub-lead, .card-p, .step p, .check-row .tx, .cell p, .banner-sub { font-size: 14px; }
    .cell { padding: 12px 8px; }
    .cta-box { padding: 48px 24px; }
    .cta-box h3 { font-size: clamp(24px, 6.4vw, 38px); }
    .calc-output { flex-direction: column; align-items: center; }
    .calc-results { width: 100%; }
  }

  @media (max-width: 560px) {
    .t5 { grid-template-columns: repeat(5, minmax(120px, 1fr)); }
    .t4 { grid-template-columns: repeat(4, minmax(120px, 1fr)); }
    .faq-item { gap: 20px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .donut-fill { transition: none; }
    .faq-v { transition: none; }
  }
</style>

<script>
  /* Tenure tab toggle */
  document.querySelectorAll<HTMLButtonElement>('[data-tab]').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.closest('.tenure-tabs')?.querySelectorAll('[data-tab]').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    });
  });

  /* FD Calculator */
  (function () {
    const pInput  = document.getElementById('c-principal') as HTMLInputElement;
    const rInput  = document.getElementById('c-rate')      as HTMLInputElement;
    const tInput  = document.getElementById('c-tenure')    as HTMLInputElement;
    const pVal    = document.getElementById('c-principal-val')!;
    const rVal    = document.getElementById('c-rate-val')!;
    const tVal    = document.getElementById('c-tenure-val')!;
    const matEl   = document.getElementById('c-maturity')!;
    const invEl   = document.getElementById('c-invested')!;
    const retEl   = document.getElementById('c-returns')!;
    const totEl   = document.getElementById('c-total')!;
    const donut   = document.getElementById('c-donut')!;
    const CIRCUM  = 2 * Math.PI * 50;

    function fmt(n: number): string {
      if (n >= 10000000) return '₹' + (n / 10000000).toFixed(2) + ' Cr';
      if (n >= 100000)   return '₹' + (n / 100000).toFixed(2) + ' L';
      if (n >= 1000)     return '₹' + (n / 1000).toFixed(1) + 'K';
      return '₹' + Math.round(n).toLocaleString('en-IN');
    }

    function calc() {
      const P = parseFloat(pInput.value);
      const r = parseFloat(rInput.value) / 100;
      const t = parseFloat(tInput.value);
      const maturity = P * Math.pow(1 + r / 4, 4 * t);
      const returns  = maturity - P;

      pVal.textContent = '₹' + Math.round(P).toLocaleString('en-IN');
      rVal.textContent = parseFloat(rInput.value).toFixed(2) + '%';
      tVal.textContent = t + (t === 1 ? ' Year' : ' Years');
      matEl.textContent = fmt(maturity);
      invEl.textContent = fmt(P);
      retEl.textContent = fmt(returns);
      totEl.textContent = fmt(maturity);

      const dash = (returns / maturity) * CIRCUM;
      (donut as SVGCircleElement).style.strokeDasharray = dash + ' ' + CIRCUM;
    }

    [pInput, rInput, tInput].forEach(el => el?.addEventListener('input', calc));
    calc();
  })();

  /* FAQ accordion — one open at a time */
  document.querySelectorAll('.faq-acc').forEach(acc => {
    acc.querySelectorAll('details').forEach(d => {
      d.addEventListener('toggle', () => {
        if ((d as HTMLDetailsElement).open) {
          acc.querySelectorAll<HTMLDetailsElement>('details').forEach(o => {
            if (o !== d) o.removeAttribute('open');
          });
        }
      });
    });
  });
</script>
