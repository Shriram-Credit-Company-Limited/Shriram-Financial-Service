---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Fixed Deposit in India — FD Interest Rates 2025 | Shriram"
  description="Invest in fixed deposit in India. Compare FD interest rates 2025, types of FD, FD calculator, tax on FD returns. Open FD online with Shriram Financial Services."
>

  <!-- ══ S1. HERO ══════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[var(--color-dark-800)] py-[100px] lg:py-[120px]">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[560px] w-[560px] rounded-full bg-[var(--color-brand)]/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-32 left-0 h-80 w-80 rounded-full bg-[var(--color-brand)]/5 blur-3xl"></div>
    <div class="site-wrap relative">
      <h1 class="equity-reveal max-w-[880px] text-[clamp(32px,4vw,52px)] font-bold leading-[1.06] text-white" style="font-family:var(--font-display)">
        Invest in <span class="text-[var(--color-brand)]">Fixed Deposit</span> in India — Guaranteed Returns
      </h1>
      <p class="equity-reveal mt-[26px] max-w-[600px] text-[18px] leading-relaxed text-white/70">
        Earn guaranteed returns on your savings with FDs. DICGC-insured bank FDs and competitive NBFC FD rates. Compare FD rates and invest online in minutes.
      </p>
      <div class="equity-reveal mt-[38px] flex flex-wrap gap-[14px]">
        <a href="/about/open-demat-account/" class="btn-primary">Open Fixed Deposit</a>
        <a href="/about/open-demat-account/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Compare FD Rates</a>
      </div>
      <div class="equity-reveal mt-[54px] flex flex-wrap gap-x-9 gap-y-3 border-t border-white/15 pt-9">
        {['✓ DICGC-insured (bank FDs)', '✓ Guaranteed returns', '✓ Flexible tenure', '✓ Senior citizen benefits'].map(f => (
          <span class="text-[15px] font-medium text-white/90">{f}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S2. WHAT IS FIXED DEPOSIT? ═══════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          What is <span class="text-[var(--color-brand)]">Fixed Deposit?</span> — Definition &amp; Meaning
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">
          A Fixed Deposit (FD) is a savings instrument where you deposit a lump sum for a fixed tenure at a pre-agreed interest rate. Your principal and returns are fully guaranteed.
        </p>
      </div>
      <div class="equity-reveal grid gap-5 sm:grid-cols-3">
        {[
          { title: 'Guaranteed Returns', desc: 'Interest rate fixed at the time of deposit — not market-linked.' },
          { title: 'Capital Safety', desc: 'Bank FDs insured by DICGC up to ₹5 lakh per bank.' },
          { title: 'Flexible Tenure', desc: 'Choose from 7 days to 10 years based on your financial goal.' },
        ].map(c => (
          <div class="product-card-light px-[28px] py-[32px]">
            <h3 class="mb-3 text-[17px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{c.title}</h3>
            <p class="text-[14px] leading-relaxed text-[var(--color-muted)]">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S2b. FD vs SAVINGS ACCOUNT vs RD ═════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          FD vs Savings Account <span class="text-[var(--color-brand)]">vs Recurring Deposit</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">
          Choose the right savings instrument — FDs, savings accounts, and recurring deposits serve different financial goals.
        </p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[14.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[22px] py-[16px] text-left text-[13px] font-semibold text-white">Feature</th>
                <th class="px-[22px] py-[16px] text-left text-[13px] font-semibold text-[var(--color-brand)]">Fixed Deposit (FD)</th>
                <th class="px-[22px] py-[16px] text-left text-[13px] font-semibold text-white/80">Savings Account</th>
                <th class="px-[22px] py-[16px] text-left text-[13px] font-semibold text-white/80">Recurring Deposit (RD)</th>
              </tr>
            </thead>
            <tbody>
              {[
                { feature: 'Investment Type', fd: 'Lump sum deposit', savings: 'Any-time deposit/withdraw', rd: 'Fixed monthly installments' },
                { feature: 'Interest Rate (p.a.)', fd: '6.5–9.4% (fixed at deposit)', savings: '2.5–7% (variable)', rd: '5.5–8% (fixed at opening)' },
                { feature: 'Liquidity', fd: 'Low — penalty on early exit', savings: 'High — withdraw anytime', rd: 'Low — penalty on premature closure' },
                { feature: 'Minimum Deposit', fd: '₹1,000 (varies by bank)', savings: '₹0–₹10,000 (MAB)', rd: '₹100/month' },
                { feature: 'Tenure', fd: '7 days – 10 years', savings: 'No tenure — ongoing', rd: '6 months – 10 years' },
                { feature: 'DICGC Insurance', fd: 'Up to ₹5 lakh', savings: 'Up to ₹5 lakh', rd: 'Up to ₹5 lakh' },
                { feature: 'Tax on Returns', fd: 'TDS on interest > ₹40K/yr', savings: 'TDS on interest > ₹10K/yr', rd: 'TDS on maturity interest' },
                { feature: 'Best For', fd: 'Lump sum, fixed-term goals', savings: 'Daily expenses, emergency fund', rd: 'Monthly savers, disciplined saving' },
              ].map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[22px] py-[14px] font-semibold text-[var(--color-ink)]">{r.feature}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[22px] py-[14px] font-medium text-[var(--color-brand-deep)]">{r.fd}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[22px] py-[14px] text-[var(--color-muted)]">{r.savings}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[22px] py-[14px] text-[var(--color-muted)]">{r.rd}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S3. HOW FIXED DEPOSITS WORK ══════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How <span class="text-[var(--color-brand)]">Fixed Deposits</span> Work — Compounding &amp; Interest
        </h2>
      </div>
      <div class="equity-reveal steps-grid overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        {[
          { n: '01', title: 'Choose FD', desc: 'Select bank/NBFC, tenure (e.g., 1 year), and payout type (cumulative or non-cumulative).' },
          { n: '02', title: 'Deposit Amount', desc: 'Transfer the principal amount. Min deposit: ₹1,000 (varies by institution).' },
          { n: '03', title: 'Interest Accrues', desc: 'Interest compounds quarterly (cumulative) or pays out monthly/quarterly (non-cumulative).' },
          { n: '04', title: 'Maturity Payout', desc: 'On maturity, receive principal + interest. Auto-renew or withdraw as needed.' },
        ].map(s => (
          <div class="px-[30px] py-[34px]">
            <div class="mb-[22px] text-[34px] font-bold leading-none text-[var(--color-brand)]">{s.n}</div>
            <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">{s.title}</h4>
            <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S4. FD INTEREST RATES — CURRENT RATES 2025 ════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          FD Interest Rates — <span class="text-[var(--color-brand)]">Current Rates 2025</span>
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">
          Indicative FD rates for general citizens and senior citizens.
        </p>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[15.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-white">Institution</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Tenure</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">General Rate (p.a.)</th>
                <th class="px-[26px] py-[17px] text-left text-[14px] font-semibold text-[var(--color-brand)]">Senior Citizen Rate (p.a.)</th>
              </tr>
            </thead>
            <tbody>
              {[
                { inst: 'SBI', tenure: '1 Year', general: '6.80%', senior: '7.30%' },
                { inst: 'HDFC Bank', tenure: '1 Year', general: '7.10%', senior: '7.60%' },
                { inst: 'ICICI Bank', tenure: '1 Year', general: '7.10%', senior: '7.60%' },
                { inst: 'Axis Bank', tenure: '1 Year', general: '7.10%', senior: '7.85%' },
                { inst: 'Small Finance Bank', tenure: '1 Year', general: '7.75–9.00%', senior: '8.25–9.50%' },
                { inst: 'Shriram Finance NBFC', tenure: '1–5 Year', general: '8.50–9.40%', senior: '8.95–9.90%' },
              ].map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-semibold text-[var(--color-ink)]">{r.inst}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.tenure}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] text-[var(--color-muted)]">{r.general}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[26px] py-[17px] font-medium text-[var(--color-dark-olive)]">{r.senior}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
      <p class="mt-4 text-[13px] text-[var(--color-muted)]">* Rates are indicative as of June 2025. Verify current rates before investing.</p>
    </div>
  </section>

  <!-- ══ S5. TYPES OF FIXED DEPOSITS ══════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          Types of <span class="text-[var(--color-brand)]">Fixed Deposits</span> in India
        </h2>
      </div>
      <div class="equity-reveal overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        <div class="overflow-x-auto">
          <table class="w-full text-[14.5px]">
            <thead>
              <tr class="bg-[var(--color-dark-olive)]">
                <th class="px-[20px] py-[16px] text-left text-[13px] font-semibold text-white">FD Type</th>
                <th class="px-[20px] py-[16px] text-left text-[13px] font-semibold text-[var(--color-brand)]">Interest</th>
                <th class="px-[20px] py-[16px] text-left text-[13px] font-semibold text-[var(--color-brand)]">Tenure</th>
                <th class="px-[20px] py-[16px] text-left text-[13px] font-semibold text-[var(--color-brand)]">Tax</th>
                <th class="px-[20px] py-[16px] text-left text-[13px] font-semibold text-[var(--color-brand)]">Best For</th>
              </tr>
            </thead>
            <tbody>
              {[
                { type: 'Cumulative FD', interest: 'Compounded, paid at maturity', tenure: '7 days – 10 years', tax: 'TDS on interest', best: 'Long-term savings' },
                { type: 'Non-Cumulative FD', interest: 'Paid monthly/quarterly', tenure: '7 days – 10 years', tax: 'TDS on interest', best: 'Regular income needs' },
                { type: 'Tax Saving FD', interest: '~7% (banks)', tenure: '5 years (lock-in)', tax: '80C deduction ₹1.5L', best: 'Tax-saving under 80C' },
                { type: 'Senior Citizen FD', interest: 'Extra 0.25–0.50% over general', tenure: 'Same as regular', tax: 'TDS applies', best: 'Retired investors' },
                { type: 'NRI FD (NRE/FCNR)', interest: 'Market rate', tenure: '1–5 years', tax: 'Tax-free in India (NRE)', best: 'NRI investors' },
              ].map((r, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-[#f8f6f1]'}>
                  <td class="border-t border-[var(--color-n400)]/50 px-[20px] py-[15px] font-semibold text-[var(--color-ink)]">{r.type}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[20px] py-[15px] text-[var(--color-muted)]">{r.interest}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[20px] py-[15px] text-[var(--color-muted)]">{r.tenure}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[20px] py-[15px] text-[var(--color-muted)]">{r.tax}</td>
                  <td class="border-t border-[var(--color-n400)]/50 px-[20px] py-[15px] text-[var(--color-muted)]">{r.best}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S6. FD INTEREST CALCULATOR ═══════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          FD <span class="text-[var(--color-brand)]">Interest Calculator</span> — Calculate Maturity Amount
        </h2>
        <p class="mt-[18px] text-[17px] leading-relaxed text-[var(--color-muted)]">
          Use our FD calculator to estimate your maturity amount based on deposit amount, rate, and tenure.
        </p>
      </div>
      <div class="equity-reveal mx-auto max-w-[760px]">
        <div class="product-card-light px-[28px] py-[32px]">
          <div class="mb-6 rounded-[10px] bg-[#f8f6f1] p-5 font-mono text-[15px] text-[var(--color-ink)]">
            <div class="mb-2 font-bold">Maturity Amount (Cumulative) = P × (1 + r/n)^(n×t)</div>
            <div class="mt-3 space-y-1 text-[13px] text-[var(--color-muted)]">
              <div><strong class="text-[var(--color-ink)]">P</strong> = Principal</div>
              <div><strong class="text-[var(--color-ink)]">r</strong> = Annual Interest Rate</div>
              <div><strong class="text-[var(--color-ink)]">n</strong> = Compounding frequency (4 for quarterly)</div>
              <div><strong class="text-[var(--color-ink)]">t</strong> = Tenure in years</div>
            </div>
          </div>
          <p class="mb-6 text-[14px] leading-relaxed text-[var(--color-muted)]">
            <strong class="text-[var(--color-ink)]">Example:</strong> ₹1,00,000 at 8.50% for 2 years (quarterly) = <strong class="text-[var(--color-dark-olive)]">₹1,18,197 at maturity</strong>
          </p>
          <a href="/calculators/" class="btn-primary inline-flex items-center gap-2">Calculate FD Returns →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S7. FD BENEFITS & FEATURES ═══════════════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          FD <span class="text-[var(--color-brand)]">Benefits &amp; Features</span> — Why Invest in Fixed Deposit
        </h2>
      </div>
      <div class="equity-reveal grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { title: 'Capital Safety', desc: 'Bank FDs up to ₹5 lakh protected by DICGC insurance. NBFC FDs are uninsured but RBI-regulated.' },
          { title: 'Predictable Returns', desc: 'Interest rate locked at deposit — no market risk. Know exactly what you earn.' },
          { title: 'Loan Against FD', desc: 'Get up to 90% of FD amount as an overdraft. No need to break your FD early.' },
          { title: 'Senior Citizen Benefits', desc: 'Extra 0.25–0.50% over general rates. Special senior citizen deposit schemes available.' },
        ].map(c => (
          <div class="product-card-light px-[28px] py-[32px]">
            <h3 class="mb-3 text-[17px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{c.title}</h3>
            <p class="text-[14px] leading-relaxed text-[var(--color-muted)]">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S8. PREMATURE WITHDRAWAL & LOAN AGAINST FD ════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          FD <span class="text-[var(--color-brand)]">Premature Withdrawal</span> &amp; Loan Against FD
        </h2>
      </div>
      <div class="equity-reveal grid gap-5 sm:grid-cols-2">
        <div class="product-card-light px-[28px] py-[32px]">
          <h3 class="mb-3 text-[20px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">Premature Withdrawal</h3>
          <p class="text-[14px] leading-relaxed text-[var(--color-muted)]">Break your FD before maturity at a penalty (typically 0.50–1.00% below applicable rate). Example: ₹1L FD at 7.5% for 2 years, broken at 18 months → earns ~6.5–7.0% for 18 months only.</p>
        </div>
        <div class="product-card-light px-[28px] py-[32px]">
          <h3 class="mb-3 text-[20px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">Loan Against FD</h3>
          <p class="text-[14px] leading-relaxed text-[var(--color-muted)]">Get an overdraft facility of up to 90% of FD value at FD rate + 1–2%. Better than breaking FD since your FD continues to earn interest while you use the loan.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ S9. HOW TO OPEN A FIXED DEPOSIT ONLINE ════════════════════════ -->
  <section class="bg-white py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          How to <span class="text-[var(--color-brand)]">Open Fixed Deposit</span> Online — Step by Step
        </h2>
      </div>
      <div class="equity-reveal steps-grid overflow-hidden rounded-[14px] border border-[var(--color-n400)]">
        {[
          { n: '01', title: 'Choose Institution', desc: 'Compare FD rates. Select bank or NBFC based on rate and safety.' },
          { n: '02', title: 'Complete KYC', desc: 'One-time PAN + Aadhaar-based digital KYC.' },
          { n: '03', title: 'Choose Tenure & Amount', desc: 'Select deposit amount, tenure, and payout type (cumulative or non-cumulative).' },
          { n: '04', title: 'Fund Your FD', desc: 'Transfer funds via net banking or UPI. Receive FD receipt (digital or physical).' },
        ].map(s => (
          <div class="px-[30px] py-[34px]">
            <div class="mb-[22px] text-[34px] font-bold leading-none text-[var(--color-brand)]">{s.n}</div>
            <h4 class="mb-[10px] text-[19px] font-medium leading-[1.25] text-[var(--color-ink)]" style="font-family:var(--font-display)">{s.title}</h4>
            <p class="text-[14.5px] leading-relaxed text-[var(--color-muted)]">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ S10. FAQs — FIXED DEPOSIT INDIA ══════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-[104px]">
    <div class="site-wrap">
      <div class="equity-reveal mx-auto mb-[56px] max-w-[760px] text-center">
        <h2 class="text-[42px] font-bold leading-[1.12] text-[var(--color-ink)]" style="font-family:var(--font-display)">
          FAQs — <span class="text-[var(--color-brand)]">Fixed Deposit</span> India
        </h2>
      </div>
      <div class="equity-reveal mx-auto max-w-[840px] border-t border-[var(--color-n400)]">
        {[
          { q: 'Is FD safe in India?', a: 'Bank FDs up to ₹5 lakh per bank are insured by DICGC (Deposit Insurance & Credit Guarantee Corporation). NBFC FDs are not DICGC-insured but regulated by RBI.' },
          { q: 'Is FD interest taxable?', a: 'Yes. FD interest is added to your income and taxed at your income slab rate. TDS at 10% is deducted by the bank if interest exceeds ₹40,000 (₹50,000 for senior citizens) per year.' },
          { q: 'What is the maximum FD insurance amount?', a: 'DICGC insures up to ₹5 lakh per depositor per bank — including principal and interest across all accounts at that bank.' },
          { q: 'Can I break FD before maturity?', a: 'Yes, with a premature withdrawal penalty of 0.50–1.00% below the applicable rate for the period held.' },
          { q: 'What is a Tax Saving FD?', a: 'A 5-year lock-in FD eligible for ₹1.5 lakh deduction under Section 80C. Interest is taxable. Premature withdrawal not allowed.' },
          { q: 'What is the difference between cumulative and non-cumulative FD?', a: 'Cumulative FD pays out principal + compounded interest at maturity. Non-cumulative FD pays interest monthly/quarterly — better for regular income.' },
          { q: 'Is senior citizen FD rate higher?', a: 'Yes. Senior citizens (60+ years) get 0.25–0.50% higher rate than the regular rate on most FDs.' },
          { q: 'Can NRIs invest in FDs in India?', a: 'Yes — through NRE FDs (interest tax-free in India, fully repatriable) or NRO FDs (interest taxable). FCNR FDs are denominated in foreign currency.' },
        ].map(item => (
          <details class="eq-faq group border-b border-[var(--color-n400)]">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-5 py-[26px] px-2">
              <span class="text-[18px] font-semibold text-[var(--color-ink)]">{item.q}</span>
              <span class="shrink-0 text-[22px] leading-none text-[var(--color-brand)] transition-transform duration-300 group-open:rotate-45">+</span>
            </summary>
            <div class="overflow-hidden px-2 pb-0 text-[16px] leading-relaxed text-[var(--color-muted)] transition-all duration-300 group-open:pb-[28px]">
              <p class="max-w-[680px]">{item.a}</p>
            </div>
          </details>
        ))}
      </div>

      <!-- Dark CTA block after FAQs -->
      <div class="equity-reveal mt-[56px] overflow-hidden rounded-[22px] bg-[var(--color-dark-800)] px-[60px] py-[64px] text-center">
        <h3 class="mx-auto max-w-[560px] text-[38px] font-bold leading-[1.12] text-white" style="font-family:var(--font-display)">Open Fixed Deposit Online — Guaranteed Returns</h3>
        <div class="mt-[34px] flex flex-wrap justify-center gap-[14px]">
          <a href="/about/open-demat-account/" class="btn-primary">Open FD</a>
          <a href="/about/open-demat-account/" class="inline-flex h-12 items-center justify-center rounded-[9px] border border-white/40 px-[26px] text-[15px] font-semibold text-white transition-colors hover:border-white">Compare Rates</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .equity-reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s cubic-bezier(0.22, 0.61, 0.36, 1), transform 0.7s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .equity-reveal.in-view { opacity: 1; transform: none; }

  .steps-grid { display: grid; grid-template-columns: repeat(2, 1fr); }
  .steps-grid > * { border-right: 1px solid var(--color-n400); border-bottom: 1px solid var(--color-n400); }
  .steps-grid > *:nth-child(2n) { border-right: 0; }
  .steps-grid > *:nth-last-child(-n+2) { border-bottom: 0; }
  @media (min-width: 1024px) {
    .steps-grid { grid-template-columns: repeat(4, 1fr); }
    .steps-grid > * { border-right: 1px solid var(--color-n400); border-bottom: 0; }
    .steps-grid > *:last-child { border-right: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .equity-reveal { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).classList.add('in-view');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.10 });
  document.querySelectorAll('.equity-reveal').forEach(el => obs.observe(el));

  document.querySelectorAll<HTMLDetailsElement>('.eq-faq').forEach(d => {
    d.addEventListener('toggle', () => {
      if (d.open) document.querySelectorAll<HTMLDetailsElement>('.eq-faq').forEach(o => { if (o !== d) o.removeAttribute('open'); });
    });
  });
</script>
