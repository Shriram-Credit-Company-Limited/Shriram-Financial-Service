---
import BaseLayout from '../layouts/BaseLayout.astro';

// ── Feature cards ("Everything you need to trade with confidence") ──
const features = [
  { icon: '⌗',  title: 'Swift, Safe & Convenient',                 body: 'Fast, secure and easy online trading from wherever you are.' },
  { icon: '⚡', title: 'Trade Anytime Anywhere',                    body: 'Place orders without geographical limits, including after market hours.' },
  { icon: '🔗', title: 'One solution for all markets',              body: 'Trade Equity, Derivatives and Currency from a single login.' },
  { icon: '🛡️', title: 'Platforms for beginners & active investors', body: "The right platform whether you're just starting out or trading actively." },
  { icon: '📞', title: 'Trained Relationship Manager',              body: 'Dedicated support and advice through your relationship manager.' },
  { icon: '🧭', title: "Call 'n' Trade facility",                   body: "Place orders over the phone while you're on the move." },
  { icon: '👤', title: 'Real-time limit enhancement',              body: 'Funds transferred reflect instantly so you can trade without delay.' },
  { icon: '🔬', title: 'Quality Research and Advisory',            body: 'Backed by sound in-house research to support informed decisions.' },
  { icon: '💬', title: 'Competitive brokerage',                    body: 'Among the most competitive rates, with no hidden charges.' },
  { icon: '🗄️', title: 'Online access to accounts and depository', body: 'Manage your trading account and depository online, anytime.' },
];

// ── "Why Karnataka Bank customers choose us" ──
const reasons = [
  { title: 'Integrated 3-in-1 Account', body: 'The 3-in-1 account comprises your Karnataka Bank Savings Bank account, Karnataka Bank Demat account (both internet-enabled), and an online trading account with Shriram Financial Services. All three are integrated, and thus called a 3-in-1 account.' },
  { title: 'Option to link existing Karnataka Bank Savings', body: 'If you are an existing client of Karnataka Bank with a Karnataka Bank savings account, you need to have it internet-enabled along with an online trading account from Shriram Financial Services.' },
  { title: 'Single Screen Trading for Multiple Products', body: 'Equity, Derivatives, Commodities & Currency Futures. With your Karnataka Bank–Shriram online trading account, you can trade in different segments (subject to activation) simultaneously, giving you the opportunity to keep watch of different markets at the same time.' },
  { title: 'Competitive Brokerage', body: 'Karnataka Bank presents its clients with one of the most competitive brokerage rates. You can rest assured that you are in safe hands and there are no hidden charges involved.' },
];
---

<BaseLayout
  title="Karnataka Bank 3-in-1 Trading Account — Online Trading with Shriram"
  description="Trade online with your Karnataka Bank 3-in-1 account — link your Karnataka Bank savings and demat accounts to a Shriram trading account for seamless, research-backed investing across Equity, Derivatives and Currency."
>

  <!-- ══ 1. HERO ══════════════════════════════════════════════════════ -->
  <section class="kb-hero" id="kb-hero">
    <div class="kb-hero-in">
      <!-- Left: copy -->
      <div class="kb-hero-left">
        <h1>Trade online with your <span class="g">Karnataka Bank</span> 3-in-1 account</h1>
        <p class="lead">A special online trading facility for Karnataka Bank customers — link your existing Bank and Demat accounts to a Shriram trading account and invest seamlessly, with research and support at hand.</p>

        <div class="kb-logos">
          <span class="kb-logo-box"><img src="/logo-shriram.svg" alt="Shriram Financial Services" /></span>
          <span class="kb-logo-box"><img src="/karnataka-bank-logo.png" alt="Karnataka Bank" /></span>
        </div>

        <div class="feats">
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;SEBI-registered</span></div>
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;Research-led</span></div>
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;Full-service</span></div>
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;Transparent</span></div>
        </div>
      </div>

      <!-- Right: form card -->
      <div class="kb-form">
        <h3 class="kb-form-h">Open Your Demat Account</h3>
        <div class="kb-field">
          <label for="kb-name">Full Name</label>
          <input id="kb-name" type="text" autocomplete="name" placeholder="e.g. Ritesh Kumar" />
        </div>
        <div class="kb-field">
          <label for="kb-mobile">Mobile Number</label>
          <input id="kb-mobile" type="tel" inputmode="numeric" autocomplete="tel" placeholder="+91 80981 22853" />
        </div>
        <div class="kb-field">
          <label for="kb-city">City</label>
          <input id="kb-city" type="text" autocomplete="address-level2" placeholder="e.g. Mumbai" />
        </div>
        <button id="kb-submit" type="button" class="btn-gold kb-submit">Get Started&nbsp;→</button>
        <p class="kb-consent">By submitting, you authorise Shriram Financial Services to contact you regarding the Karnataka Bank trading facility, overriding any DND/NDNC registration.</p>
      </div>
    </div>
  </section>

  <!-- ══ 2. FEATURES ══════════════════════════════════════════════════ -->
  <section class="section stack" id="kb-features" style="background:var(--sec-light);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Everything You Need to Trade With Confidence</h2>
      <p class="sec-lead">Swift, safe and convenient online trading designed for both first-time investors and active traders.</p>
    </div>
    <div class="kb-feat-grid">
      {features.map(f => (
        <article class="card">
          <div class="kb-ic" aria-hidden="true">{f.icon}</div>
          <h4 class="card-h">{f.title}</h4>
          <p class="card-p">{f.body}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- ══ 3. WHY CHOOSE US ═════════════════════════════════════════════ -->
  <section class="section stack" id="kb-why" style="background:var(--sec-tint);gap:56px;justify-content:center">
    <div class="stack" style="gap:16px">
      <h2 class="sec-title">Why Karnataka Bank Customers Choose Us</h2>
      <p class="sec-lead">An integrated 3-in-1 experience that keeps your banking, demat and trading working together.</p>
    </div>
    <div class="kb-why-grid">
      {reasons.map(r => (
        <article class="card kb-why-card">
          <h4 class="card-h">{r.title}</h4>
          <p class="card-p">{r.body}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- ══ 4. FINAL CTA ═════════════════════════════════════════════════ -->
  <section class="cta-sec" id="kb-cta" style="background:var(--sec-light)">
    <div class="cta-box">
      <div class="ct-tt">
        <h3>Open Your Karnataka Bank 3-in-1 Account</h3>
        <p class="ct-sub">Link your Karnataka Bank savings and demat accounts to a Shriram trading account — and start investing in minutes.</p>
      </div>
      <a class="btn-gold" href="#kb-hero">Get Started</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ══ Karnataka Bank co-brand page — equity design system ══════════════
     Reuses the DS tokens/classes (.hero gradient, .card, .sec-title,
     .btn-gold, .feats); page-scoped rules only for the 2-col hero, the
     translucent form on the olive hero, icon chips and the card grids.    */

  /* Hero — equity olive gradient, two columns */
  .kb-hero {
    padding: 0 var(--pad);
    display: flex;
    overflow: hidden;
    background: radial-gradient(125% 210% at 100% -8%, #4f583b 0%, #363a2c 50%, #1d1d1d 100%);
  }
  .kb-hero-in {
    width: 100%;
    display: flex;
    gap: 56px;
    align-items: center;
    padding: 72px 0;
  }
  .kb-hero-left { flex: 1 1 0; min-width: 0; display: flex; flex-direction: column; }

  .kb-hero-left h1 {
    font-weight: 500; font-size: clamp(30px, 4vw, 44px); line-height: 1.15;
    letter-spacing: -0.5px; color: #fff; max-width: 13ch;
  }
  .kb-hero-left h1 .g { color: var(--gold-2); }
  .kb-hero-left .lead {
    margin-top: 16px; font-weight: 400; font-size: 18px; line-height: 1.5;
    color: rgba(255,255,255,.74); max-width: 620px;
  }

  .kb-logos { margin-top: 32px; display: flex; flex-wrap: wrap; gap: 16px; }
  .kb-logo-box {
    background: #fff; border-radius: 10px; height: 60px; padding: 8px 18px;
    display: inline-flex; align-items: center; justify-content: center;
  }
  .kb-logo-box img { height: 100%; width: auto; object-fit: contain; display: block; }

  /* trust badges use the DS .feats/.feat rule (global); constrain width here */
  .kb-hero-left .feats { margin-top: 32px; max-width: 620px; }

  /* Form card on the olive hero */
  .kb-form {
    flex: none; width: 464px; align-self: center;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.16);
    border-radius: 24px;
    padding: 32px 32px 36px;
    display: flex; flex-direction: column; gap: 16px;
  }
  .kb-form-h { font-weight: 500; font-size: 20px; line-height: 1.4; color: #fff; margin-bottom: 4px; }
  .kb-field { display: flex; flex-direction: column; gap: 6px; }
  .kb-field label { font-weight: 500; font-size: 12px; color: rgba(255,255,255,0.75); }
  .kb-field input {
    height: 46px; width: 100%; padding: 0 15px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 10px;
    font-family: inherit; font-size: 14px; color: #fff;
    outline: none; transition: border-color .15s ease, background .15s ease;
  }
  .kb-field input::placeholder { color: rgba(255,255,255,0.5); }
  .kb-field input:focus { border-color: var(--gold-2); background: rgba(255,255,255,0.14); }

  /* full-width gold CTA inside the form (overrides .btn-gold fixed width) */
  .kb-submit { width: 100%; height: 46px; margin-top: 4px; border-radius: 10px; font-size: 14px; }
  .kb-consent { font-weight: 400; font-size: 12px; line-height: 1.5; color: rgba(255,255,255,0.55); text-align: center; }

  /* Feature grid — DS .card children with a gold icon chip */
  .kb-feat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .kb-ic {
    width: 48px; height: 48px; border-radius: 12px;
    background: rgba(224,168,46,0.12); color: var(--gold);
    display: flex; align-items: center; justify-content: center; font-size: 22px;
  }

  /* Why-choose grid — DS .card with a gold left accent */
  .kb-why-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
  .kb-why-card { border-left: 4px solid var(--gold-2); gap: 12px; }

  /* ── Responsive ── */
  @media (max-width: 1024px) { .kb-feat-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 900px) {
    .kb-hero-in { flex-direction: column; align-items: stretch; gap: 40px; }
    .kb-form { width: 100%; align-self: stretch; }
    .kb-why-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) { .kb-hero-in { padding: 56px 0; } }
  @media (max-width: 600px) { .kb-feat-grid { grid-template-columns: 1fr; } }
</style>

<script>
  /* Form submit → AES-256-GCM enc_details (mobile_number, customer_name, city)
     + utm_source, same scheme as the homepage hero (see index.astro). */
  const $ = (id: string) => document.getElementById(id) as HTMLInputElement | null;
  const btn  = document.getElementById('kb-submit');
  const name = $('kb-name'), mob = $('kb-mobile'), city = $('kb-city');
  if (btn && mob) {
    const BASE_URL = 'https://signup.way2wealth.com/way2wealth/individual_new';
    const AES_KEY  = 'ShriramSFS2026Way2WealthAESKey01'; // 32 bytes → AES-256 (shared with way2wealth)
    const FALLBACK = BASE_URL;
    const subtle = (window.crypto && window.crypto.subtle) || null;

    const b64url = (bytes: ArrayBuffer): string =>
      btoa(String.fromCharCode(...new Uint8Array(bytes)))
        .replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');

    const encryptPayload = async (payload: object): Promise<string> => {
      const enc   = new TextEncoder();
      const key   = await subtle!.importKey('raw', enc.encode(AES_KEY), 'AES-GCM', false, ['encrypt']);
      const iv    = crypto.getRandomValues(new Uint8Array(12));
      const ctTag = await subtle!.encrypt({ name: 'AES-GCM', iv, tagLength: 128 }, key, enc.encode(JSON.stringify(payload)));
      const packed = new Uint8Array(iv.length + ctTag.byteLength);
      packed.set(iv, 0);
      packed.set(new Uint8Array(ctTag), iv.length);
      return b64url(packed.buffer);
    };

    btn.addEventListener('click', async () => {
      const digits = (mob.value || '').replace(/\D/g, '').slice(-10);
      if (digits.length !== 10 || !subtle) { window.location.href = FALLBACK; return; }
      const payload: Record<string, string> = { mobile_number: digits };
      if (name && name.value.trim()) payload.customer_name = name.value.trim();
      if (city && city.value.trim()) payload.city = city.value.trim();
      try {
        const token = await encryptPayload(payload);
        window.location.href = BASE_URL + '?enc_details=' + token + '&utm_source=' + encodeURIComponent('karnataka-bank');
      } catch {
        window.location.href = FALLBACK;
      }
    });
  }
</script>
