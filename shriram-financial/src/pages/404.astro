---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page not found" description="The page you were looking for could not be found.">
  <section class="section" style="background:var(--sec-light);align-items:center;text-align:center;min-height:clamp(440px,50vh,640px);justify-content:center;gap:16px">
    <p style="font-weight:400;font-size:88px;line-height:1;color:var(--gold)">404</p>
    <h1 class="sec-title" style="text-transform:none">Page Not Found</h1>
    <p class="sec-lead" style="max-width:520px">The page you're looking for doesn't exist or has been moved.</p>
    <div style="margin-top:24px;display:flex;flex-wrap:wrap;justify-content:center;gap:16px">
      <a href="/" class="btn-gold">Back to Home</a>
      <a href="/products/" class="btn-gold" style="background:transparent;border:1px solid var(--card-border);color:var(--ink)">Browse Products</a>
    </div>
  </section>
</BaseLayout>
