</section>

<!-- FINAL CTA -->
<section class="cta-sec" id="sec-final-cta" style="background:var(--sec-light)">
  <div class="cta-box gr-reveal">
    <div class="ct-tt">
      <h3>Still Not Resolved?</h3>
      <p class="ct-sub">If your complaint remains unresolved after escalation, reach our support team directly or escalate to the SEBI SCORES portal.</p>
