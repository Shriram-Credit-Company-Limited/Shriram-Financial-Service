</section>

<button class="to-top" aria-label="Back to top"><svg viewBox="0 0 24 24" fill="none"><path d="M12 19V6M6 11l6-6 6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></button>

</BaseLayout>

<style>
  :root {
    --sec-light: #fef8ee;
    --sec-tint: #f6efe1;
    --card: #fffdf8;
    --card-border: #e1e0db;
    --row-line: rgba(28,28,22,.08);
    --olive-title: #2e3914;
    --olive-head: #2d3813;
    --olive-deep: #1b2010;
    --olive-ink: #2e3914;
    --ink: #1c1c16;
    --ink-2: #404040;
    --ink-3: #595959;
    --muted: #73736a;
    --gold: #e0a82e;
    --gold-2: #f2b83f;
    --gold-btn: #f3b83f;
    --pad: clamp(20px, 8vw, 144px);
    --section-y: 72px;
    --container-pad: 32px;
  }

  *, *::before, *::after { box-sizing: border-box; }
  a { color: inherit; text-decoration: none; }
  p { line-height: 1.5; }

  .section { padding: var(--section-y) var(--pad); display: flex; flex-direction: column; }
  .stack { display: flex; flex-direction: column; }
  .sub-title { font-weight: 500; font-size: 28px; color: var(--ink); line-height: 1.5; }
  .sub-lead { font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.5; }

  /* reveal */
  .gr-reveal { opacity: 0; transform: translateY(16px);
            transition: opacity .6s cubic-bezier(.4,0,.2,1), transform .6s cubic-bezier(.4,0,.2,1); }
  .gr-reveal.in { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) { .gr-reveal { opacity: 1; transform: none; transition: none; } }

  /* hero */
  .hero {
    background: radial-gradient(125% 210% at 100% -8%, #4f583b 0%, #363a2c 50%, #1d1d1d 100%);
    min-height: clamp(440px, 29vw, 552px); display: flex; flex-direction: column; justify-content: center;
    padding: 0 var(--pad);
  }
  .hero-inner { padding: 56px 0; display: flex; flex-direction: column; }
  .hero h1 { font-weight: 500; font-size: 40px; color: #fff; line-height: 1.5; max-width: 600px; }
  .hero h1 .g { color: var(--gold-2); }
  .lead { margin-top: 16px; font-weight: 400; font-size: 18px; color: rgba(255,255,255,.74); line-height: 1.5; max-width: 600px; }

  .hero-contacts { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 32px; padding-top: 32px; border-top: 1px solid rgba(255,255,255,.16); }
  .ct-pill {
    display: inline-flex; align-items: center; gap: 12px; height: 44px; padding: 0 16px;
    border-radius: 999px; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.16);
    color: #fff; font-weight: 500; font-size: 14px; line-height: 1.5;
    transition: background .2s ease, border-color .2s ease;
  }
  .ct-pill:hover { background: rgba(255,255,255,.12); border-color: rgba(255,255,255,.32); }
  .ct-pill svg { width: 16px; height: 16px; flex: none; color: var(--gold-2); }

  /* policy section */
  .policy-p { font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.5; }
  .policy-card {
    display: flex; align-items: center; gap: 24px; background: var(--card);
    border: 1px solid var(--card-border); border-radius: 24px; padding: var(--container-pad);
  }
  .policy-ico {
    width: 48px; height: 48px; flex: none; border-radius: 12px; background: #fff0d7;
    display: flex; align-items: center; justify-content: center;
  }
  .policy-ico svg { width: 24px; height: 24px; color: var(--olive-title); }
  .policy-tx { display: flex; flex-direction: column; gap: 4px; flex: 1 1 auto; min-width: 0; }
  .policy-tx h3 { font-weight: 500; font-size: 18px; color: var(--ink); line-height: 1.5; }
  .policy-tx p { font-weight: 400; font-size: 14px; color: var(--muted); line-height: 1.5; }

  /* hours bar */
  .hours-bar {
    display: flex; align-items: center; gap: 12px; background: var(--card);
    border: 1px solid var(--card-border); border-radius: 12px; padding: 16px 20px;
    font-weight: 500; font-size: 14px; color: var(--ink-2); line-height: 1.5;
  }
  .hours-bar svg { width: 20px; height: 20px; flex: none; color: var(--olive-title); }

  /* escalation grid */
  .esc-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; align-items: stretch; }
  .esc-card {
    background: var(--card); border: 1px solid var(--card-border); border-radius: 24px;
    padding: var(--container-pad); display: flex; flex-direction: column; gap: 8px;
  }
  .esc-num { font-weight: 400; font-size: 32px; color: var(--gold); line-height: 1.5; }
  .esc-role { font-weight: 500; font-size: 20px; color: var(--ink); line-height: 1.5; }
  .esc-person { font-weight: 400; font-size: 16px; color: var(--muted); line-height: 1.5; }
  .esc-meta {
    display: flex; flex-direction: column; gap: 12px; margin-top: 16px;
    padding-top: 16px; border-top: 1px solid var(--row-line);
  }
  .esc-meta a, .esc-meta span {
    display: inline-flex; align-items: flex-start; gap: 8px;
    font-weight: 500; font-size: 14px; color: var(--ink-2); line-height: 1.5; overflow-wrap: anywhere;
  }
  .esc-meta a { transition: color .2s ease; }
  .esc-meta a:hover { color: var(--olive-title); }
  .esc-meta svg { width: 16px; height: 16px; flex: none; margin-top: 4px; color: var(--gold-2); }
  .esc-ext { color: var(--muted); font-weight: 400; }

  /* CTA */
  .cta-sec { padding: var(--section-y) var(--pad); }
  .cta-box {
    border-radius: 24px; padding: 64px; height: 304px;
    background: var(--olive-deep);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 16px; text-align: center;
  }
  .ct-tt { display: flex; flex-direction: column; gap: 8px; }
  .cta-box h3 { font-weight: 400; font-size: 32px; color: #fff; line-height: 1.5; }
  .ct-sub { font-weight: 400; font-size: 16px; color: rgba(255,255,255,.72); line-height: 1.5; max-width: 560px; }
  .btn-gold {
    background: var(--gold-btn); height: 40px; min-width: 200px;
    border-radius: 4px; display: inline-flex; align-items: center; justify-content: center;
    padding: 7px 20px; font-weight: 500; font-size: 12px; color: var(--olive-ink);
    white-space: nowrap; line-height: 1.5; transition: opacity .2s; margin-top: 8px;
  }
  .btn-gold:hover { opacity: .88; }

  .section, .cta-sec { scroll-margin-top: 96px; }
  .policy-card .btn-gold { flex: none; }

  /* back to top */
  .to-top {
    position: fixed; right: 24px; bottom: 24px; width: 48px; height: 48px; border-radius: 50%;
    background: var(--olive-deep); color: var(--gold-2); border: 0; cursor: pointer;
    display: flex; align-items: center; justify-content: center; z-index: 80;
    opacity: 0; visibility: hidden; transform: translateY(8px);
    box-shadow: 0 6px 20px rgba(0,0,0,.18);
    transition: opacity .3s ease, transform .3s ease, visibility .3s;
  }
  .to-top.show { opacity: 1; visibility: visible; transform: none; }
  .to-top svg { width: 20px; height: 20px; }

  @media (max-width: 1024px) { .esc-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) {
    .policy-card { flex-direction: column; align-items: flex-start; gap: 16px; }
    .cta-box { height: auto; padding: 48px 24px; }
  }
  @media (max-width: 560px) { .esc-grid { grid-template-columns: 1fr; } }
</style>

<script>
  const reveals = document.querySelectorAll('.gr-reveal');
  if ('IntersectionObserver' in window) {
    const ro = new IntersectionObserver((entries, obs) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); obs.unobserve(e.target); } });
    }, { rootMargin: '0px 0px -10% 0px', threshold: 0.08 });
    reveals.forEach(el => ro.observe(el));
  } else {
    reveals.forEach(el => el.classList.add('in'));
  }

  // back to top
  const tt = document.querySelector('.to-top');
  if (tt) {
    window.addEventListener('scroll', () => {
      tt.classList.toggle('show', window.pageYOffset > 600);
    }, { passive: true });
    tt.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  }
</script>
