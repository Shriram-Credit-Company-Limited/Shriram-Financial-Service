<script>
  /* scroll reveal */
  const reveals = document.querySelectorAll('.reveal');
  if ('IntersectionObserver' in window) {
    const ro = new IntersectionObserver((entries, obs) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); obs.unobserve(e.target); } });
    }, { rootMargin: '0px 0px -10% 0px', threshold: 0.08 });
    reveals.forEach(el => ro.observe(el));
  } else {
    reveals.forEach(el => el.classList.add('in'));
  }

  /* mobile input format */
  const mob = document.getElementById('hf-mobile') as HTMLInputElement | null;
  if (mob) {
    mob.addEventListener('input', () => {
      let d = mob.value.replace(/\D/g, '');
      if (d.slice(0, 2) === '91') d = d.slice(2);
      d = d.slice(0, 10);
      mob.value = d ? '+91 ' + (d.length > 5 ? d.slice(0, 5) + ' ' + d.slice(5) : d) : '';
    });
  }

  /* form submit */
  document.getElementById('demat-form')?.addEventListener('submit', e => {
    e.preventDefault();
    const mobile = mob?.value.replace(/\D/g, '') ?? '';
    if (mobile.length < 10) { mob?.focus(); return; }
    const fields = document.getElementById('hf-fields');
    const success = document.getElementById('hf-success');
    if (fields) fields.style.display = 'none';
    if (success) success.style.display = 'flex';
  });

  /* FAQ accordion */
  document.querySelectorAll('.faq-acc').forEach(acc => {
    acc.querySelectorAll('.faq-item').forEach(item => {
      item.querySelector('.faq-q')?.addEventListener('click', () => {
        const isOpen = item.classList.contains('open');
        acc.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
        if (!isOpen) item.classList.add('open');
      });
    });
  });
</script>
