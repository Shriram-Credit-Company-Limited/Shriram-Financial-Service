---
import BaseLayout from '../../layouts/BaseLayout.astro';

const benefits = [
  { title: 'Hold All Investments Digitally', desc: 'Stocks, bonds, ETFs, mutual fund units, government securities — all in one digital account. No physical certificates, no storage risk.' },
  { title: '₹0 Delivery Brokerage', desc: 'Buy and hold shares for absolutely zero brokerage. Your returns stay yours, entirely — forever.' },
  { title: 'Free SEBI Research Access', desc: 'SEBI-registered equity research, daily trade ideas, and mutual fund recommendations — from Day 1 of account activation.' },
  { title: 'Dedicated Relationship Manager', desc: 'A named RM is assigned to your account within 48 hours of activation — available on call, WhatsApp, and email.' },
  { title: 'Antara Trading Platform', desc: 'Trade, invest in mutual funds, track your portfolio, and apply for IPOs — all from one unified web and mobile platform.' },
  { title: 'CDSL Depository Backed', desc: 'Your securities held securely with CDSL — a SEBI-regulated, government-backed central depository.' },
];

const readiness = [
  'You are 18 years of age or older (minors can invest through a registered guardian)',
  'You have a valid PAN card in your name',
  'You have an Aadhaar card linked to your active mobile number',
  'You have an active bank account in your name — savings or current',
  'You are an Indian resident (NRIs can invest via RBI-approved NRE/NRO routes)',
];

const faqs = [
  { q: 'What is a Demat account and why do I need one?', a: 'A Demat (Dematerialised) account holds your investments — shares, mutual funds, bonds — in digital form instead of physical certificates. It is mandatory for trading on NSE and BSE and for applying to IPOs. Think of it as your digital locker for all financial securities.' },
  { q: 'How long does it take to open a Demat account with Shriram?', a: 'The account opening process takes under 10 minutes online. Account activation happens within 24 hours of successful KYC completion. You will receive your Client ID and Antara platform access via email and SMS.' },
  { q: 'Is there any charge to open a Demat account?', a: 'Account opening is currently free (₹0). The Annual Maintenance Charge (AMC) is ₹300 + GST per year, waived for the first year. Equity delivery brokerage is permanently zero — you only pay ₹20 flat per order for intraday and F&O trades.' },
  { q: 'What documents are required to open a Demat account?', a: 'You need: PAN card, Aadhaar card (for address proof and e-Sign), a cancelled cheque or bank statement, and a passport-size photograph. All documents are uploaded digitally — no physical copies or branch visit needed.' },
  { q: 'Can NRIs open a Demat account with Shriram?', a: 'Yes. NRIs can open a Demat account through RBI-approved routes using NRE or NRO bank accounts. Please contact our support team for NRI-specific account opening guidance and documentation.' },
  { q: 'Do I get a Trading account along with the Demat account?', a: 'Yes — both Demat and Trading accounts are opened simultaneously when you apply with Shriram. Your Trading account is used to buy and sell on NSE and BSE; the Demat account holds the securities after settlement.' },
  { q: 'Is it safe to open a Demat account online?', a: 'Absolutely. The process is SEBI-compliant and uses Aadhaar OTP-based e-Sign. All documents are encrypted in transit and storage. Your securities are held with CDSL — a government-backed, SEBI-regulated depository.' },
];
---

<BaseLayout
  title="Open Demat Account Online — Free, Paperless in 10 Minutes | Shriram Financial Services"
  description="Open a free Demat account online with Shriram — 100% paperless, SEBI-registered, CDSL-backed. Zero delivery brokerage, free SEBI research and activation within 24 hours."
>

<!-- HERO -->
<section class="hero" id="sec-hero">
  <div class="hero-grid">
    <div class="hero-inner">
      <h1>Open a <span class="g">Demat Account</span> in Minutes</h1>
      <p class="lead">Hold stocks, bonds, ETFs, and mutual fund units digitally. SEBI-registered, CDSL-partnered, fully paperless — start investing today.</p>
      <div class="hero-feats">
        <div class="feats">
          <div class="feat"><span class="tk">✓</span><span class="lb">SEBI-registered</span></div>
          <div class="feat"><span class="tk">✓</span><span class="lb">CDSL-partnered</span></div>
          <div class="feat"><span class="tk">✓</span><span class="lb">Zero brokerage</span></div>
          <div class="feat"><span class="tk">✓</span><span class="lb">Free research</span></div>
        </div>
      </div>
    </div>

    <form class="hero-form hero-aside reveal" aria-label="Get started" id="demat-form">
      <div class="hf-head">
        <h2>Let&rsquo;s Get Started</h2>
        <div class="hf-meta">
          <span>100% Paperless</span>
          <span class="dot" aria-hidden="true"></span>
          <span>Open Within Minutes</span>
          <span class="dot" aria-hidden="true"></span>
          <span>SEBI Regulated</span>
        </div>
      </div>
      <div class="hf-body" id="hf-fields">
        <div class="hf-field">
          <span class="hf-flag" aria-hidden="true"></span>
          <span class="hf-divider" aria-hidden="true"></span>
          <div class="hf-field-in">
            <label for="hf-mobile">Mobile Number</label>
            <input id="hf-mobile" name="mobile" type="tel" inputmode="numeric" autocomplete="tel-national" placeholder="+91 00000 00000" />
          </div>
        </div>
        <p class="hf-note">By continuing, I agree to receive the OTP and updates via SMS/WhatsApp</p>
        <div class="hf-actions">
          <button class="btn-gold" type="submit">Get Started</button>
          <p class="hf-login">Already a part of us? <a href="https://antara.way2wealth.com/login" target="_blank" rel="noopener noreferrer">Login Here.</a></p>
        </div>
      </div>
      <div class="hf-success" id="hf-success" style="display:none">
        <svg viewBox="0 0 24 24" fill="none" stroke="var(--gold-2)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        <h3>Request Submitted!</h3>
        <p>Our executive will contact you shortly.</p>
      </div>
    </form>
  </div>
</section>

<!-- WHAT IS A DEMAT ACCOUNT -->
<section class="section stack" id="sec-about" style="background:var(--sec-light);gap:56px">
  <div class="stack reveal" style="gap:16px">
    <h2 class="sec-title">What Is A Demat Account?</h2>
    <div class="def-body">
      <p>An electronic account that holds your financial securities — stocks, bonds, ETFs, mutual fund units, and government securities — in digital form instead of physical certificates. It is maintained by CDSL or NSDL through a SEBI-registered Depository Participant like Shriram Financial Services. Combined with a Trading account (opened simultaneously), it gives you the ability to buy and sell securities on NSE and BSE instantly.</p>
    </div>
  </div>
  <div class="row-2 reveal">
    <div class="card">
      <h3 class="card-h">Held With</h3>
      <p class="card-p">Your securities sit with CDSL or NSDL — SEBI-regulated, government-backed central depositories — not on paper.</p>
    </div>
    <div class="card">
      <h3 class="card-h">What You Can Hold</h3>
      <p class="card-p">Equity Shares, Bonds, ETFs, Mutual Fund units and Government Securities — together in a single account.</p>
    </div>
  </div>
</section>

<!-- WHY OPEN WITH SHRIRAM -->
<section class="section stack" id="sec-why" style="background:var(--sec-tint);gap:56px">
  <div class="stack reveal" style="gap:16px">
    <h2 class="sec-title">Why Open A Demat Account With Shriram?</h2>
    <p class="sec-lead">Everything you need to invest professionally — at zero or flat-fee costs, with expert guidance from Day 1.</p>
  </div>
  <div class="feat-grid reveal">
    {benefits.map(b => (
      <div class="fcell">
        <h3>{b.title}</h3>
        <p>{b.desc}</p>
      </div>
    ))}
  </div>
</section>

<!-- AM I READY -->
<section class="section stack" id="sec-ready" style="background:var(--sec-light);gap:56px">
  <div class="stack reveal" style="gap:16px">
    <h2 class="sec-title">Am I Ready To Open A Demat Account?</h2>
    <p class="sec-lead">If you can tick all five boxes below, you are ready to open your account right now.</p>
  </div>
  <div class="card check-card reveal" style="gap:0">
    <ul class="check-list" style="list-style:none;margin:0;padding:0">
      {readiness.map((item, i) => (
        <>
          {i > 0 && <li class="check-sep" aria-hidden="true"></li>}
          <li class="check-row"><span class="ck" aria-hidden="true">✓</span><span class="tx">{item}</span></li>
        </>
      ))}
    </ul>
  </div>
  <div class="cta-center reveal"><a class="btn-gold" href="#sec-hero">Open a Demat Account</a></div>
</section>

<!-- DOCUMENTS REQUIRED -->
<section class="section stack" id="sec-documents" style="background:var(--sec-tint);gap:56px">
  <div class="stack reveal" style="gap:16px">
    <h2 class="sec-title">Documents Required</h2>
    <p class="sec-lead">Just four documents — all uploaded digitally from your phone or laptop. No physical copies, no branch visit.</p>
  </div>
  <div class="steps reveal">
    <div class="step"><span class="num">01</span><div class="st-body"><h4>PAN Card</h4><p>Mandatory for all investors. Used for identity verification and tax compliance under SEBI and IT regulations.</p></div></div>
    <div class="step-div" aria-hidden="true"></div>
    <div class="step"><span class="num">02</span><div class="st-body"><h4>Aadhaar Card</h4><p>For address proof and Aadhaar-based e-Sign. An OTP is sent to your Aadhaar-linked mobile number.</p></div></div>
    <div class="step-div" aria-hidden="true"></div>
    <div class="step"><span class="num">03</span><div class="st-body"><h4>Bank Account Proof</h4><p>A cancelled cheque or recent 3-month bank statement to link your savings or current account for fund transfers.</p></div></div>
    <div class="step-div" aria-hidden="true"></div>
    <div class="step"><span class="num">04</span><div class="st-body"><h4>Passport Photo</h4><p>A passport-size photograph — can be taken with your phone camera during the online account opening process.</p></div></div>
  </div>
</section>

<!-- HOW TO OPEN -->
<section class="section stack" id="sec-steps" style="background:var(--sec-light);gap:56px">
  <div class="stack reveal" style="gap:16px">
    <h2 class="sec-title">How Soon Can I Open A Trading Account?</h2>
    <p class="sec-lead"><strong>Within minutes.</strong> You can create a Trading Account swiftly in a five-stage online process that can be completed on any of your devices.</p>
    <a class="btn-gold" href="#sec-hero" style="align-self:flex-start">Open a Demat Account</a>
  </div>
  <div class="flow reveal">
    <div class="flow-line" aria-hidden="true"></div>
    <div class="flow-row">
      <div class="flow-step">
        <span class="flow-ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><circle cx="10" cy="8" r="3.2" stroke="#2e3914" stroke-width="1.6"/><path d="M4.5 19a5.6 5.6 0 0 1 10.4-2.7" stroke="#2e3914" stroke-width="1.6" stroke-linecap="round"/><path d="m15.4 18.4 1.8 1.8 3.4-3.7" stroke="#2e3914" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        <div class="flow-tx"><h4>Basic Information</h4><p>Name, mobile number, PAN — takes under two minutes.</p></div>
      </div>
      <div class="flow-step">
        <span class="flow-ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><rect x="7" y="3" width="10" height="18" rx="2.4" stroke="#2e3914" stroke-width="1.6"/><path d="M10.5 18h3" stroke="#2e3914" stroke-width="1.6" stroke-linecap="round"/></svg></span>
        <div class="flow-tx"><h4>Complete eKYC via Aadhaar</h4><p>OTP-based verification — no physical forms or branch visits.</p></div>
      </div>
      <div class="flow-step">
        <span class="flow-ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8l-5-5Z" stroke="#2e3914" stroke-width="1.6" stroke-linejoin="round"/><path d="M14 3v5h5" stroke="#2e3914" stroke-width="1.6" stroke-linejoin="round"/><path d="m8.8 14.6 1.8 1.8 3.5-3.7" stroke="#2e3914" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        <div class="flow-tx"><h4>Upload Documents</h4><p>Bank proof and a live photograph from your phone's camera.</p></div>
      </div>
      <div class="flow-step">
        <span class="flow-ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M4 19.5h16" stroke="#2e3914" stroke-width="1.6" stroke-linecap="round"/><path d="M5.5 15.2 14.6 6l3.2 3.2-9.1 9.2-3.8.6.6-3.8Z" stroke="#2e3914" stroke-width="1.6" stroke-linejoin="round"/></svg></span>
        <div class="flow-tx"><h4>Digital eSign</h4><p>Aadhaar-based e-sign replaces physical signature on all forms.</p></div>
      </div>
      <div class="flow-step">
        <span class="flow-ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="8.5" stroke="#2e3914" stroke-width="1.6"/><path d="M10.2 8.6 15.6 12l-5.4 3.4V8.6Z" fill="#2e3914"/></svg></span>
        <div class="flow-tx"><h4>Account Activation</h4><p>Credentials delivered to your registered email. Start investing.</p></div>
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="faq-wrap" id="sec-faq" style="background:var(--sec-tint)">
  <div class="faq-cols">
    <div class="faq-left reveal">
      <h2 class="faq-title">General Questions</h2>
      <div class="faq-acc">
        {faqs.map((item, i) => (
          <div class={`faq-item${i === 0 ? ' open' : ''}`}>
            <button class="faq-q" type="button">
              <span class="qt">{item.q}</span>
              <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><line class="v" x1="12" y1="5" x2="12" y2="19" stroke="#404040" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="#404040" stroke-width="2" stroke-linecap="round"/></svg></span>
            </button>
            <div class="qa-wrap"><div class="qa"><p>{item.a}</p></div></div>
          </div>
        ))}
      </div>
    </div>
    <div class="faq-side reveal">
      <div class="usr" aria-hidden="true">
        <svg viewBox="0 0 131 147" fill="none"><circle cx="65.5" cy="42" r="34" stroke="currentColor" stroke-width="2"/><path d="M4 147c0-34 27.6-61.5 61.5-61.5S127 113 127 147" stroke="currentColor" stroke-width="2"/></svg>
      </div>
      <div class="side-in">
        <div class="side-tx">
          <h3>Need A Clearer Direction?</h3>
          <p>Let's get in touch on a 15-Minute call where we would be able to answer any questions you may have. Our Advisor will additionally help map your wealth mix and demonstrate what a dedicated advisor would do differently.</p>
        </div>
        <a class="btn-gold" href="#sec-hero">Book A Discovery Call</a>
      </div>
    </div>
  </div>
</section>

<!-- FINAL CTA -->
<section class="cta-sec" id="sec-final-cta" style="background:var(--sec-light)">
  <div class="cta-box reveal">
    <div class="ct-tt">
      <h3>Open a Demat Account and <span class="g">Start Investing Today</span></h3>
      <p class="ct-sub">Free account opening · Zero delivery brokerage · CDSL-backed · 100% paperless · SEBI-registered.</p>
    </div>
    <div class="cta-actions">
      <a class="btn-gold" href="#sec-hero">Open Demat Account</a>
      <a class="btn-ghost" href="tel:18001031212">Talk to an Expert</a>
    </div>
  </div>
</section>

</BaseLayout>

<style>
  :root {
    --sec-light: #fef8ee;
    --sec-tint: #f6efe1;
    --card: #fffdf8;
    --card-border: #e1e0db;
    --row-line: rgba(28,28,22,.08);
    --olive-title: #2e3914;
    --olive-head: #2d3813;
    --olive-deep: #1b2010;
    --olive-ink: #2e3914;
    --ink: #1c1c16;
    --ink-2: #404040;
    --ink-3: #595959;
    --muted: #73736a;
    --gold-2: #f2b83f;
    --gold-btn: #f3b83f;
    --green: #009d58;
    --blue: #2f7ef4;
    --pad: clamp(20px, 8vw, 144px);
    --section-y: 72px;
    --container-pad: 32px;
    --hero-aside-w: clamp(360px, 40vw, 520px);
  }

  *, *::before, *::after { box-sizing: border-box; }
  a { color: inherit; text-decoration: none; }
  p { line-height: 1.5; }

  .section { padding: var(--section-y) var(--pad); display: flex; flex-direction: column; }
  .stack { display: flex; flex-direction: column; }
  .sec-title { font-weight: 400; font-size: 40px; color: var(--olive-title); text-transform: capitalize; line-height: 1.5; }
  .sec-lead { font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.5; }
  .card-h { font-weight: 500; font-size: 20px; color: var(--ink); line-height: 1.5; }
  .card-p { font-weight: 400; font-size: 16px; color: var(--muted); line-height: 1.5; }

  /* reveal */
  .reveal { opacity: 0; transform: translateY(16px);
            transition: opacity .6s cubic-bezier(.4,0,.2,1), transform .6s cubic-bezier(.4,0,.2,1); }
  .reveal.in { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) { .reveal { opacity: 1; transform: none; transition: none; } }

  /* hero */
  .hero {
    background: radial-gradient(125% 210% at 100% -8%, #4f583b 0%, #363a2c 50%, #1d1d1d 100%);
    min-height: clamp(440px, 29vw, 552px); display: flex; flex-direction: column; justify-content: center;
    padding: 0 var(--pad);
  }
  .hero-grid { display: flex; gap: 56px; align-items: center; padding: 56px 0; }
  .hero-inner { flex: 1 1 0; min-width: 0; display: flex; flex-direction: column; }
  .hero h1 { font-weight: 500; font-size: 40px; color: #fff; line-height: 1.5; max-width: 600px; }
  .hero h1 .g { color: var(--gold-2); }
  .lead { margin-top: 16px; font-weight: 400; font-size: 18px; color: rgba(255,255,255,.74); line-height: 1.5; max-width: 600px; }
  .hero-feats { margin-top: 40px; }
  .feats { display: flex; flex-wrap: wrap; align-items: center; gap: 14px 24px; padding-top: 36px; border-top: 1px solid rgba(255,255,255,.16); }
  .feat { display: flex; gap: 10px; align-items: center; }
  .feat .tk { color: var(--gold-2); font-weight: 500; font-size: 15px; }
  .feat .lb { color: rgba(255,255,255,.9); font-weight: 500; font-size: 16px; line-height: 1.5; white-space: nowrap; }

  /* hero warm form */
  .hero-aside { width: var(--hero-aside-w); flex: none; }
  .hero-form {
    background: #f8f4e8; border: 1px solid #e1dbc6; border-radius: 24px;
    padding: clamp(32px, 3.4vw, 48px); display: flex; flex-direction: column; gap: 40px;
  }
  .hf-head { display: flex; flex-direction: column; gap: 16px; }
  .hero-form h2 { font-weight: 500; font-size: clamp(26px, 2.4vw, 32px); color: #4f583b; line-height: 1.4; }
  .hf-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; }
  .hf-meta span { font-weight: 500; font-size: 12px; color: #666; white-space: nowrap; line-height: 1.5; }
  .hf-meta .dot { width: 4px; height: 4px; border-radius: 50%; background: #ccc; flex: none; }
  .hf-body { display: flex; flex-direction: column; gap: 24px; }
  .hf-field { background: #fff; border: 1px solid #ccc; border-radius: 8px; height: 48px;
             display: flex; align-items: center; gap: 12px; padding: 0 14px 0 16px; }
  .hf-flag { width: 18px; height: 18px; border-radius: 50%; flex: none; border: 1px solid #e6e6e6;
            background: linear-gradient(180deg, #ff9933 33%, #fff 33% 66%, #138808 66%); }
  .hf-divider { width: 1px; height: 24px; background: #e0e0e0; flex: none; }
  .hf-field-in { flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: center; gap: 1px; }
  .hf-field-in label { font-weight: 500; font-size: 10px; color: #8a8a8a; line-height: 1.2; }
  .hf-field-in input { border: 0; outline: none; background: none; font-family: inherit;
                      font-weight: 500; font-size: 14px; color: #333; padding: 0; width: 100%; }
  .hf-field-in input::placeholder { color: #999; }
  .hf-note { font-weight: 500; font-size: 12px; color: #333; line-height: 1.5; }
  .hf-actions { display: flex; flex-direction: column; gap: 16px; }
  .hero-form .btn-gold { width: 100%; height: 48px; }
  .hf-login { font-weight: 500; font-size: 12px; color: #333; line-height: 1.5; }
  .hf-login a { color: var(--blue); }
  .hf-success { display: flex; flex-direction: column; align-items: center; gap: 12px; text-align: center; padding: 16px 0; }
  .hf-success svg { width: 40px; height: 40px; }
  .hf-success h3 { font-weight: 600; font-size: 20px; color: #4f583b; line-height: 1.5; }
  .hf-success p { font-weight: 400; font-size: 14px; color: #666; line-height: 1.5; }

  /* what is demat */
  .def-body { display: flex; flex-direction: column; gap: 16px; }
  .def-body p { font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.5; }
  .row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .card { background: var(--card); border: 1px solid var(--card-border); border-radius: 24px; padding: var(--container-pad); }

  /* feat grid */
  .feat-grid { border: 1px solid var(--card-border); border-radius: 24px; overflow: hidden;
              display: grid; grid-template-columns: repeat(3,1fr); background: var(--card); }
  .fcell { padding: var(--container-pad); display: flex; flex-direction: column; gap: 12px;
          border-right: 1px solid var(--card-border); border-bottom: 1px solid var(--card-border); }
  .fcell:nth-child(3n) { border-right: 0; }
  .fcell:nth-child(n+4) { border-bottom: 0; }
  .fcell h3 { font-weight: 500; font-size: 20px; color: var(--ink); line-height: 1.5; }
  .fcell p { font-weight: 400; font-size: 16px; color: var(--muted); line-height: 1.5; }

  /* check card */
  .check-card { display: flex; flex-direction: column; }
  .check-list { display: flex; flex-direction: column; }
  .check-row { display: flex; gap: 14px; align-items: flex-start; padding: 20px 0; }
  .check-row:first-child { padding-top: 0; }
  .check-row:last-child { padding-bottom: 0; }
  .check-row .ck { color: var(--green); font-weight: 700; font-size: 15px; line-height: 1.5; flex: none; }
  .check-row .tx { flex: 1; font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.5; }
  .check-sep { height: 1px; background: var(--row-line); }
  .cta-center { display: flex; justify-content: center; }

  /* steps */
  .steps { display: flex; flex-direction: column; }
  .step { display: flex; gap: 24px; align-items: flex-start; }
  .step .num { font-weight: 400; font-size: 32px; color: var(--gold-2); line-height: 1.5; flex: none; min-width: 40px; }
  .st-body { display: flex; flex-direction: column; gap: 8px; padding-top: 4px; }
  .st-body h4 { font-weight: 500; font-size: 20px; color: var(--ink); line-height: 1.5; }
  .st-body p { font-weight: 400; font-size: 16px; color: var(--muted); line-height: 1.5; }
