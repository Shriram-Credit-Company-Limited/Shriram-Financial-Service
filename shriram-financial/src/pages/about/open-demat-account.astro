---
import BaseLayout from '../../layouts/BaseLayout.astro';

const benefits = [
  { title: 'Hold All Investments Digitally', desc: 'Stocks, bonds, ETFs, mutual fund units, government securities — all in one digital account. No physical certificates, no storage risk.' },
  { title: '₹0 Delivery Brokerage', desc: 'Buy and hold shares for absolutely zero brokerage. Your returns stay yours, entirely — forever.' },
  { title: 'Free SEBI Research Access', desc: 'SEBI-registered equity research, daily trade ideas, and mutual fund recommendations — from Day 1 of account activation.' },
  { title: 'Dedicated Relationship Manager', desc: 'A named RM is assigned to your account within 48 hours of activation — available on call, WhatsApp, and email.' },
  { title: 'Antara Trading Platform', desc: 'Trade, invest in mutual funds, track your portfolio, and apply for IPOs — all from one unified web and mobile platform.' },
  { title: 'CDSL Depository Backed', desc: 'Your securities held securely with CDSL — a SEBI-regulated, government-backed central depository.' },
];

const documents = [
  { label: 'PAN Card', desc: 'Mandatory for all investors. Used for identity verification and tax compliance under SEBI and IT regulations.' },
  { label: 'Aadhaar Card', desc: 'For address proof and Aadhaar-based e-Sign. An OTP is sent to your Aadhaar-linked mobile number.' },
  { label: 'Bank Account Proof', desc: 'A cancelled cheque or recent 3-month bank statement to link your savings or current account for fund transfers.' },
  { label: 'Passport Photo', desc: 'A passport-size photograph — can be taken with your phone camera during the online account opening process.' },
];

const steps = [
  { n: '01', title: 'Enter PAN & Mobile', desc: 'Start on the Shriram platform. Enter your mobile number for OTP verification and your PAN for identity lookup. Takes under 2 minutes.' },
  { n: '02', title: 'Fill Personal Details', desc: 'Provide full name (as on PAN), date of birth, address (as on Aadhaar), and your bank account number and IFSC code.' },
  { n: '03', title: 'Upload KYC Documents', desc: 'Upload PAN card, Aadhaar (front & back), and a cancelled cheque or bank statement. All uploads are encrypted end-to-end.' },
  { n: '04', title: 'Video KYC & e-Sign', desc: 'Complete a 2-minute live video KYC call — fully remote, no branch visit. Then e-sign documents via Aadhaar OTP instantly.' },
  { n: '05', title: 'Account Activated', desc: 'Demat and Trading account activated within 24 hours of KYC. Receive your Client ID and Antara platform access via email and SMS.' },
];

const readiness = [
  'You are 18 years of age or older (minors can invest through a registered guardian)',
  'You have a valid PAN card in your name',
  'You have an Aadhaar card linked to your active mobile number',
  'You have an active bank account in your name — savings or current',
  'You are an Indian resident (NRIs can invest via RBI-approved NRE/NRO routes)',
];

const faqs = [
  { q: 'What is a Demat account and why do I need one?', a: 'A Demat (Dematerialised) account holds your investments — shares, mutual funds, bonds — in digital form instead of physical certificates. It is mandatory for trading on NSE and BSE and for applying to IPOs. Think of it as your digital locker for all financial securities.' },
  { q: 'How long does it take to open a Demat account with Shriram?', a: 'The account opening process takes under 10 minutes online. Account activation happens within 24 hours of successful KYC completion. You will receive your Client ID and Antara platform access via email and SMS.' },
  { q: 'Is there any charge to open a Demat account?', a: 'Account opening is currently free (₹0). The Annual Maintenance Charge (AMC) is ₹300 + GST per year, waived for the first year. Equity delivery brokerage is permanently zero — you only pay ₹20 flat per order for intraday and F&O trades.' },
  { q: 'What documents are required to open a Demat account?', a: 'You need: PAN card, Aadhaar card (for address proof and e-Sign), a cancelled cheque or bank statement, and a passport-size photograph. All documents are uploaded digitally — no physical copies or branch visit needed.' },
  { q: 'Can NRIs open a Demat account with Shriram?', a: 'Yes. NRIs can open a Demat account through RBI-approved routes using NRE or NRO bank accounts. Please contact our support team for NRI-specific account opening guidance and documentation.' },
  { q: 'Do I get a Trading account along with the Demat account?', a: 'Yes — both Demat and Trading accounts are opened simultaneously when you apply with Shriram. Your Trading account is used to buy and sell on NSE and BSE; the Demat account holds the securities after settlement.' },
  { q: 'Is it safe to open a Demat account online?', a: 'Absolutely. The process is SEBI-compliant and uses Aadhaar OTP-based e-Sign. All documents are encrypted in transit and storage. Your securities are held with CDSL — a government-backed, SEBI-regulated depository.' },
];
---

<BaseLayout
  title="Open Demat Account Online — Free, Paperless in 10 Minutes | Shriram"
  description="Open a free Demat and Trading account online with Shriram Financial Services. Zero delivery brokerage, CDSL-registered, SEBI-compliant, 100% paperless in under 10 minutes."
>

  <!-- ══ 1. HERO ═══════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-grid">

        <!-- Left: copy -->
        <div class="hero-copy">
          <h1>Open a Demat Account in Minutes — <span class="g">100% Online, Zero Paperwork</span></h1>
          <p class="lead">Hold stocks, bonds, ETFs, and mutual fund units digitally. SEBI-registered, CDSL-partnered, fully paperless — start investing today.</p>
          <div class="cta-row">
            <a href="https://ekyc.shriraminsight.com/" class="btn-gold" target="_blank" rel="noopener noreferrer">Start Opening Now</a>
            <a href="/about/support/" class="btn-ghost">Talk to an Expert</a>
          </div>
          <div class="hero-feats">
            <div class="feats">
              <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;SEBI-registered</span></div>
              <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;CDSL-partnered</span></div>
              <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;Zero brokerage</span></div>
              <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;Free research</span></div>
            </div>
          </div>
        </div>

        <!-- Right: form card -->
        <div class="form-card">
          <div class="form-card-inner">
            <div class="form-head">
              <h2 class="form-title">Open a Demat Account</h2>
              <div class="form-badges">
                {['100% Digital & Paperless', 'Open Within Minutes', 'SEBI-Regulated'].map((t, i) => (
                  <div class="badge-row">
                    {i > 0 && <span class="badge-dot"></span>}
                    <span class="badge-tx">{t}</span>
                  </div>
                ))}
              </div>
            </div>

            <div class="form-fields" id="demat-form-fields">
              <div class="mobile-input">
                <span class="flag-wrap">
                  <img src="/images/india-flag.png" alt="India" class="flag-img" />
                </span>
                <span class="divider"></span>
                <div class="mobile-inner">
                  <label for="demat-mobile" class="mobile-lbl">Mobile Number</label>
                  <div class="mobile-row">
                    <span class="code">+91</span>
                    <input
                      id="demat-mobile"
                      type="tel"
                      placeholder="00000 00000"
                      maxlength="10"
                      autocomplete="tel"
                      class="mobile-inp"
                    />
                  </div>
                </div>
              </div>
              <p class="consent-tx">By continuing, I agree to receive a quick OTP verification and updates via SMS/WhatsApp.</p>
              <div class="form-actions">
                <button id="demat-submit" class="btn-gold" style="width:200px">Get Started Now</button>
                <p class="login-tx">Already a part of us?{' '}
                  <a href="https://antara.way2wealth.com/login" target="_blank" rel="noopener noreferrer" class="login-link">Login Here.</a>
                </p>
              </div>
            </div>

            <div id="demat-success" class="success-state" style="display:none">
              <div class="success-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="var(--gold-2)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:28px;height:28px"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <h3 class="success-h">Request Submitted!</h3>
              <p class="success-p">Our executive will contact you shortly.</p>
              <p class="success-ty">Thank You.</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══ 2. WHAT IS A DEMAT ACCOUNT ════════════════════════════════ -->
  <section class="section stack" style="background:var(--sec-light);gap:48px">
    <div class="row-2">
      <div class="stack" style="gap:16px;justify-content:center">
        <p class="sec-title">What Is a Demat Account?</p>
      </div>
      <div class="stack" style="gap:20px;justify-content:center">
        <p class="sec-lead">An electronic account that holds your financial securities — stocks, bonds, ETFs, mutual fund units, and government securities — in digital form instead of physical certificates.</p>
        <p class="sec-lead">It is maintained by CDSL or NSDL through a SEBI-registered Depository Participant like Shriram Financial Services. Combined with a Trading account (opened simultaneously), it gives you the ability to buy and sell securities on NSE and BSE instantly.</p>
      </div>
    </div>
  </section>

  <!-- ══ 3. WHY OPEN WITH SHRIRAM ══════════════════════════════════ -->
  <section class="section stack" style="background:var(--sec-tint);gap:48px">
    <div class="stack" style="gap:16px">
      <p class="sec-title">Why Open a Demat Account With Shriram?</p>
      <p class="sec-lead">Everything you need to invest professionally — at zero or flat-fee costs, with expert guidance from Day 1.</p>
    </div>
    <div class="cat-grid cat-3">
      {benefits.map(b => (
        <div class="cat">
          <h4>{b.title}</h4>
          <p>{b.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ══ 4. DOCUMENTS REQUIRED ══════════════════════════════════════ -->
  <section class="section stack" style="background:var(--sec-light);gap:48px">
    <div class="stack" style="gap:16px">
      <p class="sec-title">Documents Required</p>
      <p class="sec-lead">Just four documents — all uploaded digitally from your phone or laptop. No physical copies, no branch visit.</p>
    </div>
    <div class="cat-grid cat-4">
      {documents.map((d, i) => (
        <div class="cat">
          <span class="num-n">{String(i + 1).padStart(2, '0')}</span>
          <h4>{d.label}</h4>
          <p>{d.desc}</p>
        </div>
      ))}
    </div>
    <a class="btn-gold" href="https://ekyc.shriraminsight.com/" target="_blank" rel="noopener noreferrer" style="align-self:center">Open a Demat Account</a>
  </section>

  <!-- ══ 5. HOW TO OPEN — STEP BY STEP ══════════════════════════════ -->
  <section class="section stack" style="background:var(--sec-tint);gap:48px">
    <div class="stack" style="gap:16px">
      <p class="sec-title">How to Open a Demat Account — Step by Step</p>
      <p class="sec-lead">Five simple steps. Fully digital. Complete on your phone in under 10 minutes.</p>
    </div>
    <div class="num-grid">
      {steps.map(s => (
        <div class="num-item">
          <span class="num-n">{s.n}</span>
          <h4>{s.title}</h4>
          <p>{s.desc}</p>
        </div>
      ))}
    </div>
    <a class="btn-gold" href="https://ekyc.shriraminsight.com/" target="_blank" rel="noopener noreferrer" style="align-self:center">Open My Demat Account</a>
  </section>

  <!-- ══ 6. AM I READY? ═════════════════════════════════════════════ -->
  <section class="section stack" style="background:var(--sec-light);gap:48px">
    <div class="stack" style="gap:16px">
      <p class="sec-title">Am I Ready to Open a Demat Account?</p>
      <p class="sec-lead">If you can tick all five boxes below, you are ready to open your account right now.</p>
    </div>
    <div class="card check-card-full">
      <div class="check-list">
        {readiness.map((item, i) => (
          <>
            {i > 0 && <div class="check-sep"></div>}
            <div class="check-row"><span class="ck">✓</span><p class="tx">{item}</p></div>
          </>
        ))}
      </div>
    </div>
    <a class="btn-gold" href="https://ekyc.shriraminsight.com/" target="_blank" rel="noopener noreferrer" style="align-self:center">Open a Demat Account</a>
  </section>

  <!-- ══ 7. FAQ ══════════════════════════════════════════════════════ -->
  <section class="faq-wrap" style="background:var(--sec-tint)">
    <div class="faq-cols">
      <div class="faq-left">
        <h2 class="faq-title">Frequently asked<br>questions.</h2>
        <div class="faq-acc" role="list">
          {faqs.map(item => (
            <details class="faq-item" role="listitem">
              <summary class="faq-sum">
                <span class="qt">{item.q}</span>
                <svg class="faq-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="8" y1="3" x2="8" y2="13"/><line x1="3" y1="8" x2="13" y2="8" class="faq-h"/></svg>
              </summary>
              <div class="qa"><p>{item.a}</p></div>
            </details>
          ))}
        </div>
      </div>
      <div class="faq-side">
        <div class="usr" aria-hidden="true">
          <svg viewBox="0 0 131 147" fill="none"><circle cx="65.5" cy="42" r="34" stroke="currentColor" stroke-width="2"/><path d="M4 147c0-34 27.6-61.5 61.5-61.5S127 113 127 147" stroke="currentColor" stroke-width="2"/></svg>
        </div>
        <div class="side-in">
          <div class="side-tx">
            <h4>Still Have Questions?</h4>
            <p>Call our experts on <strong>1800 103 1212</strong> (Toll-Free) or start your application online in under 10 minutes.</p>
          </div>
          <div style="display:flex;flex-direction:column;gap:12px;align-self:flex-start">
            <a class="btn-gold" href="https://ekyc.shriraminsight.com/" target="_blank" rel="noopener noreferrer">Open Demat Account</a>
            <a class="btn-ghost-dark" href="/about/support/">Talk to an Expert</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 8. FINAL CTA ═══════════════════════════════════════════════ -->
  <section class="cta-sec" style="background:var(--sec-light)">
    <div class="cta-box">
      <h2 class="cta-h">Open a Demat Account and <span class="g">Start Investing Today</span></h2>
      <p class="cta-sub">Free account opening · Zero delivery brokerage · CDSL-backed · 100% paperless · SEBI-registered.</p>
      <div class="cta-row">
        <a class="btn-gold" href="https://ekyc.shriraminsight.com/" target="_blank" rel="noopener noreferrer">Open Demat Account</a>
        <a class="btn-ghost-dark-cta" href="/about/support/">Talk to an Expert</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  :root {
    --sec-light: #fef8ee;
    --sec-tint: #f6efe1;
    --card: #fffdf8;
    --card-border: #e1e0db;
    --row-line: rgba(28,28,22,.08);
    --olive-title: #2e3914;
    --olive-head: #2d3813;
    --olive-deep: #1b2010;
    --ink: #1c1c16;
    --ink-3: #595959;
    --muted: #73736a;
    --gold-2: #f2b83f;
    --gold-btn: #f3b83f;
    --olive-ink: #2e3914;
    --green: #009d58;
    --pad: clamp(20px, 8vw, 144px);
    --section-y: 72px;
    --cta-w: 220px;
  }
  *, *::before, *::after { box-sizing: border-box; }
  a { color: inherit; text-decoration: none; }
  p { line-height: 1.5; }

  .section { padding: var(--section-y) var(--pad); display: flex; flex-direction: column; }
  .stack { display: flex; flex-direction: column; }

  .sec-title { font-weight: 400; font-size: 40px; color: var(--olive-title); text-transform: capitalize; line-height: 1.5; }
  .sec-lead  { font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.6; }

  /* Hero */
  .hero {
    padding: 0 var(--pad);
    background: radial-gradient(125% 210% at 100% -8%, #4f583b 0%, #363a2c 50%, #1d1d1d 100%);
    display: flex; flex-direction: column; justify-content: center; overflow: hidden;
  }
  .hero-inner { padding: clamp(80px,12vw,140px) 0 clamp(60px,8vw,100px); }
  .hero-grid { display: grid; grid-template-columns: 1fr 400px; gap: 52px; align-items: center; }
  .hero-copy { display: flex; flex-direction: column; }
  .hero h1   { font-weight: 500; font-size: clamp(28px,4vw,44px); color: #fff; line-height: 1.15; max-width: 680px; }
  .hero h1 .g { color: var(--gold-2); }
  .lead      { margin-top: 24px; font-size: 18px; line-height: 1.5; color: rgba(255,255,255,.74); max-width: 540px; }
  .cta-row   { margin-top: 38px; display: flex; flex-wrap: wrap; gap: 14px; align-items: center; }
  .hero-feats { margin-top: 54px; }
  .feats { display: flex; flex-wrap: wrap; align-items: center; gap: 14px 24px; max-width: 760px; padding-top: 36px; border-top: 1px solid rgba(255,255,255,.16); }
  .feat  { display: flex; gap: 10px; align-items: center; }
  .feat .tk { color: var(--gold-2); font-weight: 500; font-size: 15px; }
  .feat .lb { color: rgba(255,255,255,.9); font-weight: 500; font-size: 16px; white-space: nowrap; }

  /* Form card */
  .form-card { background: var(--olive-deep); border-radius: 20px; padding: 34px; }
  .form-card-inner { display: flex; flex-direction: column; gap: 32px; }
  .form-head { display: flex; flex-direction: column; gap: 12px; }
  .form-title { font-size: 24px; font-weight: 600; color: #fff; line-height: 1.3; }
  .form-badges { display: flex; flex-wrap: wrap; align-items: center; gap: 16px 4px; }
  .badge-row { display: flex; align-items: center; gap: 8px; }
  .badge-dot { width: 4px; height: 4px; border-radius: 50%; background: rgba(255,255,255,.3); }
  .badge-tx  { font-size: 12px; font-weight: 500; color: rgba(255,255,255,.7); }
  .form-fields { display: flex; flex-direction: column; gap: 16px; }
  .mobile-input { display: flex; align-items: center; gap: 12px; height: 48px; background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.15); border-radius: 8px; padding: 0 12px; }
  .flag-wrap { width: 18px; height: 18px; border-radius: 50%; overflow: hidden; flex: none; }
  .flag-img { width: 100%; height: 100%; object-fit: cover; }
  .divider { width: 1px; height: 24px; background: rgba(255,255,255,.2); flex: none; }
  .mobile-inner { display: flex; flex-direction: column; gap: 2px; flex: 1; min-width: 0; }
  .mobile-lbl { font-size: 10px; font-weight: 500; color: rgba(255,255,255,.5); line-height: 1.2; }
  .mobile-row { display: flex; align-items: center; gap: 4px; }
  .code { font-size: 14px; font-weight: 500; color: #fff; }
  .mobile-inp { flex: 1; background: transparent; border: none; outline: none; font-size: 14px; font-weight: 500; color: #fff; }
  .mobile-inp::placeholder { color: rgba(255,255,255,.3); font-weight: 400; }
  .consent-tx { font-size: 12px; font-weight: 500; color: rgba(255,255,255,.6); line-height: 1.5; }
  .form-actions { display: flex; flex-direction: column; gap: 12px; }
  .login-tx { font-size: 12px; font-weight: 500; color: rgba(255,255,255,.5); }
  .login-link { color: #2f7ef4; }
  .login-link:hover { text-decoration: underline; }
  .success-state { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 12px; padding: 24px 0; }
  .success-icon { width: 56px; height: 56px; border-radius: 50%; background: rgba(242,184,63,.15); display: flex; align-items: center; justify-content: center; }
  .success-h { font-size: 20px; font-weight: 600; color: #fff; }
  .success-p { font-size: 14px; color: rgba(255,255,255,.55); }
  .success-ty { font-size: 22px; font-weight: 700; color: var(--gold-2); }

  /* Buttons */
  .btn-gold {
    background: var(--gold-btn); height: 40px; width: var(--cta-w);
    border-radius: 4px; display: inline-flex; align-items: center; justify-content: center;
    padding: 7px 20px; font-weight: 500; font-size: 12px; color: var(--olive-ink);
    white-space: nowrap; transition: opacity .2s; text-decoration: none;
  }
  .btn-gold:hover { opacity: .88; }
  .btn-ghost {
    height: 40px; border-radius: 9px; border: 1px solid rgba(255,255,255,.4);
    display: inline-flex; align-items: center; justify-content: center;
    padding: 7px 26px; font-weight: 600; font-size: 15px; color: #fff;
    transition: border-color .2s; text-decoration: none;
  }
  .btn-ghost:hover { border-color: #fff; }
  .btn-ghost-dark {
    height: 40px; border-radius: 4px; border: 1px solid rgba(27,32,16,.35);
    display: inline-flex; align-items: center; justify-content: center;
    padding: 7px 26px; font-weight: 500; font-size: 12px; color: var(--olive-deep);
    transition: border-color .2s; text-decoration: none;
  }
  .btn-ghost-dark:hover { border-color: var(--olive-deep); }
  .btn-ghost-dark-cta {
    height: 40px; border-radius: 4px; border: 1px solid rgba(255,255,255,.4);
    display: inline-flex; align-items: center; justify-content: center;
    padding: 7px 26px; font-weight: 500; font-size: 12px; color: #fff;
    transition: border-color .2s; text-decoration: none;
  }
  .btn-ghost-dark-cta:hover { border-color: #fff; }

  /* Row 2 */
  .row-2 { display: grid; grid-template-columns: 1fr 1.4fr; gap: 72px; align-items: start; }

  /* Cards */
  .card { background: var(--card); border: 1px solid var(--card-border); border-radius: 24px; padding: 32px; }
  .check-card-full { background: var(--card); border: 1px solid var(--card-border); border-radius: 24px; padding: 32px; }
  .check-list { display: flex; flex-direction: column; gap: 20px; }
  .check-row  { display: flex; gap: 14px; align-items: flex-start; }
  .check-row .ck { color: var(--green); font-weight: 700; font-size: 15px; line-height: 25.5px; width: 13px; flex: none; }
  .check-row .tx { flex: 1 0 0; min-width: 0; font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.5; }
  .check-sep  { height: 1px; background: var(--row-line); width: 100%; }

  /* Cat grid */
  .cat-grid {
    border: 1px solid var(--card-border); border-radius: 24px;
    overflow: hidden; display: grid; background: var(--card);
  }
  .cat-3 { grid-template-columns: repeat(3, 1fr); }
  .cat-4 { grid-template-columns: repeat(4, 1fr); }
  .cat {
    background: var(--card); padding: 32px;
    display: flex; flex-direction: column; gap: 12px;
    border-right: 1px solid var(--card-border); border-bottom: 1px solid var(--card-border);
  }
  .cat-3 .cat:nth-child(3n)  { border-right: 0; }
  .cat-3 .cat:nth-child(n+4) { border-bottom: 0; }
  .cat-3 .cat:last-child     { border-right: 0; }
  .cat-4 .cat:nth-child(4n)  { border-right: 0; }
  .cat-4 .cat:nth-child(n+5) { border-bottom: 0; }
  .cat-4 .cat:last-child     { border-right: 0; }
  .cat h4 { font-weight: 500; font-size: 20px; color: var(--ink); line-height: 1.5; }
  .cat p  { font-weight: 400; font-size: 16px; color: var(--muted); line-height: 1.5; }

  /* Num grid */
  .num-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    background: var(--card); border: 1px solid var(--card-border);
    border-radius: 24px; overflow: hidden;
  }
  .num-item {
    padding: 32px; display: flex; flex-direction: column; gap: 12px;
    border-right: 1px solid var(--card-border); border-bottom: 1px solid var(--card-border);
  }
  .num-item:nth-child(3n)        { border-right: 0; }
  .num-item:nth-last-child(-n+3) { border-bottom: 0; }
  .num-item:last-child           { border-right: 0; }
  .num-n { font-weight: 400; font-size: 36px; color: var(--gold-2); line-height: 1; display: block; }
  .num-item h4 { font-weight: 500; font-size: 20px; color: var(--ink); line-height: 1.4; }
  .num-item p  { font-weight: 400; font-size: 15px; color: var(--ink-3); line-height: 1.5; }

  /* FAQ */
  .faq-wrap { padding: 100px var(--pad); display: flex; flex-direction: column; justify-content: center; }
  .faq-cols  { display: flex; gap: 48px; align-items: stretch; }
  .faq-left  { flex: 1 0 0; min-width: 0; display: flex; flex-direction: column; gap: 48px; }
  .faq-title { font-weight: 400; font-size: 40px; color: var(--olive-title); text-transform: capitalize; line-height: 1.5; }
  .faq-acc   { border-radius: 24px; overflow: hidden; display: flex; flex-direction: column; gap: 2px; }
  .faq-item  { background: var(--card); list-style: none; }
  .faq-sum   { display: flex; align-items: flex-start; justify-content: space-between; gap: 40px; padding: 24px; cursor: pointer; list-style: none; }
  .faq-sum::-webkit-details-marker { display: none; }
  .faq-item .qt { font-weight: 500; font-size: 14px; color: #333; line-height: 1.5; flex: 1; }
  .faq-item[open] .qt { font-weight: 600; }
  .faq-icon  { width: 16px; height: 16px; flex: none; color: #404040; margin-top: 2px; }
  .faq-h     { transition: opacity .28s ease; }
  .faq-item[open] .faq-h { opacity: 0; }
  .qa { padding: 0 24px 20px; }
  .qa p { font-weight: 400; font-size: 14px; color: #404040; line-height: 1.5; }
  .faq-side {
    width: 400px; flex: none;
    background: var(--card); border: 1px solid var(--card-border);
    border-radius: 24px; padding: 32px;
    display: flex; flex-direction: column; gap: 40px; justify-content: flex-end;
    position: relative; overflow: hidden;
  }
  .usr { position: absolute; left: 32px; top: 48px; width: 130px; height: 147px; opacity: .1; }
  .usr svg { display: block; width: 100%; height: 100%; color: var(--olive-deep); }
  .side-in  { display: flex; flex-direction: column; gap: 32px; position: relative; }
  .side-tx  { display: flex; flex-direction: column; gap: 8px; color: #222320; }
  .side-tx h4 { font-weight: 500; font-size: 20px; line-height: 28px; }
  .side-tx p  { font-weight: 400; font-size: 14px; line-height: 22px; }

  /* CTA */
  .cta-sec { padding: var(--section-y) var(--pad); }
  .cta-box {
    border-radius: 22px; padding: 64px 60px;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 20px; text-align: center; background: var(--olive-deep);
  }
  .cta-h   { font-weight: 400; font-size: 36px; color: #fff; line-height: 1.4; max-width: 640px; }
  .cta-h .g { color: var(--gold-2); }
  .cta-sub { font-size: 16px; color: rgba(255,255,255,.65); line-height: 1.5; }
  .cta-box .cta-row { margin-top: 8px; }
  .cta-box .btn-gold { width: auto; }

  @media (max-width: 1024px) {
    .hero-grid { grid-template-columns: 1fr; gap: 40px; }
    .hero h1 { font-size: 32px; }
    .row-2 { grid-template-columns: 1fr; gap: 32px; }
    .faq-side { width: 320px; }
    .cat-4 { grid-template-columns: repeat(2, 1fr); }
    .cat-4 .cat:nth-child(4n) { border-right: inherit; }
    .cat-4 .cat:nth-child(n+5) { border-bottom: inherit; }
    .cat-4 .cat:nth-child(2n) { border-right: 0; }
    .cat-4 .cat:nth-last-child(-n+2) { border-bottom: 0; }
    .cat-4 .cat:last-child { border-right: 0; border-bottom: 0; }
  }
  @media (max-width: 768px) {
    .faq-cols { flex-direction: column; }
    .faq-side { width: 100%; }
    .cat-3 { grid-template-columns: 1fr 1fr; }
    .cat-3 .cat:nth-child(3n) { border-right: inherit; }
    .cat-3 .cat:nth-child(n+4) { border-bottom: inherit; }
    .cat-3 .cat:nth-child(2n) { border-right: 0; }
    .cat-3 .cat:nth-last-child(-n+2) { border-bottom: 0; }
    .cat-3 .cat:last-child { border-right: 0; border-bottom: 0; }
    .num-grid { grid-template-columns: repeat(2, 1fr); }
    .num-item:nth-child(3n) { border-right: inherit; }
    .num-item:nth-last-child(-n+3) { border-bottom: inherit; }
