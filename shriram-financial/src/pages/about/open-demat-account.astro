    .sec-title { font-size: 28px; }
    .faq-title { font-size: 28px; white-space: normal; }
    .cta-box { padding: 40px 24px; }
    .cta-h { font-size: 26px; }
  }
  @media (max-width: 480px) {
    .cat-3 { grid-template-columns: 1fr; }
    .cat-3 .cat { border-right: 0; border-bottom: 1px solid var(--card-border); }
    .cat-3 .cat:last-child { border-bottom: 0; }
    .cat-4 { grid-template-columns: 1fr; }
    .cat-4 .cat { border-right: 0; border-bottom: 1px solid var(--card-border); }
    .cat-4 .cat:last-child { border-bottom: 0; }
    .num-grid { grid-template-columns: 1fr; }
    .num-item { border-right: 0; }
  }
</style>

<script>
  document.getElementById('demat-submit')?.addEventListener('click', () => {
    const mobile = (document.getElementById('demat-mobile') as HTMLInputElement).value.trim();
    if (mobile.replace(/\D/g, '').length < 10) {
      (document.getElementById('demat-mobile') as HTMLInputElement).focus();
      return;
    }
    const formFields = document.getElementById('demat-form-fields');
    const success = document.getElementById('demat-success');
    if (formFields) formFields.style.display = 'none';
    if (success) success.style.display = 'flex';
  });

  document.querySelectorAll('.faq-acc').forEach(acc => {
    acc.addEventListener('click', e => {
      const item = e.target instanceof Element ? e.target.closest('details') : null;
      if (!item) return;
      acc.querySelectorAll('details[open]').forEach(d => { if (d !== item) d.removeAttribute('open'); });
    });
  });
</script>
