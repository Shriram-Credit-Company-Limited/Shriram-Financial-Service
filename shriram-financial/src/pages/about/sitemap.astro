---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { navigation } from '../../navigation';
---
<BaseLayout title="Sitemap" description="Full site structure of Shriram Financial Services — all products, research, tools, and about pages.">

  <section class="border-b border-[var(--color-n400)] bg-[var(--color-n100)]">
    <div class="site-wrap py-16">
      <p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-brand)]">Navigation</p>
      <h1 class="mt-4 text-[40px] font-bold text-[var(--color-n900)]" style="font-family:var(--font-display)">Sitemap</h1>
      <p class="mt-4 max-w-xl text-[15px] text-[var(--color-muted)]">Every page on the Shriram Financial Services website — products, research, tools, and information.</p>
    </div>
  </section>

  <section class="site-wrap py-16">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
      {navigation.map((section) => (
        <div>
          <h2 class="flex items-center gap-2 text-[17px] font-semibold text-[var(--color-n900)]" style="font-family:var(--font-display)">
            <a href={section.href} class="hover:text-[var(--color-brand)]">{section.label}</a>
            {section.template && (
              <span class="rounded bg-[var(--color-brand-pale)] px-2 py-0.5 text-[10px] font-bold uppercase tracking-widest text-[var(--color-brand)]">{section.template}</span>
            )}
          </h2>
          <ul class="mt-4 space-y-2">
            {section.children.map((c) => (
              <li>
                <a href={c.href} class="text-[14px] text-[var(--color-muted)] hover:text-[var(--color-brand)]">{c.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

</BaseLayout>
