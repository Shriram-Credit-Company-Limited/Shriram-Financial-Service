<script>
  // ── Tab switching ──
  const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const tabPanels = document.querySelectorAll<HTMLElement>('.tab-panel');

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.tab!;
      tabBtns.forEach(b => { b.classList.remove('active'); b.setAttribute('aria-selected', 'false'); });
      tabPanels.forEach(p => { p.classList.remove('active'); p.hidden = true; });
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');
      const panel = document.getElementById(`tab-${target}`)!;
      panel.classList.add('active');
      panel.hidden = false;
    });
  });

  // ── Branch filter ──
  document.getElementById('branchSearch')?.addEventListener('click', () => {
    const city = (document.getElementById('filterCity') as HTMLSelectElement).value.toLowerCase();
    const rows = document.querySelectorAll<HTMLElement>('.branch-row');
    rows.forEach(row => {
      const match = !city || row.dataset.city?.includes(city) || row.dataset.area?.includes(city);
      row.style.display = match ? '' : 'none';
    });
  });

  // ── Callback form ──
  document.getElementById('callbackForm')?.addEventListener('submit', e => {
    e.preventDefault();
    const btn = (e.currentTarget as HTMLFormElement).querySelector<HTMLButtonElement>('.submit-btn')!;
    btn.textContent = 'Request sent ✓';
    btn.disabled = true;
    setTimeout(() => { btn.textContent = 'Submit'; btn.disabled = false; }, 4000);
  });
</script>
