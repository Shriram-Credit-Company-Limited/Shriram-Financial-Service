---
import BaseLayout from '../../layouts/BaseLayout.astro';

const team = [
  { name: 'Placeholder Name', role: 'CEO & Designated Director', bio: 'Leads Shriram Financial Securities with a focus on client-centric wealth management, driving growth across equities, mutual funds and advisory services.' },
  { name: 'Placeholder Name', role: 'Designated Director', bio: 'Oversees regulatory compliance and strategic operations, ensuring the firm meets SEBI standards and maintains its commitment to transparent investing.' },
  { name: 'Placeholder Name', role: 'Chief Technology Officer', bio: "Architects the firm's digital platform and technology infrastructure, building tools that make professional investing accessible to every client." },
  { name: 'Placeholder Name', role: 'Independent Director', bio: 'Brings independent oversight to the Board, safeguarding the interests of all stakeholders with deep experience in financial governance.' },
  { name: 'Placeholder Name', role: 'Chief Financial Officer', bio: "Steers the firm's financial planning, capital allocation and risk controls, keeping the business resilient and built for long-term, sustainable growth." },
  { name: 'Placeholder Name', role: 'Compliance Officer', bio: 'Manages all regulatory filings and investor grievance mechanisms, ensuring full compliance with SEBI, NSE, BSE and CDSL requirements.' },
];

const milestones = [
  [
    { year: '2000', text: 'Incorporated as Sivan Web Trading Pvt. Ltd., Bengaluru. Rebranded as Way2Wealth Securities.' },
    { year: '2008', text: 'Launched commodities business; 100th franchise outlet inaugurated.' },
    { year: '2009', text: 'Launched single-screen multi-product online trading — among the first in India.' },
    { year: '2011', text: 'Online trading for Karnataka Bank clients; acquired Techno Shares & Stocks.' },
  ],
  [
    { year: '2012', text: 'Acquired Total Insurance Brokers Pvt. Ltd.; launched Mandi2Market.' },
    { year: '2013', text: 'Ranked top-10 broking entity in retail segment by BSE.' },
    { year: '2019', text: 'MCX Leading Broking House of the Year award.' },
    { year: '2026', text: 'Rebranded as Shriram Financial Securities — a unified Shriram financial identity.', now: true },
  ],
];

const offices = [
  { city: 'Chennai', address: 'Shriram House, No. 4, Burkit Road, T. Nagar, Chennai – 600 017', map: 'https://www.google.com/maps/search/?api=1&query=Shriram+House+Burkit+Road+T+Nagar+Chennai' },
  { city: 'Hyderabad', address: 'Ground Floor, Wing B, Diamond District, Old Airport Road, Begumpet – 500 016', map: 'https://www.google.com/maps/search/?api=1&query=Diamond+District+Old+Airport+Road+Begumpet+Hyderabad' },
  { city: 'Mumbai', address: '101–104, Dynasty Business Park, J.B. Nagar, Andheri East – 400 059', map: 'https://www.google.com/maps/search/?api=1&query=Dynasty+Business+Park+JB+Nagar+Andheri+East+Mumbai' },
  { city: 'New Delhi', address: '801, 8th Floor, Mercantile House, K G Marg, Connaught Place – 110 001', map: 'https://www.google.com/maps/search/?api=1&query=Mercantile+House+KG+Marg+Connaught+Place+New+Delhi' },
];
---

<BaseLayout
  title="About Shriram Financial Securities — Our Story, Mission & Leadership"
  description="A Shriram Group company delivering personalised equity, mutual fund and insurance solutions across 21 states since 2000."
>

<!-- HERO -->
<section class="hero" id="sec-hero">
  <div class="hero-inner">
    <div class="hero-content">
      <h1>India's Trusted Financial Companion <span class="g">Since 2000</span></h1>
      <p class="lead">A Shriram Group company delivering personalised equity, mutual fund and insurance solutions to retail and HNI clients across 21 states.</p>
      <div class="cta">
        <a class="btn-gold" href="/about/open-demat-account/">Open A Demat Account</a>
      </div>
    </div>
    <div class="hero-stats">
      <div class="hstat"><span class="n">₹2.08L Cr</span><span class="l">Shriram Group AUM (Dec 2025)</span></div>
      <div class="hstat"><span class="n">12M+</span><span class="l">Group customer base</span></div>
      <div class="hstat"><span class="n">50+</span><span class="l">Years of Shriram Group legacy</span></div>
      <div class="hstat"><span class="n">21</span><span class="l">States pan-India</span></div>
    </div>
  </div>
</section>

<!-- COMPANY OVERVIEW + REGULATORY -->
<section class="section stack" id="sec-overview" style="background:var(--sec-light);gap:56px">
  <div class="stack reveal" style="gap:16px">
    <h2 class="sec-title">Company Overview</h2>
    <p class="sec-lead">Shriram Financial Securities (formerly Way2Wealth Brokers Pvt. Ltd.) is a subsidiary of Shriram Credit Company Ltd and part of the Shriram Group — one of India's largest financial services conglomerates.</p>
    <p class="sec-lead ov-note">We provide a comprehensive range of wealth management and investment services to HNI, retail and institutional clients: equity, commodities, currency trading, PMS, mutual funds, AIF, IPO distribution and fixed income.</p>
  </div>
  <div class="stack reveal" style="gap:32px">
    <div class="stack" style="gap:16px">
      <h3 class="sub-title">Regulatory Standing</h3>
      <p class="sub-lead">Fully licensed and regulated by India's financial market authorities.</p>
    </div>
    <div class="reg-grid">
      <div class="reg-cell">
        <span class="reg-ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M12 3 5 6v5c0 4.4 3 8 7 9 4-1 7-4.6 7-9V6l-7-3Z" stroke="#2e3914" stroke-width="1.5" stroke-linejoin="round"/><path d="m9 12 2 2 4-4" stroke="#2e3914" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        <h4 class="card-h">SEBI Stockbroker</h4>
        <p class="card-p">NSE (Cash &amp; F&amp;O), BSE (Cash &amp; F&amp;O), MCX and NCDEX member.</p>
        <span class="reg-no">INZ000157633</span>
      </div>
      <div class="reg-cell">
        <span class="reg-ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M12 3 5 6v5c0 4.4 3 8 7 9 4-1 7-4.6 7-9V6l-7-3Z" stroke="#2e3914" stroke-width="1.5" stroke-linejoin="round"/><path d="m9 12 2 2 4-4" stroke="#2e3914" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        <h4 class="card-h">Research Analyst</h4>
        <p class="card-p">SEBI-registered in-house research team.</p>
        <span class="reg-no">INH200009624</span>
      </div>
      <div class="reg-cell">
        <span class="reg-ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M12 3 5 6v5c0 4.4 3 8 7 9 4-1 7-4.6 7-9V6l-7-3Z" stroke="#2e3914" stroke-width="1.5" stroke-linejoin="round"/><path d="m9 12 2 2 4-4" stroke="#2e3914" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        <h4 class="card-h">MF Distributor</h4>
        <p class="card-p">AMFI-registered mutual fund distributor.</p>
        <span class="reg-no">ARN 29483</span>
      </div>
      <div class="reg-cell">
        <span class="reg-ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M12 3 5 6v5c0 4.4 3 8 7 9 4-1 7-4.6 7-9V6l-7-3Z" stroke="#2e3914" stroke-width="1.5" stroke-linejoin="round"/><path d="m9 12 2 2 4-4" stroke="#2e3914" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        <h4 class="card-h">NPS Distributor</h4>
        <p class="card-p">PFRDA-registered NPS Point of Presence.</p>
      </div>
      <div class="reg-cell">
        <span class="reg-ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M12 3 5 6v5c0 4.4 3 8 7 9 4-1 7-4.6 7-9V6l-7-3Z" stroke="#2e3914" stroke-width="1.5" stroke-linejoin="round"/><path d="m9 12 2 2 4-4" stroke="#2e3914" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        <h4 class="card-h">Depository Participant</h4>
        <p class="card-p">CDSL-registered depository participant for Demat accounts.</p>
      </div>
      <div class="reg-cell">
        <span class="reg-ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><path d="M12 3 5 6v5c0 4.4 3 8 7 9 4-1 7-4.6 7-9V6l-7-3Z" stroke="#2e3914" stroke-width="1.5" stroke-linejoin="round"/><path d="m9 12 2 2 4-4" stroke="#2e3914" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        <h4 class="card-h">Insurance Broker</h4>
        <p class="card-p">IRDAI-registered broker for life and general insurance.</p>
      </div>
    </div>
  </div>
</section>

<!-- MISSION / VISION / VALUES -->
<section class="section stack" id="sec-mvv" style="background:var(--sec-tint);gap:56px">
  <div class="stack reveal" style="gap:16px">
    <h2 class="sec-title">Mission, Vision &amp; Values</h2>
    <p class="sec-lead">The principles that guide every client interaction and business decision at Shriram Financial Securities.</p>
  </div>
  <div class="mvv reveal">
    <div class="mvv-card">
      <span class="mvv-ghost" aria-hidden="true">01</span>
      <span class="mvv-num">MISSION</span>
      <h3>Empower Every Investor</h3>
      <span class="mvv-rule" aria-hidden="true"></span>
      <p>To be the pre-eminent destination for personalised financial solutions that help every individual build and create lasting wealth.</p>
    </div>
    <div class="mvv-card">
      <span class="mvv-ghost" aria-hidden="true">02</span>
      <span class="mvv-num">VISION</span>
      <h3>Knowledge That Grows Wealth</h3>
      <span class="mvv-rule" aria-hidden="true"></span>
      <p>Knowledge combined with investor trust and involvement leads to wealth growth — and an investing experience clients genuinely enjoy.</p>
    </div>
    <div class="mvv-card">
      <span class="mvv-ghost" aria-hidden="true">03</span>
      <span class="mvv-num">VALUES</span>
      <h3>Empathy · Trust · Growth</h3>
      <span class="mvv-rule" aria-hidden="true"></span>
      <p>The three pillars behind every client relationship — and the standard we hold ourselves to in every interaction.</p>
    </div>
  </div>
</section>

<!-- PARENT GROUPS -->
<section class="section stack" id="sec-group" style="background:var(--sec-light);gap:56px">
  <div class="stack reveal" style="gap:16px">
    <h2 class="sec-title">Our Parent Groups</h2>
    <p class="sec-lead">A securities business built on the scale, stability and reach of two established financial groups.</p>
  </div>
  <div class="stack" style="gap:40px">
    <div class="grp reveal">
      <div class="grp-left">
        <h3 class="sub-title">The Shriram Group</h3>
        <div class="grp-logo"><img src="/images/shriram-group.svg" alt="Shriram Group" /></div>
      </div>
      <div class="grp-body">
        <p class="sec-lead">Founded in 1974 by Shri. R. Thyagarajan, the Shriram Group works with the philosophy of financially empowering the underserved. It manages assets of over ₹2.08 lakh crore across 4,050 branches in Consumer Finance, Vehicle Finance, Life &amp; General Insurance, Chit Funds, Asset Management and Stock Broking.</p>
        <div class="chips">
          <span class="chip">80,000+ Employees</span>
          <span class="chip">3,850+ Branches</span>
          <span class="chip">Pan-Indian Reach</span>
        </div>
      </div>
    </div>
    <div class="grp-div" aria-hidden="true"></div>
    <div class="grp reveal">
      <div class="grp-left">
        <h3 class="sub-title">The Sanlam Group</h3>
        <div class="grp-logo"><img src="/images/sanlam-group.png" alt="Sanlam Group" /></div>
      </div>
      <div class="grp-body">
        <p class="sec-lead">Sanlam is a leading financial services group based in Cape Town, South Africa. Sanlam's association with the Shriram Group began in 2005 with the emergence of Shriram Life Insurance Company (SLIC), a part of the diversified Shriram Group.</p>
        <p class="sec-lead">Over the years, the relationship has deepened significantly, with Sanlam holding a key stake in the Shriram Group through its 100% subsidiary.</p>
        <div class="chips">
          <span class="chip">Founded 1918</span>
          <span class="chip">Listed on JSE</span>
          <span class="chip">Pan-African Reach</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- WHAT WE DO -->
<section class="section stack" id="sec-do" style="background:var(--sec-tint);gap:56px">
  <div class="stack reveal" style="gap:16px">
    <h2 class="sec-title">What We Do</h2>
    <p class="sec-lead">A full-service financial securities firm offering broking, distribution, fund-based services and research.</p>
  </div>
  <div class="do-grid reveal">
    <div class="do-col">
      <h3 class="do-cat">Broking</h3>
      <a class="do-item" href="/products/equity/"><h4>Equity &amp; Derivatives</h4><p>NSE, BSE, MSEI trading with institutional empanelment and algo capabilities.</p></a>
      <div class="do-div"></div>
      <a class="do-item" href="/products/commodities/"><h4>Commodities &amp; Currency</h4><p>MCX, NCDEX commodity broking and currency futures trading.</p></a>
    </div>
    <div class="do-col">
      <h3 class="do-cat">Distribution</h3>
      <a class="do-item" href="/products/mutual-funds/"><h4>Mutual Funds</h4><p>AMFI-registered distributor offering 3,000+ direct and regular funds with 0 commission.</p></a>
      <div class="do-div"></div>
      <a class="do-item" href="/products/ipo/"><h4>IPO &amp; Fixed Income</h4><p>Primary market IPO distribution and fixed income securities placement.</p></a>
    </div>
    <div class="do-col">
      <h3 class="do-cat">Fund-Based</h3>
      <a class="do-item" href="/products/las/"><h4>Loan Against Securities</h4><p>Overdraft facility against your equity and mutual fund portfolio.</p></a>
      <div class="do-div"></div>
      <a class="do-item" href="#"><h4>PMS &amp; AIF</h4><p>Portfolio Management Services and Alternative Investment Fund access for HNI clients.</p></a>
    </div>
    <div class="do-col">
      <h3 class="do-cat">Research</h3>
      <a class="do-item" href="/research/fundamental/"><h4>Fundamental Analysis</h4><p>In-depth financial modelling and valuation reports by SEBI-registered analysts.</p></a>
      <div class="do-div"></div>
      <a class="do-item" href="/research/technical/"><h4>Technical Analysis</h4><p>Chart patterns, indicators and trade setups for short-term and positional trading.</p></a>
    </div>
  </div>
</section>

<!-- KEY MILESTONES -->
<section class="section stack" id="sec-milestones" style="background:var(--sec-light);gap:56px">
  <div class="stack reveal" style="gap:16px">
    <h2 class="sec-title">Key Milestones</h2>
    <p class="sec-lead">From a small web-trading startup in Bengaluru to a pan-India financial services brand.</p>
  </div>
  <div class="timeline reveal">
    {milestones.map(col => (
      <ol class="tl-col">
        {col.map(item => (
          <li class={`tl-item${item.now ? ' now' : ''}`}>
            <span class="tl-year">{item.year}{item.now && <span class="tl-badge">Now</span>}</span>
            <p class="tl-text">{item.text}</p>
          </li>
        ))}
      </ol>
    ))}
  </div>
</section>

<!-- LEADERSHIP -->
<section class="section stack" id="sec-team" style="background:var(--sec-tint);gap:56px">
  <div class="stack reveal" style="gap:16px">
    <h2 class="sec-title">Key Managerial Personnel</h2>
    <p class="sec-lead">The leadership steering Shriram Financial Securities across strategy, technology, governance and compliance.</p>
  </div>
  <div class="team-grid reveal">
    {team.map(p => (
      <div class="card team-card">
        <span class="ico-tile" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="3.4" stroke="#f2b83f" stroke-width="1.6"/><path d="M5.5 19a6.5 6.5 0 0 1 13 0" stroke="#f2b83f" stroke-width="1.6" stroke-linecap="round"/></svg></span>
        <h3 class="team-name">{p.name}</h3>
        <p class="team-role">{p.role}</p>
        <p class="card-p">{p.bio}</p>
      </div>
    ))}
  </div>
</section>

<!-- OFFICES -->
<section class="section stack" id="sec-offices" style="background:var(--sec-light);gap:32px">
  <div class="stack reveal" style="gap:16px">
    <h2 class="sec-title">Our Offices</h2>
    <p class="sec-lead">Headquartered in Bengaluru with a presence across India's major financial hubs.</p>
  </div>
  <div class="office-banner reveal">
    <span class="office-label">Registered Head Office</span>
    <address>Rukmini Towers, 3rd &amp; 4th Floor, #3/1 Platform Road, Sheshadripuram — 560 020</address>
    <h3>Bengaluru, Karnataka</h3>
    <div class="banner-actions">
      <a href="tel:18001031212"><svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6.5 4h3l1.5 4-2 1.5a11 11 0 0 0 5 5l1.5-2 4 1.5v3a2 2 0 0 1-2.2 2A16 16 0 0 1 4.5 6.2 2 2 0 0 1 6.5 4Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>1800 103 1212</a>
    </div>
  </div>
  <div class="office-grid reveal">
    {offices.map(o => (
      <div class="card office-card">
        <h4>{o.city}</h4>
        <address>{o.address}</address>
        <a class="o-map" href={o.map} target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21s7-5.6 7-11a7 7 0 1 0-14 0c0 5.4 7 11 7 11Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><circle cx="12" cy="10" r="2.5" stroke="currentColor" stroke-width="1.6"/></svg>
          View on map
        </a>
      </div>
    ))}
  </div>
</section>

<!-- FINAL CTA -->
<section class="cta-sec" id="sec-final-cta" style="background:var(--sec-tint)">
  <div class="cta-box dark reveal">
    <div class="ct-tt">
      <h3>Ready to Invest with India's Trusted Partner?</h3>
      <p class="ct-sub">Open a free Demat account in minutes — zero delivery brokerage, SEBI-registered research and a dedicated advisor all in one place.</p>
    </div>
    <div class="cta-actions">
      <a class="btn-gold" href="/about/open-demat-account/">Open Demat Account</a>
      <a class="btn-ghost" href="/about/support/">Talk to an Advisor</a>
    </div>
  </div>
</section>

</BaseLayout>

<style>
  :root {
    --sec-light: #fef8ee;
    --sec-tint: #f6efe1;
    --card: #fffdf8;
    --card-border: #e1e0db;
    --row-line: rgba(28,28,22,.08);
    --olive-title: #2e3914;
    --olive-head: #2d3813;
    --olive-deep: #1b2010;
    --olive-ink: #2e3914;
    --ink: #1c1c16;
    --ink-2: #404040;
    --ink-3: #595959;
    --muted: #73736a;
    --gold: #d4a017;
    --gold-2: #f2b83f;
    --gold-btn: #f3b83f;
    --blue: #2f7ef4;
    --pad: clamp(20px, 8vw, 144px);
    --section-y: 72px;
    --container-pad: 32px;
  }

  *, *::before, *::after { box-sizing: border-box; }
  a { color: inherit; text-decoration: none; }
  address { font-style: normal; }
  p { line-height: 1.5; }

  .section { padding: var(--section-y) var(--pad); display: flex; flex-direction: column; }
  .stack { display: flex; flex-direction: column; }
  .sec-title { font-weight: 400; font-size: 40px; color: var(--olive-title); text-transform: capitalize; line-height: 1.5; }
  .sec-lead { font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.5; }
  .sub-title { font-weight: 500; font-size: 28px; color: var(--ink); line-height: 1.5; }
  .sub-lead { font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.5; }
  .card-h { font-weight: 500; font-size: 20px; color: var(--ink); line-height: 1.5; }
  .card-p { font-weight: 400; font-size: 16px; color: var(--muted); line-height: 1.5; }
  .ov-note { color: var(--ink-2); }

  /* reveal */
  .reveal { opacity: 0; transform: translateY(16px);
            transition: opacity .6s cubic-bezier(.4,0,.2,1), transform .6s cubic-bezier(.4,0,.2,1); }
  .reveal.in { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) { .reveal { opacity: 1; transform: none; transition: none; } }

  /* hero */
  .hero {
    background: radial-gradient(125% 210% at 100% -8%, #4f583b 0%, #363a2c 50%, #1d1d1d 100%);
    min-height: clamp(440px, 29vw, 552px); display: flex; flex-direction: column; justify-content: center;
    padding: 0 var(--pad);
  }
  .hero-inner { padding: 56px 0; display: flex; flex-direction: row; align-items: center; gap: 56px; }
  .hero-content { flex: 1 1 0; min-width: 0; display: flex; flex-direction: column; align-items: flex-start; }
  .hero h1 { font-weight: 500; font-size: 40px; color: #fff; line-height: 1.5; max-width: 600px; }
  .hero h1 .g { color: var(--gold-2); }
  .lead { margin-top: 16px; font-weight: 400; font-size: 18px; color: rgba(255,255,255,.74); line-height: 1.5; max-width: 600px; }
  .cta { margin-top: 40px; display: flex; flex-wrap: wrap; gap: 16px; }
  .btn-gold {
    background: var(--gold-btn); height: 40px; min-width: 200px;
    border-radius: 4px; display: inline-flex; align-items: center; justify-content: center;
    padding: 7px 20px; font-weight: 500; font-size: 12px; color: var(--olive-ink);
    white-space: nowrap; line-height: 1.5; transition: opacity .2s;
  }
  .btn-gold:hover { opacity: .88; }
  .btn-ghost {
    background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.45); color: #fff; height: 40px;
    min-width: 200px; border-radius: 4px; display: flex; align-items: center; justify-content: center;
    padding: 8px 20px; font-weight: 500; font-size: 12px; white-space: nowrap; line-height: 1.5;
    transition: background .2s, border-color .2s;
  }
  .btn-ghost:hover { background: rgba(255,255,255,.12); border-color: #fff; }

  /* hero stats */
  .hero-stats { flex: 0 0 auto; width: 600px; max-width: 50%; display: grid; grid-template-columns: 1fr 1fr; }
  .hstat { display: flex; flex-direction: column; gap: 4px; align-items: center; justify-content: center; text-align: center; padding: 20px 28px; }
  .hstat .n { font-weight: 600; font-size: 32px; line-height: 1.5; color: var(--gold-2); font-variant-numeric: tabular-nums; white-space: nowrap; }
  .hstat .l { font-weight: 400; font-size: 14px; line-height: 1.5; color: rgba(255,255,255,.7); }
  .hero-stats .hstat:nth-child(1) { border-right: 1px solid rgba(255,255,255,.16); border-bottom: 1px solid rgba(255,255,255,.16); }
  .hero-stats .hstat:nth-child(2) { border-bottom: 1px solid rgba(255,255,255,.16); }
  .hero-stats .hstat:nth-child(3) { border-right: 1px solid rgba(255,255,255,.16); }

  /* regulatory grid */
  .reg-grid { border: 1px solid var(--card-border); border-radius: 24px; overflow: hidden;
             display: grid; grid-template-columns: repeat(3,1fr); background: var(--card); }
  .reg-cell { padding: var(--container-pad); display: flex; flex-direction: column; gap: 12px; align-items: flex-start;
             border-right: 1px solid var(--card-border); border-bottom: 1px solid var(--card-border); }
