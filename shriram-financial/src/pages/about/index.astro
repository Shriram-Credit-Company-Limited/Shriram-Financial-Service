<script>
  const reveals = document.querySelectorAll('.reveal');
  if ('IntersectionObserver' in window) {
    const ro = new IntersectionObserver((entries, obs) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); obs.unobserve(e.target); } });
    }, { rootMargin: '0px 0px -10% 0px', threshold: 0.08 });
    reveals.forEach(el => ro.observe(el));
  } else {
    reveals.forEach(el => el.classList.add('in'));
  }

  /* equalise do-grid first items across row bands */
  const doGrid = document.querySelector('.do-grid');
  if (doGrid) {
    const firstItems = Array.from(doGrid.querySelectorAll('.do-col > .do-item:first-of-type')) as HTMLElement[];
    const alignDo = () => {
      firstItems.forEach(el => el.style.minHeight = '');
      const groups: Record<number, HTMLElement[]> = {};
      firstItems.forEach(el => {
        const key = (el.parentElement as HTMLElement).offsetTop;
        (groups[key] = groups[key] || []).push(el);
      });
      Object.values(groups).forEach(g => {
        const max = g.reduce((m, el) => Math.max(m, el.offsetHeight), 0);
        g.forEach(el => el.style.minHeight = max + 'px');
      });
    };
    let rafId: number;
    window.addEventListener('resize', () => { cancelAnimationFrame(rafId); rafId = requestAnimationFrame(alignDo); }, { passive: true });
    if (document.fonts?.ready) document.fonts.ready.then(alignDo);
    alignDo();
  }
</script>
