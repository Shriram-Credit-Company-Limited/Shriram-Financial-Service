<style>
  .about-reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s cubic-bezier(0.22, 0.61, 0.36, 1), transform 0.7s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .about-reveal.in-view { opacity: 1; transform: none; }

  /* Regulatory grid: 2-col mobile → 3-col desktop */
  .reg-grid { display: grid; grid-template-columns: repeat(2, 1fr); }
  @media (min-width: 1024px) { .reg-grid { grid-template-columns: repeat(3, 1fr); } }

  /* Services grid: 1-col mobile → 2-col tablet → 4-col desktop */
  .services-grid { display: grid; grid-template-columns: 1fr; }
  @media (min-width: 640px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .services-grid { grid-template-columns: repeat(4, 1fr); } }

  @media (prefers-reduced-motion: reduce) {
    .about-reveal { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).classList.add('in-view');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.08 });
  document.querySelectorAll('.about-reveal').forEach(el => obs.observe(el));
</script>
