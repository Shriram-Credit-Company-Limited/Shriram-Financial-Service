---

<BaseLayout
  title="Investor Charter & Regulatory Documents | Shriram Financial Services"
  description="Download and view all regulatory documents — Investor Charter, Grievance Redressal Mechanism, Annual Compliance Report, Risk Disclosures, and Policies — for Shriram Financial Services."
>

  <!-- ══ HERO ═══════════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-inner">
      <h1>Investor Charter &amp; <span class="g">Regulatory Documents</span></h1>
      <p class="lead">All mandatory disclosures, investor rights, grievance mechanisms, and compliance documents — in one place. View online or download as PDF.</p>
      <div class="hero-regs">
        {[
          { label: 'SEBI Registered', val: 'Stockbroker & RA' },
          { label: 'CDSL DP', val: 'IN-DP-165-2015' },
          { label: 'AMFI Registered', val: 'ARN 29483' },
          { label: 'PFRDA Registered', val: 'NPS POP' },
        ].map(b => (
          <div class="reg-item">
            <div class="reg-label">{b.label}</div>
            <div class="reg-val">{b.val}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ DOCUMENT LIBRARY ══════════════════════════════════════════ -->
  <section class="section doc-section" style="background:var(--sec-light)">
    <div class="doc-layout">

      <!-- Sidebar: Category Filters -->
      <aside class="doc-sidebar">
        <div class="filter-card">
          <p class="filter-head">Filter by Type</p>
          <ul class="filter-list" role="list">
            {categories.map(cat => (
              <li>
                <button
                  class="filter-btn"
                  data-filter={cat.id}
                  aria-pressed={cat.id === 'all' ? 'true' : 'false'}
                >
                  <span>{cat.label}</span>
                  <span class="filter-count">{cat.count}</span>
                </button>
              </li>
            ))}
          </ul>
        </div>

        <div class="doc-stats">
          <div class="doc-count">{documents.length}</div>
          <div class="doc-count-lbl">Documents Available</div>
          <div class="doc-stats-sep"></div>
          <p class="doc-stats-tx">All documents updated in compliance with SEBI, NSE, BSE, CDSL, and AMFI mandates.</p>
        </div>
      </aside>

      <!-- Document Grid -->
      <div class="doc-main">
        <div class="search-bar">
          <svg class="search-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="9" r="6"/><path d="m15 15 3 3"/></svg>
          <input
            id="ic-search"
            type="text"
            placeholder="Search documents…"
            class="search-inp"
            autocomplete="off"
          />
        </div>

        <div id="ic-doc-grid" class="doc-grid">
          {documents.map(doc => (
            <div
              class="ic-doc-card doc-card"
              data-category={doc.category}
              data-title={doc.title.toLowerCase()}
            >
              <div class="doc-card-body">
                <div class="doc-info">
                  <div class="doc-badges">
                    <span class="badge-cat">{doc.categoryLabel}</span>
                    {doc.badge && <span class="badge-reg">{doc.badge}</span>}
                  </div>
                  <h3 class="doc-title">{doc.title}</h3>
                  <p class="doc-sub">{doc.subtitle}</p>
                  <div class="doc-meta">
                    <span class="meta-item">
                      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" style="width:12px;height:12px"><rect x="2" y="3" width="12" height="11" rx="2"/><path d="M5 1v4M11 1v4M2 8h12"/></svg>
                      {doc.date}
                    </span>
                    <span class="meta-item meta-ref">
                      Ref: {doc.ref}
                    </span>
                  </div>
                </div>
                <div class="doc-actions">
                  <button class="ic-view-btn btn-view" data-doc-id={doc.id} aria-label={`View ${doc.title}`}>
                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px"><path d="M1 8s3-5 7-5 7 5 7 5-3 5-7 5-7-5-7-5z"/><circle cx="8" cy="8" r="2"/></svg>
                    View
                  </button>
                  <button class="ic-dl-btn btn-dl" data-doc-id={doc.id} aria-label={`Download ${doc.title}`}>
                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px"><path d="M8 2v8M5 7l3 3 3-3"/><path d="M3 13h10"/></svg>
                    Download
                  </button>
                </div>
              </div>
              <div class="doc-footer-strip">
                {doc.content.sections.length} sections · PDF available · SEBI mandated disclosure
              </div>
            </div>
          ))}
        </div>

        <div id="ic-empty" class="empty-state" style="display:none">
          <div class="empty-icon">
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" style="width:20px;height:20px"><circle cx="9" cy="9" r="6"/><path d="m15 15 3 3"/></svg>
          </div>
          <p class="empty-h">No documents match your search</p>
          <p class="empty-sub">Try a different keyword or category.</p>
        </div>
      </div>

    </div>
  </section>

  <!-- ══ LEGAL DISCLAIMER ══════════════════════════════════════════ -->
  <section class="section disc-section" style="background:var(--sec-tint)">
    <p class="disc-tx">
