        },
      ],
      footer: 'Issued in compliance with SEBI Circular SEBI/HO/IMD/IMD-I/DOF5/P/CIR/2021/553 and AMFI Best Practices Guidelines.',
    },
  },
  {
    id: 'grievance-mechanism',
    category: 'grievance',
    categoryLabel: 'Grievance Redressal',
    title: 'Grievance Redressal Mechanism',
    subtitle: 'All Segments · SEBI SCORES & ODR Compliant',
    date: 'Updated: June 2025',
    ref: 'SEBI/HO/OIAE/IGRD/CIR/P/2023/156',
    badge: 'SEBI',
    content: {
      sections: [
        {
          heading: 'Level 1 — Contact Shriram Financial Services',
          items: [
            'Email: compliance@shriramfinancialservices.com',
            'Phone: 1800 103 1212 (Toll-Free, Mon–Sat, 9 AM – 6 PM)',
            'Address: Shriram House, No. 4, Burkit Road, T. Nagar, Chennai – 600 017',
            'Expected resolution time: 30 days from the date of complaint registration.',
          ],
        },
        {
          heading: 'Level 2 — Exchange / CDSL Grievance Portal',
          items: [
            'NSE Investor Grievance: igrc.nseindia.com',
            'BSE Investor Grievance: bseindia.com/investors/grievance',
            'CDSL Investor Grievance: cdsl.co.in/investor-grievance',
            'Escalate if not resolved by Shriram within 30 days.',
          ],
        },
        {
          heading: 'Level 3 — SEBI SCORES',
          items: [
            'Portal: scores.sebi.gov.in',
            'For complaints not resolved at Level 1 or Level 2.',
            'SEBI reviews the complaint and directs the intermediary to resolve it.',
            'Helpline: 1800 266 7575 (Toll-Free)',
