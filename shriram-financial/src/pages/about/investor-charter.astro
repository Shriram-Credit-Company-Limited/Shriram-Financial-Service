  {
    id: 'risk-disclosure',
    category: 'risk',
    categoryLabel: 'Risk Disclosures',
    title: 'Risk Disclosure Document',
    subtitle: 'All Segments — Mandatory SEBI Risk Warning',
    date: 'Effective: 1 April 2025',
    ref: 'SEBI Risk Disclosure — Mandatory',
