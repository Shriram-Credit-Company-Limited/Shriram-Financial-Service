---
import BaseLayout from '../../layouts/BaseLayout.astro';

const categories = [
  { id: 'all',              label: 'All Documents',        count: 10 },
  { id: 'investor-charter', label: 'Investor Charter',     count: 4 },
  { id: 'grievance',        label: 'Grievance Redressal',  count: 1 },
  { id: 'compliance',       label: 'Annual Compliance',    count: 1 },
  { id: 'risk',             label: 'Risk Disclosures',     count: 1 },
  { id: 'policies',         label: 'Policies',             count: 3 },
];

interface DocContent {
  sections: Array<{ heading: string; items: string[] }>;
  footer?: string;
}

interface Document {
  id: string;
  category: string;
  categoryLabel: string;
  title: string;
  subtitle: string;
  date: string;
  ref: string;
  badge?: string;
  content: DocContent;
}

const documents: Document[] = [
  {
    id: 'ic-equity',
    category: 'investor-charter',
    categoryLabel: 'Investor Charter',
    title: 'Investor Charter — Equity & F&O Broking',
    subtitle: 'NSE & BSE · Cash and Derivatives Segment',
    date: 'Effective: 1 April 2025',
    ref: 'SEBI/HO/OIAE/IGRD/CIR/P/2023/156',
    badge: 'SEBI',
    content: {
      sections: [
        {
          heading: 'SEBI Registrations',
          items: [
            'NSE — Cash Market: INB231103833',
            'NSE — F&O Segment: INF231103833',
            'NSE — Currency Derivatives: INE231103833',
            'BSE — Cash Market: INB011103839',
            'BSE — F&O Segment: INF011103839',
          ],
        },
        {
          heading: 'Rights of Investors',
          items: [
            'Receive a copy of KYC form and agreement documents at account opening.',
            'Receive contract notes within 24 hours of trade execution via email or post.',
            'Receive funds and securities within SEBI-prescribed settlement timelines (T+1).',
            'Access your ledger, contract notes, and account statement at any time.',
            'Lodge grievances with the stockbroker and receive resolution within 30 days.',
            'Escalate unresolved complaints to SEBI SCORES (scores.sebi.gov.in).',
            'Use the ODR platform at smartodr.in for online dispute resolution.',
            'Receive clear information about all charges, brokerage, and applicable taxes before executing trades.',
          ],
        },
        {
          heading: 'Obligations of Investors',
          items: [
            'Provide accurate and complete KYC information and update within 30 days of any change.',
            'Read all account-opening documents, risk disclosures, and exchange rules before signing.',
            'Maintain adequate margin to avoid shortfall penalties under SEBI margin rules.',
            'Monitor your account regularly and report any unauthorised trades immediately.',
            'Not engage in insider trading, market manipulation, or illegal activities.',
            'Not execute trades based on unverified tips, rumours, or unauthenticated sources.',
          ],
        },
        {
          heading: 'Grievance Redressal',
          items: [
            'Write to: compliance@shriramfinancialservices.com',
            'Call: 1800 103 1212 (Toll-Free, Mon–Sat, 9 AM – 6 PM)',
            'Escalate to NSE/BSE grievance portal if unresolved within 30 days.',
            'Further escalate to SEBI SCORES: scores.sebi.gov.in',
            'Online dispute resolution: smartodr.in (SEBI mandated ODR platform)',
          ],
        },
      ],
      footer: 'This Investor Charter is issued in compliance with SEBI Circular SEBI/HO/OIAE/IGRD/CIR/P/2023/156 dated September 7, 2023.',
    },
  },
  {
    id: 'ic-dp',
    category: 'investor-charter',
    categoryLabel: 'Investor Charter',
    title: 'Investor Charter — Depository Participant',
    subtitle: 'CDSL · Demat Account Services',
    date: 'Effective: 1 April 2025',
    ref: 'SEBI/HO/OIAE/IGRD/CIR/P/2023/156',
    badge: 'CDSL',
    content: {
      sections: [
        {
          heading: 'DP Registration',
          items: [
            'CDSL Depository Participant Registration: IN-DP-165-2015',
            'SEBI Registered Depository Participant under the Depositories Act, 1996.',
          ],
