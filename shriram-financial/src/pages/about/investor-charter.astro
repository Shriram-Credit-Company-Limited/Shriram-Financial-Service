  {
    id: 'annual-compliance',
    category: 'compliance',
    categoryLabel: 'Annual Compliance',
    title: 'Annual Compliance Report — FY 2024–25',
    subtitle: 'Stockbroking & DP · SEBI Mandated Annual Disclosure',
    date: 'Published: 30 April 2025',
    ref: 'SEBI Annual Compliance Certificate',
    badge: 'Annual',
    content: {
      sections: [
        {
          heading: 'Compliance Summary — FY 2024–25',
          items: [
            'All SEBI, Exchange, and Depository regulations were complied with during FY 2024–25.',
            'Net Worth as per latest audited accounts meets the minimum capital adequacy requirement.',
