<style>
  :root {
    --sec-light: #fef8ee;
    --sec-tint: #f6efe1;
    --card: #fffdf8;
    --card-border: #e1e0db;
    --olive-title: #2e3914;
    --olive-deep: #1b2010;
    --ink: #1c1c16;
    --ink-3: #595959;
    --muted: #73736a;
    --gold-2: #f2b83f;
    --gold-btn: #f3b83f;
    --olive-ink: #2e3914;
    --green: #009d58;
    --pad: clamp(20px, 8vw, 144px);
    --section-y: 72px;
  }
  *, *::before, *::after { box-sizing: border-box; }
  a { color: inherit; text-decoration: none; }

  /* Hero */
  .hero {
    padding: 0 var(--pad);
    background: radial-gradient(125% 210% at 100% -8%, #4f583b 0%, #363a2c 50%, #1d1d1d 100%);
    display: flex; flex-direction: column; justify-content: center; overflow: hidden;
  }
  .hero-inner { padding: clamp(80px,10vw,120px) 0 clamp(48px,6vw,80px); display: flex; flex-direction: column; gap: 32px; }
  .hero h1 { font-weight: 500; font-size: clamp(28px,4vw,48px); color: #fff; line-height: 1.15; max-width: 680px; }
  .hero h1 .g { color: var(--gold-2); }
  .lead { font-size: 17px; line-height: 1.6; color: rgba(255,255,255,.74); max-width: 560px; }
  .hero-regs { display: flex; flex-wrap: wrap; gap: 24px 40px; padding-top: 32px; border-top: 1px solid rgba(255,255,255,.16); }
  .reg-item { display: flex; flex-direction: column; gap: 4px; }
  .reg-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--gold-2); }
  .reg-val   { font-size: 14px; color: rgba(255,255,255,.65); }

  /* Section */
  .section { padding: var(--section-y) var(--pad); }
  .doc-section { padding-top: 56px; padding-bottom: 64px; }
  .disc-section { padding-top: 40px; padding-bottom: 48px; }

  /* Doc layout */
  .doc-layout { display: flex; gap: 40px; align-items: flex-start; }

  /* Sidebar */
  .doc-sidebar { flex: none; width: 220px; position: sticky; top: 100px; display: flex; flex-direction: column; gap: 16px; }
  .filter-card { background: var(--card); border: 1px solid var(--card-border); border-radius: 16px; padding: 16px; }
  .filter-head { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--muted); padding: 0 8px; margin-bottom: 12px; }
  .filter-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 2px; }
  .filter-btn {
    width: 100%; display: flex; align-items: center; justify-content: space-between;
    padding: 8px 12px; border-radius: 10px; font-size: 14px; font-weight: 500;
    color: var(--muted); background: transparent; border: none; cursor: pointer;
    transition: background .15s, color .15s;
  }
  .filter-btn:hover { background: var(--sec-tint); color: var(--ink); }
  .filter-btn[aria-pressed="true"] { background: var(--olive-deep); color: #fff; }
  .filter-btn[aria-pressed="true"] .filter-count { background: var(--gold-btn); color: var(--olive-ink); }
  .filter-count { background: #fff; border-radius: 99px; padding: 2px 8px; font-size: 11px; font-weight: 600; color: var(--muted); }

  .doc-stats {
    background: var(--olive-deep); border-radius: 16px; padding: 20px;
    text-align: center; display: flex; flex-direction: column; gap: 8px;
  }
  .doc-count { font-size: 28px; font-weight: 700; color: var(--gold-2); }
  .doc-count-lbl { font-size: 12px; color: rgba(255,255,255,.6); }
  .doc-stats-sep { height: 1px; background: rgba(255,255,255,.1); }
  .doc-stats-tx { font-size: 11px; line-height: 1.7; color: rgba(255,255,255,.5); }

  /* Doc main */
  .doc-main { flex: 1 0 0; min-width: 0; display: flex; flex-direction: column; gap: 16px; }

  .search-bar {
    display: flex; align-items: center; gap: 12px;
    background: var(--card); border: 1px solid var(--card-border);
    border-radius: 12px; padding: 10px 16px;
  }
  .search-icon { width: 16px; height: 16px; flex: none; color: var(--muted); }
  .search-inp { flex: 1; background: transparent; border: none; outline: none; font-size: 14px; color: var(--ink); }
  .search-inp::placeholder { color: var(--muted); }

  .doc-grid { display: flex; flex-direction: column; gap: 12px; }
  .doc-card {
    background: var(--card); border: 1px solid var(--card-border);
    border-radius: 16px; overflow: hidden;
    transition: box-shadow .2s;
  }
  .doc-card:hover { box-shadow: 0 4px 24px rgba(0,0,0,.08); }
  .doc-card.hidden { display: none; }
  .doc-card-body { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; padding: 20px; }
  .doc-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 6px; }
  .doc-badges { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 4px; }
  .badge-cat { background: rgba(242,184,63,.15); color: var(--olive-ink); font-size: 11px; font-weight: 600; padding: 2px 10px; border-radius: 6px; }
  .badge-reg { background: var(--card); border: 1px solid var(--card-border); color: var(--muted); font-size: 11px; font-weight: 500; padding: 2px 10px; border-radius: 6px; }
  .doc-title { font-size: 16px; font-weight: 600; color: var(--ink); line-height: 1.3; }
  .doc-sub   { font-size: 13px; color: var(--muted); }
  .doc-meta  { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 4px; }
  .meta-item { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--muted); }
  .meta-ref  { opacity: .6; }
  .doc-actions { display: flex; flex-direction: column; gap: 8px; flex: none; }
  .btn-view {
    display: flex; align-items: center; gap: 8px; padding: 7px 16px;
    border-radius: 9px; font-size: 13px; font-weight: 600;
    background: rgba(242,184,63,.12); border: 1px solid var(--gold-2);
    color: var(--olive-ink); cursor: pointer; transition: background .15s;
  }
  .btn-view:hover { background: var(--gold-btn); }
  .btn-dl {
    display: flex; align-items: center; gap: 8px; padding: 7px 16px;
    border-radius: 9px; font-size: 13px; font-weight: 600;
    background: var(--card); border: 1px solid var(--card-border);
    color: var(--ink); cursor: pointer; transition: background .15s, border-color .15s;
  }
  .btn-dl:hover { background: var(--sec-tint); border-color: var(--muted); }
  .doc-footer-strip { background: var(--sec-tint); border-top: 1px solid var(--card-border); padding: 8px 20px; font-size: 11px; color: var(--muted); }

  /* Empty state */
  .empty-state { display: flex; flex-direction: column; align-items: center; gap: 8px; padding: 64px 0; text-align: center; }
  .empty-icon { width: 48px; height: 48px; border-radius: 50%; background: var(--sec-tint); display: flex; align-items: center; justify-content: center; }
  .empty-h   { font-size: 15px; font-weight: 500; color: var(--ink); }
  .empty-sub { font-size: 13px; color: var(--muted); }

  /* Disclaimer */
  .disc-tx { font-size: 12px; line-height: 1.9; color: var(--muted); }
  .disc-tx strong { color: var(--ink); }

  /* Print */
  @media print {
    body > *:not(#ic-modal) { display: none !important; }
    #ic-modal { display: flex !important; position: static !important; background: none !important; backdrop-filter: none !important; }
    .ic-modal-shell { box-shadow: none !important; border-radius: 0 !important; height: auto !important; max-width: 100% !important; margin: 0 !important; }
    .ic-modal-shell > *:first-child { display: none !important; }
    #ic-doc-paper { box-shadow: none !important; padding: 0 !important; }
    #ic-modal > div > div:nth-child(2) { background: white !important; padding: 0 !important; overflow: visible !important; }
  }

  @media (max-width: 900px) {
    .doc-layout { flex-direction: column; }
    .doc-sidebar { width: 100%; position: static; }
    .filter-list { flex-direction: row; flex-wrap: wrap; gap: 4px; }
    .hero h1 { font-size: 28px; }
  }
</style>

<script>
  type Section = { heading: string; items: string[] };
  type DocData = { id: string; category: string; title: string; subtitle: string; date: string; ref: string; content: { sections: Section[]; footer?: string } };
  const docs: DocData[] = JSON.parse(document.getElementById('ic-data')!.textContent!);
  const docMap = new Map(docs.map(d => [d.id, d]));

  const cards = document.querySelectorAll<HTMLElement>('.ic-doc-card');
  const emptyState = document.getElementById('ic-empty')!;
  let activeFilter = 'all';

  function applyFilters() {
    const q = (document.getElementById('ic-search') as HTMLInputElement).value.toLowerCase().trim();
    let visible = 0;
    cards.forEach(card => {
      const catMatch = activeFilter === 'all' || card.dataset.category === activeFilter;
      const searchMatch = !q || (card.dataset.title ?? '').includes(q);
      const show = catMatch && searchMatch;
      card.classList.toggle('hidden', !show);
      if (show) visible++;
    });
    emptyState.style.display = visible > 0 ? 'none' : 'flex';
  }

  document.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach(b => b.setAttribute('aria-pressed', 'false'));
      btn.setAttribute('aria-pressed', 'true');
      activeFilter = btn.dataset.filter ?? 'all';
      applyFilters();
    });
  });

  document.getElementById('ic-search')!.addEventListener('input', applyFilters);

  const modal     = document.getElementById('ic-modal')!;
  const closeBtn  = document.getElementById('ic-close-btn')!;
  const printBtn  = document.getElementById('ic-print-btn')!;
  const titleEl   = document.getElementById('ic-modal-title')!;
  const titleBar  = document.getElementById('ic-modal-title-bar')!;
  const subtitleEl= document.getElementById('ic-modal-subtitle')!;
  const dateEl    = document.getElementById('ic-modal-date')!;
  const refEl     = document.getElementById('ic-modal-ref')!;
  const bodyEl    = document.getElementById('ic-modal-body')!;
  const footerEl  = document.getElementById('ic-modal-footer')!;

  function openDoc(id: string) {
    const doc = docMap.get(id);
    if (!doc) return;
    titleEl.textContent    = doc.title;
    titleBar.textContent   = doc.title;
    subtitleEl.textContent = doc.subtitle;
    dateEl.textContent     = doc.date;
    refEl.textContent      = `Ref: ${doc.ref}`;
    footerEl.textContent   = doc.content.footer ?? '';
    bodyEl.innerHTML = doc.content.sections.map(sec => `
      <div>
        <h2 style="font-size:14px;font-weight:700;color:#1a2010;margin-bottom:10px;padding-bottom:6px;border-bottom:1px solid #ddd;font-family:var(--font-display)">${sec.heading}</h2>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:7px">
          ${sec.items.map(item => `
            <li style="display:flex;gap:10px;align-items:flex-start">
              <span style="color:#f3b83f;font-size:16px;line-height:1.4;flex-shrink:0">·</span>
              <span style="color:#555;font-size:13px;line-height:1.7">${item}</span>
            </li>
          `).join('')}
        </ul>
      </div>
    `).join('');
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    (modal.querySelector('.ic-modal-shell') as HTMLElement)?.scrollTo({ top: 0 });
  }

  function closeModal() {
    modal.style.display = 'none';
    document.body.style.overflow = '';
  }

  document.querySelectorAll<HTMLButtonElement>('.ic-view-btn').forEach(btn => {
    btn.addEventListener('click', () => openDoc(btn.dataset.docId!));
  });
  document.querySelectorAll<HTMLButtonElement>('.ic-dl-btn').forEach(btn => {
    btn.addEventListener('click', () => { openDoc(btn.dataset.docId!); setTimeout(() => window.print(), 400); });
  });
  closeBtn.addEventListener('click', closeModal);
  printBtn.addEventListener('click', () => window.print());
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && modal.style.display !== 'none') closeModal(); });
</script>
