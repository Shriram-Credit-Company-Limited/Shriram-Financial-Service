        {
          heading: 'Obligations of Investors',
          items: [
            'Provide valid PAN and KYC documents at account opening.',
            'Keep the BO ID, login credentials, and TPIN confidential.',
            'Report loss of TPIN or unauthorized transaction immediately.',
            'Ensure the mobile number and email linked to the account are always active and updated.',
            'Not pledge securities without understanding the implications.',
          ],
        },
        {
          heading: 'DP Grievance Redressal',
          items: [
            'Contact: compliance@shriramfinancialservices.com',
            'CDSL Investor Grievance Portal: cdsl.co.in/investor-grievance',
            'SEBI SCORES escalation: scores.sebi.gov.in',
            'Arbitration available through CDSL as per DP–Client agreement.',
          ],
        },
      ],
      footer: 'Issued in compliance with SEBI Circular SEBI/HO/OIAE/IGRD/CIR/P/2023/156 and CDSL DP Operating Instructions.',
