---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Become a Partner — Shriram Financial Services"
  description="Join India's fastest growing partner network. Register in less than 30 seconds — zero investment, 40% revenue share, full Shriram support."
>

  <!-- ══ 1. HERO ═══════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden pt-20 pb-16 lg:pt-28 lg:pb-24">
    <div class="hero-wave" aria-hidden="true"></div>
    <video
      class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-1000"
      autoplay muted playsinline loop preload="auto" aria-hidden="true"
      onloadeddata="this.style.opacity='1'"
    >
      <source src="/videos/BG.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-gradient-to-r from-white/82 via-white/48 to-white/0" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-black/8 via-transparent to-black/12" aria-hidden="true"></div>

    <div class="site-wrap relative z-10">
      <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">

        <!-- Left: headline -->
        <div class="reveal">
          <p class="text-[11px] font-bold uppercase tracking-[0.15em] text-[var(--color-brand)]">Partner with Shriram</p>
          <h1 class="mt-4 text-[32px] font-bold leading-[1.12] text-[#2e3914] lg:text-[40px]" style="font-family:var(--font-display)">
            Partner with Us.<br/>
            <span class="text-[var(--color-brand)]">Earn Unlimited Income.</span>
          </h1>
          <p class="mt-5 max-w-[500px] text-[17px] leading-relaxed text-[#2e3914]/70">
            Join India's fastest growing partner network. Build your own financial advisory practice — backed by the Shriram brand, technology, and research.
          </p>
          <a href="#benefits" class="mt-8 inline-flex h-[48px] items-center justify-center rounded-[6px] bg-[#2e3914] px-8 text-[14px] font-medium text-white transition-colors hover:bg-[#1a2010]">Learn More</a>
        </div>

        <!-- Right: transparent glass registration card -->
        <div class="reveal reveal-2">
          <div id="partner-card" class="warm-form overflow-hidden">

            <!-- Card header with progress -->
            <div class="border-b border-[rgba(46,57,20,0.10)] px-8 py-6">
              <h2 class="text-[20px] font-bold text-[#2e3914]" style="font-family:var(--font-display)">Partner Registration</h2>
              <p class="mt-0.5 text-[13px] text-[#2e3914]/50">in less than 30 seconds</p>
              <div class="mt-5 flex items-center">
                <div class="flex flex-col items-center gap-1.5" data-step-dot="1">
                  <div class="h-3 w-3 rounded-full bg-[var(--color-brand)] transition-all duration-300 ring-2 ring-[var(--color-brand)]/30"></div>
                  <span class="text-[10px] font-bold text-[#2e3914] transition-colors duration-300">Name</span>
                </div>
                <div class="mx-2 h-px flex-1 bg-[#2e3914]/15 transition-all duration-300" id="line-1"></div>
                <div class="flex flex-col items-center gap-1.5" data-step-dot="2">
                  <div class="h-3 w-3 rounded-full bg-[#2e3914]/20 transition-all duration-300"></div>
                  <span class="text-[10px] font-semibold text-[#2e3914]/35 transition-colors duration-300">Mobile</span>
                </div>
                <div class="mx-2 h-px flex-1 bg-[#2e3914]/15 transition-all duration-300" id="line-2"></div>
                <div class="flex flex-col items-center gap-1.5" data-step-dot="3">
                  <div class="h-3 w-3 rounded-full bg-[#2e3914]/20 transition-all duration-300"></div>
                  <span class="text-[10px] font-semibold text-[#2e3914]/35 transition-colors duration-300">City</span>
                </div>
              </div>
            </div>

            <!-- Steps container -->
            <div class="relative" style="min-height:230px">

              <!-- Step 1: Name -->
              <div id="step-1" class="form-step px-8 py-8">
                <p class="text-[11px] font-bold uppercase tracking-widest text-[#2e3914]/50">Step 1 of 3</p>
                <p class="mt-3 text-[22px] font-bold text-[#2e3914]" style="font-family:var(--font-display)">What should we call you?</p>
                <label class="mt-6 block">
                  <span class="text-[11px] font-bold uppercase tracking-wider text-[#2e3914]/50">Full Name</span>
                  <input id="input-name" type="text" placeholder="Enter your full name" class="field mt-2" autocomplete="name" />
                </label>
                <div class="mt-6 flex justify-end">
                  <button id="next-1" class="btn-primary">Next →</button>
                </div>
              </div>

              <!-- Step 2: Mobile -->
              <div id="step-2" class="form-step hidden px-8 py-8">
                <p class="text-[11px] font-bold uppercase tracking-widest text-[#2e3914]/50">Step 2 of 3</p>
                <p class="mt-3 text-[22px] font-bold text-[#2e3914]" style="font-family:var(--font-display)">Your Mobile number</p>
                <label class="mt-6 block">
                  <span class="text-[11px] font-bold uppercase tracking-wider text-[#2e3914]/50">Mobile Number</span>
                  <input id="input-mobile" type="tel" placeholder="+91 XXXXX XXXXX" maxlength="13" class="field mt-2" autocomplete="tel" />
                </label>
                <div class="mt-6 flex justify-between">
                  <button id="back-2" class="step-back-btn">← Back</button>
                  <button id="next-2" class="btn-primary">Send OTP →</button>
                </div>
              </div>

              <!-- Step OTP -->
              <div id="step-otp" class="form-step hidden px-8 py-8">
                <p class="text-[11px] font-bold uppercase tracking-widest text-[#2e3914]/50">Verification</p>
                <p class="mt-3 text-[22px] font-bold text-[#2e3914]" style="font-family:var(--font-display)">Verify your number</p>
                <p class="mt-1 text-[14px] text-[#2e3914]/60">OTP sent to <span id="otp-number" class="font-semibold text-[#2e3914]"></span></p>
                <label class="mt-6 block">
                  <span class="text-[11px] font-bold uppercase tracking-wider text-[#2e3914]/50">Enter OTP</span>
                  <input id="input-otp" type="text" placeholder="• • • • • •" maxlength="6" class="field mt-2 text-center text-[22px] tracking-[0.5em] font-bold" autocomplete="one-time-code" inputmode="numeric" />
                </label>
                <p class="mt-2 text-[12px] text-[#2e3914]/50">Didn't receive it? <button id="resend-otp" class="font-semibold text-[var(--color-brand)] hover:underline">Resend OTP</button></p>
                <div class="mt-6 flex justify-between">
                  <button id="back-otp" class="step-back-btn">← Back</button>
                  <button id="verify-otp" class="btn-primary">Verify →</button>
                </div>
              </div>

              <!-- Step 3: City -->
              <div id="step-3" class="form-step hidden px-8 py-8">
                <p class="text-[11px] font-bold uppercase tracking-widest text-[#2e3914]/50">Step 3 of 3</p>
                <p class="mt-3 text-[22px] font-bold text-[#2e3914]" style="font-family:var(--font-display)">Which city are you from?</p>
                <label class="mt-6 block">
                  <span class="text-[11px] font-bold uppercase tracking-wider text-[#2e3914]/50">City</span>
                  <input id="input-city" type="text" placeholder="e.g. Mumbai, Delhi, Chennai…" class="field mt-2" autocomplete="address-level2" />
                </label>
                <div class="mt-6 flex justify-between">
                  <button id="back-3" class="step-back-btn">← Back</button>
                  <button id="submit-form" class="btn-primary">Submit →</button>
                </div>
              </div>

              <!-- Success state -->
              <div id="step-success" class="form-step hidden px-8 py-10 text-center">
                <div class="mx-auto mb-5 flex h-16 w-16 items-center justify-center rounded-full bg-[var(--color-brand)]/15">
                  <svg viewBox="0 0 24 24" fill="none" stroke="var(--color-brand)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-8 w-8"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <h3 class="text-[20px] font-bold text-[#2e3914]" style="font-family:var(--font-display)">Request Submitted!</h3>
                <p class="mt-2 text-[15px] text-[#2e3914]/60">Our executive will contact you shortly.</p>
                <p class="mt-3 text-[22px] font-bold text-[var(--color-brand)]" style="font-family:var(--font-display)">Thank You.</p>
              </div>

            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══ 2. STATS BAR ══════════════════════════════════════════════ -->
  <section class="bg-[var(--color-dark-olive)]">
    <div class="site-wrap">
      <div class="flex flex-col divide-y divide-white/10 sm:flex-row sm:divide-x sm:divide-y-0">
        {[
          { value: '5 Lakh+', label: 'Active Clients' },
          { value: '40%', label: 'Revenue Share' },
          { value: 'Zero', label: 'Investment Required' },
        ].map(s => (
          <div class="flex-1 px-8 py-6 text-center">
            <div class="text-[30px] font-bold text-[var(--color-brand)]" style="font-family:var(--font-display)">{s.value}</div>
            <div class="mt-0.5 text-[13px] text-white/60">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 3. BENEFITS ═══════════════════════════════════════════════ -->
  <section class="bg-[#faf8f4] py-16 lg:py-24" id="benefits">
    <div class="site-wrap">
      <div class="text-center">
        <p class="text-[11px] font-bold uppercase tracking-[0.15em] text-[var(--color-brand)]">Why Partner With Us</p>
        <h2 class="mt-3 text-[32px] font-bold text-[var(--color-ink)] lg:text-[42px]" style="font-family:var(--font-display)">Benefits That Set Us Apart</h2>
      </div>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {[
          {
            icon: `<svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><circle cx="14" cy="14" r="11"/><path d="M14 7v7l4 2.5"/></svg>`,
            title: 'Earn Recurring Income',
            desc: 'Revenue share on every client trade — equity, F&O, commodities, currency — for life.',
          },
          {
            icon: `<svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><rect x="3" y="7" width="22" height="16" rx="3"/><path d="M19 7V5a2 2 0 0 0-2-2h-6a2 2 0 0 0-2 2v2"/><line x1="14" y1="12" x2="14" y2="18"/><line x1="11" y1="15" x2="17" y2="15"/></svg>`,
            title: 'Zero Upfront Investment',
            desc: 'No capital required. Start your partner journey immediately with full Shriram backing.',
          },
          {
            icon: `<svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><polyline points="3 18 10 11 16 16 25 7"/><polyline points="19 7 25 7 25 13"/></svg>`,
            title: 'SEBI-Backed Research',
            desc: 'Full access to in-house SEBI-registered research to give your clients professional-grade advice.',
          },
          {
            icon: `<svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><circle cx="10" cy="9" r="4"/><path d="M2 23c0-5 3.6-9 8-9"/><circle cx="21" cy="19" r="5"/><path d="M18 19h6M21 16v6"/></svg>`,
            title: 'Dedicated Partner Manager',
            desc: 'A named Shriram relationship manager for client escalations, product queries, and support.',
          },
          {
            icon: `<svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><rect x="3" y="3" width="9" height="9" rx="1"/><rect x="16" y="3" width="9" height="9" rx="1"/><rect x="3" y="16" width="9" height="9" rx="1"/><rect x="16" y="16" width="9" height="9" rx="1"/></svg>`,
            title: 'Antara Partner Dashboard',
            desc: 'Onboard clients digitally, track portfolios, and monitor your earnings in real time.',
          },
          {
            icon: `<svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M14 2l3 8h8l-7 5 3 9-7-5-7 5 3-9L3 10h8z"/></svg>`,
            title: '50-Year Brand Trust',
            desc: 'Operate under the Shriram name — a brand clients inherently trust. Acquire clients faster.',
          },
        ].map((b, i) => (
          <div class={`reveal reveal-${(i % 3) + 1} rounded-[20px] border border-[var(--color-n400)] bg-white p-7`}>
            <div class="flex h-11 w-11 items-center justify-center rounded-[12px] bg-[var(--color-dark-olive)] text-[var(--color-brand)]" set:html={b.icon} />
            <h3 class="mt-5 text-[17px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">{b.title}</h3>
            <p class="mt-2 text-[14px] leading-relaxed text-[var(--color-muted)]">{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 4. HOW IT WORKS ═══════════════════════════════════════════ -->
  <section class="bg-[var(--color-dark-800)] py-16 lg:py-24">
    <div class="site-wrap">
      <div class="text-center">
        <p class="text-[11px] font-bold uppercase tracking-[0.15em] text-[var(--color-brand)]">Simple Process</p>
        <h2 class="mt-3 text-[32px] font-bold text-white lg:text-[42px]" style="font-family:var(--font-display)">How It Works</h2>
      </div>
      <div class="mt-14 grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { step: '01', title: 'Register in 30 Seconds', desc: 'Fill in your name, mobile number, and city. That\'s all we need to get started.' },
          { step: '02', title: 'Get Onboarded',          desc: 'Complete your partner KYC and agreement digitally. No branch visit required.' },
          { step: '03', title: 'Start Referring Clients', desc: 'Use your Antara Partner Dashboard to onboard clients and track their activity.' },
          { step: '04', title: 'Earn Every Month',        desc: 'Receive revenue share credits monthly — growing as your client base grows.' },
        ].map((s, i) => (
          <div class={`reveal reveal-${i + 1}`}>
            <div class="text-[44px] font-bold text-[var(--color-brand)]/15 leading-none" style="font-family:var(--font-display)">{s.step}</div>
            <div class="mt-3 h-px w-10 bg-[var(--color-brand)]"></div>
            <h3 class="mt-4 text-[18px] font-bold text-white" style="font-family:var(--font-display)">{s.title}</h3>
            <p class="mt-2 text-[14px] leading-relaxed text-white/50">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 5. PRODUCT PORTFOLIO ══════════════════════════════════════ -->
  <section class="bg-white py-16 lg:py-24">
    <div class="site-wrap">
      <div class="text-center">
        <p class="text-[11px] font-bold uppercase tracking-[0.15em] text-[var(--color-brand)]">What You Can Offer</p>
        <h2 class="mt-3 text-[32px] font-bold text-[var(--color-ink)] lg:text-[42px]" style="font-family:var(--font-display)">Product Portfolio</h2>
      </div>
      <div class="mt-10 flex flex-wrap justify-center gap-3">
        {[
          { id: 'trading',    label: 'Trading' },
          { id: 'investment', label: 'Investment' },
          { id: 'loans',      label: 'Loans' },
          { id: 'insurance',  label: 'Insurance' },
        ].map((t, i) => (
          <button
            class="portfolio-tab rounded-full px-6 py-2.5 text-[14px] font-semibold transition-all"
            data-portfolio={t.id}
            data-active={i === 0 ? 'true' : 'false'}
          >
            {t.label}
          </button>
        ))}
      </div>
      <div class="mt-10">
        <div id="portfolio-trading" class="portfolio-panel grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {['Equity & F&O', 'Commodities', 'Currency Derivatives', 'Intraday Trading', 'Derivatives', 'IPO Applications'].map(item => (
            <div class="rounded-[14px] border border-[var(--color-n400)] bg-[var(--color-n100)] px-6 py-5">
              <div class="mb-3 h-1 w-8 rounded-full bg-[var(--color-brand)]"></div>
              <p class="text-[15px] font-semibold text-[var(--color-ink)]">{item}</p>
            </div>
          ))}
        </div>
        <div id="portfolio-investment" class="portfolio-panel hidden grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {['Mutual Funds', 'NPS', 'Fixed Deposits', 'Bonds & Debentures', 'Portfolio Management Services', 'SIP & STP'].map(item => (
            <div class="rounded-[14px] border border-[var(--color-n400)] bg-[var(--color-n100)] px-6 py-5">
              <div class="mb-3 h-1 w-8 rounded-full bg-[var(--color-brand)]"></div>
              <p class="text-[15px] font-semibold text-[var(--color-ink)]">{item}</p>
            </div>
          ))}
        </div>
        <div id="portfolio-loans" class="portfolio-panel hidden grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {['Home Loans', 'Personal Loans', 'Business Loans', 'Education Loans', 'Loan Against Securities', 'NBFC Loans'].map(item => (
            <div class="rounded-[14px] border border-[var(--color-n400)] bg-[var(--color-n100)] px-6 py-5">
              <div class="mb-3 h-1 w-8 rounded-full bg-[var(--color-brand)]"></div>
              <p class="text-[15px] font-semibold text-[var(--color-ink)]">{item}</p>
            </div>
          ))}
        </div>
        <div id="portfolio-insurance" class="portfolio-panel hidden grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {['Term Life Insurance', 'Health Insurance', 'Vehicle Insurance', 'ULIP Plans', 'Annuity Products', 'Critical Illness Cover'].map(item => (
            <div class="rounded-[14px] border border-[var(--color-n400)] bg-[var(--color-n100)] px-6 py-5">
              <div class="mb-3 h-1 w-8 rounded-full bg-[var(--color-brand)]"></div>
              <p class="text-[15px] font-semibold text-[var(--color-ink)]">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 6. ELIGIBILITY ════════════════════════════════════════════ -->
  <section class="bg-[var(--color-dark-olive)] py-16 lg:py-24">
    <div class="site-wrap">
      <div class="text-center">
        <p class="text-[11px] font-bold uppercase tracking-[0.15em] text-[var(--color-brand)]">Requirements</p>
        <h2 class="mt-3 text-[32px] font-bold text-white lg:text-[42px]" style="font-family:var(--font-display)">Eligibility Criteria</h2>
      </div>
      <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { title: 'Age 18+',               desc: 'Must be 18 years or above to apply.' },
          { title: 'Valid PAN Card',         desc: 'A valid PAN card is mandatory for KYC.' },
          { title: 'Active Bank Account',    desc: 'Savings or current bank account required.' },
          { title: 'Zero Capital Required',  desc: 'No investment needed to get started.' },
          { title: 'Basic Finance Knowledge', desc: 'Familiarity with investment products is helpful but not mandatory.' },
          { title: 'Client Network',         desc: 'A local network of clients or leads is an advantage.' },
        ].map(e => (
          <div class="flex gap-4 rounded-[16px] bg-white/5 p-6">
            <div class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-[var(--color-brand)]/20">
              <div class="h-2 w-2 rounded-full bg-[var(--color-brand)]"></div>
            </div>
            <div>
              <h3 class="text-[15px] font-bold text-white">{e.title}</h3>
              <p class="mt-1 text-[13px] leading-relaxed text-white/55">{e.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 7. TESTIMONIALS ═══════════════════════════════════════════ -->
  <section class="bg-[#faf8f4] py-16 lg:py-24">
    <div class="site-wrap">
      <div class="text-center">
        <p class="text-[11px] font-bold uppercase tracking-[0.15em] text-[var(--color-brand)]">Partner Testimonials</p>
        <h2 class="mt-3 text-[32px] font-bold text-[var(--color-ink)] lg:text-[42px]" style="font-family:var(--font-display)">Hear From Our Partners</h2>
      </div>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { name: 'Ramesh K.',  city: 'Chennai',   quote: 'I\'ve been a Shriram partner for 3 years. The revenue share is consistent and the partner dashboard makes tracking earnings effortless.' },
          { name: 'Priya M.',   city: 'Pune',      quote: 'Starting with zero investment and earning 40% revenue share was unbelievable at first. Now I run my own financial advisory practice full-time.' },
          { name: 'Suresh P.',  city: 'Hyderabad', quote: 'The research support from Shriram sets me apart from other advisors in my area. My clients trust my recommendations because they\'re backed by real data.' },
        ].map(t => (
          <div class="rounded-[20px] border border-[var(--color-n400)] bg-white p-7">
            <div class="flex gap-0.5 text-[var(--color-brand)]">
              {Array(5).fill(0).map(() => (
                <svg viewBox="0 0 12 12" fill="currentColor" class="h-3.5 w-3.5"><path d="M6 0l1.5 4.5H12L8 7.5l1.5 4.5L6 9.5 2.5 12 4 7.5.5 4.5H6z"/></svg>
              ))}
            </div>
            <p class="mt-4 text-[14px] leading-relaxed text-[var(--color-muted)]">"{t.quote}"</p>
            <div class="mt-5 flex items-center gap-3">
              <div class="flex h-9 w-9 items-center justify-center rounded-full bg-[var(--color-dark-olive)] text-[13px] font-bold text-[var(--color-brand)]">{t.name[0]}</div>
              <div>
                <p class="text-[14px] font-bold text-[var(--color-ink)]">{t.name}</p>
                <p class="text-[12px] text-[var(--color-muted)]">{t.city}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 8. FAQ ═════════════════════════════════════════════════════ -->
  <section class="bg-white py-16 lg:py-24">
    <div class="site-wrap">
      <div class="mx-auto max-w-[760px]">
        <div class="text-center">
          <p class="text-[11px] font-bold uppercase tracking-[0.15em] text-[var(--color-brand)]">Got Questions?</p>
          <h2 class="mt-3 text-[32px] font-bold text-[var(--color-ink)] lg:text-[42px]" style="font-family:var(--font-display)">Frequently Asked Questions</h2>
        </div>
        <div class="mt-12 divide-y divide-[var(--color-n400)] overflow-hidden rounded-[20px] border border-[var(--color-n400)]">
          {[
            { q: 'Who can become a Partner?',              a: 'Anyone 18+ with a valid PAN card and a bank account can apply. We welcome sub-brokers, insurance agents, CAs, retired banking professionals, and entrepreneurs with client networks.' },
            { q: 'What is the commission structure?',      a: 'Partners earn up to 40% revenue share on trades made by referred clients. Mutual fund trail commissions, IPO referral income, and quarterly performance bonuses are additional earning opportunities.' },
            { q: 'Do I need a SEBI registration?',         a: 'Not to start. You begin as a referral partner under our SEBI registration. We support you in obtaining your AMFI ARN and NISM certifications if you want to independently advise clients.' },
            { q: 'How long does onboarding take?',         a: 'Partner KYC and agreement is fully digital and typically completes within 2–3 business days. Once onboarded, you can immediately start referring clients through the Antara Partner Dashboard.' },
          ].map(f => (
            <details class="group px-6 py-5">
              <summary class="flex cursor-pointer list-none items-start justify-between gap-4 text-[15px] font-semibold text-[var(--color-ink)]">
                <span>{f.q}</span>
                <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-[var(--color-muted)] transition-transform duration-200 group-open:rotate-180" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 7.5l5 5 5-5"/></svg>
              </summary>
              <p class="mt-3 pr-8 text-[14px] leading-relaxed text-[var(--color-muted)]">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 9. CTA BANNER ═════════════════════════════════════════════ -->
  <section class="bg-[var(--color-dark-800)] py-14 lg:py-20">
    <div class="site-wrap text-center">
      <h2 class="text-[28px] font-bold text-white lg:text-[36px]" style="font-family:var(--font-display)">Ready to Start Earning?</h2>
      <p class="mt-3 text-[15px] text-white/55">Register in 30 seconds. Zero investment. Unlimited income.</p>
      <button
        id="cta-register"
        class="mt-7 inline-flex h-12 items-center justify-center rounded-[6px] bg-[var(--color-brand)] px-10 text-[14px] font-bold text-[var(--color-dark-800)] transition-colors hover:opacity-90"
      >
        Register as a Partner
      </button>
    </div>
  </section>

</BaseLayout>

<style>
  /* Portfolio tab active/inactive */
  .portfolio-tab[data-active="true"]  { background-color: var(--color-dark-olive); color: var(--color-brand); }
  .portfolio-tab[data-active="false"] { background-color: var(--color-n100); color: var(--color-muted); }
  .portfolio-tab[data-active="false"]:hover { background-color: var(--color-n400); }

  /* Step back button */
  .step-back-btn {
    border: 1px solid rgba(46,57,20,0.18);
    border-radius: 8px;
    padding: 10px 20px;
    font-size: 14px;
    font-weight: 600;
    color: rgba(46,57,20,0.55);
    background: transparent;
    cursor: pointer;
    transition: background 0.15s;
  }
  .step-back-btn:hover { background: rgba(46,57,20,0.06); }

  /* Step slide-in animation */
  @keyframes slideIn {
    from { opacity: 0; transform: translateX(16px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  .form-step:not(.hidden) { animation: slideIn 0.28s ease; }
</style>

<script>
  /* ── Multi-step form ─────────────────────────────────────────── */
  const allSteps = ['step-1', 'step-2', 'step-otp', 'step-3', 'step-success'];
  let currentStep = 1;

  // Collected across steps — submitted together on the final step.
  const lead: { name: string; mobile: string; city: string } = {
    name: '', mobile: '', city: '',
  };

  function showStep(id: string) {
    allSteps.forEach(s => {
      const el = document.getElementById(s);
      if (!el) return;
      el.classList.toggle('hidden', s !== id);
    });
  }

  function setProgress(active: number) {
    document.querySelectorAll<HTMLElement>('[data-step-dot]').forEach(dot => {
      const n = parseInt(dot.dataset.stepDot ?? '0');
      const circle = dot.querySelector('div') as HTMLElement;
      const label  = dot.querySelector('span') as HTMLElement;
      const on = n <= active;
      circle.style.backgroundColor = on ? 'var(--color-brand)' : 'rgba(46,57,20,0.18)';
      circle.style.boxShadow = on ? '0 0 0 3px rgba(243,184,63,0.25)' : 'none';
      label.style.color      = on ? '#2e3914' : 'rgba(46,57,20,0.35)';
      label.style.fontWeight = on ? '700' : '400';
    });
    const line1 = document.getElementById('line-1');
    const line2 = document.getElementById('line-2');
    if (line1) line1.style.backgroundColor = active >= 2 ? 'rgba(243,184,63,0.5)' : 'rgba(46,57,20,0.12)';
    if (line2) line2.style.backgroundColor = active >= 3 ? 'rgba(243,184,63,0.5)' : 'rgba(46,57,20,0.12)';
  }

  // Step 1 → 2
  document.getElementById('next-1')?.addEventListener('click', () => {
    const name = (document.getElementById('input-name') as HTMLInputElement).value.trim();
    if (!name) { (document.getElementById('input-name') as HTMLInputElement).focus(); return; }
    lead.name = name;
    showStep('step-2');
    setProgress(1);
    currentStep = 2;
  });

  // Step 2 back
  document.getElementById('back-2')?.addEventListener('click', () => {
    showStep('step-1');
    setProgress(0);
    currentStep = 1;
  });

  // Step 2 → OTP
  document.getElementById('next-2')?.addEventListener('click', () => {
    const mobile = (document.getElementById('input-mobile') as HTMLInputElement).value.trim();
    if (mobile.replace(/\D/g, '').length < 10) {
      (document.getElementById('input-mobile') as HTMLInputElement).focus();
      return;
    }
    lead.mobile = mobile;
    const display = document.getElementById('otp-number');
    if (display) display.textContent = mobile;
    showStep('step-otp');
    setProgress(2);
    currentStep = 2.5;
  });

  // OTP back
  document.getElementById('back-otp')?.addEventListener('click', () => {
    showStep('step-2');
    setProgress(1);
    currentStep = 2;
  });

  // Resend OTP
  document.getElementById('resend-otp')?.addEventListener('click', () => {
    const btn = document.getElementById('resend-otp') as HTMLButtonElement;
    btn.textContent = 'OTP Sent!';
    btn.disabled = true;
    setTimeout(() => { btn.textContent = 'Resend OTP'; btn.disabled = false; }, 30000);
  });

  // OTP → Step 3
  document.getElementById('verify-otp')?.addEventListener('click', () => {
    const otp = (document.getElementById('input-otp') as HTMLInputElement).value.trim();
    if (otp.replace(/\D/g, '').length < 4) {
      (document.getElementById('input-otp') as HTMLInputElement).focus();
      return;
    }
    showStep('step-3');
    setProgress(2);
    currentStep = 3;
  });

  // Step 3 back
  document.getElementById('back-3')?.addEventListener('click', () => {
    showStep('step-otp');
    setProgress(2);
    currentStep = 2.5;
  });

  // Submit → POST lead → Success
  document.getElementById('submit-form')?.addEventListener('click', async () => {
    const city = (document.getElementById('input-city') as HTMLInputElement).value.trim();
    if (!city) { (document.getElementById('input-city') as HTMLInputElement).focus(); return; }
    lead.city = city;

    const btn = document.getElementById('submit-form') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Submitting…';

    try {
      await fetch('/api/partner-lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(lead),
      });
    } catch {
      // Network error — show success anyway; lead will be logged server-side
      // when DATABASE_URL is configured.
    }

    showStep('step-success');
    setProgress(3);
    currentStep = 4;
  });

  // CTA banner → scroll to form and reset if done
  document.getElementById('cta-register')?.addEventListener('click', () => {
    document.getElementById('partner-card')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    if (currentStep === 4) {
      showStep('step-1');
      setProgress(0);
      currentStep = 1;
      (document.getElementById('input-name') as HTMLInputElement).value = '';
      (document.getElementById('input-mobile') as HTMLInputElement).value = '';
      (document.getElementById('input-otp') as HTMLInputElement).value = '';
      (document.getElementById('input-city') as HTMLInputElement).value = '';
    }
  });

  /* ── Product portfolio tabs ──────────────────────────────────── */
  document.querySelectorAll<HTMLButtonElement>('.portfolio-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.portfolio;
      document.querySelectorAll('.portfolio-panel').forEach(p => p.classList.add('hidden'));
      document.getElementById(`portfolio-${target}`)?.classList.remove('hidden');
      document.querySelectorAll<HTMLButtonElement>('.portfolio-tab').forEach(t => {
        t.dataset.active = t.dataset.portfolio === target ? 'true' : 'false';
      });
    });
  });
</script>
