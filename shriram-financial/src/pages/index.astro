<script>
  /* Hero "Get Started Now" → way2wealth signup. way2wealth's page decodes the prefill
     param `enc_details` with atob() → JSON.parse (their standard payload: mobile_number,
     customer_name, token, pan_number2, reference_code, dob1). So we send
     enc_details = base64( JSON{ mobile_number } ) + utm_source (plaintext for analytics).
     Falls back to the plain signup URL if <10 digits. */
  const heroMobile = document.getElementById('hero-mobile') as HTMLInputElement | null;
  const heroGetStarted = document.getElementById('hero-get-started') as HTMLAnchorElement | null;
  if (heroMobile && heroGetStarted) {
    const BASE_URL = 'https://signup.way2wealth.com/way2wealth/individual_new';
    const UTM      = 'sfs';
    const FALLBACK = BASE_URL;

    heroGetStarted.addEventListener('click', (e) => {
      e.preventDefault();
      const digits = (heroMobile.value || '').replace(/\D/g, '').slice(-10);
      if (digits.length !== 10) { window.location.href = FALLBACK; return; }
      // base64-encoded JSON — matches way2wealth's atob() → JSON.parse decoder
      const encDetails = btoa(JSON.stringify({ mobile_number: digits }));
      const url = BASE_URL
                + '?enc_details=' + encodeURIComponent(encDetails)
                + '&utm_source='  + encodeURIComponent(UTM);
      window.location.href = url;
    });
  }

  /* Fade in hero video */
  const heroVideo = document.getElementById('hero-video') as HTMLVideoElement | null;
  const heroWave  = document.querySelector('.hero-wave') as HTMLElement | null;
  if (heroVideo) {
    const showVideo = () => {
      heroVideo.style.opacity = '1';
      if (heroWave) heroWave.style.opacity = '0';
    };

    const tryPlay = () => {
      heroVideo.play().catch(() => {});
    };

    if (heroVideo.readyState >= 3) {
      showVideo();
      tryPlay();
    } else {
      heroVideo.addEventListener('canplay', () => { showVideo(); tryPlay(); }, { once: true });
      heroVideo.addEventListener('loadeddata', () => { showVideo(); tryPlay(); }, { once: true });
      // Fallback: show after 1.5s regardless
      setTimeout(() => { showVideo(); tryPlay(); }, 1500);
    }

  }

  /* "How Are We Different?" — pinned section: page scroll drives the card
     panel while the sticky block is held; after the last card the page
     scrolls on normally. */
  const differPinWrap = document.getElementById('differ-pin-wrap');
  const differScroll  = document.getElementById('differ-scroll');
  const differCollage = document.getElementById('differ-collage');
  if (differPinWrap && differScroll) {
    const onScroll = () => {
      const rect   = differPinWrap.getBoundingClientRect();
      const runway = differPinWrap.offsetHeight - window.innerHeight;
      if (runway <= 0) return;
      const progress = Math.min(1, Math.max(0, -rect.top / runway));
      differScroll.scrollTop = progress * (differScroll.scrollHeight - differScroll.clientHeight);
      // Collage parallax: img is 130% tall, drift it up to -23% in sync with scroll
      if (differCollage) differCollage.style.transform = `translateY(${(-progress * 23).toFixed(2)}%)`;
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    onScroll();
  }

  /* Product cards — inward scroll-reveal */
  const productCards = document.querySelectorAll<HTMLElement>('.product-card-reveal');
  if (productCards.length) {
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const card = entry.target as HTMLElement;
            card.classList.add('revealed');
            revealObserver.unobserve(card);
            // Clear the stagger delay once the reveal finishes so the
            // hover background transition isn't delayed by it.
            setTimeout(() => { card.style.transitionDelay = '0ms'; }, 950);
          }
        });
      },
      { threshold: 0.12 }
    );
    productCards.forEach(card => revealObserver.observe(card));
  }

  /* FAQ accordion — only one question open at a time */
  const faqAccord = document.getElementById('faq-accord');
  faqAccord?.querySelectorAll('details').forEach(d => {
    d.addEventListener('toggle', () => {
      if (d.open) {
        faqAccord.querySelectorAll<HTMLDetailsElement>('details').forEach(other => {
          if (other !== d) other.removeAttribute('open');
        });
      }
    });
  });
</script>
