<script>
  /* Fade in hero video + seamless manual loop */
  const heroVideo = document.getElementById('hero-video') as HTMLVideoElement | null;
  const heroWave  = document.querySelector('.hero-wave') as HTMLElement | null;
  if (heroVideo) {
    const showVideo = () => {
      heroVideo.classList.remove('opacity-0');
      heroVideo.classList.add('opacity-100');
      if (heroWave) heroWave.style.opacity = '0';
    };
    if (heroVideo.readyState >= 3) showVideo();
    else heroVideo.addEventListener('canplaythrough', showVideo, { once: true });

    heroVideo.addEventListener('timeupdate', () => {
      if (heroVideo.duration && heroVideo.currentTime >= heroVideo.duration - 0.08) {
        heroVideo.currentTime = 0;
      }
    });

    heroVideo.addEventListener('ended', () => {
      heroVideo.currentTime = 0;
      heroVideo.play();
    });
  }

  /* Accordion — one open at a time */
  const accord = document.getElementById('differ-accord');
  accord?.querySelectorAll('details').forEach(d => {
    d.addEventListener('toggle', () => {
      if (d.open) {
        accord.querySelectorAll<HTMLDetailsElement>('details').forEach(other => {
          if (other !== d) other.removeAttribute('open');
        });
      }
    });
  });
</script>
