---
import BaseLayout from '../layouts/BaseLayout.astro';

const differItems = [
  {
    num: 'I.',
    title: 'Research-Backed Insights',
    sub: 'Get clear, high-accuracy buy and sell recommendations from our SEBI-registered market experts. No complex jargon—just simple, real-time data and market reports to help you trade with absolute confidence.',
    points: [],
    cta: 'Explore Research',
    href: '/research/',
  },
  {
    num: 'II.',
    title: 'A Relationship-Led Human Experience',
    sub: 'Premium investing experience with dedicated relationship management. Get mapped with experienced domain experts who understand your risk appetite and financial milestones. Experience seamless, personalised portfolio reviews over a call or in person.',
    points: [],
    cta: 'Meet Your Advisor',
    href: '/about/',
  },
  {
    num: 'III.',
    title: 'Partner Network',
    sub: 'Through our strong nationwide partnerships with India\'s top financial institutions, we open doors for you. Get access to specialised premium investment options, curated Portfolio Management Services (PMS), and wealth products usually reserved for big investors.',
    points: [],
    cta: 'Our Story',
    href: '/about/',
  },
  {
    num: 'IV.',
    title: 'Gentle Reminders, Zero Stress',
    sub: 'Get personalised, instant notifications on your phone only for things that matter. Know exactly when to enter or exit a stock, track your watchlist, and get alerts when your portfolio needs a quick update.',
    points: [],
    cta: 'Explore Antara',
    href: '/about/antara-web-login/',
  },
];

const advisoryCards = [
  {
    img: '/images/advisory/icon-1.png',
    title: 'Daily Expert Stock Picks',
    body: 'Get daily, SEBI-registered stock recommendations and market trends before you start your trading day.',
    cta: 'Explore Now',
    href: '/research/',
  },
  {
    img: '/images/advisory/icon-2.png',
    title: 'Share Market Trading',
    body: 'Buy and sell shares seamlessly on the NSE and BSE with a secure platform.',
    cta: 'Explore Market',
    href: '/products/equity/',
  },
  {
    img: '/images/advisory/icon-3.png',
    title: "Today's Trading Ideas",
    body: 'Learn proven techniques from seasoned traders.',
    cta: 'Discover Trading Ideas',
    href: '/research/technical/',
  },
  {
    img: '/images/advisory/icon-4.png',
    title: 'Market Guidance',
    body: 'Stay aware and updated with real-time analysis and clear, human advice.',
    cta: 'Connect With An Advisor',
    href: '/about/support/',
  },
];

const allProducts = [
  { label: 'Stocks / Shares',               href: '/products/equity/',        sub: 'Buy and sell shares across NSE & BSE with expert stock recommendations, real-time market data, and zero brokerage on delivery trades.',  img: '/images/products/icon-equity.svg' },
  { label: 'Margin Trading Facility (MTF)', href: '/products/mtf/',           sub: 'Trade with leverage and increase your buying power with flexible margin options.',       img: '/images/products/icon-mtf.svg' },
  { label: 'Derivatives',                   href: '/products/derivative/',    sub: 'Trade Futures & Options on NSE & BSE. Hedge your portfolio or capitalise on short-term opportunities.',                                   img: '/images/products/icon-derivatives.svg' },
  { label: 'Mutual Funds',                  href: '/products/mutual-funds/',  sub: 'Compare 3,000+ Mutual funds and invest in Direct Plans with 0% commission.',           img: '/images/products/icon-mf.svg' },
  { label: 'Loan Against Mutual Funds (LAMF)', href: '/products/mtf/',        sub: 'Get instant loans against your mutual fund holdings at competitive interest rates.',    img: '/images/products/icon-lamf.svg' },
  { label: 'Initial Public Offering (IPO)', href: '/products/ipo/',           sub: 'Stay updated and apply for IPO across NSE & BSE—follow companies as they debut on the stock market.',                                    img: '/images/products/icon-ipo.svg' },
  { label: 'Exchange Traded Funds (ETF)',    href: '/products/etf/',           sub: 'Diversify your portfolio with ETFs tracking indices, sectors, and commodities.',        img: '/images/products/icon-etf.svg' },
  { label: 'National Pension Scheme (NPS)', href: '/products/nps/',           sub: 'Build a tax-efficient retirement corpus with government-backed National Pension Scheme.',                                                  img: '/images/products/icon-nps.svg' },
];

const faqs = [
  {
    q: 'What is a Demat Account?',
    a: 'A Demat Account holds your financial shares, mutual funds, and bonds safely in an electronic format. It is mandatory for trading in the Indian stock market.',
  },
  {
    q: 'What are the benefits of a Demat Account?',
    a: 'A Demat account completely eliminates the risk of theft, loss, or damage to physical paper certificates. It enables instant, one-click online buying and selling of shares, reduces paperwork, and ensures all your investments are visible in one secure place.',
  },
  {
    q: 'What are the brokerage charges for options trading with Shriram Securities?',
    a: 'Brokerage charges for options trading are structured to be competitive and straightforward. Shriram Securities charges a flat fee of ₹20 per executed order for options trading. To further understand and calculate the total costs, including brokerage, taxes, and other fees, you can use the Brokerage Calculator. This tool helps you estimate the net profit or loss on your trades by accounting for all applicable charges.',
  },
  {
    q: 'Are there any charges associated with the Demat Account?',
    a: 'Account opening and Annual Maintenance Charges (AMC) are ₹0 for both Trading and Demat Accounts. Standard SEBI and exchange-mandated statutory charges (STT, exchange transaction charges, GST, SEBI fees) apply to all trades as per regulations.',
  },
  {
    q: 'What is Intraday brokerage and Option brokerage?',
    a: 'Intraday brokerage is the small fee charged when you buy and sell a stock on the exact same day. Option brokerage is a fixed flat fee (like our standard ₹20 per order) charged for trading in options contracts, regardless of how big or small the transaction volume is.',
  },
  {
    q: 'Can I have multiple Demat Accounts?',
    a: 'Yes, absolutely! Legally, you can open more than one Demat account in India, provided they are opened with different stockbrokers. However, you can only link one Demat account to your primary trading account at a time.',
  },
  {
    q: 'Is a Demat Account mandatory for applying for an IPO?',
    a: 'Yes. When a new company lists on the share market, its digital shares must be deposited directly into an electronic account. Therefore, you must have an active Demat account to apply for and receive shares in an IPO.',
  },
];
---

<BaseLayout title="" description="Shriram Financial Services — Advisory-Led Wealth Curation. Invest across equity, mutual funds, bonds and more with India's most trusted platform.">

  <!-- ══ HERO ══ -->
  <section class="relative xl:min-h-[calc(100vh-80px)] overflow-hidden">
    <div class="hero-wave" aria-hidden="true"></div>
    <video id="hero-video"
      class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-1000"
      autoplay muted playsinline loop preload="auto" aria-hidden="true">
      <source src="/videos/BG.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-gradient-to-r from-white/82 via-white/48 to-white/0" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-black/8 via-transparent to-black/12" aria-hidden="true"></div>

    <div class="site-wrap relative z-10 flex items-start gap-8 py-14 sm:py-20 lg:py-24 xl:min-h-[calc(100vh-80px)] xl:items-center xl:gap-12 xl:py-0">

      <!-- Left text -->
      <div class="w-full xl:max-w-[690px] xl:shrink-0 reveal reveal-1">
        <h1 class="text-[28px] font-normal leading-[1.30] text-[#2e3914] sm:text-[36px] lg:text-[clamp(36px,2.5vw,48px)]" style="font-family:var(--font-display)">
          Smart Investing Made Simple.<br>
          <span class="lg:whitespace-nowrap"><span class="font-bold text-[var(--color-brand)]">Guided</span> by Experts.</span>
        </h1>
        <p class="mt-5 text-[15px] leading-relaxed text-[#2e3914] lg:text-[17px]">
          Invest with confidence using India's most trusted, advisor-led platform.
        </p>

        <!-- Trust badges -->
        <div class="mt-5 flex flex-wrap items-center gap-x-3 gap-y-1.5">
          {['Trusted by 10 Lakh+ Investors', 'SEBI Regulated', 'Pan-India Presence'].map((t, i) => (
            <div class="flex items-center gap-3">
              {i > 0 && <span class="trust-dot"></span>}
              <span class="text-[14px] font-medium text-[#2e3914]">{t}</span>
            </div>
          ))}
        </div>

        <div class="mt-8">
          <a href="/about/antara-web-login/" class="inline-flex items-center justify-center gap-1.5 h-[48px] px-6 rounded-[6px] bg-[#2e3914] text-white text-[14px] font-medium hover:bg-[#1a2010] transition-colors" style="width:220px">Explore Antara</a>
        </div>
      </div>

      <!-- Right: glass Open Demat card -->
      <div class="reveal reveal-2 hidden flex-1 justify-end xl:flex xl:pr-[4%]">
        <div class="warm-form w-full max-w-[660px] p-10 xl:p-[64px]">

          <!-- Title + badges (gap-[16px] per Figma) -->
          <div class="flex flex-col gap-4">
            <h2 class="text-[32px] font-medium leading-tight text-[#4f583b]">
              Open a Demat Account
            </h2>
            <div class="flex flex-wrap items-center gap-x-4 gap-y-1.5">
              {['100% Digital & Paperless', 'Open Within Minutes', 'SEBI-Regulated'].map((t, i) => (
                <div class="flex items-center gap-4">
                  {i > 0 && <span class="trust-dot"></span>}
                  <span class="text-[12px] font-medium text-[#4f583b]">{t}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Form fields (gap-[48px] from title block, gap-[24px] between fields) -->
          <div class="mt-12 flex flex-col gap-6">
            <!-- Mobile input (Figma 163:3230 — 48px, 18px flag circle, 10px label, 14px number) -->
            <div class="flex h-[48px] items-center gap-3 rounded-[8px] border border-[var(--color-n500)] bg-white py-3 pl-4 pr-3.5">
              <span class="h-[18px] w-[18px] shrink-0 overflow-hidden rounded-full">
                <img src="/images/india-flag.png" alt="India" class="h-full w-full object-cover" />
              </span>
              <span class="h-6 w-px shrink-0 bg-[var(--color-n400)]"></span>
              <div class="flex min-w-0 flex-1 flex-col justify-center gap-[2px]">
                <label for="hero-mobile" class="text-[10px] font-medium leading-[1.2] text-[var(--color-n700)]">Mobile Number</label>
                <div class="flex items-center gap-1">
                  <span class="text-[14px] font-medium leading-[1.4] text-[var(--color-n900)]">+91</span>
                  <input
                    id="hero-mobile"
                    type="tel"
                    placeholder="00000 00000"
                    class="min-w-0 flex-1 border-none bg-transparent text-[14px] font-medium leading-[1.4] text-[var(--color-n900)] outline-none placeholder:font-normal placeholder:text-[var(--color-n500)]"
                  />
                </div>
              </div>
            </div>

            <!-- Consent text -->
            <p class="text-[12px] font-medium leading-[1.5] text-[var(--color-n900)]">
              By continuing, I agree to receive a quick OTP verification and updates via SMS/WhatsApp.
            </p>

            <!-- Buttons (gap-[16px]) -->
            <div class="flex flex-col gap-4">
              <a href="/about/open-demat-account/" class="inline-flex h-[48px] w-[220px] self-start items-center justify-center rounded-[6px] bg-[#f3b83f] text-[12px] font-medium text-[#202318] transition-colors hover:bg-[#d4982a]">
                Get Started Now
              </a>
              <p class="text-[12px] font-medium text-[var(--color-n900)]">
                Already a part of us?{' '}
                <a href="/about/antara-web-login/" class="text-[#2f7ef4] hover:underline">Login Here.</a>
              </p>
            </div>
          </div>

        </div>
      </div>

    </div>
  </section>

  <!-- ══ HOW ARE WE DIFFERENT? ══
       Tall runway wrapper + sticky inner block: page scroll is mapped to the
       card panel while the section is pinned; after the 4th card the page
       scrolls on normally. -->
  <section class="bg-[#FFFCF3]" id="differ-pin-wrap" style="height:280vh">
    <div class="sticky top-[80px] flex h-[calc(100vh-80px)] items-center">
    <!-- Figma 163:3255 — block sits 32px from screen edges, not site-wrap width -->
    <div class="w-full px-8 py-8">
      <div class="relative overflow-hidden rounded-[24px] lg:h-[min(923px,calc(100vh-144px))]" style="background:radial-gradient(ellipse 132% 312% at 117% -4%,#4F583B 0%,#3F4733 14%,#363A2C 25%,#2a2d23 38%,#1d1d1d 55%,#1d1d1d 100%);">
        <!-- Shriram history collage on the left at 10% opacity (Figma 222:3636 / 185:3410);
             drifts slowly upward with scroll progress -->
        <div class="pointer-events-none absolute inset-y-0 left-0 w-full overflow-hidden opacity-10 lg:w-[64%]"
             style="-webkit-mask-image:linear-gradient(to right,#000 55%,transparent 95%);mask-image:linear-gradient(to right,#000 55%,transparent 95%);">
          <img id="differ-collage" src="/images/differ-collage.png" alt=""
               class="h-[130%] w-full object-cover object-top will-change-transform" />
        </div>
        <!-- Same gradient painted ON TOP, fading in left->right to bury the photo edge -->
        <div class="pointer-events-none absolute inset-0"
             style="background:radial-gradient(ellipse 132% 312% at 117% -4%,#4F583B 0%,#3F4733 14%,#363A2C 25%,#2a2d23 38%,#1d1d1d 55%,#1d1d1d 100%);-webkit-mask-image:linear-gradient(to right,transparent 25%,#000 58%);mask-image:linear-gradient(to right,transparent 25%,#000 58%);"></div>

        <!-- Centered columns (Figma placement); right rail spans the entire section height -->
        <div class="relative z-10 flex h-full flex-col gap-10 p-8 lg:flex-row lg:items-center lg:justify-center lg:gap-[88px] lg:px-[112px] lg:py-0">

          <!-- Left: heading + subtitle (Figma: 648px col, 40px/18px type, 16px gap) -->
          <div class="self-center drop-shadow-[0px_3px_3.4px_rgba(0,0,0,0.45)] lg:w-[648px] lg:shrink-0">
            <h2 class="text-[28px] font-normal leading-[1.4] text-white sm:text-[34px] lg:text-[40px]" style="font-family:var(--font-display)">
              Why Shriram Financial <span class="font-semibold text-[#f3b83f]">Services?</span>
            </h2>
            <p class="mt-4 text-[15px] leading-[1.5] text-white lg:text-[18px]">
              Real Humans | Smart Tech | Better Returns. Because Your Money Deserves Personal Attention, we combine easy-to-use technology with real human experts and data-backed research to help you build lasting, long-term wealth.
            </p>
          </div>

          <!-- Right: full-height card rail with glassy top/bottom edge fades -->
          <div class="relative w-full lg:h-full lg:w-[625px] lg:shrink-0 lg:self-stretch">
          <div id="differ-scroll" class="no-scrollbar flex h-[410px] w-full flex-col gap-[96px] overflow-hidden lg:h-full">
            {differItems.map((item) => (
              <div class="flex h-[410px] w-full shrink-0 items-center overflow-hidden rounded-[24px] border-2 border-[rgba(255,255,255,0.27)] border-b-[#f3b83f] px-8 py-10 lg:px-[56px] lg:py-[88px]"
                   style="background:rgba(116,116,116,0.10);backdrop-filter:blur(27.55px);-webkit-backdrop-filter:blur(27.55px);">
                <div class="flex h-full w-full flex-col justify-end gap-6 text-[#f8f4e8] lg:gap-[40px]">
                  <div class="flex flex-col gap-2">
                    <h3 class="text-[22px] font-medium leading-[1.5] lg:text-[32px]" style="font-family:var(--font-body)">{item.num} {item.title}</h3>
                    <p class="text-[14px] leading-[1.3] lg:text-[16px]">{item.sub}</p>
                  </div>
                  <ul class="flex flex-col gap-4">
                    {item.points.map(p => (
                      <li class="flex items-start gap-2.5 text-[14px] leading-[1.4]">
                        <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-[#f8f4e8]"></span>
                        {p}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            ))}
          </div>
          <div class="differ-fade differ-fade-top" aria-hidden="true"></div>
          <div class="differ-fade differ-fade-bottom" aria-hidden="true"></div>
          </div>

        </div>
      </div>
    </div>
    </div>
  </section>

  <!-- ══ STRATEGIC ADVISORY ══ -->
  <section class="bg-[#FFFCF3]">
    <div class="site-wrap py-16 lg:py-20">
      <h2 class="text-[22px] font-normal text-[var(--color-n900)] sm:text-[28px] lg:text-[42px]" style="font-family:var(--font-display)">
        Strategic Advisory For Every Investor
      </h2>
      <p class="mt-4 max-w-4xl text-[15px] text-[var(--color-muted)]">
        Whether you're placing your first trade, investing in SIP or rebalancing a large portfolio, our SEBI-registered analysts and personal relationship managers ensure every move you make is research-backed.
      </p>

      <div class="advisory-grid mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {advisoryCards.map((c) => (
          <div class="advisory-card group relative flex h-[322px] flex-col justify-center overflow-hidden rounded-[24px] bg-[#f8f4e8] px-6 py-10">
            <!-- Content + icon slide up on hover (per 4-card video) -->
            <div class="flex flex-col transition-transform duration-300 group-hover:-translate-y-7">
              <img src={c.img} alt="" class="h-[80px] w-[100px] shrink-0 object-contain object-left" />
              <div class="mt-8 flex flex-col gap-3">
                <h3 class="text-[16px] font-bold uppercase tracking-[1.2px] text-[#2e3914]">{c.title}</h3>
                <p class="text-[14px] leading-[1.5] text-[#4f583b]">{c.body}</p>
              </div>
            </div>
            <!-- Citrus pill CTA slides up from below -->
            <a href={c.href}
               class="absolute bottom-0 left-0 right-0 flex h-[56px] translate-y-[64px] items-center justify-center gap-3 bg-[#f3b83f] text-[14px] font-medium text-[#2e3914] opacity-0 transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">
              {c.cta}
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 shrink-0"><path d="M2 8h11M9 4l4 4-4 4"/></svg>
            </a>
          </div>
        ))}
      </div>

      <!-- Nudge CTA (Figma: #FFF0D7 bar with illustration) -->
      <div class="mt-6 flex flex-col items-center justify-between overflow-hidden rounded-[24px] bg-[#FFF0D7] sm:flex-row">
        <div class="ml-8 hidden h-[141px] w-[170px] shrink-0 items-center justify-center py-2 sm:flex">
          <img src="/images/advisory/nudge-illustration.svg" alt="" width="170" height="141" class="h-full w-auto object-contain" />
        </div>
        <div class="flex flex-1 items-center justify-between gap-6 px-8 py-6">
          <div>
            <p class="text-[18px] font-semibold text-[var(--color-n900)]">
              Confused About Where to Start? <span class="text-[var(--color-brand)]">We've got your back.</span>
            </p>
            <p class="mt-2 max-w-xl text-[14px] leading-relaxed text-[var(--color-muted)]">
              Our dedicated financial specialists will look at your current savings and help you build a personalised, easy-to-follow wealth plan for your future.
            </p>
          </div>
          <a href="/about/support/" class="btn-primary shrink-0">Schedule a Call</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ PRODUCTS ══ (rounded block, 32px from screen edges, 923px tall — same as differ) -->
  <section class="bg-[#FFFCF3] px-8 py-8">
    <div class="relative overflow-hidden rounded-[24px] lg:flex lg:min-h-[min(923px,calc(100vh-96px))] lg:flex-col lg:justify-center" style="background:radial-gradient(ellipse 132% 312% at 117% -4%,#4F583B 0%,#3F4733 14%,#363A2C 25%,#2a2d23 38%,#1d1d1d 55%,#1d1d1d 100%);">
    <div class="site-wrap relative py-16 lg:py-20">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h2 class="text-[26px] font-normal leading-tight text-white sm:text-[32px] lg:text-[44px]" style="font-family:var(--font-display)">
            Trade, Invest or Borrow — <span class="font-semibold text-[#f3b83f]">All at One Place.</span>
          </h2>
          <p class="mt-3 text-[15px] text-[rgba(255,255,255,0.55)]">
            From expert advice to instant, one-tap investments, everything you need to manage your money is right here.
          </p>
        </div>
        <a href="/products/" class="shrink-0 text-[13px] font-semibold text-[var(--color-brand-light)] hover:text-white">
          View All Our Products →
        </a>
      </div>
      <div class="mt-10 grid grid-cols-2 gap-4 lg:grid-cols-4" id="products-grid">
        {allProducts.map((p, i) => (
          <a href={p.href}
             class="product-card-reveal group relative flex h-[284px] flex-col overflow-hidden rounded-[24px] border border-white/10 bg-[#2b2c2b] p-8 hover:z-10 hover:bg-[#2e3914]"
             data-row={i < 4 ? '1' : '2'}
             style={`transition-delay:${(i % 4) * 90}ms`}>
            <!-- Giant citrus circle shrinks into the 80px top-right circle on hover -->
            <div class="product-card-circle">
              <svg viewBox="0 0 24 24" fill="none" stroke="#202318" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 shrink-0">
                <path d="M7 17L17 7M17 7H7M17 7v10"/>
              </svg>
            </div>
            <!-- Content centered; slides up on hover as View More reveals (per 8-card video) -->
            <div class="relative z-10 flex h-full flex-col justify-center">
              <img src={p.img} alt="" class="h-[44px] w-[44px] shrink-0 object-contain" />
              <h3 class="mt-6 text-[16px] font-bold leading-snug text-white" style="font-family:var(--font-display)">{p.label}</h3>
              <p class="mt-2 text-[13px] leading-[1.6] text-white/70">{p.sub}</p>
              <span class="block max-h-0 overflow-hidden text-[12px] font-medium text-white/80 opacity-0 transition-all duration-300 group-hover:mt-5 group-hover:max-h-[24px] group-hover:opacity-100">View More</span>
            </div>
          </a>
        ))}
      </div>
    </div>
    </div>
  </section>

  <!-- ══ HOW SOON CAN I START? ══ -->
  <section class="bg-[#FFFCF3]">
    <div class="site-wrap py-36">

      <!-- Top row: text left + rocket right -->
      <div class="relative flex items-start justify-between gap-12">

        <!-- Left: heading + subtitle + CTA -->
        <div class="flex max-w-[600px] flex-col gap-12">
          <div class="flex flex-col gap-4">
            <h2 class="whitespace-nowrap text-[40px] font-normal leading-[1.4] text-[var(--color-n900)]" style="font-family:var(--font-body)">
              How to Open your Demat Account?
            </h2>
            <p class="text-[18px] leading-relaxed tracking-[0.36px] text-[var(--color-n900)]" style="font-family:var(--font-body)">
              Fully digital, paperless, and SEBI-compliant. Complete the below steps from your phone or laptop — no branch visit needed.
            </p>
          </div>
          <a href="/about/open-demat-account/"
             class="flex h-[40px] w-[220px] items-center justify-center rounded-[6px] bg-[var(--color-brand)] text-[12px] font-medium text-[#202318] transition-colors hover:bg-[var(--color-brand-hover)]">
            Open a Demat Account
          </a>
        </div>

        <!-- Right: rocket illustration — flush to the right section edge -->
        <div class="hidden flex-1 items-center lg:flex" style="margin-right: calc(-1 * clamp(1rem, 6vw, 8rem))">
          <img src="/images/how-soon-illustration.svg" alt="Rocket launch illustration"
               width="777" height="340"
               class="h-auto w-full max-h-[360px] object-contain object-right" />
        </div>
      </div>

      <!-- Steps row — Figma 185:3609: #FFF0D7 pills + dashed connector (#EBDEC6, 2px, 7-7) -->
      <div class="relative mt-32">
        <div class="absolute top-[31px] hidden h-[2px] sm:left-[10%] sm:right-[10%] sm:block"
