---
import BaseLayout from '../layouts/BaseLayout.astro';

const differItems = [
  {
    num: 'I.',
    title: 'Research-Backed Insights',
    sub: 'SEBI-registered analysis — not third-party tips or unverified calls',
    points: [
      'Access high-conviction equity, F&O, and mutual fund research published by SEBI-registered analysts (INH200009624) — every call is legally accountable.',
      'Daily technical views, quarterly company deep-dives, and macro reports give you the edge to invest with confidence, not speculation.',
    ],
    cta: 'Explore Research',
    href: '/research/',
  },
  {
    num: 'II.',
    title: 'Relationship-Led Human Experience',
    sub: 'Dedicated relationship managers who know your name, not just your portfolio',
    points: [
      'Every Shriram client is mapped to a named Relationship Manager who understands your risk appetite, financial milestones, and goals.',
      'Get personalised portfolio reviews over a call or in person — no chatbots, no automated responses, no generic advice.',
    ],
    cta: 'Meet Your Advisor',
    href: '/about/',
  },
  {
    num: 'III.',
    title: 'Partner Network',
    sub: 'A trusted network of 3,000+ branches across India',
    points: [
      'With over 3,000 branches across India, Shriram Financial Services brings professional wealth management to every corner of the country.',
      'Our extensive partner network ensures you always have access to a local expert who understands your region and market conditions.',
    ],
    cta: 'Find a Branch',
    href: '/about/',
  },
  {
    num: 'IV.',
    title: 'Personalized Notifications',
    sub: 'Real-time alerts tailored to your portfolio and goals',
    points: [
      'Receive personalized research alerts, price targets, and portfolio rebalancing reminders pushed directly to your Antara dashboard and mobile app.',
      'Custom watchlist alerts, IPO opening notifications, and dividend announcements relevant to your holdings — stay informed, never miss an opportunity.',
    ],
    cta: 'Explore Antara',
    href: '/about/antara-web-login/',
  },
];

const advisoryCards = [
  {
    title: 'Expert Research Calls',
    body: 'Access SEBI-registered equity research backed by fundamental and technical analysis. Every call is legally accountable — not unverified tips.',
    icon: `<svg viewBox="0 0 40 40" fill="none"><rect width="40" height="40" rx="8" fill="#EEF4FF"/><path d="M10 28l5-5 4 4 6-8 5-3" stroke="#0E52CB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M30 10v5h-5" stroke="#0E52CB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    title: 'Trade Indian Equities',
    body: 'Buy and sell stocks on NSE and BSE with zero delivery brokerage and flat ₹20 for intraday. Full Level 2 market depth on Antara.',
    icon: `<svg viewBox="0 0 40 40" fill="none"><rect width="40" height="40" rx="8" fill="#EEF4FF"/><polyline points="8,28 14,20 18,24 26,14 32,10" stroke="#0E52CB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><polyline points="26,10 32,10 32,16" stroke="#0E52CB" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    title: "Today's Trading Ideas",
    body: 'Daily technical setups and intraday opportunities from our in-house research team — with defined entry, target, and stop-loss levels.',
    icon: `<svg viewBox="0 0 40 40" fill="none"><rect width="40" height="40" rx="8" fill="#EEF4FF"/><circle cx="20" cy="18" r="8" stroke="#0E52CB" stroke-width="1.5"/><path d="M20 10v8l5 3" stroke="#0E52CB" stroke-width="1.5" stroke-linecap="round"/><path d="M14 30h12" stroke="#0E52CB" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    title: 'Get Expert Advice',
    body: 'Talk to a dedicated Relationship Manager for personalised portfolio guidance. Schedule a call, visit a branch, or chat online — available when markets move.',
    icon: `<svg viewBox="0 0 40 40" fill="none"><rect width="40" height="40" rx="8" fill="#EEF4FF"/><circle cx="20" cy="14" r="5" stroke="#0E52CB" stroke-width="1.5"/><path d="M10 30c0-5.5 4.5-10 10-10s10 4.5 10 10" stroke="#0E52CB" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
];

const allProducts = [
  { label: 'Stocks',       href: '/products/equity/',       icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><polyline points="3,17 8,11 12,15 19,7"/><polyline points="15,7 19,7 19,11"/></svg>` },
  { label: 'MTF',          href: '/products/mtf/',          icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><ellipse cx="12" cy="7" rx="7" ry="2.5"/><path d="M5 7v5c0 1.4 3.1 2.5 7 2.5S19 13.4 19 12V7"/><path d="M5 12v3c0 1.4 3.1 2.5 7 2.5"/><path d="M17 18l2-2 2 2M19 16v4"/></svg>` },
  { label: 'Derivatives',  href: '/products/derivative/',   icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M7 17V7m0 0L4 10m3-3 3 3M17 7v10m0 0 3-3m-3 3-3-3"/></svg>` },
  { label: 'Mutual Funds', href: '/products/mutual-funds/', icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M12 3a9 9 0 0 1 9 9H12V3z"/><circle cx="12" cy="12" r="9"/></svg>` },
  { label: 'LAMF',         href: '/products/mtf/',          icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M10 13a5 5 0 0 0 7 .5l3-3a5 5 0 0 0-7-7L11 5"/><path d="M14 11a5 5 0 0 0-7-.5l-3 3a5 5 0 0 0 7 7l1.5-1.5"/></svg>` },
  { label: 'IPO',          href: '/products/ipo/',          icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M4.5 17.5c-1.5 1.2-1.5 4-1.5 4s2.8-.3 4-1.5a1.8 1.8 0 0 0-2.5-2.5z"/><path d="M12 15.5 10 13A19 19 0 0 1 11.5 10 11 11 0 0 1 20 3c0 2-.5 6.5-5.5 10a19 19 0 0 1-2.5 2.5z"/></svg>` },
  { label: 'ETF',          href: '/products/etf/',          icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>` },
  { label: 'NPS',          href: '/products/nps/',          icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M20 12A8 8 0 1 0 4 12h16Z"/><path d="M15 16a3 3 0 0 1-6 0v-4"/></svg>` },
];

const startSteps = [
  {
    title: 'Basic Information',
    desc: 'Name, mobile number, PAN — takes under two minutes.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/><path d="M16 5l1.5 1.5L20 4"/></svg>`,
  },
  {
    title: 'Complete eKYC via Aadhaar',
    desc: 'OTP-based verification — no physical forms or branch visits.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M9 7h6M9 11h4M9 15h2"/></svg>`,
  },
  {
    title: 'Upload Documents',
    desc: "Bank proof and a live photograph from your phone's camera.",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="M9 15l2 2 4-4"/></svg>`,
  },
  {
    title: 'Digital eSign',
    desc: 'Aadhaar-based e-sign replaces physical signature on all forms.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>`,
  },
  {
    title: 'Account Activation',
    desc: 'Credentials delivered to your registered email. Start investing.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>`,
  },
];

const faqs = [
  {
    q: 'What is a Demat Account?',
    a: 'A Demat (Dematerialised) Account is a digital repository that holds your financial securities — stocks, bonds, ETFs, and mutual fund units — in electronic form. Just as a bank account holds your money, a Demat account holds your investments securely with CDSL or NSDL as the depository.',
  },
  {
    q: 'What are the benefits of a Demat Account?',
    a: 'A Demat account eliminates the risk of physical share certificates being lost, stolen, or damaged. It enables faster settlement (T+1), easier nomination and transmission of assets, and a single consolidated view of all your holdings — equity, bonds, ETFs, and IPO allotments — in one place.',
  },
  {
    q: 'What are the brokerage charges for options trading with Shriram Securities?',
    a: 'Brokerage charges for options trading are structured to be competitive and straightforward. Shriram Securities charges a flat fee of ₹20 per executed order for options trading. To further understand and calculate the total costs, including brokerage, taxes, and other fees, you can use the Brokerage Calculator. This tool helps you estimate the net profit or loss on your trades by accounting for all applicable charges.',
  },
  {
    q: 'Are there any charges associated with the Demat Account?',
    a: 'Account opening is completely free (₹0). Annual Maintenance Charges (AMC) are also ₹0 for the first year. Transaction charges apply only when you buy or sell — at a flat 0.5% for delivery trades and ₹20 flat for intraday and F&O orders. There are no hidden fees or minimum balance requirements.',
  },
  {
    q: 'What is Intraday brokerage and Option brokerage?',
    a: 'Intraday brokerage applies when you buy and sell the same stock within the same trading day. At Shriram, intraday equity trades are charged at a flat ₹20 per executed order. Option brokerage is also flat ₹20 per executed order regardless of the premium or trade size — so a ₹5 lot and a ₹5 lakh lot cost the same.',
  },
  {
    q: 'Can I have multiple Demat Accounts?',
    a: "Yes, there is no regulatory restriction on holding multiple Demat accounts with different depository participants (DPs). However, each account has its own AMC and maintenance obligations. Most investors find a single, well-featured account like Shriram's Antara platform sufficient for all their investment needs.",
  },
  {
    q: 'Is a Demat Account mandatory for applying for an IPO?',
    a: 'Yes. SEBI mandates that all IPO applications — whether through UPI ASBA or net banking — require a valid Demat account for share allotment. If allotted, shares are credited directly to your Demat account within T+6 days of the IPO closing date. Without a Demat account, you cannot receive IPO allotments.',
  },
];
---

<BaseLayout title="" description="Shriram Financial Services — Advisory-Led Wealth Curation. Invest across equity, mutual funds, bonds and more with India's most trusted platform.">

  <!-- ══ HERO ══ -->
  <section class="relative xl:min-h-[calc(100vh-88px)] overflow-hidden">
    <div class="hero-wave" aria-hidden="true"></div>
    <video id="hero-video"
      class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-1000"
      autoplay muted playsinline aria-hidden="true">
      <source src="/9150545-hd_1920_1080_24fps.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-gradient-to-r from-white/82 via-white/48 to-white/0" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-black/8 via-transparent to-black/12" aria-hidden="true"></div>

    <div class="site-wrap relative z-10 flex items-start gap-8 py-14 sm:py-20 lg:py-24 xl:min-h-[calc(100vh-88px)] xl:items-center xl:gap-12 xl:py-0">

      <!-- Left text -->
      <div class="w-full xl:max-w-[580px] xl:shrink-0 reveal reveal-1">
        <h1 class="text-[28px] font-bold leading-[1.25] text-[var(--color-n900)] sm:text-[36px] lg:text-[54px]" style="font-family:var(--font-display)">
          Beyond Portfolios;<br>
          <span class="text-[var(--color-brand)]">Advisory-Led</span><br>
          Wealth Curation
        </h1>
        <p class="mt-5 text-[15px] leading-relaxed text-[var(--color-n800)] lg:text-[17px]">
          Expert advisory, SEBI-registered research, and a dedicated Relationship Manager — everything you need to grow wealth intelligently.
        </p>

        <!-- Trust badges -->
        <div class="mt-5 flex flex-wrap items-center gap-x-3 gap-y-1.5">
          {['10 L+ Investors', 'SEBI Registered', '50+ Years of Trust'].map((t, i) => (
            <div class="flex items-center gap-3">
              {i > 0 && <span class="trust-dot"></span>}
              <span class="text-[13px] font-medium text-[var(--color-n800)]">{t}</span>
            </div>
          ))}
        </div>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/about/open-demat-account/" class="btn-primary">Open a Demat Account</a>
          <a href="/about/antara-web-login/"
             class="inline-flex h-12 items-center rounded border border-[var(--color-brand)] px-6 text-[14px] font-medium text-[var(--color-brand)] transition-colors hover:bg-[var(--color-brand-pale)]">
            Explore Antara
          </a>
        </div>

        <!-- Mini stats row -->
        <div class="mt-10 flex flex-wrap gap-6">
          {[
            { val: '₹0', label: 'Delivery Brokerage' },
            { val: '₹20', label: 'Flat F&O Brokerage' },
            { val: '10 min', label: 'Account Opening' },
          ].map(s => (
            <div class="flex flex-col gap-0.5">
              <span class="text-[18px] font-bold text-[var(--color-brand)] sm:text-[22px]" style="font-family:var(--font-display)">{s.val}</span>
              <span class="text-[11px] text-[var(--color-muted)]">{s.label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: glassmorphism Open Demat card -->
      <div class="reveal reveal-2 hidden flex-1 justify-end xl:flex">
        <div class="glass-form w-full max-w-[540px] rounded-xl p-10">
          <h2 class="text-[30px] font-semibold text-[var(--color-n900)]" style="font-family:var(--font-display)">
            Open a Demat Account
          </h2>
          <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-1.5">
            {['100% Paperless', 'Within 10 Minutes', 'SEBI Regulated'].map((t, i) => (
              <div class="flex items-center gap-3">
                {i > 0 && <span class="trust-dot" style="background:#999"></span>}
                <span class="text-[12px] font-medium text-[var(--color-n700)]">{t}</span>
              </div>
            ))}
          </div>
          <div class="mt-8">
            <div class="flex h-[52px] items-center gap-3 rounded-lg border border-[var(--color-n500)] bg-white px-4 shadow-sm">
              <span class="text-[20px]">🇮🇳</span>
              <span class="h-5 w-px bg-[var(--color-n400)]"></span>
              <div class="flex-1">
                <div class="text-[10px] font-semibold uppercase tracking-wide text-[var(--color-n700)]">Mobile Number</div>
                <div class="text-[15px] font-medium text-[var(--color-n800)]">+91</div>
              </div>
            </div>
            <p class="mt-2.5 text-[11px] text-[var(--color-n700)]">
              By continuing, I agree to receive OTP and account updates via SMS/WhatsApp.
            </p>
          </div>
          <div class="mt-6 space-y-3">
            <a href="/about/open-demat-account/" class="btn-primary w-full justify-center text-[15px]">
              Get Started — It's Free
            </a>
            <p class="text-center text-[13px] text-[var(--color-n900)]">
              Already a client?{' '}
              <a href="/about/antara-web-login/" class="font-bold text-[var(--color-link)] hover:underline">Login to Antara</a>
            </p>
          </div>
          <!-- Social proof -->
          <div class="mt-8 flex items-center gap-3 rounded-lg bg-white/60 px-4 py-3">
            <div class="flex -space-x-2">
              {['#3B5', '#47B', '#B73', '#6A3'].map(c => (
                <div class="h-7 w-7 rounded-full border-2 border-white" style={`background:${c}B`}></div>
              ))}
            </div>
            <p class="text-[12px] text-[var(--color-n800)]">Join <strong>10 lakh+</strong> investors who trust Shriram</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ══ HOW ARE WE DIFFERENT? ══ -->
  <section class="bg-[var(--color-dark-800)]">
    <div class="site-wrap py-16 lg:py-20">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-20">
        <div class="border-gold-left self-start lg:sticky lg:top-28">
          <h2 class="text-[24px] font-bold leading-tight text-white sm:text-[30px] lg:text-[42px]" style="font-family:var(--font-display)">
            How Are We<br>Different?
          </h2>
          <p class="mt-4 text-[15px] leading-relaxed text-[rgba(255,255,255,0.65)]">
            We go beyond execution-only by fusing 50 years of trust, human-led advisory, SEBI-registered research, and technology that delivers better investing outcomes — building long-term wealth, not just portfolios.
          </p>
        </div>
        <div class="space-y-0" id="differ-accord">
          {differItems.map((item, i) => (
            <details class="accord-item group" open={i === 0}>
              <summary class="flex cursor-pointer select-none items-start justify-between gap-4 px-6 py-7">
                <div class="flex-1">
                  <div class="flex items-baseline gap-3">
                    <span class="text-[13px] font-bold text-[rgba(255,255,255,0.40)]">{item.num}</span>
                    <h3 class="text-[20px] font-semibold text-white" style="font-family:var(--font-display)">{item.title}</h3>
                  </div>
                  <p class="mt-1 text-[13px] text-[rgba(255,255,255,0.50)]">{item.sub}</p>
                </div>
                <span class="mt-1 shrink-0 text-[rgba(255,255,255,0.40)] transition-transform group-open:rotate-90">
                  <svg viewBox="0 0 16 16" fill="currentColor" class="h-4 w-4"><path d="M6 4l4 4-4 4V4z"/></svg>
                </span>
              </summary>
              <div class="px-6 pb-7">
                <ul class="space-y-2.5">
                  {item.points.map(p => (
                    <li class="flex items-start gap-2.5 text-[14px] text-[rgba(255,255,255,0.65)]">
                      <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--color-gold)]"></span>
                      {p}
                    </li>
                  ))}
                </ul>
                <a href={item.href} class="mt-6 inline-flex items-center gap-2 rounded border border-[rgba(255,255,255,0.25)] px-5 py-2.5 text-[13px] font-medium text-white transition-colors hover:border-white hover:bg-white/10">
                  {item.cta}
                  <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" class="h-3 w-3"><path d="M2 6h8M6 2l4 4-4 4"/></svg>
                </a>
              </div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══ ADVISORY SERVICES ══ -->
  <section class="bg-white">
    <div class="site-wrap py-16 lg:py-20">
      <p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-brand)]">Advisory Services</p>
      <h2 class="mt-3 text-[22px] font-bold text-[var(--color-n900)] sm:text-[28px] lg:text-[38px]" style="font-family:var(--font-display)">
        Expert Advisory for Every Investor
      </h2>
      <p class="mt-3 max-w-3xl text-[15px] text-[var(--color-muted)]">
        From your first SIP to a managed equity portfolio, our Relationship Managers collaborate with you so every investment decision is backed by professional insight — not guesswork.
      </p>
      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {advisoryCards.map(c => (
          <div class="product-card-light p-6">
            <span set:html={c.icon} class="h-10 w-10 block"/>
            <h3 class="mt-4 text-[16px] font-semibold text-[var(--color-n900)]" style="font-family:var(--font-display)">{c.title}</h3>
            <p class="mt-2 text-[13px] leading-relaxed text-[var(--color-muted)]">{c.body}</p>
          </div>
        ))}
      </div>
      <!-- Nudge banner -->
      <div class="mt-10 flex flex-col items-start justify-between gap-4 rounded-lg border border-[var(--color-brand)]/20 bg-[var(--color-brand-pale)] px-8 py-6 sm:flex-row sm:items-center">
        <div>
          <p class="text-[16px] font-semibold text-[var(--color-n900)]">Unsure on where to begin? We've got you.</p>
          <p class="mt-1 text-[13px] text-[var(--color-muted)]">Book a free discovery call — our advisor will map your wealth mix and show you what a dedicated advisor does differently.</p>
        </div>
        <a href="/about/support/" class="btn-primary shrink-0">Schedule a Call</a>
      </div>
    </div>
  </section>

  <!-- ══ PRODUCTS: TRADE, INVEST OR LEND ══ -->
  <section class="relative overflow-hidden bg-[var(--color-dark-900)]">
    <div class="pointer-events-none absolute inset-0 opacity-[0.03]"
         style="background-image:repeating-linear-gradient(-45deg,#fff 0,#fff 1px,transparent 0,transparent 50%);background-size:20px 20px;"></div>
    <div class="site-wrap relative py-16 lg:py-20">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h2 class="text-[22px] font-bold leading-tight text-white sm:text-[28px] lg:text-[38px]" style="font-family:var(--font-display)">
            Trade, Invest Or Lend.<br class="hidden sm:block"> All At One Place.
          </h2>
          <p class="mt-2 text-[15px] text-[rgba(255,255,255,0.60)]">
            One account. Every asset class. From equity delivery to loan against mutual funds.
          </p>
        </div>
        <a href="/products/" class="shrink-0 text-[13px] font-semibold text-[var(--color-brand-light)] hover:text-white">
          View All Products →
        </a>
      </div>
      <div class="mt-10 grid grid-cols-2 gap-3 sm:grid-cols-4 lg:grid-cols-4">
        {allProducts.map(p => (
          <a href={p.href} class="product-card-dark group flex items-center gap-3 px-5 py-4">
            <span class="grid h-9 w-9 shrink-0 place-items-center rounded bg-white/8 text-white/70 transition-colors group-hover:bg-[var(--color-brand)]/30 group-hover:text-white">
              <span class="h-4.5 w-4.5" set:html={p.icon}/>
            </span>
            <span class="text-[14px] font-medium text-white/80 group-hover:text-white">{p.label}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ HOW SOON CAN I START? ══ -->
  <section class="bg-[var(--color-n100)]">
    <div class="site-wrap py-16 lg:py-20">
      <!-- Top: text + rocket illustration -->
      <div class="grid items-start gap-10 lg:grid-cols-2 lg:gap-16">
        <div>
          <h2 class="text-[28px] font-bold text-[var(--color-n900)] sm:text-[34px] lg:text-[44px]" style="font-family:var(--font-display)">
