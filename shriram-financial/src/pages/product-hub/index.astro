---
import BaseLayout from '../../layouts/BaseLayout.astro';

const cards = [
  {
    title: 'SIP Calculator',
    desc: 'Estimate the future value of your monthly SIP investment.',
    tab: 'sip',
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-12 w-12 opacity-20"><path d="M6 6v36h36"/><path d="m12 30 8-8 8 8 10-10"/></svg>`,
  },
  {
    title: 'Lumpsum Calculator',
    desc: 'Forecast returns on a one-time investment over any horizon.',
    tab: 'lumpsum',
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-12 w-12 opacity-20"><path d="M24 4v40M34 10H19a7 7 0 0 0 0 14h10a7 7 0 0 1 0 14H12"/></svg>`,
  },
  {
    title: 'SWP Calculator',
    desc: 'See how long your corpus lasts with monthly withdrawals.',
    tab: 'swp',
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-12 w-12 opacity-20"><path d="M38 24H10M24 10l-14 14 14 14"/></svg>`,
  },
  {
    title: 'Fixed Deposit Calculator',
    desc: 'Compute FD maturity value with quarterly compounding.',
    tab: 'fd',
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-12 w-12 opacity-20"><rect x="6" y="14" width="36" height="28" rx="4"/><path d="M16 14V10a4 4 0 0 1 8 0v4"/><path d="M24 24v8"/><path d="M20 28h8"/></svg>`,
  },
  {
    title: 'NPS Calculator',
    desc: 'Estimate your pension corpus and monthly pension at retirement.',
    tab: 'nps',
    soon: true,
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-12 w-12 opacity-20"><circle cx="24" cy="16" r="8"/><path d="M8 40c0-8 7.2-14 16-14s16 6 16 14"/></svg>`,
  },
];
---

<BaseLayout
  title="Calculator Hub — All Financial Calculators | Shriram Financial Services"
  description="Free online financial calculators — SIP, Lumpsum, FD, SWP, NPS and more. Plan investments, estimate returns, and map your retirement — all in one place."
>

  <!-- ══ 1. HERO ═══════════════════════════════════════════════════ -->
  <section class="border-b border-[var(--color-n400)] bg-[#faf8f4]">
    <div class="site-wrap py-14 lg:py-20">
      <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">

        <!-- Left: text -->
        <div>
          <h1
            class="reveal reveal-1 text-[28px] font-bold leading-tight text-[var(--color-ink)] sm:text-[36px] lg:text-[44px]"
            style="font-family:var(--font-display)"
          >
            All the Calculators You Need,<br />All in One Place.
          </h1>
          <p class="reveal reveal-2 mt-5 max-w-lg text-[15px] leading-relaxed text-[var(--color-muted)] lg:text-[16px]">
            Plan investments, estimate EMIs, optimise taxes, and map your retirement — all the financial tools you need, free and instant.
          </p>
          <div class="reveal reveal-3 mt-8 flex flex-wrap gap-5">
            {[
              { label: 'Free & Instant' },
              { label: 'No Sign-up Needed' },
              { label: 'SEBI-Regulated Platform' },
            ].map(b => (
              <div class="flex items-center gap-2 text-[13px] font-medium text-[var(--color-muted)]">
                <span class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-[var(--color-brand)]"></span>
                {b.label}
              </div>
            ))}
          </div>
        </div>

        <!-- Right: visual -->
        <div class="reveal reveal-2 hidden lg:block">
          <div class="aspect-[4/3] overflow-hidden rounded-[20px] bg-[var(--color-dark-800)] p-8 shadow-xl">
            <!-- Mini dashboard illustration -->
            <div class="flex h-full flex-col justify-between">
              <div class="flex items-center justify-between">
                <div class="space-y-1.5">
                  <div class="h-2 w-24 rounded-full bg-white/10"></div>
                  <div class="h-2 w-16 rounded-full bg-white/10"></div>
                </div>
                <div class="rounded-lg bg-[var(--color-brand)] px-3 py-1.5 text-[11px] font-bold text-[var(--color-dark-800)]">LIVE</div>
              </div>
              <div class="space-y-3">
                <div class="text-[11px] font-medium text-white/40 uppercase tracking-wider">Estimated Returns</div>
                <div class="text-[38px] font-bold text-white" style="font-family:var(--font-display)">₹48.7L</div>
                <div class="flex items-end gap-1.5 h-16">
                  {[3,5,4,7,6,8,7,10,9,12,11,14].map((h, i) => (
                    <div
                      class="flex-1 rounded-t-sm"
                      style={`height:${h * 7}%; background: ${i === 11 ? 'var(--color-brand)' : 'rgba(255,255,255,0.12)'}`}
                    ></div>
                  ))}
                </div>
              </div>
              <div class="grid grid-cols-2 gap-3">
                <div class="rounded-xl bg-white/5 px-4 py-3">
                  <div class="text-[10px] text-white/40">Invested</div>
                  <div class="mt-1 text-[15px] font-semibold text-white">₹12.0L</div>
                </div>
                <div class="rounded-xl bg-white/5 px-4 py-3">
                  <div class="text-[10px] text-white/40">Returns</div>
                  <div class="mt-1 text-[15px] font-semibold text-[var(--color-brand)]">₹36.7L</div>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══ 2. CALCULATOR CARDS (2-2-1 grid) ══════════════════════════ -->
  <section class="bg-white py-16 lg:py-24">
    <div class="site-wrap">
      <div class="mx-auto max-w-[900px]">

        <!-- Row 1 + Row 2: 2-column grid -->
        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
          {cards.filter(c => !c.soon).map(c => (
            <div
              data-calc-tab={c.tab}
              class="group relative flex cursor-pointer flex-col justify-between rounded-[20px] border border-[var(--color-n400)] bg-[var(--color-n100)] p-7 transition-all duration-200 hover:-translate-y-1 hover:border-[var(--color-brand)]/30 hover:shadow-lg"
              style="min-height: 200px;"
            >
              <!-- Background icon -->
              <div class="absolute bottom-5 right-5 text-[var(--color-ink)]" set:html={c.icon} />

              <!-- Title -->
              <h3
                class="text-[20px] font-bold text-[var(--color-ink)] lg:text-[22px]"
                style="font-family:var(--font-display)"
              >
                {c.title}
              </h3>

              <!-- CTA -->
              <div class="mt-6">
                <span class="text-[15px] italic text-[var(--color-brand)] group-hover:underline">
                  Calculate Now →
                </span>
              </div>
            </div>
          ))}
        </div>

        <!-- Row 3: NPS (centered, half-width) -->
        {cards.filter(c => c.soon).map(c => (
          <div class="mx-auto mt-5 w-full sm:w-1/2">
            <div
              class="group relative flex flex-col justify-between rounded-[20px] border border-[var(--color-n400)] bg-[var(--color-n100)] p-7 transition-all duration-200"
              style="min-height: 200px;"
            >
              <div class="absolute right-4 top-4 rounded-full bg-[var(--color-brand-light)] px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider text-[var(--color-brand-deep)]">
                Coming Soon
              </div>
              <div class="absolute bottom-5 right-5 text-[var(--color-ink)]" set:html={c.icon} />
              <h3
                class="text-[20px] font-bold text-[var(--color-ink)] lg:text-[22px]"
                style="font-family:var(--font-display)"
              >
                {c.title}
              </h3>
              <div class="mt-6">
                <span class="text-[15px] italic text-[var(--color-muted)]">Calculate Now →</span>
              </div>
            </div>
          </div>
        ))}

      </div>
    </div>
  </section>

  <!-- ══ 3. INTERACTIVE CALCULATORS ════════════════════════════════ -->
  <section class="bg-[#f8f6f1] py-16 lg:py-24" id="calculators">
    <div class="site-wrap">
      <p class="text-[11px] font-bold uppercase tracking-widest text-[var(--color-brand)]">Try It Now</p>
      <h2 class="mt-3 text-[28px] font-bold text-[var(--color-ink)] lg:text-[38px]" style="font-family:var(--font-display)">
        Free Interactive Calculators
      </h2>

      <!-- Tab bar -->
      <div class="mt-8 mb-8 flex flex-wrap gap-2 rounded-xl border border-[var(--color-n400)] bg-white p-1.5 shadow-sm">
        {[
          { id: 'sip',     label: 'SIP Calculator' },
          { id: 'lumpsum', label: 'Lumpsum' },
          { id: 'fd',      label: 'FD Calculator' },
          { id: 'swp',     label: 'SWP Calculator' },
        ].map(t => (
          <button
            data-tab={t.id}
            class="calc-tab flex-1 rounded-lg px-4 py-2.5 text-[14px] font-semibold transition-all text-[var(--color-muted)] hover:text-[var(--color-ink)]"
          >
            {t.label}
          </button>
        ))}
      </div>

      <!-- SIP Panel -->
      <div id="panel-sip" class="calc-panel">
        <div class="grid gap-8 rounded-[24px] border border-[var(--color-n400)] bg-white p-5 shadow-sm md:grid-cols-2 md:p-8 lg:p-10">
          <div>
            <h2 class="text-[24px] font-semibold text-[var(--color-n900)]" style="font-family:var(--font-display)">SIP Calculator</h2>
            <p class="mt-2 text-[14px] text-[var(--color-muted)]">Estimate the future value of a monthly Systematic Investment Plan.</p>
            <div class="mt-8 space-y-6">
              <label class="block"><span class="text-[13px] font-semibold text-[var(--color-ink)]">Monthly investment (₹)</span><input id="sip-amount" type="number" value="10000" min="500" step="500" class="field mt-2 text-[16px] font-semibold" /></label>
              <label class="block"><span class="text-[13px] font-semibold text-[var(--color-ink)]">Expected return (% p.a.)</span><input id="sip-rate" type="number" value="12" min="1" max="30" step="0.5" class="field mt-2 text-[16px] font-semibold" /></label>
              <label class="block"><span class="text-[13px] font-semibold text-[var(--color-ink)]">Time period (years)</span><input id="sip-years" type="number" value="10" min="1" max="40" step="1" class="field mt-2 text-[16px] font-semibold" /></label>
            </div>
          </div>
          <div class="flex flex-col gap-6">
            <div class="flex-1 rounded-[24px] bg-[var(--color-dark-800)] p-5 text-center md:p-8">
              <span class="text-[13px] font-medium text-white/60">Estimated wealth at maturity</span>
              <div id="sip-result" class="mt-3 text-[32px] font-bold text-white md:text-[48px]" style="font-family:var(--font-display)">₹0</div>
              <div class="mt-6 divide-y divide-white/10 rounded-lg bg-white/5 px-4 text-[13px]">
                <div class="flex justify-between py-3"><span class="text-white/60">Total invested</span><span id="sip-invested" class="font-semibold text-white">₹0</span></div>
                <div class="flex justify-between py-3"><span class="text-white/60">Estimated returns</span><span id="sip-gains" class="font-semibold text-[var(--color-gold)]">₹0</span></div>
              </div>
            </div>
            <p class="text-[11px] text-[var(--color-subtle)]">Illustrative only. Mutual Fund investments are subject to market risk.</p>
          </div>
        </div>
      </div>

      <!-- Lumpsum Panel -->
      <div id="panel-lumpsum" class="calc-panel hidden">
        <div class="grid gap-8 rounded-[24px] border border-[var(--color-n400)] bg-white p-5 shadow-sm md:grid-cols-2 md:p-8 lg:p-10">
          <div>
            <h2 class="text-[24px] font-semibold text-[var(--color-n900)]" style="font-family:var(--font-display)">Lumpsum Calculator</h2>
            <p class="mt-2 text-[14px] text-[var(--color-muted)]">Estimate returns on a one-time investment over your chosen horizon.</p>
            <div class="mt-8 space-y-6">
              <label class="block"><span class="text-[13px] font-semibold text-[var(--color-ink)]">One-time investment (₹)</span><input id="ls-amount" type="number" value="100000" min="1000" step="1000" class="field mt-2 text-[16px] font-semibold" /></label>
              <label class="block"><span class="text-[13px] font-semibold text-[var(--color-ink)]">Expected return (% p.a.)</span><input id="ls-rate" type="number" value="12" min="1" max="30" step="0.5" class="field mt-2 text-[16px] font-semibold" /></label>
              <label class="block"><span class="text-[13px] font-semibold text-[var(--color-ink)]">Time period (years)</span><input id="ls-years" type="number" value="10" min="1" max="40" step="1" class="field mt-2 text-[16px] font-semibold" /></label>
            </div>
          </div>
          <div class="flex flex-col gap-6">
            <div class="flex-1 rounded-[24px] bg-[var(--color-dark-800)] p-5 text-center md:p-8">
              <span class="text-[13px] font-medium text-white/60">Estimated wealth at maturity</span>
              <div id="ls-result" class="mt-3 text-[32px] font-bold text-white md:text-[48px]" style="font-family:var(--font-display)">₹0</div>
              <div class="mt-6 divide-y divide-white/10 rounded-lg bg-white/5 px-4 text-[13px]">
                <div class="flex justify-between py-3"><span class="text-white/60">Amount invested</span><span id="ls-invested" class="font-semibold text-white">₹0</span></div>
                <div class="flex justify-between py-3"><span class="text-white/60">Estimated returns</span><span id="ls-gains" class="font-semibold text-[var(--color-gold)]">₹0</span></div>
              </div>
            </div>
            <p class="text-[11px] text-[var(--color-subtle)]">Illustrative only. Past performance does not guarantee future returns.</p>
          </div>
        </div>
      </div>

      <!-- FD Panel -->
      <div id="panel-fd" class="calc-panel hidden">
        <div class="grid gap-8 rounded-[24px] border border-[var(--color-n400)] bg-white p-5 shadow-sm md:grid-cols-2 md:p-8 lg:p-10">
          <div>
            <h2 class="text-[24px] font-semibold text-[var(--color-n900)]" style="font-family:var(--font-display)">FD Calculator</h2>
            <p class="mt-2 text-[14px] text-[var(--color-muted)]">Estimate the maturity value of your Fixed Deposit with quarterly compounding.</p>
            <div class="mt-8 space-y-6">
              <label class="block"><span class="text-[13px] font-semibold text-[var(--color-ink)]">Principal amount (₹)</span><input id="fd-amount" type="number" value="100000" min="1000" step="1000" class="field mt-2 text-[16px] font-semibold" /></label>
              <label class="block"><span class="text-[13px] font-semibold text-[var(--color-ink)]">Interest rate (% p.a.)</span><input id="fd-rate" type="number" value="7.5" min="1" max="15" step="0.25" class="field mt-2 text-[16px] font-semibold" /></label>
              <label class="block"><span class="text-[13px] font-semibold text-[var(--color-ink)]">Tenure (years)</span><input id="fd-years" type="number" value="3" min="1" max="10" step="1" class="field mt-2 text-[16px] font-semibold" /></label>
            </div>
          </div>
          <div class="flex flex-col gap-6">
            <div class="flex-1 rounded-[24px] bg-[var(--color-dark-800)] p-5 text-center md:p-8">
              <span class="text-[13px] font-medium text-white/60">Maturity value</span>
              <div id="fd-result" class="mt-3 text-[32px] font-bold text-white md:text-[48px]" style="font-family:var(--font-display)">₹0</div>
              <div class="mt-6 divide-y divide-white/10 rounded-lg bg-white/5 px-4 text-[13px]">
                <div class="flex justify-between py-3"><span class="text-white/60">Principal invested</span><span id="fd-principal" class="font-semibold text-white">₹0</span></div>
                <div class="flex justify-between py-3"><span class="text-white/60">Interest earned</span><span id="fd-interest" class="font-semibold text-[var(--color-gold)]">₹0</span></div>
              </div>
            </div>
            <p class="text-[11px] text-[var(--color-subtle)]">Assumes quarterly compounding. Actual rates may vary by institution.</p>
          </div>
        </div>
      </div>

      <!-- SWP Panel -->
      <div id="panel-swp" class="calc-panel hidden">
        <div class="grid gap-8 rounded-[24px] border border-[var(--color-n400)] bg-white p-5 shadow-sm md:grid-cols-2 md:p-8 lg:p-10">
          <div>
            <h2 class="text-[24px] font-semibold text-[var(--color-n900)]" style="font-family:var(--font-display)">SWP Calculator</h2>
            <p class="mt-2 text-[14px] text-[var(--color-muted)]">Estimate how long your retirement corpus lasts with monthly withdrawals.</p>
            <div class="mt-8 space-y-6">
              <label class="block"><span class="text-[13px] font-semibold text-[var(--color-ink)]">Initial corpus (₹)</span><input id="swp-corpus" type="number" value="2000000" min="10000" step="10000" class="field mt-2 text-[16px] font-semibold" /></label>
              <label class="block"><span class="text-[13px] font-semibold text-[var(--color-ink)]">Monthly withdrawal (₹)</span><input id="swp-withdrawal" type="number" value="20000" min="1000" step="1000" class="field mt-2 text-[16px] font-semibold" /></label>
              <label class="block"><span class="text-[13px] font-semibold text-[var(--color-ink)]">Expected return (% p.a.)</span><input id="swp-rate" type="number" value="8" min="1" max="20" step="0.5" class="field mt-2 text-[16px] font-semibold" /></label>
            </div>
          </div>
          <div class="flex flex-col gap-6">
            <div class="flex-1 rounded-[24px] bg-[var(--color-dark-800)] p-5 text-center md:p-8">
              <span class="text-[13px] font-medium text-white/60">Corpus lasts for</span>
              <div id="swp-result" class="mt-3 text-[32px] font-bold text-white md:text-[48px]" style="font-family:var(--font-display)">— yrs</div>
              <div class="mt-6 divide-y divide-white/10 rounded-lg bg-white/5 px-4 text-[13px]">
                <div class="flex justify-between py-3"><span class="text-white/60">Total amount withdrawn</span><span id="swp-total" class="font-semibold text-white">₹0</span></div>
                <div class="flex justify-between py-3"><span class="text-white/60">Remaining corpus</span><span id="swp-remaining" class="font-semibold text-[var(--color-gold)]">₹0</span></div>
              </div>
            </div>
            <p class="text-[11px] text-[var(--color-subtle)]">Illustrative only. Not a guarantee of income.</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ══ 4. CTA BANNER ═════════════════════════════════════════════ -->
  <section class="bg-[var(--color-dark-olive)] py-12 lg:py-16">
    <div class="site-wrap">
      <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-center">
        <div>
          <h2 class="text-[24px] font-bold text-white lg:text-[30px]" style="font-family:var(--font-display)">
            Open Demat Account
          </h2>
          <p class="mt-1.5 text-[14px] text-white/60">In less than 5 minutes</p>
        </div>
        <a
          href="/about/open-demat-account/"
          class="flex-shrink-0 inline-flex h-12 items-center justify-center rounded-[6px] bg-[var(--color-brand)] px-8 text-[14px] font-bold text-[var(--color-dark-800)] transition-colors hover:bg-[var(--color-brand-hover)]"
        >
          Open Demat Account
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  const fmt = (n: number) => '₹' + Math.round(n).toLocaleString('en-IN');
  const el  = (id: string) => document.getElementById(id) as HTMLElement;
  const val = (id: string) => parseFloat((document.getElementById(id) as HTMLInputElement).value) || 0;

  function calcSip() {
    const P = val('sip-amount'), r = val('sip-rate') / 100 / 12, n = val('sip-years') * 12;
    const fv = r === 0 ? P * n : P * ((Math.pow(1 + r, n) - 1) / r) * (1 + r);
    const invested = P * n;
    el('sip-result').textContent   = fmt(fv);
    el('sip-invested').textContent = fmt(invested);
    el('sip-gains').textContent    = fmt(fv - invested);
  }
  ['sip-amount','sip-rate','sip-years'].forEach(id => document.getElementById(id)?.addEventListener('input', calcSip));
  calcSip();

  function calcLs() {
    const P = val('ls-amount'), r = val('ls-rate') / 100, n = val('ls-years');
    const fv = P * Math.pow(1 + r, n);
    el('ls-result').textContent   = fmt(fv);
    el('ls-invested').textContent = fmt(P);
    el('ls-gains').textContent    = fmt(fv - P);
  }
  ['ls-amount','ls-rate','ls-years'].forEach(id => document.getElementById(id)?.addEventListener('input', calcLs));
  calcLs();

  function calcFd() {
    const P = val('fd-amount'), r = val('fd-rate') / 100, n = val('fd-years');
    const fv = P * Math.pow(1 + r / 4, 4 * n);
    el('fd-result').textContent    = fmt(fv);
    el('fd-principal').textContent = fmt(P);
    el('fd-interest').textContent  = fmt(fv - P);
  }
  ['fd-amount','fd-rate','fd-years'].forEach(id => document.getElementById(id)?.addEventListener('input', calcFd));
  calcFd();

  function calcSwp() {
    const corpus = val('swp-corpus'), monthly = val('swp-withdrawal'), r = val('swp-rate') / 100 / 12;
    let bal = corpus, months = 0;
    while (bal > 0 && months < 600) { bal = bal * (1 + r) - monthly; months++; }
    el('swp-result').textContent    = months >= 600 ? '50+ yrs' : `${(months / 12).toFixed(1)} yrs`;
    el('swp-total').textContent     = fmt(monthly * months);
    el('swp-remaining').textContent = fmt(Math.max(0, bal));
  }
  ['swp-corpus','swp-withdrawal','swp-rate'].forEach(id => document.getElementById(id)?.addEventListener('input', calcSwp));
  calcSwp();

  /* ── Tabs ── */
  const tabs   = document.querySelectorAll<HTMLButtonElement>('.calc-tab');
  const panels = document.querySelectorAll<HTMLElement>('.calc-panel');

  function activateTab(target: string) {
    tabs.forEach(t => {
      t.style.removeProperty('background-color');
      t.style.removeProperty('color');
      if (t.dataset.tab === target) {
        t.style.setProperty('background-color', 'var(--color-dark-olive)');
        t.style.color = 'var(--color-brand)';
      }
    });
    panels.forEach(p => p.classList.toggle('hidden', p.id !== `panel-${target}`));
  }
  activateTab('sip');
  tabs.forEach(tab => tab.addEventListener('click', () => { if (tab.dataset.tab) activateTab(tab.dataset.tab); }));

  /* ── Card clicks → scroll + activate tab ── */
  document.querySelectorAll<HTMLElement>('[data-calc-tab]').forEach(card => {
    const tab = card.dataset.calcTab;
    if (!tab || tab === 'nps') return;
    card.addEventListener('click', () => {
      document.getElementById('calculators')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      setTimeout(() => activateTab(tab), 400);
    });
  });
</script>
