---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Calculators — Shriram Financial Services"
  description="Free financial calculators from Shriram — SIP, lumpsum, SWP, fixed deposit and NPS. Plan investments and estimate returns instantly, no sign-up."
>

<section class="calc-hero" id="sec-hero">
  <h1>All the Calculators You Need, <span class="g">All in One Place.</span></h1>
  <p class="ch-lead">Plan investments, estimate returns, optimise taxes, and map your retirement — all the financial tools you need, free and instant.</p>
  <div class="ch-chips">
    <span class="chip"><span class="tk">✓</span> 100% Free</span>
    <span class="chip"><span class="tk">✓</span> Instant Results</span>
    <span class="chip"><span class="tk">✓</span> No Sign-up Required</span>
    <span class="chip"><span class="tk">✓</span> Accurate Projections</span>
  </div>
</section>

<section class="section stack" id="sec-calculators" style="gap:56px">
  <div class="stack" style="gap:16px">
    <h2 class="sec-title">Explore Our Calculators</h2>
    <p class="sec-lead">Pick a tool and get instant, accurate projections to plan every part of your financial journey.</p>
  </div>
  <div class="calc-grid">
    <a class="calc-card" href="/calculators/sip/">
      <span class="cc-title">SIP Calculator</span>
      <span class="cc-desc">Project the future value of your monthly SIP investments.</span>
      <span class="cc-cta">Calculate Now <span class="arr">→</span></span>
    </a>
    <a class="calc-card" href="/calculators/lumpsum/">
      <span class="cc-title">Lumpsum Calculator</span>
      <span class="cc-desc">See how a one-time investment grows over your chosen horizon.</span>
      <span class="cc-cta">Calculate Now <span class="arr">→</span></span>
    </a>
    <a class="calc-card" href="/calculators/swp/">
      <span class="cc-title">SWP Calculator</span>
      <span class="cc-desc">Plan steady withdrawals while the rest of your corpus stays invested.</span>
      <span class="cc-cta">Calculate Now <span class="arr">→</span></span>
    </a>
    <a class="calc-card" href="/calculators/fd/">
      <span class="cc-title">Fixed Deposit Calculator</span>
      <span class="cc-desc">Estimate maturity value and interest earned on your deposit.</span>
      <span class="cc-cta">Calculate Now <span class="arr">→</span></span>
    </a>
    <a class="calc-card" href="/calculators/nps/">
      <span class="cc-title">NPS Calculator</span>
      <span class="cc-desc">Forecast your retirement corpus and expected monthly pension.</span>
      <span class="cc-cta">Calculate Now <span class="arr">→</span></span>
    </a>
    <div class="calc-card cta-tile">
      <span class="cc-title">Open a Demat Account</span>
      <span class="cc-desc">Like what you see? Start investing in under 5 minutes — zero paperwork.</span>
      <a class="btn-gold" href="/about/open-demat-account/">Open Demat Account</a>
    </div>
  </div>
</section>

</BaseLayout>

<style>
  :root {
    --sec-light: #fef8ee;
    --sec-tint: #f6efe1;
    --card: #fffdf8;
    --card-border: #e1e0db;
    --olive-title: #2e3914;
    --olive-deep: #1b2010;
    --olive-ink: #2e3914;
    --ink: #1c1c16;
    --ink-3: #595959;
    --muted: #73736a;
    --gold-2: #f2b83f;
    --gold-btn: #f3b83f;
    --pad: clamp(20px, 8vw, 144px);
    --section-y: 72px;
  }

  *, *::before, *::after { box-sizing: border-box; }
  a { color: inherit; text-decoration: none; }
  p { line-height: 1.5; }

  .section { padding: var(--section-y) var(--pad); display: flex; flex-direction: column; }
  .stack { display: flex; flex-direction: column; }
  .sec-title { font-weight: 400; font-size: 40px; color: var(--olive-title); text-transform: capitalize; line-height: 1.5; }
  .sec-lead { font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.5; }

  .calc-hero {
    background: radial-gradient(125% 210% at 100% -8%, #4f583b 0%, #363a2c 50%, #1d1d1d 100%);
    min-height: clamp(440px, 29vw, 552px); display: flex; flex-direction: column; justify-content: center;
    padding: 72px var(--pad);
  }
  .calc-hero h1 { font-weight: 500; font-size: 40px; line-height: 1.5; color: #fff; max-width: 780px; }
  .calc-hero h1 .g { color: var(--gold-2); }
  .ch-lead { margin-top: 16px; font-weight: 400; font-size: 18px; line-height: 1.5; color: rgba(255,255,255,.74); max-width: 600px; }
  .ch-chips {
    margin-top: 40px; padding-top: 36px; border-top: 1px solid rgba(255,255,255,.16);
    max-width: 840px; display: flex; flex-wrap: wrap; gap: 16px 32px;
  }
  .chip { display: flex; align-items: center; gap: 10px; font-weight: 500; font-size: 16px; color: rgba(255,255,255,.9); }
  .chip .tk { color: var(--gold-2); font-size: 15px; }

  .calc-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .calc-card {
    background: var(--card); border: 1px solid var(--card-border); border-radius: 24px;
    padding: 32px; display: flex; flex-direction: column; gap: 16px; color: inherit;
    transition: border-color .22s ease;
  }
  a.calc-card:hover { border-color: var(--olive-deep); }
  .cc-title { font-weight: 500; font-size: 20px; color: var(--ink); line-height: 1.3; }
  .cc-desc { flex: 1 1 auto; font-weight: 400; font-size: 15px; color: var(--muted); line-height: 1.5; }
  .cc-cta { display: inline-flex; align-items: center; gap: 8px; color: var(--olive-title); font-weight: 600; font-size: 15px; }
  .cc-cta .arr { transition: transform .25s ease; }
  a.calc-card:hover .cc-cta .arr { transform: translateX(5px); }

  .cta-tile { background: var(--olive-deep); border-color: var(--olive-deep); }
  .cta-tile .cc-title { color: #fff; }
  .cta-tile .cc-desc { color: rgba(255,255,255,.72); }
  .cta-tile .btn-gold { margin-top: 4px; }

  .btn-gold {
    background: var(--gold-btn); height: 40px;
    border-radius: 4px; display: inline-flex; align-items: center; justify-content: center;
    padding: 7px 20px; font-weight: 500; font-size: 12px; color: var(--olive-ink);
    white-space: nowrap; transition: opacity .2s; width: fit-content;
  }
  .btn-gold:hover { opacity: .88; }

  @media (max-width: 1024px) { .calc-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) {
    .calc-grid { grid-template-columns: 1fr; }
    .calc-hero h1 { font-size: clamp(28px, 7vw, 40px); }
    .ch-lead { font-size: 16px; }
    .sec-title { font-size: 28px; }
  }
</style>
