---
import BaseLayout from '../../layouts/BaseLayout.astro';

const calcs = [
  { slug: 'sip',     title: 'SIP Calculator',      desc: 'Estimate the wealth you build by investing a fixed amount every month through a Systematic Investment Plan.' },
  { slug: 'lumpsum', title: 'Lumpsum Calculator',   desc: 'Project the future value of a one-time investment at different return rates and time horizons.' },
  { slug: 'fd',      title: 'Fixed Deposit Calculator', desc: 'Calculate the maturity amount and interest earned on your FD — cumulative or non-cumulative.' },
  { slug: 'swp',     title: 'SWP Calculator',       desc: 'See how long your retirement corpus lasts with a Systematic Withdrawal Plan and a chosen monthly income.' },
  { slug: 'nps',     title: 'NPS Calculator',       desc: 'Estimate your NPS retirement corpus, tax-free lump sum, and monthly pension with PFRDA-standard calculations.' },
];

const why = [
  'All calculators are completely free — no sign-up, no login, no personal data required',
  'Results update instantly as you move the sliders — experiment with any number in seconds',
  'Each calculator includes a detailed explanation of the formula and a worked example in rupees',
  'Reverse-engineer your goals — find the SIP amount or lumpsum needed to hit a target corpus',
  'Built for Indian investors — amounts in ₹, returns benchmarked to Indian market norms',
];
---

<BaseLayout
  title="Free Financial Calculators — SIP, FD, NPS, SWP, Lumpsum | Shriram"
  description="Free online financial calculators for Indian investors — SIP, Lumpsum, Fixed Deposit, SWP, and NPS. Instant, accurate, no sign-up required."
>

  <!-- ══ 1. HERO ══════════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-inner">
      <h1>Financial Calculators — <span class="g">Plan Every Decision</span></h1>
      <p class="lead">Five free tools for Indian investors. SIP, Lumpsum, FD, SWP, and NPS — each with instant results, worked examples, and goal-based reverse calculation.</p>
      <div class="cta-row">
        <a class="btn-gold" href="/about/open-demat-account/">Open Demat Account</a>
        <a class="btn-ghost" href="/about/support/">Talk to an Expert</a>
      </div>
      <div class="hero-feats">
        <div class="feats">
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;100% Free</span></div>
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;No Sign-Up Required</span></div>
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;Instant Results</span></div>
          <div class="feat"><span class="tk">✓</span><span class="lb">&nbsp;Indian Market Benchmarks</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ 2. CALCULATORS GRID ══════════════════════════════════════════ -->
  <section class="section stack" style="background:var(--sec-light);gap:48px">
    <div class="stack" style="gap:16px">
      <p class="sec-title">All Calculators</p>
      <p class="sec-lead">Choose a calculator to start planning your financial goals — from monthly SIP investing to retirement corpus estimation.</p>
    </div>
    <div class="cat-grid cat-3">
      {calcs.map(c => (
        <a href={`/calculators/${c.slug}/`} class="cat calc-cat">
          <h3>{c.title}</h3>
          <p>{c.desc}</p>
          <span class="calc-go">Calculate →</span>
        </a>
      ))}
    </div>
  </section>

  <!-- ══ 3. WHY USE OUR CALCULATORS ═══════════════════════════════════ -->
  <section class="section stack" style="background:var(--sec-tint);gap:48px">
    <div class="stack" style="gap:16px">
      <p class="sec-title">Why Use Our Calculators?</p>
      <p class="sec-lead">Our calculators are built for accuracy and simplicity — designed to give you the clarity to invest with purpose, not just habit.</p>
    </div>
    <div class="card check-card-full">
      <div class="check-list">
        {why.map((item, i) => (
          <>
            {i > 0 && <div class="check-sep"></div>}
            <div class="check-row"><span class="ck">✓</span><p class="tx">{item}</p></div>
          </>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 4. CTA ════════════════════════════════════════════════════════ -->
  <section class="cta-sec" style="background:var(--sec-light)">
    <div class="cta-box">
      <h2 class="cta-h">Ready to Put Your Plan <span class="g">into Action?</span></h2>
      <p class="cta-sub">Open a free Demat account with Shriram and start investing in minutes — zero delivery brokerage, SEBI-registered, fully paperless.</p>
      <div class="cta-row">
        <a class="btn-gold" href="/about/open-demat-account/">Open Demat Account</a>
        <a class="btn-ghost-dark" href="/about/support/">Talk to an Expert</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  :root {
    --sec-light: #fef8ee;
    --sec-tint: #f6efe1;
    --card: #fffdf8;
    --card-border: #e1e0db;
    --olive-title: #2e3914;
    --olive-deep: #1b2010;
    --ink: #1c1c16;
    --ink-3: #595959;
    --muted: #73736a;
    --gold-2: #f2b83f;
    --gold-btn: #f3b83f;
    --olive-ink: #2e3914;
    --green: #009d58;
    --pad: clamp(20px, 8vw, 144px);
    --section-y: 72px;
    --cta-w: 220px;
  }

  *, *::before, *::after { box-sizing: border-box; }
  a { color: inherit; text-decoration: none; }
  p { line-height: 1.5; }

  .section {
    padding: var(--section-y) var(--pad);
    display: flex; flex-direction: column;
  }
  .stack { display: flex; flex-direction: column; }

  .sec-title { font-weight: 400; font-size: 40px; color: var(--olive-title); text-transform: capitalize; line-height: 1.5; }
  .sec-lead  { font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.6; }

  /* Hero */
  .hero {
    padding: 0 var(--pad);
    background: radial-gradient(125% 210% at 100% -8%, #4f583b 0%, #363a2c 50%, #1d1d1d 100%);
    display: flex; flex-direction: column; justify-content: center; overflow: hidden;
  }
  .hero-inner { padding: clamp(80px,12vw,140px) 0 clamp(48px,6vw,80px); display: flex; flex-direction: column; }
  .hero h1   { font-weight: 500; font-size: 40px; color: #fff; line-height: 1.5; max-width: 800px; }
  .hero h1 .g { color: var(--gold-2); }
  .hero .lead { margin-top: 32px; font-size: 18px; line-height: 1.5; color: rgba(255,255,255,.74); max-width: 620px; }
  .cta-row   { margin-top: 40px; display: flex; flex-wrap: wrap; gap: 14px; align-items: center; }
  .hero-feats { margin-top: 40px; }
  .feats { display: flex; flex-wrap: wrap; align-items: center; gap: 14px 16px; max-width: 760px; padding-top: 36px; border-top: 1px solid rgba(255,255,255,.16); }
  .feat  { display: flex; gap: 10px; align-items: center; }
  .feat .tk { color: var(--gold-2); font-weight: 500; font-size: 15px; width: 13px; }
  .feat .lb { color: rgba(255,255,255,.9); font-weight: 500; font-size: 16px; line-height: 1.5; white-space: nowrap; }

  /* Buttons */
  .btn-gold {
    background: var(--gold-btn); height: 40px; width: var(--cta-w);
    border-radius: 4px; display: inline-flex; align-items: center; justify-content: center;
    padding: 7px 20px; font-weight: 500; font-size: 12px; color: var(--olive-ink);
    white-space: nowrap; transition: opacity .2s;
  }
  .btn-gold:hover { opacity: .88; }
  .btn-ghost {
    height: 40px; border-radius: 9px; border: 1px solid rgba(255,255,255,.4);
    display: inline-flex; align-items: center; justify-content: center;
    padding: 7px 26px; font-weight: 600; font-size: 15px; color: #fff;
    transition: border-color .2s;
  }
  .btn-ghost:hover { border-color: #fff; }
  .btn-ghost-dark {
    height: 40px; border-radius: 4px; border: 1px solid rgba(27,32,16,.35);
    display: inline-flex; align-items: center; justify-content: center;
    padding: 7px 26px; font-weight: 500; font-size: 12px; color: var(--olive-deep);
    transition: border-color .2s;
  }
  .btn-ghost-dark:hover { border-color: var(--olive-deep); }

  /* Cat grid */
  .cat-grid {
    border: 1px solid var(--card-border); border-radius: 24px;
    overflow: hidden; display: grid; background: var(--card);
  }
  .cat-3 { grid-template-columns: repeat(3, 1fr); }
  .cat {
    background: var(--card); padding: 32px;
    display: flex; flex-direction: column; gap: 12px;
    border-right: 1px solid var(--card-border); border-bottom: 1px solid var(--card-border);
  }
  .cat-3 .cat:nth-child(3n)  { border-right: 0; }
  .cat-3 .cat:nth-child(n+4) { border-bottom: 0; }
  .cat-3 .cat:last-child     { border-right: 0; }
  .cat h3 { font-weight: 500; font-size: 20px; color: var(--ink); line-height: 1.5; }
  .cat p  { font-weight: 400; font-size: 16px; color: var(--muted); line-height: 1.5; flex: 1; }
  .calc-cat { text-decoration: none; transition: background .15s; }
  .calc-cat:hover { background: var(--sec-light); }
  .calc-go { font-weight: 600; font-size: 13px; color: var(--gold-2); margin-top: 8px; }

  /* Check card */
  .card { background: var(--card); border: 1px solid var(--card-border); border-radius: 24px; padding: 32px; }
  .check-card-full { background: var(--card); border: 1px solid var(--card-border); border-radius: 24px; padding: 32px; }
  .check-list { display: flex; flex-direction: column; gap: 20px; }
  .check-row  { display: flex; gap: 14px; align-items: flex-start; }
  .check-row .ck { color: var(--green); font-weight: 700; font-size: 15px; line-height: 25.5px; width: 13px; flex: none; }
  .check-row .tx { flex: 1 0 0; min-width: 0; font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.5; }
  .check-sep  { height: 1px; background: rgba(28,28,22,.08); width: 100%; }

  /* CTA */
  .cta-sec { padding: var(--section-y) var(--pad); }
  .cta-box {
    border-radius: 22px; padding: 64px 60px;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 20px; text-align: center;
    background: var(--olive-deep);
  }
  .cta-h   { font-weight: 400; font-size: 36px; color: #fff; line-height: 1.4; max-width: 640px; }
  .cta-h .g { color: var(--gold-2); }
  .cta-sub { font-size: 16px; color: rgba(255,255,255,.65); line-height: 1.5; }
  .cta-box .cta-row { margin-top: 8px; }
  .cta-box .btn-gold { width: auto; }

  @media (max-width: 900px) {
    .cat-3 { grid-template-columns: 1fr 1fr; }
    .cat-3 .cat:nth-child(3n)  { border-right: inherit; }
    .cat-3 .cat:nth-child(n+4) { border-bottom: inherit; }
    .cat-3 .cat:nth-child(2n)  { border-right: 0; }
    .cat-3 .cat:nth-last-child(-n+2) { border-bottom: 0; }
    .cat-3 .cat:last-child { border-right: 0; border-bottom: 0; }
  }
  @media (max-width: 600px) {
    .cat-3 { grid-template-columns: 1fr; }
    .cat-3 .cat { border-right: 0; border-bottom: 1px solid var(--card-border); }
    .cat-3 .cat:last-child { border-bottom: 0; }
    .hero h1 { font-size: 28px; }
    .sec-title { font-size: 28px; }
    .cta-box { padding: 40px 24px; }
    .cta-h { font-size: 26px; }
  }
</style>
