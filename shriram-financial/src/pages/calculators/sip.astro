---
import BaseLayout from '../../layouts/BaseLayout.astro';

const faqs = [
  {
    q: 'What is a SIP and how is it different from a lumpsum investment?',
    a: 'A Systematic Investment Plan (SIP) lets you invest a fixed amount at regular intervals — usually monthly — rather than committing a large sum all at once. This spreads your entry points across market cycles, averages out your purchase cost over time (rupee-cost averaging) and makes investing more affordable and disciplined. A lumpsum, by contrast, is a single one-time investment.',
  },
  {
    q: 'How accurate are the results from this SIP calculator?',
    a: 'The calculator applies the standard SIP future-value formula precisely to the inputs you provide. However, the expected rate of return is an assumption — real market returns fluctuate year to year. Treat the output as a well-grounded estimate for planning purposes rather than a guaranteed outcome.',
  },
  {
    q: 'Can I change or stop my SIP amount later?',
    a: 'Yes. SIPs are flexible — you can increase, decrease, pause or stop your contributions at any time, and many investors use a step-up SIP to raise their instalment each year as their income grows. There is typically no penalty for modifying or stopping a SIP.',
  },
  {
    q: 'What is a realistic rate of return to assume?',
    a: 'For equity-oriented funds, investors often use a long-term assumption in the range of 10–12% per annum, while debt-oriented funds are usually modelled lower. The right figure depends on your fund choice and risk appetite — it is wise to run the calculator with both an optimistic and a conservative rate to understand the range of possible outcomes.',
  },
  {
    q: 'Is there a minimum amount required to start a SIP?',
    a: 'Many funds let you start a SIP with as little as ₹500 per month, making it accessible to almost every investor. You can always increase your contribution as your savings capacity grows.',
  },
];
---

<BaseLayout
  title="SIP Calculator — Estimate Your Mutual Fund Returns | Shriram Financial Services"
  description="Free SIP calculator to estimate the future value of your monthly investments. Model step-up SIPs and choose your investment frequency — instant, no sign-up."
>

<!-- HERO -->
<section class="hero" id="sec-hero">
  <div class="hero-inner">
    <h1>Plan Smarter With The <span class="g">SIP Calculator</span></h1>
    <p class="lead">Estimate your future wealth instantly by adjusting your monthly SIP amount, duration, and return rate.</p>
    <div class="cta"><a class="btn-gold" href="/about/open-demat-account/">Open Demat Account</a></div>
    <div class="hero-feats">
      <div class="feats">
        <div class="feat"><span class="tk" aria-hidden="true">✓</span><span class="lb">&nbsp;100% Free</span></div>
        <div class="feat"><span class="tk" aria-hidden="true">✓</span><span class="lb">&nbsp;Instant Results</span></div>
        <div class="feat"><span class="tk" aria-hidden="true">✓</span><span class="lb">&nbsp;No Sign-up Required</span></div>
        <div class="feat"><span class="tk" aria-hidden="true">✓</span><span class="lb">&nbsp;Accurate Projections</span></div>
      </div>
    </div>
  </div>
</section>

<!-- CALCULATOR -->
<section class="section stack" id="sec-calc" style="background:var(--sec-light);gap:24px">
  <h2 class="sec-title">SIP Calculator</h2>
  <p class="calc-hint">Drag the sliders or type your own numbers — results update instantly. Switch frequency or add an annual step-up to model a growing SIP.</p>

  <div class="calc-row">
    <div class="card calc-panel">
      <div class="freq-toggle" role="group" aria-label="Investment frequency">
        <button type="button" class="freq-btn is-active" data-freq="12" aria-pressed="true">Monthly</button>
        <button type="button" class="freq-btn" data-freq="4" aria-pressed="false">Quarterly</button>
        <button type="button" class="freq-btn" data-freq="1" aria-pressed="false">Yearly</button>
      </div>

      <div class="fields">
        <div class="field">
          <div class="field-top">
            <label for="amt">SIP amount</label>
            <div class="field-val"><span class="pfx">₹</span><input id="amt" type="text" inputmode="numeric" value="10,000" aria-label="SIP amount in rupees per instalment" /></div>
          </div>
          <input class="slider" id="amtR" type="range" min="500" max="100000" step="500" value="10000" aria-label="SIP amount" />
          <div class="slider-scale"><span>₹500</span><span>₹1,00,000</span></div>
        </div>

        <div class="field">
          <div class="field-top">
            <label for="dur">Investment duration</label>
            <div class="field-val"><input id="dur" type="text" inputmode="numeric" value="10" aria-label="Investment duration in years" /><span class="sfx">Yr</span></div>
          </div>
          <input class="slider" id="durR" type="range" min="1" max="40" step="1" value="10" aria-label="Investment duration in years" />
          <div class="slider-scale"><span>1 Yr</span><span>40 Yr</span></div>
        </div>

        <div class="field">
          <div class="field-top">
            <label for="rate">Expected rate of return</label>
            <div class="field-val"><input id="rate" type="text" inputmode="decimal" value="10" aria-label="Expected annual rate of return in percent" /><span class="sfx">%</span></div>
          </div>
          <input class="slider" id="rateR" type="range" min="1" max="30" step="0.5" value="10" aria-label="Expected annual rate of return in percent" />
          <div class="slider-scale"><span>1%</span><span>30%</span></div>
        </div>

        <div class="field">
          <div class="field-top">
            <label for="step">Annual step-up</label>
            <div class="field-val"><input id="step" type="text" inputmode="decimal" value="0" aria-label="Annual step-up in percent" /><span class="sfx">%</span></div>
          </div>
          <input class="slider" id="stepR" type="range" min="0" max="25" step="1" value="0" aria-label="Annual step-up in percent" />
          <div class="slider-scale"><span>0%</span><span>25%</span></div>
        </div>
      </div>
    </div>

    <div class="calc-results">
      <div class="bar-wrap">
        <div class="bar-top">
          <div class="bar-head">
            <span class="bar-cap">Total Assumed Value</span>
            <span class="bar-tot" id="d-tot">₹20,65,520</span>
          </div>
          <div class="stack-bar" role="img" aria-label="Total assumed value split between invested amount and estimated returns">
            <div class="seg seg-inv" id="seg-inv" style="width:58%"></div>
            <div class="seg seg-ret" id="seg-ret" style="width:42%"></div>
          </div>
        </div>

        <div class="res-cards">
          <div class="res-card">
            <div class="res-top"><span class="dot" style="background:var(--c-inv)"></span>Invested Amount</div>
            <div class="res-val" id="r-inv">₹12,00,000</div>
          </div>
          <div class="res-card">
            <div class="res-top"><span class="dot" style="background:var(--c-ret)"></span>Estimated Returns</div>
            <div class="res-val" id="r-ret">₹8,65,520</div>
          </div>
        </div>

        <div class="bar-div" role="presentation"></div>

        <p class="bar-note">Note: Figures are illustrative and assume a constant annual rate of return compounded over the full term; actual mutual-fund returns fluctuate and are not guaranteed.</p>
      </div>

      <div class="ready-bar">
        <p class="ready-text">Start a <strong id="cta-amt">₹10,000/month SIP</strong> and build your future</p>
        <a class="ready-btn" href="/about/open-demat-account/">Open Demat Account</a>
      </div>
    </div>
  </div>

  <p class="sr-only" id="sr-summary" aria-live="polite"></p>
</section>

<!-- WHAT IS A SIP CALCULATOR -->
<section class="section stack" id="sec-what" style="background:var(--sec-tint);gap:24px">
  <h2 class="sec-title">What Is A SIP Calculator?</h2>
  <p class="sec-lead">A SIP calculator is a free online tool that estimates the maturity value of your Systematic Investment Plan. By entering your monthly contribution, the length of time you plan to stay invested and an expected annual rate of return, it projects how much wealth you could accumulate. It removes the guesswork from financial planning, giving you an instant, data-backed picture of your investment journey so you can set realistic goals and invest with confidence.</p>
</section>

<!-- HOW A SIP CALCULATOR HELPS -->
<section class="section stack" id="sec-help" style="background:var(--sec-light);gap:24px">
  <h2 class="sec-title">How A SIP Calculator Helps You</h2>
  <p class="sec-lead">Planning your investments by hand is tedious and error-prone. A SIP calculator does the heavy lifting in seconds, so you can focus on the decisions that matter:</p>
  <ul class="bullets">
    <li>Instantly estimate the future value of your monthly investments without complex manual calculations.</li>
    <li>Compare different scenarios by changing your contribution, duration or expected return to find what fits your goals.</li>
    <li>Understand how much of your final corpus comes from invested capital versus estimated returns.</li>
    <li>Set realistic, time-bound financial goals — be it a home, education, or retirement — and track progress toward them.</li>
  </ul>
</section>

<!-- HOW DOES A SIP CALCULATOR WORK -->
<section class="section stack" id="sec-work" style="background:var(--sec-tint);gap:24px">
  <h2 class="sec-title">How Does A SIP Calculator Work?</h2>
  <p class="sec-lead">The calculator uses the standard future-value formula for a series of regular investments: M = P × ({[1 + i]ⁿ &minus; 1} &divide; i) &times; (1 + i), where P is your periodic investment, i is the periodic rate of return (your annual rate divided by the number of instalments per year) and n is the total number of instalments. It compounds each contribution over the remaining investment period and sums them to arrive at your projected maturity value. Because every instalment earns returns for a different length of time, the tool captures the true effect of compounding far more accurately than a simple multiplication ever could. When you add an annual step-up, each year&rsquo;s instalment is increased before the next year&rsquo;s compounding begins.</p>
</section>

<!-- ADVANTAGES -->
<section class="section stack" id="sec-adv" style="background:var(--sec-light);gap:24px">
  <h2 class="sec-title">Advantages Of A SIP Calculator</h2>
  <p class="sec-lead">Whether you are a first-time investor or a seasoned one, a SIP calculator brings clarity and discipline to your planning:</p>
  <ul class="bullets">
    <li>Accurate, instant projections that account for compounding across the entire investment horizon.</li>
    <li>Completely free to use, with no sign-up required and results delivered in real time.</li>
    <li>Helps you decide a comfortable monthly amount that aligns with your income and goals.</li>
    <li>Encourages consistent, disciplined investing by making the long-term payoff easy to visualise.</li>
  </ul>
</section>

<!-- EXPLORE MORE -->
<section class="section stack" id="sec-explore" style="background:var(--sec-tint);gap:40px">
  <h2 class="sec-title">Explore More</h2>
  <div class="explore-grid">
    <a class="xcard" href="/calculators/">
      <span class="xc-title">Brokerage Calculator</span>
      <span class="xc-desc">Estimate the all-in cost of a trade across brokerage, taxes and charges.</span>
      <span class="xc-cta">Calculate Now <span class="arr">→</span></span>
    </a>
    <a class="xcard" href="/calculators/lumpsum/">
      <span class="xc-title">Lumpsum Calculator</span>
      <span class="xc-desc">See how a one-time investment grows over your chosen horizon.</span>
      <span class="xc-cta">Calculate Now <span class="arr">→</span></span>
    </a>
    <a class="xcard" href="/calculators/">
      <span class="xc-title">Income Tax Calculator</span>
      <span class="xc-desc">Work out your tax liability across the old and new regimes.</span>
      <span class="xc-cta">Calculate Now <span class="arr">→</span></span>
    </a>
    <a class="xcard" href="/calculators/">
      <span class="xc-title">Mutual Fund Calculator</span>
      <span class="xc-desc">Project returns across SIP and lumpsum mutual-fund investments.</span>
      <span class="xc-cta">Calculate Now <span class="arr">→</span></span>
    </a>
  </div>
</section>

<!-- FAQ -->
<section class="faq-wrap" id="sec-faq" style="background:var(--sec-light)">
  <div class="faq-cols">
    <div class="faq-left">
      <h2 class="faq-title">General Questions</h2>
      <div class="faq-acc">
        {faqs.map((item, i) => (
          <div class={`faq-item${i === 0 ? ' open' : ''}`}>
            <button class="faq-q" type="button">
              <span class="qt">{item.q}</span>
              <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none"><line class="v" x1="12" y1="5" x2="12" y2="19" stroke="#404040" stroke-width="2" stroke-linecap="round"/><line x1="5" y1="12" x2="19" y2="12" stroke="#404040" stroke-width="2" stroke-linecap="round"/></svg></span>
            </button>
            <div class="qa-wrap"><div class="qa"><p>{item.a}</p></div></div>
          </div>
        ))}
      </div>
    </div>
    <div class="faq-side">
      <div class="usr" aria-hidden="true">
        <svg viewBox="0 0 131 147" fill="none"><circle cx="65.5" cy="42" r="34" stroke="currentColor" stroke-width="2"/><path d="M4 147c0-34 27.6-61.5 61.5-61.5S127 113 127 147" stroke="currentColor" stroke-width="2"/></svg>
      </div>
      <div class="side-in">
        <div class="side-tx">
          <h3>Need A Clearer Direction?</h3>
          <p>Let&rsquo;s get in touch on a 15-Minute call where we would be able to answer any questions you may have. Our Advisor will additionally help map your wealth mix and demonstrate what a dedicated advisor would do differently.</p>
        </div>
        <a class="btn-gold" href="/about/open-demat-account/">Book A Discovery Call</a>
      </div>
    </div>
  </div>
</section>

</BaseLayout>

<style>
  :root {
    --sec-light: #fef8ee;
    --sec-tint: #f6efe1;
    --card: #fffdf8;
    --card-border: #e1e0db;
    --olive-title: #2e3914;
    --olive-head: #2d3813;
    --olive-deep: #1b2010;
    --olive-ink: #2e3914;
    --ink: #1c1c16;
    --ink-2: #404040;
    --ink-3: #595959;
    --muted: #73736a;
    --gold-2: #f2b83f;
    --gold-btn: #f3b83f;
    --c-inv: #4f583b;
    --c-ret: #f3b83f;
    --pad: clamp(20px, 8vw, 144px);
    --section-y: 72px;
    --container-pad: 32px;
  }

  *, *::before, *::after { box-sizing: border-box; }
  a { color: inherit; text-decoration: none; }
  p { line-height: 1.5; }

  .section { padding: var(--section-y) var(--pad); display: flex; flex-direction: column; }
  .stack { display: flex; flex-direction: column; }
  .sec-title { font-weight: 400; font-size: 40px; color: var(--olive-title); text-transform: capitalize; line-height: 1.5; }
  .sec-lead { font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.5; }
  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }

  /* HERO */
  .hero {
    background: radial-gradient(125% 210% at 100% -8%, #4f583b 0%, #363a2c 50%, #1d1d1d 100%);
    min-height: clamp(440px, 29vw, 552px); display: flex; flex-direction: column; justify-content: center;
    padding: 0 var(--pad);
  }
  .hero-inner { padding: 56px 0; display: flex; flex-direction: column; }
  .hero h1 { font-weight: 500; font-size: 40px; color: #fff; line-height: 1.5; max-width: 600px; }
  .hero h1 .g { color: var(--gold-2); }
  .lead { margin-top: 16px; font-weight: 400; font-size: 18px; color: rgba(255,255,255,.74); line-height: 1.5; max-width: 600px; }
  .cta { margin-top: 24px; }
  .hero-feats { margin-top: 40px; }
  .feats { display: flex; flex-wrap: wrap; align-items: center; gap: 14px 24px; padding-top: 36px; border-top: 1px solid rgba(255,255,255,.16); }
  .feat { display: flex; gap: 10px; align-items: center; }
  .feat .tk { color: var(--gold-2); font-weight: 500; font-size: 15px; }
  .feat .lb { color: rgba(255,255,255,.9); font-weight: 500; font-size: 16px; line-height: 1.5; white-space: nowrap; }

  /* CALCULATOR LAYOUT */
  .calc-row { display: flex; gap: 24px; align-items: stretch; flex-wrap: wrap; }
  .calc-panel { flex: 1.6 1 380px; min-width: 0; display: flex; flex-direction: column; gap: 24px; }
  .calc-results { flex: 1 1 340px; min-width: 0; display: flex; flex-direction: column; gap: 32px; }
  .calc-hint { font-weight: 400; font-size: 15px; color: var(--muted); line-height: 1.5; }

  /* card base */
  .card { background: var(--card); border: 1px solid var(--card-border); border-radius: 24px; padding: var(--container-pad); }

  /* frequency toggle */
  .freq-toggle { display: inline-flex; align-self: flex-start; background: #f0ece1;
                border: 1px solid var(--card-border); border-radius: 10px; padding: 4px; gap: 4px; }
  .freq-btn { border: 0; background: none; font-family: inherit; cursor: pointer; padding: 8px 16px;
             border-radius: 7px; font-weight: 500; font-size: 14px; color: var(--ink-3);
             transition: background .2s ease, color .2s ease; }
  .freq-btn.is-active { background: var(--olive-head); color: #fff; }

  /* slider fields */
  .fields { display: flex; flex-direction: column; gap: 32px; }
  .field { display: flex; flex-direction: column; gap: 12px; }
  .field-top { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
  .field-top label { font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.5; }
  .field-val { display: flex; align-items: center; gap: 4px; border: 1px solid var(--card-border);
              border-radius: 8px; padding: 8px 12px; background: #fff; min-width: 128px; justify-content: flex-end; }
  .field-val:focus-within { border-color: var(--olive-head); }
  .field-val .pfx,.field-val .sfx { font-weight: 500; font-size: 15px; color: var(--ink-2); white-space: nowrap; }
  .field-val input { width: 78px; border: 0; outline: 0; background: transparent; text-align: right;
                    font-family: inherit; font-weight: 500; font-size: 15px; color: var(--ink); -moz-appearance: textfield; }
  .field-val input::-webkit-outer-spin-button,
  .field-val input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }

  /* range slider */
  .slider { -webkit-appearance: none; appearance: none; width: 100%; height: 6px; border-radius: 999px;
           background: #f3f3f3; outline: none; cursor: pointer; margin: 0; }
  .slider::-webkit-slider-thumb { -webkit-appearance: none; appearance: none; width: 18px; height: 18px;
           border-radius: 50%; background: #fff; border: 2px solid #4f583b;
           box-shadow: 0 1px 4px rgba(0,0,0,.18); cursor: pointer; }
  .slider::-moz-range-thumb { width: 18px; height: 18px; border: 2px solid #4f583b; border-radius: 50%;
           background: #fff; box-shadow: 0 1px 4px rgba(0,0,0,.18); cursor: pointer; }
  .slider::-moz-range-track { height: 6px; border-radius: 999px; background: transparent; }
  .slider-scale { display: flex; justify-content: space-between; font-weight: 400; font-size: 12px; color: var(--muted); }

  /* results bar card */
  .bar-wrap { flex: 1 1 auto; background: var(--card); border: 1px solid var(--card-border); border-radius: 24px;
             padding: var(--container-pad); display: flex; flex-direction: column; gap: 24px; justify-content: center; }
  .bar-top { display: flex; flex-direction: column; gap: 16px; }
  .bar-head { display: flex; flex-direction: column; gap: 8px; }
  .bar-cap { font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.5; }
  .bar-tot { font-weight: 600; font-size: 28px; color: #4f583b; line-height: 1.5; }
  .stack-bar { display: flex; height: 36px; border-radius: 8px; overflow: hidden; background: #e6e3da; }
  .stack-bar .seg { height: 100%; min-width: 0; transition: width .3s ease; }
  .stack-bar .seg-inv { background: var(--c-inv); }
  .stack-bar .seg-ret { background: var(--c-ret); }
  .bar-div { width: 100%; height: 1px; background: var(--card-border); }
  .bar-note { font-weight: 400; font-size: 14px; color: var(--muted); line-height: 1.5; }

  /* res split */
  .res-cards { display: flex; gap: 32px; }
  .res-card { flex: 1 1 0; min-width: 0; display: flex; flex-direction: column; gap: 8px; justify-content: center; }
  .res-top { display: flex; align-items: center; gap: 8px; font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.5; }
  .res-top .dot { width: 8px; height: 8px; border-radius: 50%; flex: none; }
  .res-val { font-weight: 500; font-size: 24px; color: var(--ink); line-height: 1.5; overflow-wrap: anywhere; padding-left: 16px; }

  /* ready bar */
  .ready-bar { background: #ffd277; border-radius: 24px; padding: 16px 24px; display: flex; align-items: center;
              justify-content: space-between; gap: 12px 24px; flex-wrap: wrap; }
  .ready-text { font-weight: 500; font-size: 16px; color: var(--ink); line-height: 1.4; }
  .ready-btn { flex: none; background: #fff0d7; color: var(--olive-ink); height: 40px; padding: 7px 20px; border-radius: 4px;
              display: flex; align-items: center; justify-content: center; font-weight: 500; font-size: 12px;
              white-space: nowrap; transition: opacity .2s; }
  .ready-btn:hover { opacity: .88; }

  /* btn-gold */
  .btn-gold {
    background: var(--gold-btn); height: 40px; min-width: 180px; border-radius: 4px;
    display: inline-flex; align-items: center; justify-content: center;
    padding: 7px 20px; font-weight: 500; font-size: 12px; color: var(--olive-ink);
    white-space: nowrap; line-height: 1.5; transition: opacity .2s;
  }
  .btn-gold:hover { opacity: .88; }

  /* bullets */
  .bullets { list-style: none; display: flex; flex-direction: column; gap: 14px; padding: 0; margin: 0; }
  .bullets li { position: relative; padding-left: 24px; font-weight: 400; font-size: 16px; color: var(--ink-3); line-height: 1.5; }
  .bullets li::before { content: ''; position: absolute; left: 7px; top: 9px; width: 6px; height: 6px;
                        border-radius: 50%; background: var(--olive-title); }

  /* explore grid */
  .explore-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 24px; }
  .xcard { background: var(--olive-deep); border: 1px solid var(--olive-deep); border-radius: 24px; padding: 32px;
          display: flex; flex-direction: column; color: inherit;
          transition: background-color .25s ease, border-color .25s ease; }
  .xcard:hover { background: #26301a; border-color: #3a471b; }
  .xc-title { font-weight: 500; font-size: 19px; color: #fff; line-height: 1.3; }
  .xc-desc { margin-top: 12px; font-weight: 400; font-size: 14px; color: rgba(255,255,255,.72); line-height: 1.5; }
  .xc-cta { margin-top: 24px; display: inline-flex; align-items: center; gap: 8px; color: var(--gold-2); font-weight: 600; font-size: 14px; }
  .xc-cta .arr { transition: transform .25s ease; }
  .xcard:hover .xc-cta .arr { transform: translateX(5px); }

  /* FAQ */
  .faq-wrap { padding: 100px var(--pad); display: flex; flex-direction: column; }
  .faq-cols { display: flex; gap: 48px; align-items: stretch; }
  .faq-left { flex: 1 0 0; min-width: 0; display: flex; flex-direction: column; gap: 48px; }
  .faq-title { font-weight: 400; font-size: 40px; color: var(--olive-title); text-transform: capitalize; line-height: 1.5; }
  .faq-acc { display: flex; flex-direction: column; gap: 2px; border: 1px solid var(--card-border); border-radius: 16px; overflow: hidden; padding: 1px; }
  .faq-item { background: var(--card); }
  .faq-q { width: 100%; display: flex; align-items: flex-start; justify-content: space-between; gap: 40px;
           padding: 24px; cursor: pointer; background: none; border: 0; text-align: left; }
  .faq-q .qt { font-weight: 500; font-size: 14px; color: #333; line-height: 1.5; flex: 1; }
  .faq-icon { width: 24px; height: 24px; flex: none; }
  .faq-icon svg { width: 24px; height: 24px; display: block; }
  .faq-icon svg .v { transform-box: fill-box; transform-origin: center;
                    transition: transform .38s cubic-bezier(.4,0,.2,1), opacity .38s ease; }
  .faq-item.open .faq-icon svg .v { transform: scaleY(0); opacity: 0; }
  .qa-wrap { display: grid; grid-template-rows: 0fr; transition: grid-template-rows .38s cubic-bezier(.4,0,.2,1); }
  .faq-item.open .qa-wrap { grid-template-rows: 1fr; }
  .qa { overflow: hidden; min-height: 0; }
  .qa p { padding: 0 24px 20px; font-weight: 400; font-size: 14px; color: #404040; line-height: 1.5; }
  .faq-side {
    width: 464px; flex: none; background: var(--card); border-radius: 24px; padding: var(--container-pad);
    display: flex; flex-direction: column; gap: 40px; justify-content: flex-end;
    position: relative; overflow: hidden; border: 1px solid var(--card-border);
  }
  .usr { position: absolute; left: var(--container-pad); top: 64px; width: 128px; height: 144px; opacity: .1; }
  .usr svg { display: block; width: 100%; height: 100%; color: var(--olive-deep); }
  .side-in { display: flex; flex-direction: column; gap: 32px; position: relative; }
  .side-tx { display: flex; flex-direction: column; gap: 8px; }
  .side-tx h3 { font-weight: 500; font-size: 20px; color: var(--ink); line-height: 1.5; }
  .side-tx p { font-weight: 400; font-size: 14px; color: var(--ink-3); line-height: 1.5; }

  @media (max-width: 1024px) { .explore-grid { grid-template-columns: repeat(2,1fr); } }
  @media (max-width: 900px) { .calc-panel,.calc-results { flex: 1 1 100%; } }
  @media (max-width: 768px) {
    .bullets li { font-size: 14px; }
    .bar-cap,.res-top { font-size: 14px; }
    .bar-tot { font-size: 24px; }
    .res-val { font-size: 20px; }
    .faq-cols { flex-direction: column; }
    .faq-side { width: 100%; }
    .sec-title { font-size: 28px; }
    .faq-title { font-size: 28px; }
  }
  @media (max-width: 560px) {
    .explore-grid { grid-template-columns: 1fr; }
    .res-cards { gap: 16px; }
    .field-top { gap: 10px; }
    .field-top label { font-size: 14px; }
    .field-val { min-width: 96px; }
    .field-val input { width: 56px; }
    .ready-bar { flex-direction: column; align-items: stretch; gap: 14px; }
    .ready-btn { width: 100%; }
  }
</style>

<script>
  (function(){
    var fmt    = new Intl.NumberFormat('en-IN', { maximumFractionDigits: 0 });
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    var amt  = document.getElementById('amt')  as HTMLInputElement;
    var amtR = document.getElementById('amtR') as HTMLInputElement;
    var dur  = document.getElementById('dur')  as HTMLInputElement;
    var durR = document.getElementById('durR') as HTMLInputElement;
    var rate = document.getElementById('rate') as HTMLInputElement;
    var rateR= document.getElementById('rateR')as HTMLInputElement;
    var step = document.getElementById('step') as HTMLInputElement;
    var stepR= document.getElementById('stepR')as HTMLInputElement;
    var freq = 12;

    var segInv = document.getElementById('seg-inv') as HTMLElement;
    var segRet = document.getElementById('seg-ret') as HTMLElement;
    var last = { inv: 0, ret: 0, tot: 0 };

    function digits(s: string){ return String(s).replace(/[^0-9.]/g, ''); }
    function clamp(v: number, mn: number, mx: number){ return Math.max(mn, Math.min(mx, v)); }

    function fillSlider(sl: HTMLInputElement){
      var p = (+sl.value - +sl.min) / (+sl.max - +sl.min) * 100;
      sl.style.background = 'linear-gradient(90deg,#4f583b 0%,#4f583b ' + p + '%,#f3f3f3 ' + p + '%,#f3f3f3 100%)';
    }

    function compute(amount: number, years: number, ratePct: number, stepPct: number, perYear: number){
      var n = Math.round(years * perYear), i = ratePct / 100 / perYear;
      var contribution = amount, balance = 0, invested = 0;
      for(var p = 1; p <= n; p++){
        if(p > 1 && (p - 1) % perYear === 0) contribution *= (1 + stepPct / 100);
        balance = (balance + contribution) * (1 + i);
        invested += contribution;
      }
      return { fv: balance, invested: invested, returns: balance - invested };
    }

    function countTo(el: HTMLElement | null, from: number, to: number, fn: (v: number) => string){
      if(!el) return;
      if(reduce || from === to){ el.textContent = fn(to); return; }
      var t0: number | null = null, d = 350;
      function tick(ts: number){
        if(t0 === null) t0 = ts;
        var t = Math.min(1, (ts - t0) / d), e = 1 - Math.pow(1 - t, 3);
        el.textContent = fn(from + (to - from) * e);
        if(t < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }

    function freqWord(){ return freq === 12 ? 'month' : freq === 4 ? 'quarter' : 'year'; }

    function render(animate: boolean){
      var amount = clamp(parseFloat(digits(amt.value)) || 0, +amtR.min, +amtR.max);
      var years  = clamp(parseFloat(digits(dur.value)) || 0, +durR.min, +durR.max);
      var ratePct= clamp(parseFloat(digits(rate.value)) || 0, +rateR.min, +rateR.max);
      var stepPct= clamp(parseFloat(digits(step.value)) || 0, +stepR.min, +stepR.max);

      var r = compute(amount, years, ratePct, stepPct, freq);
      var rupee = (v: number) => '₹' + fmt.format(Math.round(v));

      if(animate){
        countTo(document.getElementById('r-inv'), last.inv, r.invested, rupee);
        countTo(document.getElementById('r-ret'), last.ret, r.returns, rupee);
        countTo(document.getElementById('d-tot'), last.tot, r.fv, rupee);
      } else {
        var ri = document.getElementById('r-inv');
        var rr = document.getElementById('r-ret');
        var dt = document.getElementById('d-tot');
        if(ri) ri.textContent = rupee(r.invested);
        if(rr) rr.textContent = rupee(r.returns);
        if(dt) dt.textContent = rupee(r.fv);
      }
      last = { inv: r.invested, ret: r.returns, tot: r.fv };

      var invPct = r.fv > 0 ? r.invested / r.fv * 100 : 0;
      if(segInv) segInv.style.width = invPct + '%';
      if(segRet) segRet.style.width = (100 - invPct) + '%';

      var ctaAmt = document.getElementById('cta-amt');
      if(ctaAmt) ctaAmt.textContent = '₹' + fmt.format(amount) + '/' + freqWord() + ' SIP';

      var sr = document.getElementById('sr-summary');
      if(sr) sr.textContent = 'Projected total value ' + rupee(r.fv) + ' from ' + rupee(r.invested) + ' invested over ' + years + ' years.';

      try { history.replaceState(null, '', '?amt=' + amount + '&dur=' + years + '&rate=' + ratePct + '&step=' + stepPct + '&freq=' + freq); } catch(e){ /* ignore */ }

      amtR.setAttribute('aria-valuetext', '₹' + fmt.format(amount));
      durR.setAttribute('aria-valuetext', years + ' years');
      rateR.setAttribute('aria-valuetext', ratePct + ' percent');
      stepR.setAttribute('aria-valuetext', stepPct + ' percent');
    }

    function pairNumberAndSlider(numEl: HTMLInputElement, slEl: HTMLInputElement, group: boolean){
      slEl.addEventListener('input', function(){
        numEl.value = group ? fmt.format(+slEl.value) : slEl.value;
        fillSlider(slEl); render(false);
      });
      numEl.addEventListener('input', function(){
        var raw = parseFloat(digits(numEl.value)) || 0;
        if(group){ numEl.value = raw ? fmt.format(raw) : ''; }
        slEl.value = String(clamp(raw, +slEl.min, +slEl.max));
        fillSlider(slEl); render(false);
      });
      numEl.addEventListener('change', function(){
        var v = clamp(parseFloat(digits(numEl.value)) || +slEl.min, +slEl.min, +slEl.max);
        numEl.value = group ? fmt.format(v) : String(v);
        slEl.value = String(v); fillSlider(slEl); render(true);
      });
    }
    pairNumberAndSlider(amt, amtR, true);
    pairNumberAndSlider(dur, durR, false);
    pairNumberAndSlider(rate, rateR, false);
    pairNumberAndSlider(step, stepR, false);

    document.querySelectorAll('.freq-btn').forEach(function(btn){
      btn.addEventListener('click', function(){
        freq = parseInt((btn as HTMLElement).getAttribute('data-freq') || '12', 10);
        document.querySelectorAll('.freq-btn').forEach(function(b){
          var on = b === btn;
          b.classList.toggle('is-active', on);
          b.setAttribute('aria-pressed', on ? 'true' : 'false');
        });
        render(true);
      });
    });

    (function initFromUrl(){
      var p = new URLSearchParams(location.search);
      function setNum(el: HTMLInputElement, sl: HTMLInputElement, key: string, group: boolean){
        if(!p.has(key)) return;
        var v = clamp(parseFloat(p.get(key) || '') || +sl.min, +sl.min, +sl.max);
        sl.value = String(v); el.value = group ? fmt.format(v) : String(v);
      }
      setNum(amt, amtR, 'amt', true);
      setNum(dur, durR, 'dur', false);
      setNum(rate, rateR, 'rate', false);
      setNum(step, stepR, 'step', false);
      if(p.has('freq')){
        var f = parseInt(p.get('freq') || '', 10);
        if(f === 12 || f === 4 || f === 1){
          freq = f;
          document.querySelectorAll('.freq-btn').forEach(function(b){
            var on = parseInt((b as HTMLElement).getAttribute('data-freq') || '', 10) === f;
            b.classList.toggle('is-active', on);
            b.setAttribute('aria-pressed', on ? 'true' : 'false');
          });
        }
      }
    })();

    [amtR, durR, rateR, stepR].forEach(fillSlider);
    render(true);

    /* FAQ accordion */
    document.querySelectorAll('.faq-acc').forEach(function(acc){
      acc.querySelectorAll('.faq-item').forEach(function(item){
        item.querySelector('.faq-q')?.addEventListener('click', function(){
          var isOpen = item.classList.contains('open');
          acc.querySelectorAll('.faq-item').forEach(function(i){ i.classList.remove('open'); });
          if(!isOpen) item.classList.add('open');
        });
      });
    });
  })();
</script>
