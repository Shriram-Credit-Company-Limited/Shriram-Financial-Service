---
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  const calcData: Record<string, any> = {
  sip: {
    title: 'SIP Calculator',
    subtitle: 'Calculate the returns on your monthly Systematic Investment Plan and plan your wealth goals.',
    inputs: [
      { id: 'sip-amount', label: 'Monthly Investment', min: 500, max: 100000, step: 500, value: 10000, prefix: '₹' },
      { id: 'sip-rate',   label: 'Expected Return (% p.a.)', min: 1, max: 30, step: 0.5, value: 12, suffix: '%' },
      { id: 'sip-years',  label: 'Investment Period', min: 1, max: 40, step: 1, value: 10, suffix: ' yrs' },
    ],
    whatIs: 'A SIP Calculator is a free online tool that estimates how much wealth you can build by investing a fixed amount every month in a mutual fund. It applies the power of compounding to show how even small, regular investments can grow into a significant corpus over time — without you needing to time the market. Enter your monthly amount, expected return rate, and tenure, and the calculator instantly shows your total invested amount, estimated returns, and final corpus value.',
    howHelps: {
      body: 'Whether you are saving for retirement, a home, or your child\'s education, a SIP calculator helps you make informed, data-backed decisions before committing to a plan.',
      points: [
        'Set realistic investment goals and timelines — know exactly what monthly SIP amount gets you to your target corpus',
        'Compare how different monthly amounts, return rates, and time horizons affect your final wealth',
        'Understand the real impact of compounding — see how time in the market beats timing the market',
        'Reverse-calculate the monthly SIP needed to reach a specific financial goal',
        'Plan a Step-Up SIP strategy — see how increasing your SIP by 10% annually dramatically grows your corpus vs a flat SIP',
      ],
    },
    howWorks: 'The SIP calculator uses the future value of a recurring investment formula: FV = P × [(1 + r)^n − 1] / r × (1 + r), where P is your monthly investment, r is the monthly rate of return (annual rate ÷ 12), and n is the total number of months. For example, ₹10,000/month at 12% p.a. for 15 years grows to approximately ₹50.5 lakhs on a total investment of ₹18 lakhs — meaning your money more than doubles through compounding alone. Each month\'s investment earns returns from the point it is made, creating an accelerating compounding effect the longer you stay invested.',
    advantages: {
      body: 'A SIP calculator gives you the clarity to invest with purpose — not just habit. It turns abstract numbers into a concrete wealth-building plan.',
      points: [
        'Completely free — no sign-up, no login, no personal information required',
        'Instant results as you adjust your monthly amount, rate, or tenure',
        'Helps you stay committed to your SIP by showing the long-term payoff in rupee terms',
        'Lets you see the impact of starting early — even 2 extra years can add lakhs to your corpus',
        'Works for any mutual fund category — equity, debt, hybrid, or ELSS',
      ],
    },
    faqs: [
      { q: 'Is SIP return guaranteed?', a: 'No. SIP returns depend on the mutual fund\'s performance, which is market-linked. The calculator uses an assumed rate as an estimate. Equity mutual funds have historically delivered 10%–15% p.a. over long periods (10+ years), but actual returns will vary. Past performance is not indicative of future results.' },
      { q: 'Can I change my SIP amount after starting?', a: 'Yes. Most mutual funds allow you to increase, decrease, pause, or stop your SIP at any time without penalty. You can estimate the impact of increasing your SIP by ₹1,000–₹2,000/month using this calculator — even small increases significantly boost your final corpus over a 10–15 year period.' },
      { q: 'What is the minimum SIP amount with Shriram Financial Services?', a: 'You can start a SIP with as little as ₹500 per month through Shriram Financial Services. Open a free Demat account to get started — completely paperless and SEBI-registered.' },
      { q: 'What is a Step-Up SIP and should I use it?', a: 'A Step-Up SIP (also called a Top-Up SIP) lets you automatically increase your monthly investment by a fixed percentage each year — typically 10%. For example, starting at ₹5,000/month with a 10% annual step-up grows your corpus significantly more than a flat ₹5,000/month SIP over 20 years. It aligns your investment growth with your income growth.' },
      { q: 'How much should I invest in SIP to become a crorepati?', a: 'At 12% p.a., a monthly SIP of ₹6,000 for 25 years or ₹17,500 for 15 years reaches ₹1 crore. The earlier you start, the lower the monthly amount you need. Use this calculator to reverse-engineer the exact SIP needed for your target corpus.' },
    ],
    related: ['lumpsum', 'fd', 'swp'],
  },

  lumpsum: {
    title: 'Lumpsum Calculator',
    subtitle: 'Estimate the future value of a one-time investment and plan your wealth milestones.',
    inputs: [
      { id: 'ls-amount', label: 'One-Time Investment', min: 1000, max: 10000000, step: 1000, value: 100000, prefix: '₹' },
      { id: 'ls-rate',   label: 'Expected Return (% p.a.)', min: 1, max: 30, step: 0.5, value: 12, suffix: '%' },
      { id: 'ls-years',  label: 'Investment Period', min: 1, max: 40, step: 1, value: 10, suffix: ' yrs' },
    ],
    whatIs: 'A Lumpsum Calculator helps you estimate how much a one-time investment will grow over a chosen period at an expected rate of return. It applies the compound interest formula to project the future value of your capital — ideal for investors who have a large sum available such as a bonus, sale proceeds, maturity payout, or inheritance, and want to understand exactly how that amount can compound into wealth over time.',
    howHelps: {
      body: 'Before parking a large sum in any investment, it helps to visualise what that money could become at different return rates and time horizons. The lumpsum calculator gives you that instant projection.',
      points: [
        'Estimate the future value of any one-time investment at different return rates',
        'Compare short-term vs. long-term investment horizons and see the compounding difference',
        'Decide between investing a lumpsum now versus spreading it as a SIP',
        'Map your corpus to a specific life goal — retirement, child\'s education, or home down payment',
        'Understand how inflation impacts your real returns alongside nominal growth',
      ],
    },
    howWorks: 'The lumpsum calculator applies the compound interest formula: FV = P × (1 + r)^n, where P is your principal (initial investment), r is the annual rate of return, and n is the number of years. For example, ₹1 lakh invested at 12% p.a. for 10 years grows to approximately ₹3.1 lakhs — your money triples without any additional contribution. Unlike SIP where investments happen monthly, lumpsum investing means the entire principal compounds from day one, which can result in significantly higher returns when markets perform well over long periods.',
    advantages: {
      body: 'A lumpsum calculator removes the guesswork from one-time investing and helps you commit capital with clarity and confidence.',
      points: [
        'Instant calculation — no sign-up or app download needed',
        'Understand how time horizon dramatically affects your final corpus',
        'Compare lumpsum vs. SIP strategies side-by-side before making a decision',
        'Helps you pick the right mutual fund category (equity, debt, hybrid) based on goals and tenure',
        'Plan goal-based investing — know the lumpsum today needed to hit a future corpus target',
      ],
    },
    faqs: [
      { q: 'Is lumpsum investing better than SIP?', a: 'Neither is universally better. Lumpsum works well when you have a large sum available and markets are at attractive valuations. SIP suits regular income earners and averages out market volatility through rupee cost averaging. Many investors combine both: SIP for monthly savings, lumpsum for bonuses or windfalls.' },
      { q: 'What is a good expected return rate for lumpsum calculations?', a: 'For equity mutual funds, a conservative long-term estimate is 10%–12% p.a. For debt funds, 6%–8% p.a. is reasonable. These are illustrative estimates — actual returns depend on market conditions and fund selection. For retirement planning, using 10%–11% is prudent to avoid overestimating your future corpus.' },
      { q: 'What is the difference between absolute return and CAGR?', a: 'Absolute return is the total percentage gain from entry to exit (e.g., ₹1L grows to ₹2L = 100% absolute return). CAGR (Compound Annual Growth Rate) is the year-on-year equivalent — the same ₹1L to ₹2L in 6 years = 12.25% CAGR. CAGR is more useful for comparing investments across different time periods.' },
      { q: 'How is lumpsum mutual fund gain taxed in India?', a: 'For equity mutual funds: gains held under 12 months are taxed at 20% (STCG). Gains above ₹1.25 lakh held over 12 months are taxed at 12.5% (LTCG). For debt mutual funds, gains are taxed as per your income slab regardless of holding period. ELSS has a 3-year lock-in with 12.5% LTCG on gains. Rates as per Budget 2025-26.' },
      { q: 'How do I start a lumpsum investment with Shriram?', a: 'Open a free Demat account with Shriram Financial Services and access 5,000+ direct mutual fund schemes with zero commission. Our SEBI-registered research team can help you identify the right fund for your lumpsum based on your risk profile and investment horizon.' },
    ],
    related: ['sip', 'fd', 'swp'],
  },

  fd: {
    title: 'Fixed Deposit Calculator',
    subtitle: 'Calculate the maturity value and interest income of your Fixed Deposit instantly.',
    inputs: [
      { id: 'fd-amount', label: 'Principal Amount', min: 1000, max: 10000000, step: 1000, value: 100000, prefix: '₹' },
      { id: 'fd-rate',   label: 'Interest Rate (% p.a.)', min: 1, max: 15, step: 0.25, value: 7.5, suffix: '%' },
      { id: 'fd-years',  label: 'Tenure', min: 1, max: 10, step: 1, value: 3, suffix: ' yrs' },
    ],
    whatIs: 'An FD Calculator is a free online tool that instantly computes the maturity amount and interest earned on a fixed deposit, based on your principal, tenure, interest rate, and compounding frequency. It removes manual calculation errors and helps you compare FD options across banks and NBFCs before investing. Senior citizens can also account for the additional 0.25%–0.75% interest rate advantage most banks offer.',
    howHelps: {
      body: 'Before booking a Fixed Deposit, it is essential to compare offers and understand what your money will actually earn — including post-tax income. The FD calculator makes this instant.',
      points: [
        'Know the exact maturity amount and total interest earned before booking any FD',
        'Compare cumulative (reinvested) vs non-cumulative (monthly payout) FD returns side-by-side',
        'Factor in TDS deduction for accurate post-tax income planning',
        'Evaluate the senior citizen rate advantage — see the rupee difference at +0.50%',
        'Plan an FD laddering strategy by estimating returns at staggered tenures for better liquidity',
      ],
    },
    howWorks: 'Most Indian bank FDs use quarterly compounding for cumulative deposits. The formula is: A = P × (1 + r/4)^(4 × n), where P is the principal, r is the annual interest rate as a decimal, and n is the tenure in years. For simple interest (non-cumulative FDs or tenures under 6 months): SI = P × r × t / 100. For example, ₹5 lakhs at 7% for 3 years with quarterly compounding grows to approximately ₹6.17 lakhs — earning ₹1.17 lakhs in interest. The calculator handles both cumulative and simple interest modes automatically.',
    advantages: {
      body: 'An FD calculator is the simplest way to make a fully informed decision before locking in your money.',
      points: [
        'Accurate maturity value using the industry-standard quarterly compounding method',
        'Free and instant — no bank account or login required',
        'Compare returns on multiple FD options across banks to find the best rate',
        'Helps you decide between cumulative (reinvested) and non-cumulative (payout) FDs',
        'Identify when TDS will be deducted (interest above ₹50,000/yr for senior citizens; ₹40,000 for others)',
      ],
    },
    faqs: [
      { q: 'Is FD interest taxable in India?', a: 'Yes. FD interest is fully taxable as "Income from Other Sources" at your income tax slab rate. Banks deduct TDS at 10% if interest exceeds ₹40,000 per financial year (₹50,000 for senior citizens). Submit Form 15G (below 60 yrs) or 15H (60+ yrs) to avoid TDS if your total income is below the taxable limit.' },
      { q: 'What is the difference between cumulative and non-cumulative FD?', a: 'In a cumulative FD, interest is compounded and paid at maturity — giving you a higher total return. In a non-cumulative FD, interest is paid out monthly, quarterly, or annually — giving you regular income. Cumulative FDs are better for long-term wealth building; non-cumulative FDs suit retirees needing regular cash flow.' },
      { q: 'What happens if I withdraw my FD before maturity?', a: 'Premature withdrawal typically incurs a penalty of 0.5%–1% on the contracted interest rate for the period held. The maturity amount shown in this calculator assumes full-tenure FD. Breaking early reduces your effective return. Always check your bank\'s premature withdrawal penalty before booking.' },
      { q: 'What is FD laddering and how does it help?', a: 'FD laddering means splitting a large sum across multiple FDs with staggered maturities (e.g., ₹2L each for 1Y, 2Y, 3Y, 4Y, 5Y). This gives you annual liquidity, lets you reinvest at prevailing rates as each FD matures, and avoids being fully locked in at one rate. It typically earns more than a single large FD over the same period.' },
      { q: 'Is NBFC FD safe? Is it covered by DICGC?', a: 'DICGC insurance (up to ₹5 lakh) covers only scheduled commercial banks — not NBFCs. NBFC FDs offer higher rates but carry higher risk. Before investing in an NBFC FD, check its credit rating (prefer CRISIL or ICRA AAA-rated NBFCs) and limit exposure to a small portion of your overall FD portfolio.' },
    ],
    related: ['sip', 'lumpsum', 'swp'],
  },

  swp: {
    title: 'SWP Calculator',
    subtitle: 'Estimate how long your investment corpus will last with a Systematic Withdrawal Plan.',
    inputs: [
      { id: 'swp-corpus',     label: 'Initial Corpus', min: 10000, max: 100000000, step: 10000, value: 2000000, prefix: '₹' },
      { id: 'swp-withdrawal', label: 'Monthly Withdrawal', min: 1000, max: 500000, step: 1000, value: 20000, prefix: '₹' },
      { id: 'swp-rate',       label: 'Expected Return (% p.a.)', min: 1, max: 20, step: 0.5, value: 8, suffix: '%' },
    ],
    whatIs: 'A Systematic Withdrawal Plan (SWP) Calculator helps you estimate how long a lump-sum corpus will last when you withdraw a fixed amount every month. It is widely used by retirees and senior citizens who want a steady, predictable monthly income from their mutual fund investments without fully depleting their corpus. The key insight: if your remaining corpus earns more than you withdraw each month, it can sustain withdrawals indefinitely — the SWP calculator shows you exactly where that balance point lies.',
    howHelps: {
      body: 'Retirement planning is as much about managing withdrawals sustainably as it is about building a corpus. The SWP calculator helps you find the right balance between income and longevity.',
      points: [
        'Estimate how many years your retirement corpus will sustain your chosen monthly withdrawal',
        'Find the optimal monthly withdrawal amount that makes your corpus last the longest',
        'Understand how the return rate on remaining funds extends — or shortens — how long money lasts',
        'Compare different corpus sizes and withdrawal amounts before finalising your retirement plan',
        'See the impact of a Step-Up SWP: increasing annual withdrawal to keep pace with inflation',
      ],
    },
    howWorks: 'Each month, the remaining corpus earns the expected monthly return (annual rate ÷ 12), and then your chosen withdrawal amount is subtracted. The calculator repeats this monthly cycle — grow, then withdraw — until the corpus is exhausted or 50 years is reached. For example, a ₹20 lakh corpus at 8% p.a. with ₹20,000/month withdrawal lasts approximately 15 years. The critical insight: if your monthly return (corpus × rate ÷ 12) equals or exceeds your withdrawal, the corpus never depletes — a state of perpetual withdrawal known as a "self-sustaining SWP."',
    advantages: {
      body: 'An SWP calculator helps you retire with confidence — knowing exactly how long your savings will last and what monthly income is sustainable.',
      points: [
        'Plan a sustainable monthly income from your retirement corpus without guesswork',
        'Experiment with withdrawal amounts to find your ideal retirement budget',
        'Completely free — no sign-up or personal information required',
        'Helps you avoid outliving your savings with careful, data-backed planning',
        'Better post-tax income vs FD for higher tax bracket investors — long-term capital gains taxed at lower rates',
      ],
    },
    faqs: [
      { q: 'Is SWP better than bank FD for retirement income?', a: 'For most retirees in higher tax brackets, SWP from a balanced or debt mutual fund provides better post-tax income than a bank FD. FD interest is taxed at your full slab rate. With equity/hybrid funds, long-term capital gains above ₹1.25 lakh are taxed at only 12.5% — significantly lower than 20%–30% slab rates.' },
      { q: 'What happens if the corpus earns more than I withdraw?', a: 'If the monthly returns on your corpus exceed your monthly withdrawal, the corpus grows over time — meaning your SWP can last indefinitely. The calculator shows "50+ yrs" in this scenario. For example, a ₹1 crore corpus at 9% p.a. earns ₹75,000/month — any withdrawal below this is self-sustaining.' },
      { q: 'What is a Step-Up SWP and why does it matter for retirement?', a: 'A Step-Up SWP increases your monthly withdrawal by a fixed percentage each year — typically 5%–6% — to match inflation. Without a step-up, ₹20,000/month today has the purchasing power of only ~₹12,200 after 10 years at 5% inflation. A step-up SWP helps maintain your real standard of living through retirement.' },
      { q: 'Which mutual fund type is best for SWP?', a: 'Balanced Advantage Funds and Hybrid Funds are popular for SWP — they provide stable returns with equity upside while limiting downside risk. Debt funds work well for conservative retirees. Avoid pure equity funds for short-tenure SWP (under 5 years) due to market volatility risk.' },
      { q: 'Can I set up an SWP with Shriram Financial Services?', a: 'Yes. You can set up an automated SWP from any mutual fund in your Shriram portfolio. Our relationship managers can help you choose the right fund type — debt, balanced, or hybrid — to optimise your monthly SWP income with the best possible tax efficiency.' },
    ],
    related: ['sip', 'lumpsum', 'fd'],
  },

  nps: {
    title: 'NPS Calculator',
    subtitle: 'Estimate your NPS retirement corpus, tax-free lump sum, and monthly pension with industry-standard calculations.',
    inputs: [
      { id: 'nps-age',          label: 'Current Age',                min: 18,  max: 59,      step: 1,   value: 30,    suffix: ' yrs' },
      { id: 'nps-retire',       label: 'Retirement Age',             min: 40,  max: 70,      step: 1,   value: 60,    suffix: ' yrs' },
      { id: 'nps-amount',       label: 'Monthly Contribution',       min: 500, max: 100000,  step: 500, value: 5000,  prefix: '₹' },
      { id: 'nps-rate',         label: 'Expected Return (% p.a.)',   min: 4,   max: 15,      step: 0.5, value: 10,    suffix: '%' },
      { id: 'nps-annuity-pct',  label: 'Annuity Purchase (%)',       min: 40,  max: 100,     step: 5,   value: 40,    suffix: '%' },
      { id: 'nps-annuity-rate', label: 'Annuity Rate (% p.a.)',      min: 4,   max: 10,      step: 0.5, value: 6,     suffix: '%' },
    ],
    whatIs: 'The NPS Calculator is a free online tool that estimates your retirement corpus, tax-free lump sum withdrawal, and estimated monthly pension based on your NPS contributions. It accounts for your current age, retirement age, monthly contribution, expected return rate, annuity purchase percentage, and annuity rate — giving you a complete two-stage retirement projection. NPS is regulated by PFRDA and backed by the Government of India, making it one of India\'s most trusted and tax-efficient retirement vehicles.',
    howHelps: {
      body: 'NPS\'s dual-output nature — lump sum plus monthly pension — makes retirement planning complex without a calculator. This tool makes it simple and actionable.',
      points: [
        'Project your total NPS corpus at retirement based on current age, contribution, and expected return',
        'See your tax-free lump sum withdrawal amount (up to 60% of corpus — fully exempt at age 60)',
        'Calculate your estimated monthly pension from the annuity portion (minimum 40% of corpus)',
        'Understand the impact of increasing your monthly contribution on your final retirement income',
        'Check whether your projected monthly pension covers your current lifestyle expenses',
      ],
    },
    howWorks: 'NPS calculation happens in two stages. Stage 1 — Corpus Accumulation: A = P × [(1 + r/12)^(n×12) − 1] / (r/12) × (1 + r/12), where P is monthly contribution, r is annual return rate, and n is tenure in years. Stage 2 — Pension Conversion: Monthly Pension = (Annuity Corpus × Annuity Rate) ÷ 12. For example, ₹5,000/month for 30 years at 10% p.a. builds a corpus of approximately ₹1.13 crore. At 40% annuitised at 6%: Lump Sum = ₹68 lakhs (tax-free) | Annuity Corpus = ₹45 lakhs | Monthly Pension = ₹22,500.',
    advantages: {
      body: 'NPS is one of the most tax-efficient retirement vehicles in India — and this calculator helps you unlock its full potential.',
      points: [
        'Triple tax benefit: deductions under 80CCD(1) up to ₹1.5L, additional ₹50,000 under 80CCD(1B), and employer contribution under 80CCD(2)',
        'The 60% lump sum at retirement is completely tax-free — a major advantage over most other retirement products',
        'Market-linked growth with flexible equity allocation up to 75% for higher long-term returns',
        'PFRDA-regulated, government-backed scheme with among the lowest fund management charges in India',
        'Portable across jobs, cities, and sectors via your permanent PRAN number',
      ],
    },
    faqs: [
      { q: 'What is the minimum NPS contribution per year?', a: 'For a Tier I NPS account, the minimum annual contribution is ₹1,000 with no maximum limit. For maximum tax benefit, contribute at least ₹2 lakhs per year — ₹1.5L under 80CCD(1) within Sec 80C, plus ₹50,000 additional under 80CCD(1B). Employer contributions under 80CCD(2) are deductible over and above these limits.' },
      { q: 'Is the NPS annuity income taxable?', a: 'Yes — this is the most commonly misunderstood NPS tax rule. The 60% lump sum at retirement is completely tax-free. However, the monthly pension you receive from the annuity is added to your taxable income each year and taxed at your applicable slab rate. It is not tax-free income. Plan your annuity corpus size accordingly.' },
      { q: 'What happens to my NPS if I exit before 60?', a: 'Premature exit before age 60 requires you to use at least 80% of the corpus to purchase an annuity — only 20% can be withdrawn as a lump sum, which is also taxable. This makes NPS a strong long-term commitment. If your total corpus is below ₹2.5 lakhs, you can withdraw the full amount.' },
      { q: 'What return rate should I assume in the NPS calculator?', a: 'For a balanced NPS portfolio (50% equity, 30% corporate debt, 20% govt securities — Auto Choice Moderate), 9%–10% p.a. is a reasonable long-term estimate. For aggressive equity-heavy allocation (75% equity), 10%–11% may be used. Conservative investors with high debt allocation should use 7%–8%.' },
      { q: 'Can I increase my NPS contribution over time?', a: 'Yes. You can increase, decrease, or modify NPS contributions at any time. Many investors start small and increase by 10%–15% annually alongside salary increments. A step-up contribution strategy — starting at ₹3,000/month and increasing 10% each year — builds a significantly larger corpus than a flat contribution over 25–30 years.' },
    ],
    related: ['sip', 'swp', 'lumpsum'],
  },
};

  return Object.entries(calcData).map(([slug, data]) => ({
    params: { slug },
    props: {
      slug,
      ...data,
      relatedCalcs: (data.related as string[]).map((s: string) => ({ slug: s, title: calcData[s].title })),
    },
  }));
}

const { slug, title, subtitle, inputs, whatIs, howHelps, howWorks, advantages, faqs, relatedCalcs } = Astro.props;
---

<BaseLayout
  title={`${title} — Free Online Calculator | Shriram Financial Services`}
  description={subtitle}
>

  <!-- ══ 1. HERO + CALCULATOR ═══════════════════════════════════════ -->
  <section class="border-b border-[var(--color-n400)] bg-[#faf8f4] py-12 lg:py-16">
    <div class="site-wrap">

      <h1 class="reveal reveal-1 mb-8 text-[28px] font-bold text-[var(--color-ink)] sm:text-[34px]" style="font-family:var(--font-display)">
        {title}
      </h1>

      <div class="grid gap-6 lg:grid-cols-[1fr_280px]">

        <!-- Calculator panel -->
        <div class="rounded-[20px] border border-[var(--color-n400)] bg-white p-6 shadow-sm lg:p-8">
          <div class="grid gap-8 md:grid-cols-[1fr_260px]">

            <!-- Inputs -->
            <div class="space-y-7">
              {inputs.map((inp: any) => (
                <div>
                  <div class="mb-2 flex items-center justify-between">
                    <label for={inp.id} class="text-[13px] font-semibold text-[var(--color-ink)]">{inp.label}</label>
                    <span id={`${inp.id}-display`} class="text-[14px] font-bold text-[var(--color-dark-olive)]">
                      {inp.prefix ?? ''}{inp.value.toLocaleString('en-IN')}{inp.suffix ?? ''}
                    </span>
                  </div>
                  <input
                    type="range"
                    id={inp.id}
                    min={inp.min}
                    max={inp.max}
                    step={inp.step}
                    value={inp.value}
                    class="calc-slider w-full"
                    data-prefix={inp.prefix ?? ''}
                    data-suffix={inp.suffix ?? ''}
                  />
                  <div class="mt-1 flex justify-between text-[11px] text-[var(--color-subtle)]">
                    <span>{inp.prefix ?? ''}{inp.min.toLocaleString('en-IN')}{inp.suffix ?? ''}</span>
                    <span>{inp.prefix ?? ''}{inp.max.toLocaleString('en-IN')}{inp.suffix ?? ''}</span>
                  </div>
                </div>
              ))}
            </div>

            <!-- Results -->
            <div class="flex flex-col gap-4">
              <div class="flex flex-1 items-center justify-center">
                <div class="relative h-40 w-40">
                  <svg viewBox="0 0 120 120" class="h-full w-full -rotate-90">
                    <circle cx="60" cy="60" r="50" fill="none" stroke="var(--color-n400)" stroke-width="12"/>
                    <circle id="donut-returns" cx="60" cy="60" r="50" fill="none" stroke="var(--color-brand)" stroke-width="12" stroke-dasharray="314 314" stroke-dashoffset="157" stroke-linecap="round"/>
                  </svg>
                  <div class="absolute inset-0 flex flex-col items-center justify-center text-center">
                    <div class="text-[10px] text-[var(--color-muted)]">Total Value</div>
                    <div id="calc-total" class="text-[16px] font-bold text-[var(--color-ink)]" style="font-family:var(--font-display)">₹0</div>
                  </div>
                </div>
              </div>
              <div class="space-y-2.5">
                <div class="flex items-center justify-between rounded-xl bg-[var(--color-n100)] px-4 py-3">
                  <div class="flex items-center gap-2 text-[12px] text-[var(--color-muted)]">
                    <span class="h-2.5 w-2.5 rounded-full bg-[var(--color-n400)]"></span>
                    <span id="calc-invested-label">Invested Amount</span>
                  </div>
                  <span id="calc-invested" class="text-[13px] font-bold text-[var(--color-ink)]">₹0</span>
                </div>
                <div class="flex items-center justify-between rounded-xl bg-[var(--color-brand-light)] px-4 py-3">
                  <div class="flex items-center gap-2 text-[12px] text-[var(--color-muted)]">
                    <span class="h-2.5 w-2.5 rounded-full bg-[var(--color-brand)]"></span>
                    <span id="calc-gains-label">Estimated Returns</span>
                  </div>
                  <span id="calc-gains" class="text-[13px] font-bold text-[var(--color-brand-deep)]">₹0</span>
